#!/usr/bin/env python3
"""Small GNU-timeout-compatible subset used by Herbert's shell harnesses."""

from __future__ import annotations

import os
import re
import signal
import subprocess
import sys


def usage() -> int:
    print("usage: timeout [-s SIGNAL] DURATION COMMAND [ARG...]", file=sys.stderr)
    return 125


def parse_duration(raw: str) -> float:
    match = re.fullmatch(r"([0-9]+(?:\.[0-9]+)?)([smhd]?)", raw)
    if not match:
        raise ValueError(f"invalid duration {raw!r}")
    value = float(match.group(1))
    suffix = match.group(2)
    scale = {"": 1, "s": 1, "m": 60, "h": 3600, "d": 86400}[suffix]
    return value * scale


def parse_signal(raw: str) -> signal.Signals:
    name = raw.upper()
    if name.startswith("SIG"):
        name = name[3:]
    if name.isdigit():
        return signal.Signals(int(name))
    try:
        return getattr(signal, f"SIG{name}")
    except AttributeError as exc:
        raise ValueError(f"invalid signal {raw!r}") from exc


def shell_returncode(code: int) -> int:
    if code < 0:
        return 128 + (-code)
    return code & 0xFF


def terminate_process_group(proc: subprocess.Popen[bytes], sig: signal.Signals) -> None:
    if proc.poll() is not None:
        return
    try:
        os.killpg(proc.pid, sig)
    except ProcessLookupError:
        return
    try:
        proc.wait(timeout=1.0)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait()


def main(argv: list[str]) -> int:
    if not argv or argv[0] in {"-h", "--help"}:
        return usage()

    sig = signal.SIGTERM
    if argv[0] == "-s":
        if len(argv) < 4:
            return usage()
        try:
            sig = parse_signal(argv[1])
        except ValueError as exc:
            print(f"timeout: {exc}", file=sys.stderr)
            return 125
        argv = argv[2:]

    if len(argv) < 2:
        return usage()

    try:
        seconds = parse_duration(argv[0])
    except ValueError as exc:
        print(f"timeout: {exc}", file=sys.stderr)
        return 125

    cmd = argv[1:]
    try:
        proc = subprocess.Popen(cmd, start_new_session=True)
    except FileNotFoundError:
        print(f"timeout: failed to run command {cmd[0]!r}: No such file or directory", file=sys.stderr)
        return 127
    except PermissionError:
        print(f"timeout: failed to run command {cmd[0]!r}: Permission denied", file=sys.stderr)
        return 126

    def interrupted(signum: int, _frame: object) -> None:
        terminate_process_group(proc, signal.Signals(signum))
        raise SystemExit(128 + signum)

    previous_handlers: dict[int, object] = {}
    for handled in (signal.SIGINT, signal.SIGTERM, signal.SIGHUP, signal.SIGQUIT):
        previous_handlers[handled] = signal.getsignal(handled)
        signal.signal(handled, interrupted)

    try:
        return shell_returncode(proc.wait(timeout=seconds))
    except subprocess.TimeoutExpired:
        terminate_process_group(proc, sig)
        return 124
    finally:
        for handled, handler in previous_handlers.items():
            signal.signal(handled, handler)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
