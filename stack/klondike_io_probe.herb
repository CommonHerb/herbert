func main():
    let incoming = clogger()
    let b = new_buffer()
    do append(b, 'K')
    do append(b, 'L')
    do append(b, 'O')
    do append(b, 'N')
    do append(b, 'D')
    do append(b, 'I')
    do append(b, 'K')
    do append(b, 'E')
    do append(b, '-')
    do append(b, 'I')
    do append(b, 'O')
    do append(b, '\n')
    let marker = freeze(b)
    do flogger(marker)
    return length(incoming)
end
