func nc_emit_entry_check(start_len, buf, want, label):
    let got = length(freeze(buf)) - start_len
    if got != want:
        return nc_fail(418, 0, label)
    end
    return 0
end

func nc_emit_entry_stub(buf, main_entry, has_clogger, has_heap, has_faultable, main_ret, code_len, strings):
    let layout = nc_entry_layout(has_heap, has_faultable, main_ret)
    let start_len = length(freeze(buf))
    if has_heap != 0:
        buf = nc_emit_heap_stub(buf)
    end
    let ck = nc_emit_entry_check(start_len, buf, layout.0, "entry-heap")
    if ck != 0:
        return (ck, buf)
    end
    do append(buf, 232)
    buf = nc_append_rel32(buf, main_entry, layout.0 + 5)
    do append(buf, 232)
    buf = nc_append_rel32(buf, layout.5, layout.0 + 10)
    do append(buf, 184)
    do append(buf, 231)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 49)
    do append(buf, 255)
    do append(buf, 15)
    do append(buf, 5)
    ck = nc_emit_entry_check(start_len, buf, layout.4, "entry-head")
    if ck != 0:
        return (ck, buf)
    end
    if has_faultable != 0:
        let ro_base = code_len + nc_rodata_len(strings) - nc_fault_rodata_len()
        buf = nc_emit_fault_helpers(buf, ro_base, nc_fault_helper_start(has_heap, has_faultable, main_ret))
    end
    ck = nc_emit_entry_check(start_len, buf, layout.5, "entry-fault")
    if ck != 0:
        return (ck, buf)
    end
    buf = nc_emit_render_main(buf, main_ret, layout.5)
    ck = nc_emit_entry_check(start_len, buf, layout.6, "entry-render")
    if ck != 0:
        return (ck, buf)
    end
    return (0, buf)
end

func nc_lower_loop(fn, funcs, meta, metas, layout, layouts, strings, code_len, diag_base, i, n, buf):
    if i >= n:
        return buf
    end
    let code = fn.4
    let instr = get(code, i)
    let op = instr.0
    let a = instr.1
    let g = nc_group(code, i, n, fn, funcs, meta, metas)
    let instr_off = layout.0 + get(layout.1, i)
    if op == 0:
        buf = nc_emit_push_int(buf, a)
    elif op == 1:
        buf = nc_emit_push_bool(buf, a)
    elif op == 2:
        buf = nc_emit_push_str(buf, strings, a, instr_off, code_len)
    elif op == 3:
        buf = nc_emit_load_local(buf, get(meta.3, a), get(meta.4, a))
    elif op == 4:
        buf = nc_emit_store_local(buf, get(meta.3, a), get(meta.4, a))
    elif op == 5:
        buf = nc_emit_add(buf)
    elif op == 6:
        buf = nc_emit_sub(buf)
    elif op == 7:
        buf = nc_emit_cmp_setcc(buf, 146)
    elif op == 8:
        buf = nc_emit_cmp_setcc(buf, 150)
    elif op == 9:
        buf = nc_emit_cmp_setcc(buf, 151)
    elif op == 10:
        buf = nc_emit_cmp_setcc(buf, 147)
    elif op == 11:
        buf = nc_emit_cmp_setcc(buf, 148)
    elif op == 12:
        buf = nc_emit_cmp_setcc(buf, 149)
    elif op == 13:
        buf = nc_emit_not(buf)
    elif op == 36:
        buf = nc_emit_band(buf)
    elif op == 37:
        buf = nc_emit_bor(buf)
    elif op == 38:
        buf = nc_emit_bxor(buf)
    elif op == 39:
        buf = nc_emit_shl(buf)
    elif op == 40:
        buf = nc_emit_shr(buf)
    elif op == 41:
        buf = nc_emit_bnot(buf)
    elif op == 42:
        buf = nc_emit_mul(buf)
    elif op == 43:
        buf = nc_emit_div_or_mod(buf, 0, diag_base + nc_fault_exit1_rel(), instr_off)
    elif op == 44:
        buf = nc_emit_div_or_mod(buf, 1, diag_base + nc_fault_exit1_rel(), instr_off)
    elif op == 15:
        buf = nc_emit_tuple_get(buf, meta, i)
    elif op == 16:
        buf = nc_emit_br(buf, layout.0 + get(layout.1, a), instr_off + 5)
    elif op == 17:
        buf = nc_emit_br_if_false(buf, layout.0 + get(layout.1, a), instr_off + 10)
    elif op == 18:
        buf = nc_emit_br_and(buf, layout.0 + get(layout.1, a), instr_off + 13)
    elif op == 19:
        buf = nc_emit_br_or(buf, layout.0 + get(layout.1, a), instr_off + 13)
    elif op == 20:
        let callee_layout = get(layouts, instr.1)
        let cm = get(meta.11, i)
        if cm.2 == 2:
            buf = nc_emit_tail_call(buf, callee_layout.0, instr_off + g.0, meta.0, cm.0, meta.6, 0)
        elif cm.2 == 3:
            buf = nc_emit_tail_call(buf, callee_layout.0, instr_off + g.0, meta.0, cm.0, meta.6, 1)
        else:
            let call_base = instr_off + 5
            if cm.2 == 1:
                call_base = instr_off + nc_disp_len_rbp(1, nc_sret_scratch_mag(meta.7, cm.1, 0)) + 5
            end
            buf = nc_emit_normal_call(buf, callee_layout.0, call_base, meta, cm)
        end
    elif op == 21:
        buf = nc_emit_ret(buf, meta)
    elif op == 22:
        buf = nc_emit_length(buf)
    elif op == 23:
        buf = nc_emit_index(buf, get(fn.6, i), diag_base + nc_fault_diag_index_rel(), instr_off)
    elif op == 25:
        buf = nc_emit_equal(buf)
    elif op == 26:
        buf = nc_emit_new_buffer(buf)
    elif op == 27:
        buf = nc_emit_freeze(buf)
    elif op == 28:
        buf = nc_emit_new_array(buf, get(meta.14, i).1)
    elif op == 29:
        buf = nc_emit_get(buf, get(meta.14, i).1, get(fn.6, i), diag_base + nc_fault_diag_get_rel(), instr_off)
    elif op == 30:
        buf = nc_emit_count(buf)
    elif op == 31:
        buf = nc_emit_buf_append(buf, get(fn.6, i), diag_base + nc_fault_diag_append_rel(), instr_off)
    elif op == 32:
        buf = nc_emit_arr_add(buf, get(meta.14, i).1)
    elif op == 33:
        buf = nc_emit_clogger(buf)
    elif op == 34:
        buf = nc_emit_flogger(buf)
    elif op == 35:
        buf = nc_emit_fwriter(buf)
    end
    return nc_lower_loop(fn, funcs, meta, metas, layout, layouts, strings, code_len, diag_base, g.1, n, buf)
end

func nc_emit_function(buf, fn, funcs, meta, metas, layout, layouts, strings, code_len, diag_base):
    let start_len = length(freeze(buf))
    buf = nc_emit_prologue(buf, layout.3)
    buf = nc_emit_sret_save(buf, meta)
    buf = nc_emit_arg_copies_loop(buf, 0, meta.0)
    let after_prefix = length(freeze(buf)) - start_len
    if after_prefix != layout.4:
        return (nc_fail(418, 0, "prefix"), buf)
    end
    buf = nc_lower_loop(fn, funcs, meta, metas, layout, layouts, strings, code_len, diag_base, 0, count(fn.4), buf)
    let len = length(freeze(buf)) - start_len
    if len != layout.5:
        return (nc_fail(418, 0, "length"), buf)
    end
    return (0, buf)
end

func nc_emit_functions_loop(buf, funcs, metas, layouts, strings, code_len, diag_base, i, n):
    if i >= n:
        return (0, buf)
    end
    let r = nc_emit_function(buf, get(funcs, i), funcs, get(metas, i), metas, get(layouts, i), layouts, strings, code_len, diag_base)
    if r.0 != 0:
        return r
    end
    return nc_emit_functions_loop(r.1, funcs, metas, layouts, strings, code_len, diag_base, i + 1, n)
end

func nc_emit_zeroes_loop(buf, n):
    if n <= 0:
        return buf
    end
    do append(buf, 0)
    return nc_emit_zeroes_loop(buf, n - 1)
end

func nc_emit_rodata_loop(buf, strings, i, n):
    if i >= n:
        return buf
    end
    buf = append_str(buf, get(strings, i))
    return nc_emit_rodata_loop(buf, strings, i + 1, n)
end

func nc_emit_rodata(buf, strings):
    return nc_emit_rodata_loop(buf, strings, 0, count(strings))
end

func nc_append_fault_rodata(strings):
    do add(strings, "herbert: line ")
    do add(strings, ": index: position ")
    do add(strings, ": get: position ")
    do add(strings, ": append: byte value ")
    do add(strings, " out of range (length ")
    do add(strings, " out of range (count ")
    do add(strings, " out of range 0..255")
    do add(strings, ")\n")
    do add(strings, "\n")
    return strings
end

-- ====================================================================
-- L1 (first kernel-arc link): freestanding 32-bit Multiboot1 emit mode.
-- A SECOND back-end target, selected by an anchored first-line directive
-- "-- emit: multiboot32" in the stdin source. The compiler's own source
-- has no such first line, so self-compilation stays on the x86-64 Linux
-- ELF path and the gen2==gen1 fixpoint is preserved. Scope: 32-bit
-- protected mode, paging off; subset = integer literal, multiply, return.
-- The emitted image computes the byte with a real runtime imul (0F AF C1,
-- 32-bit, no REX.W) and writes it -- framed 0xDE <byte> 0xAD -- to debugcon
-- 0xE9 via the DX form, then a RESULT-DEPENDENT isa-debug-exit completion
-- (((payload ^ 0x31) & 0x7F)) and a Bochs power-off. Graded on the far-axis
-- dual-substrate (QEMU + Bochs) oracle vs a host-derived golden, NOT C.
-- See bootstrap/tests/run_native_codegen_link17.sh. Exact byte layout was
-- proven on BOTH substrates before implementation (the empirical gate);
-- a valid ELF cannot place the multiboot header at byte 0, so the header
-- sits at the page-aligned segment offset 0x1000 (vaddr 0x100000) with
-- e_entry = 0x10000c, and a one-entry (NULL) section table is required or
-- GRUB rejects e_shoff (QEMU -kernel tolerates its absence; GRUB does not).
-- ====================================================================

func nc_mb_marker_match(source, marker, i, n):
    if i >= n:
        return true
    end
    if i >= length(source):
        return false
    end
    if index(source, i) != index(marker, i):
        return false
    end
    return nc_mb_marker_match(source, marker, i + 1, n)
end

func nc_is_multiboot32(source):
    let marker = "-- emit: multiboot32"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    -- Require the marker to be a COMPLETE first line (followed by a newline),
    -- so "-- emit: multiboot32whatever" does NOT select the mode (it falls to
    -- the ELF64 path). Marker-only input (no newline) is not a real program.
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- zonday (third kernel-arc link): the "-- emit: multiboot32-idt" directive selects
-- a third emit mode -- a freestanding image that installs its OWN GDT + IDT and
-- catches the CPU's own #DE (divide-by-zero) fault, vectoring to a handler that is
-- the real compiled-Herbert main() body. The marker must be a COMPLETE first line
-- (newline at mlen); it does NOT collide with "-- emit: multiboot32" because at the
-- plain marker's length the -idt source has '-' (the "-idt" tail), not a newline,
-- so nc_is_multiboot32 returns false for an -idt program (checked first in main).
func nc_is_multiboot32_idt(source):
    let marker = "-- emit: multiboot32-idt"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- chosen (fourth kernel-arc link): the FOURTH freestanding emit mode. Detects the
-- anchored first-line directive "-- emit: multiboot32-page". The "-page" suffix means
-- nc_is_multiboot32 (which requires the marker be followed immediately by a newline)
-- does NOT match it (source[20] is '-', not 10), so the three existing modes stay
-- byte-identical and the self-host fixpoint is trivially preserved.
func nc_is_multiboot32_page(source):
    let marker = "-- emit: multiboot32-page"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- The FIFTH freestanding emit mode. Detects "-- emit: multiboot32-store": the image
-- writes a page-table entry at a RUNTIME-COMPUTED address (the first store-to-an-address,
-- candidate (d)), mapping a page left unmapped at build time, then accesses it and it
-- succeeds -- the MMU is the judge. The "-store" suffix means nc_is_multiboot32 /
-- _page / _idt do NOT match it, so the four prior modes stay byte-identical.
func nc_is_multiboot32_store(source):
    let marker = "-- emit: multiboot32-store"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- The SIXTH freestanding emit mode (DEMAND PAGING / iret-resumption). Detects
-- "-- emit: multiboot32-demand": the image touches a page left UNMAPPED at build time,
-- takes the CPU's own #PF, and a handler MAPS the page at runtime (liberi's computed PTE
-- store, sourced from CR2), flushes the TLB, drops the #PF error code, and `iret`s -- so the
-- faulting load RE-EXECUTES and now SUCCEEDS, reading a build-time-seeded frame. The first
-- link whose fault handler RESUMES (every prior handler ended cli;hlt). The proof byte comes
-- from the RESUMED LOAD (seed[V] = V^0x5A), so it can only appear via a genuine iret-resume
-- AND tracks the compiled body. The "-demand" suffix means nc_is_multiboot32 / _store / _page
-- / _idt do NOT match it, so the five prior modes stay byte-identical (fixpoint preserved).
func nc_is_multiboot32_demand(source):
    let marker = "-- emit: multiboot32-demand"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- timer (seventh kernel-arc link): the "-- emit: multiboot32-timer" directive selects
-- the freestanding image that takes the first ASYNCHRONOUS interrupt -- it remaps the
-- 8259 PIC, programs the 8254 PIT, `sti`s, and on the PIT's timer IRQ0 the CPU vectors
-- (vec 0x20) to a handler that is the compiled main() body + the shared epilogue. The
-- "-timer" suffix means nc_is_multiboot32 / _idt / _page / _store / _demand do NOT match
-- it, so the six prior modes stay byte-identical (the self-host fixpoint is preserved).
func nc_is_multiboot32_timer(source):
    let marker = "-- emit: multiboot32-timer"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- tick (talkert, eighth kernel-arc link): the "-- emit: multiboot32-tick" directive selects
-- the freestanding image that SURVIVES + REPEATS the asynchronous timer interrupt -- the
-- async-SURVIVAL half talcott's exit-on-first-IRQ deferred. Same boot/PIC/PIT/IDT shape as
-- timer, but the handler now ACKNOWLEDGES the PIC (non-specific EOI `out 0x20,0x20`) and
-- `iret`-RESUMES the interrupted mainline (an IRQ frame has NO error code, so NO `add esp,4`),
-- counting ticks in a register (esi, which survives across interrupts) until the Nth tick
-- (N=3 -> 2 genuine EOI+iret resume cycles), when it runs the compiled body + emits. The
-- "-tick" suffix means nc_is_multiboot32 / _idt / _page / _store / _demand / _timer do NOT
-- match it, so the seven prior modes stay byte-identical (the self-host fixpoint is preserved).
func nc_is_multiboot32_tick(source):
    let marker = "-- emit: multiboot32-tick"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- hoopteeter (ninth kernel-arc link): the "-- emit: multiboot32-long" directive selects
-- the freestanding image that crosses from 32-bit protected mode into 64-bit LONG MODE and
-- proves it -- the compiled main() body computes a value V (32-bit), it is stashed in esi
-- (which SURVIVES the mode transition), and after entering 64-bit a REX.W observable emits a
-- 64-bit-distinguishing proof byte = high dword of (V * 0x10001), extracted by a REX.W shr-by-32 that
-- is a NO-OP in 32-bit (the proof is X in 64-bit, a different byte in 32-bit/compat). The
-- "-long" suffix means nc_is_multiboot32 / _idt / _page / _store / _demand / _timer / _tick do
-- NOT match it, so the eight prior modes stay byte-identical (the self-host fixpoint gen2==gen1
-- is preserved).
func nc_is_multiboot32_long(source):
    let marker = "-- emit: multiboot32-long"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- The toakie freestanding subset (widens lingo's {PUSH_INT, MUL, RET}): adds
-- LOAD_LOCAL (3), STORE_LOCAL (4), ADD (5), SUB (6), EQ (11), BR (16),
-- BR_IF_FALSE (17) -- a single acyclic function that makes a data-dependent
-- branch from computed state. Anything else (calls 20, div/mod 43/44, the other
-- comparators 7-10/12, bitwise 36-41, tuples 14/15, strings, heap, and/or
-- short-circuit 18/19) stays rejected -- the honest narrow boundary, widened by
-- later kernel links. Every newly-admitted opcode is exercised by a forcing
-- probe; nothing is admitted for ergonomics.
func nc32_op_allowed(op):
    if op == 0:
        return true
    end
    if op == 3:
        return true
    end
    if op == 4:
        return true
    end
    if op == 5:
        return true
    end
    if op == 6:
        return true
    end
    if op == 11:
        return true
    end
    if op == 16:
        return true
    end
    if op == 17:
        return true
    end
    if op == 21:
        return true
    end
    if op == 42:
        return true
    end
    return false
end

-- Stack effect of each admitted op (pops then pushes). Used by the depth gate.
func nc32_pops(op):
    if op == 4:
        return 1
    end
    if op == 5:
        return 2
    end
    if op == 6:
        return 2
    end
    if op == 11:
        return 2
    end
    if op == 42:
        return 2
    end
    if op == 17:
        return 1
    end
    if op == 21:
        return 1
    end
    return 0
end

func nc32_pushes(op):
    if op == 0:
        return 1
    end
    if op == 3:
        return 1
    end
    if op == 5:
        return 1
    end
    if op == 6:
        return 1
    end
    if op == 11:
        return 1
    end
    if op == 42:
        return 1
    end
    return 0
end

-- nlocals = max(slot)+1 over LOAD_LOCAL/STORE_LOCAL; 0 if none. Slot reuse
-- across if-arms means the env's final counter can understate the peak, so the
-- frame is sized from the actual slots the code touches.
func nc32_nlocals_loop(code, i, n, acc):
    if i >= n:
        return acc
    end
    let op = get(code, i).0
    let a = acc
    if op == 3 or op == 4:
        if get(code, i).1 + 1 > a:
            a = get(code, i).1 + 1
        end
    end
    return nc32_nlocals_loop(code, i + 1, n, a)
end

-- PASS A of the depth gate (Codex C1): record the stack depth BEFORE each instr
-- by a linear forward walk, rejecting any unknown opcode, any underflow, and any
-- RET not at depth exactly 1 (every return -- terminal or mid-body -- pops the
-- one result into eax/al). Returns (ok, depths). Herbert ints are unsigned, so
-- every subtraction is guarded by a prior `cur < pops` check (no wraparound).
func nc32_build_depths(code, i, n, cur, depths):
    if i >= n:
        return (1, depths)
    end
    let op = get(code, i).0
    if not nc32_op_allowed(op):
        return (0, depths)
    end
    -- Structural stack-budget guard (Codex H7): the freestanding image reuses
    -- lingo's fixed 16 KiB reserve (memsz = 12 + code_len + 16384) for both the
    -- ebp frame and the expression stack. nlocals is capped at 31 (<=124 B); cap
    -- the value-stack depth at 3000 (<=12 KiB) so frame + expr stack cannot
    -- scribble below the reserve. Real acyclic probes peak under 10; this is a
    -- defense-in-depth ceiling, not a real limit.
    if cur > 3000:
        return (0, depths)
    end
    let pops = nc32_pops(op)
    if cur < pops:
        return (0, depths)
    end
    do add(depths, cur)
    if op == 21:
        if cur != 1:
            return (0, depths)
        end
    end
    return nc32_build_depths(code, i + 1, n, cur - pops + nc32_pushes(op), depths)
end

-- PASS B of the depth gate (Codex C1): every branch must target strictly forward
-- (forbids loops/back-edges structurally), within (i, n], and the depth it hands
-- the target must AGREE with the depth the linear fall-through reaches there. A
-- merge-point depth mismatch is what would otherwise boot and print a stable
-- WRONG byte, defeating the dual-substrate oracle. target == n is the epilogue
-- (depth 0). depths[i] >= 1 for op 17 is guaranteed by PASS A.
func nc32_check_branches(code, i, n, depths):
    if i >= n:
        return true
    end
    let op = get(code, i).0
    if op == 16 or op == 17:
        let t = get(code, i).1
        if t <= i:
            return false
        end
        -- Strictly forward AND strictly inside the body (Codex C3): a branch
        -- target == n would jump to the epilogue skipping the result `pop eax`,
        -- leaving al stale. The epilogue is reachable only via a mid-body RET's
        -- own jmp, never an IR branch operand (no valid structured program emits
        -- one), so reject t >= n outright.
        if t >= n:
            return false
        end
        let want = get(depths, i)
        if op == 17:
            want = want - 1
        end
        let actual = 0
        if t < n:
            actual = get(depths, t)
        end
        if actual != want:
            return false
        end
    end
    return nc32_check_branches(code, i + 1, n, depths)
end

-- The full subset gate: ends in RET, all opcodes admitted + stack-balanced
-- (PASS A), all branches forward + depth-agreeing (PASS B). Defense-in-depth: a
-- verified AST already lowers to balanced structured IR, but the far-axis oracle
-- has no C reference, so the gate proves well-formedness itself.
func nc32_body_ok(code, n):
    if n == 0:
        return false
    end
    if get(code, n - 1).0 != 21:
        return false
    end
    let bd = nc32_build_depths(code, 0, n, 0, new_array(int))
    if bd.0 == 0:
        return false
    end
    return nc32_check_branches(code, 0, n, bd.1)
end

-- 32-bit instruction sizes (the toakie lowering; NOT a de-REX of the x86-64
-- table). Terminal RET is 1 byte (pop eax, fall through to the epilogue);
-- mid-body RET is 6 (pop eax; jmp epilogue). Drives the two-pass layout that
-- resolves branch rel32s.
func nc32_op_size(op, is_last):
    if op == 0:
        return 5
    end
    if op == 3:
        return 3
    end
    if op == 4:
        return 3
    end
    if op == 5:
        return 5
    end
    if op == 6:
        return 5
    end
    if op == 11:
        return 11
    end
    if op == 16:
        return 5
    end
    if op == 17:
        return 9
    end
    if op == 42:
        return 6
    end
    if op == 45:
        return 18
    end
    if op == 46:
        return 8
    end
    if op == 21:
        if is_last == 1:
            return 1
        end
        return 6
    end
    return 0
end

-- PASS 1 layout: byte offset of each instr from code start (offsets INCLUDE the
-- prefix, so a branch rel cancels the prefix). Returns (offs, epilogue_off); a
-- branch target == n resolves to epilogue_off.
func nc32_layout_loop(code, i, n, cur, offs):
    if i >= n:
        return (offs, cur)
    end
    do add(offs, cur)
    let il = 0
    if i == n - 1:
        il = 1
    end
    return nc32_layout_loop(code, i + 1, n, cur + nc32_op_size(get(code, i).0, il), offs)
end

-- Frame-local displacement as a disp8 byte: [ebp - 4*(slot+1)]. nlocals is
-- capped at 31 upstream (max slot 30), so 4*(slot+1) <= 124 fits a signed byte.
-- The cap is 31 not 32 because the frame prologue is `sub esp, imm8` (83 EC ib),
-- which SIGN-EXTENDS: frame = 4*32 = 128 would encode as 0x80 = -128 and ADD to
-- esp. So 31 locals (frame 124, 0x7C) is the true boundary, not the disp8 limit.
func nc32_emit_local_disp(buf, slot):
    do append(buf, 256 - 4 * (slot + 1))
    return buf
end

-- PASS 2 lowering: emit each instr's bytes, resolving BR/BR_IF_FALSE/mid-RET
-- rel32 from the layout. All rel32s are non-negative (forward-only branches,
-- gated), so nc_append_le32 serializes them directly.
func nc32_lower_loop(buf, code, i, n, offs, epi):
    if i >= n:
        return buf
    end
    let op = get(code, i).0
    let il = 0
    if i == n - 1:
        il = 1
    end
    let endoff = get(offs, i) + nc32_op_size(op, il)
    if op == 0:
        do append(buf, 104)
        buf = nc_append_le32(buf, get(code, i).1)
    elif op == 3:
        do append(buf, 255)
        do append(buf, 117)
        buf = nc32_emit_local_disp(buf, get(code, i).1)
    elif op == 4:
        do append(buf, 143)
        do append(buf, 69)
        buf = nc32_emit_local_disp(buf, get(code, i).1)
    elif op == 5:
        do append(buf, 89)
        do append(buf, 88)
        do append(buf, 1)
        do append(buf, 200)
        do append(buf, 80)
    elif op == 6:
        do append(buf, 89)
        do append(buf, 88)
        do append(buf, 41)
        do append(buf, 200)
        do append(buf, 80)
    elif op == 11:
        do append(buf, 89)
        do append(buf, 88)
        do append(buf, 57)
        do append(buf, 200)
        do append(buf, 15)
        do append(buf, 148)
        do append(buf, 192)
        do append(buf, 15)
        do append(buf, 182)
        do append(buf, 192)
        do append(buf, 80)
    elif op == 42:
        do append(buf, 89)
        do append(buf, 88)
        do append(buf, 15)
        do append(buf, 175)
        do append(buf, 193)
        do append(buf, 80)
    elif op == 16:
        do append(buf, 233)
        let t = get(code, i).1
        let toff = epi
        if t < n:
            toff = get(offs, t)
        end
        buf = nc_append_le32(buf, toff - endoff)
    elif op == 17:
        do append(buf, 88)
        do append(buf, 133)
        do append(buf, 192)
        do append(buf, 15)
        do append(buf, 132)
        let t2 = get(code, i).1
        let toff2 = epi
        if t2 < n:
            toff2 = get(offs, t2)
        end
        buf = nc_append_le32(buf, toff2 - endoff)
    elif op == 45:
        -- trukfit op_input_byte: poll COM1 LSR (0x3FD) for Data-Ready, then read the
        -- RBR (0x3F8) and push the byte zero-extended. 18 bytes, self-contained (the
        -- jz back-edge is an internal rel8); the value provably traces to the RBR read.
        do append(buf, 102)   -- 66
        do append(buf, 186)   -- BA  mov dx, 0x03FD (LSR)
        do append(buf, 253)   -- FD
        do append(buf, 3)     -- 03
        do append(buf, 236)   -- EC  in al, dx
        do append(buf, 168)   -- A8  test al,
        do append(buf, 1)     -- 01     1 (Data-Ready)
        do append(buf, 116)   -- 74  jz
        do append(buf, 247)   -- F7     rel8 -9 -> back to the mov dx,0x3FD
        do append(buf, 102)   -- 66
        do append(buf, 186)   -- BA  mov dx, 0x03F8 (RBR)
        do append(buf, 248)   -- F8
        do append(buf, 3)     -- 03
        do append(buf, 236)   -- EC  in al, dx  (the live byte)
        do append(buf, 15)    -- 0F
        do append(buf, 182)   -- B6  movzx eax, al
        do append(buf, 192)   -- C0
        do append(buf, 80)    -- 50  push eax
    elif op == 46:
        -- lodger op_module_byte: movzx eax, byte [answer_cell @ 0x100048]; push eax. 8 bytes.
        -- answer cell is at the FIXED lodger layout vaddr (CELLBASE 0x100018 + slot 12*4 = 0x100048).
        do append(buf, 15)    -- 0F
        do append(buf, 182)   -- B6
        do append(buf, 5)     -- 05  movzx eax, byte [imm32]
        buf = nc_append_le32(buf, 1048648)
        do append(buf, 80)    -- 50  push eax
    elif op == 21:
        if il == 1:
            do append(buf, 88)
        else:
            do append(buf, 88)
            do append(buf, 233)
            buf = nc_append_le32(buf, epi - endoff)
        end
    end
    return nc32_lower_loop(buf, code, i + 1, n, offs, epi)
end

func nc32_emit_out_char(buf, c):
    do append(buf, 176)
    do append(buf, c)
    do append(buf, 238)
    return buf
end

-- Fixed 58-byte epilogue: frame the payload on 0xE9, a result-dependent
-- isa-debug-exit completion, a Bochs power-off, then halt.
func nc32_emit_epilogue(buf):
    do append(buf, 136)
    do append(buf, 195)
    do append(buf, 102)
    do append(buf, 186)
    do append(buf, 233)
    do append(buf, 0)
    do append(buf, 176)
    do append(buf, 222)
    do append(buf, 238)
    do append(buf, 136)
    do append(buf, 216)
    do append(buf, 238)
    do append(buf, 176)
    do append(buf, 173)
    do append(buf, 238)
    do append(buf, 136)
    do append(buf, 216)
    do append(buf, 52)
    do append(buf, 49)
    do append(buf, 36)
    do append(buf, 127)
    do append(buf, 102)
    do append(buf, 186)
    do append(buf, 244)
    do append(buf, 0)
    do append(buf, 238)
    do append(buf, 102)
    do append(buf, 186)
    do append(buf, 0)
    do append(buf, 137)
    buf = nc32_emit_out_char(buf, 83)
    buf = nc32_emit_out_char(buf, 104)
    buf = nc32_emit_out_char(buf, 117)
    buf = nc32_emit_out_char(buf, 116)
    buf = nc32_emit_out_char(buf, 100)
    buf = nc32_emit_out_char(buf, 111)
    buf = nc32_emit_out_char(buf, 119)
    buf = nc32_emit_out_char(buf, 110)
    do append(buf, 250)
    do append(buf, 244)
    do append(buf, 235)
    do append(buf, 253)
    return buf
end

func nc32_roundup4(v):
    let r = v % 4
    if r == 0:
        return v
    end
    return v + 4 - r
end

func nc32_emit_ehdr(buf, entry, shoff):
    do append(buf, 127)
    do append(buf, 69)
    do append(buf, 76)
    do append(buf, 70)
    do append(buf, 1)
    do append(buf, 1)
    do append(buf, 1)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 2)
    do append(buf, 0)
    do append(buf, 3)
    do append(buf, 0)
    do append(buf, 1)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    buf = nc_append_le32(buf, entry)
    buf = nc_append_le32(buf, 52)
    buf = nc_append_le32(buf, shoff)
    buf = nc_append_le32(buf, 0)
    do append(buf, 52)
    do append(buf, 0)
    do append(buf, 32)
    do append(buf, 0)
    do append(buf, 1)
    do append(buf, 0)
    do append(buf, 40)
    do append(buf, 0)
    do append(buf, 1)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    return buf
end

func nc32_emit_phdr(buf, filesz, memsz):
    buf = nc_append_le32(buf, 1)
    buf = nc_append_le32(buf, 4096)
    buf = nc_append_le32(buf, 1048576)
    buf = nc_append_le32(buf, 1048576)
    buf = nc_append_le32(buf, filesz)
    buf = nc_append_le32(buf, memsz)
    buf = nc_append_le32(buf, 7)
    buf = nc_append_le32(buf, 4096)
    return buf
end

func nc32_emit_mbheader(buf):
    do append(buf, 2)
    do append(buf, 176)
    do append(buf, 173)
    do append(buf, 27)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 254)
    do append(buf, 79)
    do append(buf, 82)
    do append(buf, 228)
    return buf
end

-- trukfit (f3 device input) helpers ----------------------------------------------
-- One UART register write: mov dx,port (66 BA pp pp) ; mov al,val (B0 vv) ; out dx,al (EE).
func nc32_uart_out(buf, port, val):
    do append(buf, 102)
    do append(buf, 186)
    do append(buf, port % 256)
    do append(buf, port / 256)
    do append(buf, 176)
    do append(buf, val)
    do append(buf, 238)
    return buf
end

-- COM1 init, ROBUST order (force LCR/DLAB=0 FIRST so IER=0 lands on IER, not DLM):
-- 8N1; IER=0; DLAB=1; DLL=1; DLM=0; 8N1(DLAB=0); FCR off (FIFO off); DTR|RTS. 56 bytes.
func nc32_uart_init(buf):
    buf = nc32_uart_out(buf, 1019, 3)
    buf = nc32_uart_out(buf, 1017, 0)
    buf = nc32_uart_out(buf, 1019, 128)
    buf = nc32_uart_out(buf, 1016, 1)
    buf = nc32_uart_out(buf, 1017, 0)
    buf = nc32_uart_out(buf, 1019, 3)
    buf = nc32_uart_out(buf, 1018, 0)
    buf = nc32_uart_out(buf, 1020, 3)
    return buf
end

func nc32_count_input_loop(code, i, n, cnt):
    if i >= n:
        return cnt
    end
    let c = cnt
    if get(code, i).0 == 45:
        c = c + 1
    end
    return nc32_count_input_loop(code, i + 1, n, c)
end

func nc32_count_input(code, n):
    return nc32_count_input_loop(code, 0, n, 0)
end

-- The input mode is STRAIGHT-LINE (no branches): with no op 16/17, the single static
-- input_byte (nc32_count_input == 1) is provably the single DYNAMIC read on the only path
-- -- there is no dead-read-in-a-branch. Control flow is f2/trikea's domain; the device-read
-- capability needs none. (Codex diff-review hardening.)
func nc32_has_branch_loop(code, i, n):
    if i >= n:
        return false
    end
    let op = get(code, i).0
    if op == 16 or op == 17:
        return true
    end
    return nc32_has_branch_loop(code, i + 1, n)
end

func nc32_has_branch(code, n):
    return nc32_has_branch_loop(code, 0, n)
end

-- Structural-validation proxy: op 45 (input_byte) has the SAME stack effect as a
-- push_int (op 0), so map it to op 0 for nc32_body_ok's depth/branch walk. The REAL
-- code (with op 45) is what gets laid out and lowered; build_depths never sees op 45,
-- so every other mode (which lacks the proxy) auto-rejects an input body.
func nc32_input_proxy_loop(out, code, i, n):
    if i >= n:
        return out
    end
    let e = get(code, i)
    if e.0 == 45:
        do add(out, (0, 0, 0))
    else:
        do add(out, e)
    end
    return nc32_input_proxy_loop(out, code, i + 1, n)
end

func nc32_input_proxy(code, n):
    return nc32_input_proxy_loop(new_array((int, int, int)), code, 0, n)
end

func nc_is_multiboot32_input(source):
    let marker = "-- emit: multiboot32-input"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- The trukfit emit driver: a freestanding 32-bit image whose compiled body READS one
-- late-bound byte from COM1 (input_byte/op 45), transforms it via the toakie subset,
-- and emits the result through the proven epilogue. UART init is emitted ONCE in the
-- prologue (after mov esp, before the rbp frame). prefix_len = 5 (mov esp) + 56 (uart)
-- [+ 5 rbp frame]. Reuses nc32_layout/lower/epilogue verbatim (op 45 added to
-- size/lower only) so all prior modes stay byte-identical.
func nc_emit_multiboot32_input_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let fa = nc_fail(506, 0, "multiboot32-input: main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let fb = nc_fail(507, 0, "multiboot32-input: main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if nc32_count_input(code, n) != 1:
        let fi = nc_fail(508, 0, "multiboot32-input: main must read input_byte() exactly once")
        return 0
    end
    if nc32_has_branch(code, n):
        let fh = nc_fail(513, 0, "multiboot32-input: control flow (if/branch) not in the straight-line input subset")
        return 0
    end
    let proxy = nc32_input_proxy(code, n)
    if not nc32_body_ok(proxy, n):
        let fc = nc_fail(509, 0, "multiboot32-input: body not in the input/control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let fd = nc_fail(510, 0, "multiboot32-input: too many locals (max 31)")
        return 0
    end
    let prefix_len = 61
    if nlocals > 0:
        prefix_len = 66
    end
    let lay = nc32_layout_loop(code, 0, n, prefix_len, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - prefix_len:
        let fe = nc_fail(511, 0, "multiboot32-input: body length invariant")
        return 0
    end
    let code_len = prefix_len + bodylen + 58
    let memsz = 12 + code_len + 16384
    let esp_val = 1048576 + memsz
    let cbuf = new_buffer()
    do append(cbuf, 188)
    cbuf = nc_append_le32(cbuf, esp_val)
    cbuf = nc32_uart_init(cbuf)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    let frozen_code = freeze(cbuf)
    if length(frozen_code) != code_len:
        let fg = nc_fail(512, 0, "multiboot32-input: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- ===========================================================================
-- lodger (seventeenth kernel-arc link): the program-lifecycle germ. The kernel
-- runs ONE build-unknown program (a Multiboot module the loader delivers) --
-- discovers it via mbinfo at runtime, parses the memory map, allocates one
-- floored non-overlapping stack page (D20: a bare-metal bump allocator with a
-- physical-ownership exclusion set), transfers control to a runtime-discovered
-- entry, collects the answer, halts clean. The emitted head below is BYTE-EXACT
-- to the silicon-proven assembler (audits/link17-lifecycle/step0/lodger.py);
-- it was machine-generated from it. esp_top (=kernel end =stack top) is the only
-- per-probe variable. Cells at fixed vaddr 0x100018. See 01-step0-results.
-- ===========================================================================
-- dr: out eax as 4 raw LE bytes to 0xE9 (the ownership-dump primitive). 17 bytes.
func nc32_ldg_dr(buf):
    do append(buf, 230)
    do append(buf, 233)
    do append(buf, 193)
    do append(buf, 232)
    do append(buf, 8)
    do append(buf, 230)
    do append(buf, 233)
    do append(buf, 193)
    do append(buf, 232)
    do append(buf, 8)
    do append(buf, 230)
    do append(buf, 233)
    do append(buf, 193)
    do append(buf, 232)
    do append(buf, 8)
    do append(buf, 230)
    do append(buf, 233)
    return buf
end

-- The lodger head (prefix): ebx-capture@0 ; jmp over cells+failframes ; cells ;
-- fail frames + shutdown tail ; glue (magic/flags/mods/mmap-walk/bump-alloc/
-- ownership-dump/indirect-call/answer-store/cld). Ends at cld -> falls through
-- to the compiled body. esp_top = 0x100000 + memsz (kernel end = stack top).
func nc32_lodger_emit_head(buf, esp_top):
    do append(buf, 137)
