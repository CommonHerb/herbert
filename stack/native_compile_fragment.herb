func nc_emit_disp_rbp_lea_rsp(buf, neg, mag):
    do append(buf, 72)
    do append(buf, 141)
    if nc_signed_fits8(neg, mag):
        do append(buf, 101)
        return nc_append_s8(buf, neg, mag)
    end
    do append(buf, 165)
    return nc_append_s32(buf, neg, mag)
end

func nc_emit_rsp_load_rax(buf, mag):
    do append(buf, 72)
    do append(buf, 139)
    if mag <= 127:
        do append(buf, 68)
        do append(buf, 36)
        do append(buf, mag)
        return buf
    end
    do append(buf, 132)
    do append(buf, 36)
    return nc_append_le32(buf, mag)
end

func nc_emit_disp_rbp_store_r11(buf, neg, mag):
    do append(buf, 76)
    do append(buf, 137)
    if nc_signed_fits8(neg, mag):
        do append(buf, 93)
        return nc_append_s8(buf, neg, mag)
    end
    do append(buf, 157)
    return nc_append_s32(buf, neg, mag)
end

func nc_emit_prologue(buf, frame_sz):
    do append(buf, 85)
    do append(buf, 72)
    do append(buf, 137)
    do append(buf, 229)
    if frame_sz <= 127:
        do append(buf, 72)
        do append(buf, 131)
        do append(buf, 236)
        do append(buf, frame_sz)
    else:
        do append(buf, 72)
        do append(buf, 129)
        do append(buf, 236)
        buf = nc_append_le32(buf, frame_sz)
    end
    return buf
end

func nc_emit_arg_copies_loop(buf, k, n):
    if k >= n:
        return buf
    end
    let src_mag = 16 + nc_mul8(n - 1 - k)
    let dst_mag = nc_local_mag(k)
    buf = nc_emit_disp_rbp_load_rax(buf, 0, src_mag)
    buf = nc_emit_disp_rbp_store_rax(buf, 1, dst_mag)
    return nc_emit_arg_copies_loop(buf, k + 1, n)
end

func nc_emit_read(buf, n_locals, scratch_sz):
    do append(buf, 49)
    do append(buf, 192)
    do append(buf, 49)
    do append(buf, 255)
    buf = nc_emit_disp_rbp_lea_rsi(buf, 1, nc_mul8(n_locals) + scratch_sz)
    do append(buf, 186)
    buf = nc_append_le32(buf, scratch_sz)
    do append(buf, 15)
    do append(buf, 5)
    return buf
end

func nc_emit_push_int(buf, n):
    do append(buf, 72)
    do append(buf, 184)
    buf = nc_append_le64(buf, n)
    do append(buf, 80)
    return buf
end

func nc_emit_push_bool(buf, n):
    do append(buf, 106)
    do append(buf, n)
    return buf
end

func nc_emit_load_local(buf, slot):
    buf = nc_emit_disp_rbp_load_rax(buf, 1, nc_local_mag(slot))
    do append(buf, 80)
    return buf
end

func nc_emit_store_local(buf, slot):
    do append(buf, 88)
    return nc_emit_disp_rbp_store_rax(buf, 1, nc_local_mag(slot))
end

func nc_emit_read_byte(buf, fn, scratch_sz, k):
    buf = nc_emit_disp_rbp_read_byte(buf, 1, nc_mul8(fn.3) + scratch_sz - k)
    do append(buf, 80)
    return buf
end

