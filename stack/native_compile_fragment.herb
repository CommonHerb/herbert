func nc_arg_copy_len_loop(k, nwords, acc):
    if k >= nwords:
        return acc
    end
    let src_mag = 16 + nc_mul8(nwords - 1 - k)
    let dst_mag = nc_local_mag(k)
    return nc_arg_copy_len_loop(k + 1, nwords, acc + nc_disp_len_rbp(0, src_mag) + nc_disp_len_rbp(1, dst_mag))
end

func nc_load_local_len_loop(base, j, width, acc):
    if j >= width:
        return acc
    end
    return nc_load_local_len_loop(base, j + 1, width, acc + nc_disp_len_rbp(1, nc_local_mag(base + j)) + 1)
end

func nc_load_local_len(base, width):
    return nc_load_local_len_loop(base, 0, width, 0)
end

func nc_store_local_len_loop(base, j, acc):
    if j == 0 - 1:
        return acc
    end
    return nc_store_local_len_loop(base, j - 1, acc + 1 + nc_disp_len_rbp(1, nc_local_mag(base + j)))
end

func nc_store_local_len(base, width):
    return nc_store_local_len_loop(base, width - 1, 0)
end

func nc_sret_save_len(meta):
    if meta.6 == 0 - 1:
        return 0
    end
    return nc_disp_len_rbp(1, nc_local_mag(meta.6))
end

func nc_group_single_len(op):
    if op == 0:
        return 11
    end
    if op == 1:
        return 2
    end
    if op == 2:
        return 16
    end
    if op == 5 or op == 6:
        return 6
    end
    if op == 7 or op == 8 or op == 9 or op == 10 or op == 11 or op == 12:
        return 13
    end
    if op == 13:
        return 12
    end
    if op == 14:
        return 0
    end
    if op == 16:
        return 5
    end
    if op == 17:
        return 10
    end
    if op == 18 or op == 19:
        return 17
    end
    if op == 21:
        return 3
    end
    if op == 22:
        return 3
    end
    if op == 23:
        return 27
    end
    if op == 25:
        return 50
    end
    if op == 26:
        return 84
    end
    if op == 27:
        return 75
    end
    if op == 28:
        return 84
    end
    if op == 30:
        return 5
    end
    if op == 31:
        return 135
    end
    if op == 33:
        return 91
    end
    if op == 34:
        return 44
    end
    if op == 35:
        return 120
    end
    -- Bitwise / shift (36-41). LOAD-BEARING for branch-displacement layout:
    -- pass 1 sizes every instruction here; a missing arm would give the new
    -- ops length 0 and silently rot every branch offset in any function that
    -- uses them. band/bor/bxor/shl/shr are the same 6-byte shape as add/sub
    -- (pop rcx; pop rax; <3-byte op>; push rax); bnot is 5 bytes (pop rax;
    -- not rax; push rax) like op 30 (count).
    if op == 36 or op == 37 or op == 38 or op == 39 or op == 40:
        return 6
    end
    if op == 41:
        return 5
    end
    -- Multiplicative (42-44). LOAD-BEARING for branch-displacement layout: a
    -- wrong length here silently rots every branch offset in any function that
    -- uses these ops. mul is 7 bytes (pop rcx; pop rax; imul rax,rcx [4 bytes];
    -- push rax). div and mod are 18 bytes each: pop rcx; pop rax; test rcx,rcx
    -- [3]; jz exit1 [6]; xor rdx,rdx [3]; div rcx [3]; push rax|rdx [1]. These
    -- MUST match the byte counts emitted by nc_emit_mul / nc_emit_div_or_mod.
    if op == 42:
        return 7
    end
    if op == 43 or op == 44:
        return 18
    end
    return 0
end

