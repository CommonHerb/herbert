func nc_string_offset_loop(strings, i, target, acc):
    if i >= target:
        return acc
    end
    return nc_string_offset_loop(strings, i + 1, target, acc + length(get(strings, i)))
end

func nc_string_offset(strings, idx):
    return nc_string_offset_loop(strings, 0, idx, 0)
end

func nc_rodata_len_loop(strings, i, n, acc):
    if i >= n:
        return acc
    end
    return nc_rodata_len_loop(strings, i + 1, n, acc + length(get(strings, i)))
