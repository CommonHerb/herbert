-- Multiboot header REQUESTING memory info (flags bit1=MEMINFO): magic 1BADB002, flags 2,
-- checksum 0xE4524FFC. A NEW function -- the shared nc32_emit_mbheader (flags=0) is untouched
-- (fixpoint-safe). lodger consumes the mmap, so it requests it.
func nc32_emit_mbheader_meminfo(buf):
    do append(buf, 2)
    do append(buf, 176)
    do append(buf, 173)
    do append(buf, 27)
    do append(buf, 2)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 252)
    do append(buf, 79)
    do append(buf, 82)
    do append(buf, 228)
    return buf
end

func nc32_count_module_loop(code, i, n, cnt):
    if i >= n:
        return cnt
    end
    let c = cnt
    if get(code, i).0 == 46:
        c = c + 1
    end
    return nc32_count_module_loop(code, i + 1, n, c)
end

func nc32_count_module(code, n):
    return nc32_count_module_loop(code, 0, n, 0)
end

-- op 46 (module_byte) has the SAME stack effect as push_int (op 0); map it to op 0 for
-- nc32_body_ok's depth walk (the input-mode proxy pattern). The REAL code keeps op 46.
func nc32_module_proxy_loop(out, code, i, n):
    if i >= n:
        return out
    end
    let e = get(code, i)
    if e.0 == 46:
        do add(out, (0, 0, 0))
    else:
        do add(out, e)
    end
    return nc32_module_proxy_loop(out, code, i + 1, n)
end

func nc32_module_proxy(code, n):
    return nc32_module_proxy_loop(new_array((int, int, int)), code, 0, n)
end

func nc_is_multiboot32_lodger(source):
    let marker = "-- emit: multiboot32-lodger"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- lodger driver: head (program-lifecycle germ) + compiled body (reads module_byte() exactly
-- once, straight-line toakie subset) + shared epilogue. prefix_len = 1493 (head ends at cld;
-- +5 if the body has an ebp frame). Reuses nc32_emit_ehdr/phdr/epilogue verbatim; the mbheader
-- is the MEMINFO variant.
func nc_emit_multiboot32_lodger_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let fa = nc_fail(530, 0, "multiboot32-lodger: main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let fb = nc_fail(531, 0, "multiboot32-lodger: main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if nc32_count_module(code, n) != 1:
        let fi = nc_fail(532, 0, "multiboot32-lodger: main must read module_byte() exactly once")
        return 0
    end
    if nc32_has_branch(code, n):
        let fh = nc_fail(533, 0, "multiboot32-lodger: control flow (if/branch) not in the straight-line lodger subset")
        return 0
    end
    let proxy = nc32_module_proxy(code, n)
    if not nc32_body_ok(proxy, n):
        let fc = nc_fail(534, 0, "multiboot32-lodger: body not in the module/locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let fd = nc_fail(535, 0, "multiboot32-lodger: too many locals (max 31)")
        return 0
    end
    let prefix_len = 1493
    if nlocals > 0:
        prefix_len = 1498
    end
    let lay = nc32_layout_loop(code, 0, n, prefix_len, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - prefix_len:
        let fe = nc_fail(536, 0, "multiboot32-lodger: body length invariant")
        return 0
    end
    let code_len = prefix_len + bodylen + 58
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let cbuf = new_buffer()
    cbuf = nc32_lodger_emit_head(cbuf, esp_top)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    let frozen_code = freeze(cbuf)
    if length(frozen_code) != code_len:
        let fg = nc_fail(537, 0, "multiboot32-lodger: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader_meminfo(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end


func nc_emit_multiboot32_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(450, 0, "multiboot32: main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f6 = nc_fail(454, 0, "multiboot32: main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f2 = nc_fail(451, 0, "multiboot32: body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(453, 0, "multiboot32: too many locals (max 31)")
        return 0
    end
    let prefix_len = 5
    if nlocals > 0:
        prefix_len = 10
    end
    let lay = nc32_layout_loop(code, 0, n, prefix_len, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - prefix_len:
        let f5 = nc_fail(452, 0, "multiboot32: body length invariant")
        return 0
    end
    let code_len = prefix_len + bodylen + 58
    let memsz = 12 + code_len + 16384
    let esp_val = 1048576 + memsz
    let cbuf = new_buffer()
    do append(cbuf, 188)
    cbuf = nc_append_le32(cbuf, esp_val)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    let frozen_code = freeze(cbuf)
    if length(frozen_code) != code_len:
        let f3 = nc_fail(452, 0, "multiboot32: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- zonday: the fixed 63-byte STRUCTURAL head (emitter-laid-out, like the ELF/MB
-- headers -- it is honest structure, not compiled Herbert). In execution order:
-- cli; lgdt my own GDT; far-jmp to reload CS=0x08; reload DS/ES/FS/GS/SS=0x10
-- (stale bootloader selectors index into MY new GDT -- QEMU and GRUB differ, so
-- they MUST be refreshed or one substrate triple-faults); mov esp (so the #DE
-- frame push lands in valid stack); lidt; then the #DE trigger (xor edx,edx; xor
-- ecx,ecx; div ecx); then the SENTINEL fall-through (mov al,0xBB; jmp epilogue --
-- reached only if the fault never fires, e.g. a mutation removed the trigger, so
-- a wrong byte is emitted -> RED); then the WRAPPER (the IDT gate vectors HERE):
-- cmp [esp], <faulting div EIP>; jne sentinel -- only a genuine #DE pushes that
-- EIP, so a non-fault entry cannot forge the proof; it then falls into the handler.
-- Three vaddrs are constants off V0=0x10000c (=1048588): far-jmp target V0+15,
-- the div EIP V0+45, the gate target (=this wrapper) V0+54. The GDTR/IDTR bases and
-- esp_top and the sentinel rel32 vary with the program and are passed in.
func nc32_idt_emit_head(buf, gdtr_vaddr, esp_top, idtr_vaddr, sentinel_rel32):
    do append(buf, 250)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 21)
    buf = nc_append_le32(buf, gdtr_vaddr)
    do append(buf, 234)
    buf = nc_append_le32(buf, 1048603)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 102)
    do append(buf, 184)
    do append(buf, 16)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, 216)
    do append(buf, 142)
    do append(buf, 192)
    do append(buf, 142)
    do append(buf, 224)
    do append(buf, 142)
    do append(buf, 232)
    do append(buf, 142)
    do append(buf, 208)
    do append(buf, 188)
    buf = nc_append_le32(buf, esp_top)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 29)
    buf = nc_append_le32(buf, idtr_vaddr)
    do append(buf, 49)
    do append(buf, 210)
    do append(buf, 49)
    do append(buf, 201)
    do append(buf, 247)
    do append(buf, 241)
    do append(buf, 176)
    do append(buf, 187)
    do append(buf, 233)
    buf = nc_append_le32(buf, sentinel_rel32)
    do append(buf, 129)
    do append(buf, 60)
    do append(buf, 36)
    buf = nc_append_le32(buf, 1048633)
    do append(buf, 117)
    do append(buf, 240)
    return buf
end

-- zonday: the 44-byte data tables (emitter-laid-out at fixed vaddrs in the loaded
-- RWX image -- never built at runtime, so NO store-to-arbitrary-address primitive
-- is introduced, and typed-memory stays deferred). A flat 3-entry GDT (null + 32-bit
-- code 0x08 + 32-bit data 0x10), its GDTR (limit 23), a 1-entry IDT (vector 0/#DE:
-- gate offset = the wrapper vaddr, selector 0x0008, attr 0x8E = present/DPL0/32-bit
-- interrupt gate), and its IDTR (limit 7 -- only vector 0; any other exception finds
-- no gate -> triple-fault-reset, which is a correct RED for this fail-closed fixture).
func nc32_idt_emit_tables(buf, gdt_vaddr, idt_vaddr, gate_vaddr):
    buf = nc_emit_zeroes_loop(buf, 8)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 154)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 146)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 23)
    do append(buf, 0)
    buf = nc_append_le32(buf, gdt_vaddr)
    let glo = gate_vaddr % 65536
    let ghi_full = gate_vaddr / 65536
    let ghi = ghi_full % 65536
    do append(buf, glo % 256)
    do append(buf, glo / 256)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, ghi % 256)
    do append(buf, ghi / 256)
    do append(buf, 7)
    do append(buf, 0)
    buf = nc_append_le32(buf, idt_vaddr)
    return buf
end

-- zonday driver. Layout (vaddr V0=0x10000c): [HEAD 63] [handler: ebp-frame(0|5) +
-- toakie body + shared 58-byte epilogue] [tables 44]. The handler IS the compiled
-- main() body (toakie subset: locals, + - *, ==, if/else, return) -- the anti-
-- ceremony guard: the proof byte is produced by NORMAL compiled lowering, not a
-- canned blob. The handler has NO `mov esp` (the head already set it; the wrapper
-- validated the fault frame first) -- it runs below the #DE frame and falls into the
-- shared epilogue. It does NOT iret (a #DE re-faults on return; iret-resumption is a
-- deferred later link). Reuses lingo's ehdr/phdr/mbheader and toakie's verifier +
-- 2-pass layout/lowering + epilogue verbatim, so the existing modes are untouched.
func nc_emit_multiboot32_idt_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(455, 0, "multiboot32-idt: handler main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(456, 0, "multiboot32-idt: handler main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(457, 0, "multiboot32-idt: handler body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(458, 0, "multiboot32-idt: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(459, 0, "multiboot32-idt: body length invariant")
        return 0
    end
    let head_len = 63
    let hb = epi + 58
    let code_len = head_len + hb + 44
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let gdt_off = head_len + hb
    let gdt_vaddr = 1048588 + gdt_off
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 8
    let gate_vaddr = 1048642
    let epi_off_in_code = head_len + epi
    let sentinel_rel32 = epi_off_in_code - 54
    let cbuf = new_buffer()
    cbuf = nc32_idt_emit_head(cbuf, gdtr_vaddr, esp_top, idtr_vaddr, sentinel_rel32)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    cbuf = nc32_idt_emit_tables(cbuf, gdt_vaddr, idt_vaddr, gate_vaddr)
    let frozen_code = freeze(cbuf)
    if length(frozen_code) != code_len:
        let f6 = nc_fail(459, 0, "multiboot32-idt: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- timer: one `out imm8, al` (B0 val E6 port) -- byte output to a fixed port. The PIC
-- (0x20/0x21/0xA0/0xA1) and PIT (0x43/0x40) ports are all <= 0xFF, so the immediate-port
-- form is used; NO `in` (D18 port input stays deferred -- a full IMR write, not a
-- mask-preserving read).
func nc32_timer_out_imm(buf, val, port):
    do append(buf, 176)
    do append(buf, val)
    do append(buf, 230)
    do append(buf, port)
    return buf
end

-- timer (seventh kernel-arc link). The 97-byte HEAD: the 41-byte GDT-install (cli; lgdt;
-- far-jmp CS=0x08; reload DS/ES/FS/GS/SS=0x10; mov esp; lidt -- identical to zonday/chosen
-- up to here), then the NEW async setup: remap the 8259 PIC so IRQ0..15 land at vectors
-- 0x20..0x2F and unmask ONLY IRQ0 (full IMR writes, no read); program the 8254 PIT channel
-- 0 (mode 2, divisor 0xFFFF); `sti`; then a hlt-loop. The mainline here NEVER emits -- the
-- proof byte can only come via the asynchronous IRQ0 vectoring to the handler that follows.
func nc32_timer_emit_head(buf, gdtr_vaddr, esp_top, idtr_vaddr):
    do append(buf, 250)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 21)
    buf = nc_append_le32(buf, gdtr_vaddr)
    do append(buf, 234)
    buf = nc_append_le32(buf, 1048603)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 102)
    do append(buf, 184)
    do append(buf, 16)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, 216)
    do append(buf, 142)
    do append(buf, 192)
    do append(buf, 142)
    do append(buf, 224)
    do append(buf, 142)
    do append(buf, 232)
    do append(buf, 142)
    do append(buf, 208)
    do append(buf, 188)
    buf = nc_append_le32(buf, esp_top)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 29)
    buf = nc_append_le32(buf, idtr_vaddr)
    buf = nc32_timer_out_imm(buf, 17, 32)
    buf = nc32_timer_out_imm(buf, 17, 160)
    buf = nc32_timer_out_imm(buf, 32, 33)
    buf = nc32_timer_out_imm(buf, 40, 161)
    buf = nc32_timer_out_imm(buf, 4, 33)
    buf = nc32_timer_out_imm(buf, 2, 161)
    buf = nc32_timer_out_imm(buf, 1, 33)
    buf = nc32_timer_out_imm(buf, 1, 161)
    buf = nc32_timer_out_imm(buf, 254, 33)
    buf = nc32_timer_out_imm(buf, 255, 161)
    buf = nc32_timer_out_imm(buf, 52, 67)
    buf = nc32_timer_out_imm(buf, 255, 64)
    buf = nc32_timer_out_imm(buf, 255, 64)
    do append(buf, 251)
    do append(buf, 244)
    do append(buf, 235)
    do append(buf, 253)
    return buf
end

-- tick (talkert): the 99-byte HEAD. Byte-identical to the 97-byte timer head EXCEPT it
-- inserts `xor esi,esi` (31 F6) immediately before `sti` -- zeroing the tick counter that
-- lives in esi and SURVIVES across the asynchronous interrupts (the CPU does not save/restore
-- GP registers on an interrupt-gate, and the idle mainline sti;hlt;jmp never touches esi, so
-- esi persists as architectural state from one IRQ0 to the next). NO pusha/popa: with an idle
-- mainline that holds no live GP register, save/restore would be ceremony -- worse, saving and
-- restoring esi around the handler's `inc esi` would PREVENT the counter from advancing. The
-- register-counter makes register-state-survival load-bearing instead (clobber esi -> RED).
-- NOTE the buffer variable is named `hbuf` (not the usual `buf`): this head deliberately
-- duplicates talcott's timer-head byte sequence (out_imm writes + sti;hlt;jmp tail), which
-- talcott's link23 MUTATION harness anchors on as `buf = nc32_timer_out_imm(buf, ...)` /
-- `do append(buf, 251)`. Using a distinct variable name keeps those anchors UNIQUE to the timer
-- head (the chosen/liberi/scottie/talcott "disambiguate a shared-block anchor at source" rule).
func nc32_tick_emit_head(hbuf, gdtr_vaddr, esp_top, idtr_vaddr):
    do append(hbuf, 250)
    do append(hbuf, 15)
    do append(hbuf, 1)
    do append(hbuf, 21)
    hbuf = nc_append_le32(hbuf, gdtr_vaddr)
    do append(hbuf, 234)
    hbuf = nc_append_le32(hbuf, 1048603)
    do append(hbuf, 8)
    do append(hbuf, 0)
    do append(hbuf, 102)
    do append(hbuf, 184)
    do append(hbuf, 16)
    do append(hbuf, 0)
    do append(hbuf, 142)
    do append(hbuf, 216)
    do append(hbuf, 142)
    do append(hbuf, 192)
    do append(hbuf, 142)
    do append(hbuf, 224)
    do append(hbuf, 142)
    do append(hbuf, 232)
    do append(hbuf, 142)
    do append(hbuf, 208)
    do append(hbuf, 188)
    hbuf = nc_append_le32(hbuf, esp_top)
    do append(hbuf, 15)
    do append(hbuf, 1)
    do append(hbuf, 29)
    hbuf = nc_append_le32(hbuf, idtr_vaddr)
    hbuf = nc32_timer_out_imm(hbuf, 17, 32)
    hbuf = nc32_timer_out_imm(hbuf, 17, 160)
    hbuf = nc32_timer_out_imm(hbuf, 32, 33)
    hbuf = nc32_timer_out_imm(hbuf, 40, 161)
    hbuf = nc32_timer_out_imm(hbuf, 4, 33)
    hbuf = nc32_timer_out_imm(hbuf, 2, 161)
    hbuf = nc32_timer_out_imm(hbuf, 1, 33)
    hbuf = nc32_timer_out_imm(hbuf, 1, 161)
    hbuf = nc32_timer_out_imm(hbuf, 254, 33)
    hbuf = nc32_timer_out_imm(hbuf, 255, 161)
    hbuf = nc32_timer_out_imm(hbuf, 52, 67)
    hbuf = nc32_timer_out_imm(hbuf, 255, 64)
    hbuf = nc32_timer_out_imm(hbuf, 255, 64)
    do append(hbuf, 49)
    do append(hbuf, 246)
    do append(hbuf, 251)
    do append(hbuf, 244)
    do append(hbuf, 235)
    do append(hbuf, 253)
    return hbuf
end

-- timer: the 300-byte data tables. A flat 3-entry GDT (null + 32-bit code 0x08 + 32-bit
-- data 0x10) + GDTR (limit 23); a 33-entry IDT -- vectors 0..31 NOT-PRESENT (fail-closed:
-- any masked IRQ or stray exception triple-faults, a correct RED), vector 0x20 = the IRQ0
-- gate (offset = the handler vaddr, selector 0x08, attr 0x8E = present/DPL0/32-bit
-- interrupt gate) -- + IDTR (limit 0x107). Emitter-laid-out at fixed vaddrs (no
-- store-to-arbitrary-address; typed-memory stays deferred).
func nc32_timer_emit_tables(buf, gdt_vaddr, idt_vaddr, gate_vaddr):
    buf = nc_emit_zeroes_loop(buf, 8)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 154)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 146)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 23)
    do append(buf, 0)
    buf = nc_append_le32(buf, gdt_vaddr)
    buf = nc_emit_zeroes_loop(buf, 256)
    let glo = gate_vaddr % 65536
    let ghi_full = gate_vaddr / 65536
    let ghi = ghi_full % 65536
    do append(buf, glo % 256)
    do append(buf, glo / 256)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, ghi % 256)
    do append(buf, ghi / 256)
    do append(buf, 7)
    do append(buf, 1)
    buf = nc_append_le32(buf, idt_vaddr)
    return buf
end

-- timer driver (the first ASYNCHRONOUS interrupt). Layout (vaddr V0=0x10000c):
-- [HEAD 97: GDT-install + PIC-remap + PIT-program + sti + hlt-loop] [HANDLER: ebp-frame(0|5)
-- + compiled toakie body + shared 58-byte epilogue] [TABLES 300]. The handler IS the
-- compiled main() body (toakie subset), reached ONLY via the IDT vec-0x20 gate when the
-- PIT's IRQ0 fires asynchronously -- the anti-ceremony guard: the proof byte is produced by
-- NORMAL compiled lowering on the async path, and the mainline head never emits. MINIMAL:
-- exit-on-first-IRQ (the epilogue's isa-debug-exit / Bochs power-off fire before any second
-- tick) -- NO EOI, NO iret-resume (those are the next link). Reuses zonday's GDT-install
-- shape + toakie's verifier/2-pass layout/lowering + the shared epilogue verbatim, so the
-- six prior emit modes stay byte-identical (the self-host fixpoint gen2==gen1 is preserved).
func nc_emit_multiboot32_timer_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(481, 0, "multiboot32-timer: handler main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(482, 0, "multiboot32-timer: handler main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(483, 0, "multiboot32-timer: handler body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(484, 0, "multiboot32-timer: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(485, 0, "multiboot32-timer: body length invariant")
        return 0
    end
    let head_len = 97
    let hb = epi + 58
    let tables_len = 300
    let code_len = head_len + hb + tables_len
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let gdt_off = head_len + hb
    let gdt_vaddr = 1048588 + gdt_off
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 264
    let gate_vaddr = 1048588 + head_len
    let cbuf = new_buffer()
    cbuf = nc32_timer_emit_head(cbuf, gdtr_vaddr, esp_top, idtr_vaddr)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    cbuf = nc32_timer_emit_tables(cbuf, gdt_vaddr, idt_vaddr, gate_vaddr)
    let frozen_code = freeze(cbuf)
    if length(frozen_code) != code_len:
        let f6 = nc_fail(485, 0, "multiboot32-timer: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- tick (talkert, eighth kernel-arc link): the acknowledged / periodic timer. Layout
-- (vaddr V0=0x10000c): [HEAD 99: GDT-install + PIC-remap + PIT-program + xor esi,esi + sti +
-- hlt-loop] [HANDLER: inc esi; cmp esi,3; jb .ack; ebp-frame(0|5) + compiled body + epilogue;
-- .ack: EOI(out 0x20,0x20) + iret] [TABLES 300 (reused verbatim from timer, parametric on the
-- gate vaddr = V0+99)]. On each IRQ0 the handler counts the tick in esi; for the first N-1=2
-- ticks it ACKNOWLEDGES the PIC and `iret`-RESUMES the mainline (the first async iret-resume --
-- an IRQ frame has NO error code, so NO `add esp,4`, unlike scottie's #PF); on the Nth (3rd)
-- tick esi==3 so it falls through to the compiled body + the shared epilogue, which emits the
-- proof byte and exits. The byte = the compiled body's return value (anti-ceremony: it tracks
-- the body) AND can only appear after surviving N ticks (it tracks the count). Deterministic by
-- COUNT, not wall-time (QEMU vs Bochs PIT rates differ; exit on esi==N is timing-independent).
-- Pays D19's async-SURVIVAL half (EOI + iret-resume + periodicity) that talcott deferred.
func nc_emit_multiboot32_tick_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(486, 0, "multiboot32-tick: handler main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(487, 0, "multiboot32-tick: handler main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(488, 0, "multiboot32-tick: handler body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(489, 0, "multiboot32-tick: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(490, 0, "multiboot32-tick: body length invariant")
        return 0
    end
    let head_len = 99
    let hb = epi + 73
    let tables_len = 300
    let code_len = head_len + hb + tables_len
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let gdt_off = head_len + hb
    let gdt_vaddr = 1048588 + gdt_off
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 264
    let gate_vaddr = head_len + 1048588
    let cbuf = new_buffer()
    cbuf = nc32_tick_emit_head(cbuf, gdtr_vaddr, esp_top, idtr_vaddr)
    do append(cbuf, 70)
    do append(cbuf, 131)
    do append(cbuf, 254)
    do append(cbuf, 3)
    do append(cbuf, 15)
    do append(cbuf, 130)
    let jb_rel = epi + 58
    cbuf = nc_append_le32(cbuf, jb_rel)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    do append(cbuf, 176)
    do append(cbuf, 32)
    do append(cbuf, 230)
    do append(cbuf, 32)
    do append(cbuf, 207)
    cbuf = nc32_timer_emit_tables(cbuf, gdt_vaddr, idt_vaddr, gate_vaddr)
    let frozen_code = freeze(cbuf)
    if length(frozen_code) != code_len:
        let f6 = nc_fail(491, 0, "multiboot32-tick: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- rizzing (the ELEVENTH kernel-arc link): the freestanding image's first MAINLINE task
-- that synchronizes with the timer ISR through a SHARED MEMORY word. Reuses talkert's
-- 32-bit substrate but: the tick counter moves esi -> a memory word `tick`; the IRQ0 ISR
-- becomes PURE GLUE (push eax; inc dword [tick]; EOI; pop eax; iret) -- it preserves the
-- mainline's eax (else an IRQ between the spin's load and compare corrupts the test; the
-- Bochs substrate caught this); the compiled body moves from the handler to the MAINLINE,
-- which SPINS on [tick] (mov eax,[tick]; cmp eax,N; jb) until N ticks have accrued, then cli
-- and runs the compiled body + the shared epilogue (proof byte = the body's return value,
-- reachable only after surviving N async ticks). The IDT vec-0x20 gate points at the glue
-- ISR. The compiled body uses the EXISTING control-flow+locals subset UNCHANGED (no widen),
-- so the ten prior modes stay byte-identical and the self-host fixpoint is preserved.
func nc32_rizz_emit_head(rbuf, gdtr_vaddr, esp_top, idtr_vaddr, tick_vaddr):
    do append(rbuf, 250)
    do append(rbuf, 15)
    do append(rbuf, 1)
    do append(rbuf, 21)
    rbuf = nc_append_le32(rbuf, gdtr_vaddr)
    do append(rbuf, 234)
    rbuf = nc_append_le32(rbuf, 1048603)
    do append(rbuf, 8)
    do append(rbuf, 0)
    do append(rbuf, 102)
    do append(rbuf, 184)
    do append(rbuf, 16)
    do append(rbuf, 0)
    do append(rbuf, 142)
    do append(rbuf, 216)
    do append(rbuf, 142)
    do append(rbuf, 192)
    do append(rbuf, 142)
    do append(rbuf, 224)
    do append(rbuf, 142)
    do append(rbuf, 232)
    do append(rbuf, 142)
    do append(rbuf, 208)
    do append(rbuf, 188)
    rbuf = nc_append_le32(rbuf, esp_top)
    do append(rbuf, 15)
    do append(rbuf, 1)
    do append(rbuf, 29)
    rbuf = nc_append_le32(rbuf, idtr_vaddr)
    rbuf = nc32_timer_out_imm(rbuf, 17, 32)
    rbuf = nc32_timer_out_imm(rbuf, 17, 160)
    rbuf = nc32_timer_out_imm(rbuf, 32, 33)
    rbuf = nc32_timer_out_imm(rbuf, 40, 161)
    rbuf = nc32_timer_out_imm(rbuf, 4, 33)
    rbuf = nc32_timer_out_imm(rbuf, 2, 161)
    rbuf = nc32_timer_out_imm(rbuf, 1, 33)
    rbuf = nc32_timer_out_imm(rbuf, 1, 161)
    rbuf = nc32_timer_out_imm(rbuf, 254, 33)
    rbuf = nc32_timer_out_imm(rbuf, 255, 161)
    rbuf = nc32_timer_out_imm(rbuf, 52, 67)
    rbuf = nc32_timer_out_imm(rbuf, 255, 64)
    rbuf = nc32_timer_out_imm(rbuf, 255, 64)
    do append(rbuf, 199)
    do append(rbuf, 5)
    rbuf = nc_append_le32(rbuf, tick_vaddr)
    rbuf = nc_append_le32(rbuf, 0)
    do append(rbuf, 251)
    return rbuf
end

func nc_emit_multiboot32_rizzing_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(492, 0, "multiboot32-rizzing: task main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(493, 0, "multiboot32-rizzing: task main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(494, 0, "multiboot32-rizzing: task body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(495, 0, "multiboot32-rizzing: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(496, 0, "multiboot32-rizzing: body length invariant")
        return 0
    end
    let head_len = 104
    let glue_len = 11
    let isr_len = 13
    let mainline_len = head_len + glue_len + epi + 58
    let isr_off = mainline_len
    let tables_off = isr_off + isr_len
    let tick_off = nc32_roundup4(tables_off + 300)
    let code_len = tick_off + 4
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let gate_vaddr = 1048588 + isr_off
    let gdt_vaddr = 1048588 + tables_off
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 264
    let tick_vaddr = 1048588 + tick_off
    let mbuf = new_buffer()
    mbuf = nc32_rizz_emit_head(mbuf, gdtr_vaddr, esp_top, idtr_vaddr, tick_vaddr)
    do append(mbuf, 161)
    mbuf = nc_append_le32(mbuf, tick_vaddr)
    do append(mbuf, 131)
    do append(mbuf, 248)
    do append(mbuf, 3)
    do append(mbuf, 114)
    do append(mbuf, 246)
    do append(mbuf, 250)
    if nlocals > 0:
        do append(mbuf, 137)
        do append(mbuf, 229)
        do append(mbuf, 131)
        do append(mbuf, 236)
        do append(mbuf, 4 * nlocals)
    end
    mbuf = append_str(mbuf, freeze(bodybuf))
    mbuf = nc32_emit_epilogue(mbuf)
    do append(mbuf, 80)
    do append(mbuf, 255)
    do append(mbuf, 5)
    mbuf = nc_append_le32(mbuf, tick_vaddr)
    do append(mbuf, 176)
    do append(mbuf, 32)
    do append(mbuf, 230)
    do append(mbuf, 32)
    do append(mbuf, 88)
    do append(mbuf, 207)
    mbuf = nc32_timer_emit_tables(mbuf, gdt_vaddr, idt_vaddr, gate_vaddr)
    mbuf = nc_emit_zeroes_loop(mbuf, tick_off - tables_off - 300)
    mbuf = nc_append_le32(mbuf, 0)
    let frozen_code = freeze(mbuf)
    if length(frozen_code) != code_len:
        let f6 = nc_fail(497, 0, "multiboot32-rizzing: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

func nc_is_multiboot32_rizzing(source):
    let marker = "-- emit: multiboot32-rizzing"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- bluefield (the TWELFTH kernel-arc link): the freestanding image's first PREEMPTIVE
-- CONTEXT SWITCH between two tasks. Reuses talkert/rizzing's 32-bit substrate (GDT-install,
-- PIC remap, PIT program, the flat tables) but the IRQ0 ISR is no longer pure glue: it is a
-- SCHEDULER that saves the running task's full GP+esp context into its TCB slot and restores
-- the other task's (pusha; save esp -> [tcb+cur*4]; flip cur; load esp <- [tcb+cur*4]; EOI;
-- popa; iret). Task B is started "from cold" via a pre-laid 44-byte SEEDED stack block (8 GP
-- dwords in popa order + an iret frame eip=B_entry, cs=0x08, eflags=0x202). The forcing
-- observable is count-deterministic (a two-flag aready/bran handshake, NOT wall-time): task A's
-- compiled body computes vA, A CARRIES it in edx (a register the toakie/rizzing lowering never
-- writes), sets aready, then SPINS on bran; the timer preempts A, the scheduler switches to B,
-- B writes its marker vB to [shared], waits on aready, CLOBBERS edx (mov edx,0xB7B7B7B7), sets
-- bran, and spins; the timer preempts B, the scheduler restores A's edx=vA, and A recovers
-- (mov eax,edx; add eax,[shared]) and emits the proof byte = (vA + vB) mod 256 via the shared
-- 58-byte epilogue. The byte is correct ONLY if the switch genuinely SAVED A's edx (pusha onto
-- A's stack) across B's clobber and RESTORED it (popa) -- a fake/absent switch yields a wrong
-- byte or no frame. Task A's compiled body uses the EXISTING control-flow+locals subset
-- UNCHANGED (no widen); task B is hand-emitted glue (lower_program_poly prunes from main, so a
-- second compiled task would be dead-pruned -- the non-proof task is glue, like rizzing's ISR),
-- so the eleven prior emit modes stay byte-identical and the self-host fixpoint gen2==gen1 holds.
-- Graded on the far-axis DUAL-SUBSTRATE oracle (QEMU + Bochs vs a host-derived golden), not C.
-- HONEST SCOPE: this is a preemptive ring-0 GP+esp+eip+eflags context switch, NOT a full
-- architectural one (no segment regs / CR3 / FPU / per-task address space).
func nc32_bf_emit_head(bfh, gdtr_vaddr, esp_top, idtr_vaddr, cur_vaddr, tcb1_vaddr, seed_vaddr):
    do append(bfh, 250)
    do append(bfh, 15)
    do append(bfh, 1)
    do append(bfh, 21)
    bfh = nc_append_le32(bfh, gdtr_vaddr)
    do append(bfh, 234)
    bfh = nc_append_le32(bfh, 1048603)
    do append(bfh, 8)
    do append(bfh, 0)
    do append(bfh, 102)
    do append(bfh, 184)
    do append(bfh, 16)
    do append(bfh, 0)
    do append(bfh, 142)
    do append(bfh, 216)
    do append(bfh, 142)
    do append(bfh, 192)
    do append(bfh, 142)
    do append(bfh, 224)
    do append(bfh, 142)
    do append(bfh, 232)
    do append(bfh, 142)
    do append(bfh, 208)
    do append(bfh, 188)
    bfh = nc_append_le32(bfh, esp_top)
    do append(bfh, 15)
    do append(bfh, 1)
    do append(bfh, 29)
    bfh = nc_append_le32(bfh, idtr_vaddr)
    bfh = nc32_timer_out_imm(bfh, 17, 32)
    bfh = nc32_timer_out_imm(bfh, 17, 160)
    bfh = nc32_timer_out_imm(bfh, 32, 33)
    bfh = nc32_timer_out_imm(bfh, 40, 161)
    bfh = nc32_timer_out_imm(bfh, 4, 33)
    bfh = nc32_timer_out_imm(bfh, 2, 161)
    bfh = nc32_timer_out_imm(bfh, 1, 33)
    bfh = nc32_timer_out_imm(bfh, 1, 161)
    bfh = nc32_timer_out_imm(bfh, 254, 33)
    bfh = nc32_timer_out_imm(bfh, 255, 161)
    bfh = nc32_timer_out_imm(bfh, 52, 67)
    bfh = nc32_timer_out_imm(bfh, 255, 64)
    bfh = nc32_timer_out_imm(bfh, 255, 64)
    do append(bfh, 199)
    do append(bfh, 5)
    bfh = nc_append_le32(bfh, cur_vaddr)
    bfh = nc_append_le32(bfh, 0)
    do append(bfh, 199)
    do append(bfh, 5)
    bfh = nc_append_le32(bfh, tcb1_vaddr)
    bfh = nc_append_le32(bfh, seed_vaddr)
    do append(bfh, 251)
    return bfh
end

func nc_emit_multiboot32_bluefield_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(498, 0, "multiboot32-bluefield: task A main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(499, 0, "multiboot32-bluefield: task A main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(500, 0, "multiboot32-bluefield: task A body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(501, 0, "multiboot32-bluefield: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(502, 0, "multiboot32-bluefield: body length invariant")
        return 0
    end
    -- task A = ebp_prefix + body + a_glue(31: carry 2 + ready 10 + spin 11 + recover 2 + add 6) + epilogue 58
    let a_len = ebp_prefix + bodylen + 31 + 58
    let off_A = 114
    let off_B = off_A + a_len
    let off_sched = off_B + 37
    let off_tables = off_sched + 34
    let off_after = off_tables + 300
    let off_data = nc32_roundup4(off_after)
    let cur_vaddr = 1048588 + off_data
    let tcb_vaddr = 1048588 + off_data + 4
    let tcb1_vaddr = tcb_vaddr + 4
    let aready_vaddr = 1048588 + off_data + 12
    let bran_vaddr = 1048588 + off_data + 16
    let shared_vaddr = 1048588 + off_data + 20
    let off_seed = off_data + 24 + 256
    let seed_vaddr = 1048588 + off_seed
    let code_len = off_seed + 44 + 16
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let gate_vaddr = 1048588 + off_sched
    let gdt_vaddr = 1048588 + off_tables
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 264
    let b_entry = 1048588 + off_B
    let bfm = new_buffer()
    bfm = nc32_bf_emit_head(bfm, gdtr_vaddr, esp_top, idtr_vaddr, cur_vaddr, tcb1_vaddr, seed_vaddr)
    if nlocals > 0:
        do append(bfm, 137)
        do append(bfm, 229)
        do append(bfm, 131)
        do append(bfm, 236)
        do append(bfm, 4 * nlocals)
    end
    bfm = append_str(bfm, freeze(bodybuf))
    do append(bfm, 137)
    do append(bfm, 194)
    do append(bfm, 199)
    do append(bfm, 5)
    bfm = nc_append_le32(bfm, aready_vaddr)
    bfm = nc_append_le32(bfm, 1)
    do append(bfm, 161)
    bfm = nc_append_le32(bfm, bran_vaddr)
    do append(bfm, 131)
    do append(bfm, 248)
    do append(bfm, 1)
    do append(bfm, 117)
    do append(bfm, 246)
    do append(bfm, 250)
    do append(bfm, 137)
    do append(bfm, 208)
    do append(bfm, 3)
    do append(bfm, 5)
    bfm = nc_append_le32(bfm, shared_vaddr)
    bfm = nc32_emit_epilogue(bfm)
    do append(bfm, 184)
    bfm = nc_append_le32(bfm, 46)
    do append(bfm, 163)
    bfm = nc_append_le32(bfm, shared_vaddr)
    do append(bfm, 161)
    bfm = nc_append_le32(bfm, aready_vaddr)
    do append(bfm, 131)
    do append(bfm, 248)
    do append(bfm, 1)
    do append(bfm, 117)
    do append(bfm, 246)
    do append(bfm, 186)
    do append(bfm, 183)
    do append(bfm, 183)
    do append(bfm, 183)
    do append(bfm, 183)
    do append(bfm, 199)
    do append(bfm, 5)
    bfm = nc_append_le32(bfm, bran_vaddr)
    bfm = nc_append_le32(bfm, 1)
    do append(bfm, 235)
    do append(bfm, 254)
    do append(bfm, 96)
    do append(bfm, 161)
    bfm = nc_append_le32(bfm, cur_vaddr)
    do append(bfm, 137)
    do append(bfm, 36)
    do append(bfm, 133)
    bfm = nc_append_le32(bfm, tcb_vaddr)
    do append(bfm, 131)
    do append(bfm, 240)
    do append(bfm, 1)
    do append(bfm, 163)
    bfm = nc_append_le32(bfm, cur_vaddr)
    do append(bfm, 139)
    do append(bfm, 36)
    do append(bfm, 133)
    bfm = nc_append_le32(bfm, tcb_vaddr)
    do append(bfm, 176)
    do append(bfm, 32)
    do append(bfm, 230)
    do append(bfm, 32)
    do append(bfm, 97)
    do append(bfm, 207)
    bfm = nc32_timer_emit_tables(bfm, gdt_vaddr, idt_vaddr, gate_vaddr)
    bfm = nc_emit_zeroes_loop(bfm, off_data - off_after)
    bfm = nc_emit_zeroes_loop(bfm, 24)
    bfm = nc_emit_zeroes_loop(bfm, 256)
    bfm = nc_emit_zeroes_loop(bfm, 32)
    bfm = nc_append_le32(bfm, b_entry)
    bfm = nc_append_le32(bfm, 8)
    bfm = nc_append_le32(bfm, 514)
    bfm = nc_emit_zeroes_loop(bfm, 16)
    let frozen_code = freeze(bfm)
    if length(frozen_code) != code_len:
        let f6 = nc_fail(503, 0, "multiboot32-bluefield: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

func nc_is_multiboot32_bluefield(source):
    let marker = "-- emit: multiboot32-bluefield"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- ============================================================================
-- contigo (fifteenth kernel-arc link / f1): the first DATA-DEPENDENT scheduling
-- decision. The timer-IRQ0 scheduler READS an input-derived state cell (inq, set
-- by the mainline from a late-bound COM1 byte) and takes a cmp;jcc to SELECT which
-- of two seeded tasks to dispatch via iret. Selected by "-- emit: multiboot32-contigo".
-- Layout (V0=0x10000c): [HEAD' 174: GDT-install + UART init + PIC-remap + PIT-program
-- + input read->inq + sti + jmp$ idle] [TASK A: ebp? + compiled body + epilogue 58]
-- [TASK B: mov eax,46 + epilogue 58] [SCHEDULER 30] [TABLES 300] [inq 8] [seedA 44]
-- [seedB 44] [guard 16]. Seed eflags = 0x002 (IF=0): one-shot cold dispatch (the task
-- runs uninterrupted to hlt, so no re-preemption / double-emit). The mainline idles
-- (jmp $) and NEVER emits; both tasks are reached ONLY via the scheduler's iret.
-- ============================================================================
func nc32_co_emit_head(coh, gdtr_vaddr, esp_top, idtr_vaddr, inq_vaddr):
    do append(coh, 250)
    do append(coh, 15)
    do append(coh, 1)
    do append(coh, 21)
    coh = nc_append_le32(coh, gdtr_vaddr)
    do append(coh, 234)
    coh = nc_append_le32(coh, 1048603)
    do append(coh, 8)
    do append(coh, 0)
    do append(coh, 102)
    do append(coh, 184)
    do append(coh, 16)
    do append(coh, 0)
    do append(coh, 142)
    do append(coh, 216)
    do append(coh, 142)
    do append(coh, 192)
    do append(coh, 142)
    do append(coh, 224)
    do append(coh, 142)
    do append(coh, 232)
    do append(coh, 142)
    do append(coh, 208)
    do append(coh, 188)
    coh = nc_append_le32(coh, esp_top)
    do append(coh, 15)
    do append(coh, 1)
    do append(coh, 29)
    coh = nc_append_le32(coh, idtr_vaddr)
    coh = nc32_uart_init(coh)
    coh = nc32_timer_out_imm(coh, 17, 32)
    coh = nc32_timer_out_imm(coh, 17, 160)
    coh = nc32_timer_out_imm(coh, 32, 33)
    coh = nc32_timer_out_imm(coh, 40, 161)
    coh = nc32_timer_out_imm(coh, 4, 33)
    coh = nc32_timer_out_imm(coh, 2, 161)
    coh = nc32_timer_out_imm(coh, 1, 33)
    coh = nc32_timer_out_imm(coh, 1, 161)
    coh = nc32_timer_out_imm(coh, 254, 33)
    coh = nc32_timer_out_imm(coh, 255, 161)
    coh = nc32_timer_out_imm(coh, 52, 67)
    coh = nc32_timer_out_imm(coh, 255, 64)
    coh = nc32_timer_out_imm(coh, 255, 64)
    do append(coh, 102)
    do append(coh, 186)
    do append(coh, 253)
    do append(coh, 3)
    do append(coh, 236)
    do append(coh, 168)
    do append(coh, 1)
    do append(coh, 116)
    do append(coh, 247)
    do append(coh, 102)
    do append(coh, 186)
    do append(coh, 248)
    do append(coh, 3)
    do append(coh, 236)
    do append(coh, 15)
    do append(coh, 182)
    do append(coh, 192)
    do append(coh, 163)
    coh = nc_append_le32(coh, inq_vaddr)
    do append(coh, 251)
    do append(coh, 235)
    do append(coh, 254)
    return coh
end

func nc_emit_multiboot32_contigo_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(514, 0, "multiboot32-contigo: task A main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(515, 0, "multiboot32-contigo: task A main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(516, 0, "multiboot32-contigo: task A body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(517, 0, "multiboot32-contigo: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(518, 0, "multiboot32-contigo: body length invariant")
        return 0
    end
    let off_A = 174
    let a_len = ebp_prefix + bodylen + 58
    let off_B = off_A + a_len
    let off_sched = off_B + 63
    let off_tables = off_sched + 30
    let off_after = off_tables + 300
    let off_data = nc32_roundup4(off_after)
    let inq_vaddr = 1048588 + off_data
    -- each task runs on its OWN 256-byte stack laid BELOW its seed (the seed's iret frame sits at the
    -- TOP): after `mov esp,seed; popa; iret` esp = seed+44 and the body's rbp frame + pushes grow DOWN
    -- through the dead seed into the 256-byte reserve -- so even a 31-local body never reaches inq /
    -- the tables / live code (closes the cross-model seed-stack-clobber flag; bluefield ran task A on
    -- the big mainline stack, but contigo dispatches BOTH tasks onto seeds, so each needs real headroom).
    let off_stackA = off_data + 8
    let off_seedA = off_stackA + 256
    let off_stackB = off_seedA + 44
    let off_seedB = off_stackB + 256
    let off_guard = off_seedB + 44
    let code_len = off_guard + 16
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let gate_vaddr = 1048588 + off_sched
    let gdt_vaddr = 1048588 + off_tables
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 264
    let seedA_vaddr = 1048588 + off_seedA
    let seedB_vaddr = 1048588 + off_seedB
    let a_entry = 1048588 + off_A
    let b_entry = 1048588 + off_B
    let com = new_buffer()
    com = nc32_co_emit_head(com, gdtr_vaddr, esp_top, idtr_vaddr, inq_vaddr)
    if nlocals > 0:
        do append(com, 137)
        do append(com, 229)
        do append(com, 131)
        do append(com, 236)
        do append(com, 4 * nlocals)
    end
    com = append_str(com, freeze(bodybuf))
    com = nc32_emit_epilogue(com)
    do append(com, 184)
    com = nc_append_le32(com, 46)
    com = nc32_emit_epilogue(com)
    do append(com, 176)
    do append(com, 32)
    do append(com, 230)
    do append(com, 32)
    do append(com, 161)
    com = nc_append_le32(com, inq_vaddr)
    do append(com, 61)
    com = nc_append_le32(com, 128)
    do append(com, 115)
    do append(com, 7)
    do append(com, 188)
    com = nc_append_le32(com, seedA_vaddr)
    do append(com, 235)
    do append(com, 5)
    do append(com, 188)
    com = nc_append_le32(com, seedB_vaddr)
    do append(com, 97)
    do append(com, 207)
    com = nc32_timer_emit_tables(com, gdt_vaddr, idt_vaddr, gate_vaddr)
    com = nc_emit_zeroes_loop(com, off_data - off_after)
    com = nc_append_le32(com, 0)
    com = nc_emit_zeroes_loop(com, 4)
    com = nc_emit_zeroes_loop(com, 256)
    com = nc_emit_zeroes_loop(com, 32)
    com = nc_append_le32(com, a_entry)
    com = nc_append_le32(com, 8)
    com = nc_append_le32(com, 2)
    com = nc_emit_zeroes_loop(com, 256)
    com = nc_emit_zeroes_loop(com, 32)
    com = nc_append_le32(com, b_entry)
    com = nc_append_le32(com, 8)
    com = nc_append_le32(com, 2)
    com = nc_emit_zeroes_loop(com, 16)
    let frozen_code = freeze(com)
    if length(frozen_code) != code_len:
        let f6 = nc_fail(519, 0, "multiboot32-contigo: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

func nc_is_multiboot32_contigo(source):
    let marker = "-- emit: multiboot32-contigo"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- ============================================================================
-- cloggard (sixteenth kernel-arc link / f1-deepening): the first DATA-DEPENDENT
-- MULTI-QUANTUM scheduler -- a timer-IRQ0 run-queue that dispatches a SEQUENCE of
-- K=4 WARM tasks (bluefield save/restore sustained across quanta) and emits an
-- ordered TRACE on 0xE9, the schedule being a function of runtime input recomputed
-- EACH quantum (contigo's input-select, made a sequence). Selected by the directive
-- "-- emit: multiboot32-cloggard". Layout (V0=0x10000c): [HEAD 224: GDT-install +
-- UART + PIC/PIT + input read->inq + init {pos,done,cur,tcb0,tcb1} + sti + jmp$ idle]
-- [TASK A: mov esp,stackA + ebp? + body (->edi=vA) + accumulate/emit glue 37] [TASK B:
-- mov esp,stackB + marker glue 38] [SCHEDULER 128] [TABLES 300] [cells 24][seedA 44]
-- [seedB 44][stackA 256][stackB 256][guard 16]. Seeds eflags=0x202 (IF=1). Each
-- task per grant: inc acc; emit "DE (base+acc) AD"; mov [done],1; hlt (park); loop.
-- The scheduler advances ONLY on [done]==1 (DONE-FLAG INTERLOCK -- the per-grant unit
-- is bounded by the hlt and gated by done, so the K-byte trace is bit-identical on
-- QEMU and Bochs regardless of tick timing); next=(inq>>pos)&1 reads [inq] each
-- quantum; exit (isa-debug-exit + Bochs power-off) when pos>=K AND [done]==1.
-- ============================================================================
-- 15-byte framed emit: al -> "DE al AD" on 0xE9. Buffer `clf` not `buf` (anchor-collision: link25/26).
func nc32_clog_frame(clf):
    do append(clf, 136)
    do append(clf, 195)
    do append(clf, 102)
    do append(clf, 186)
    do append(clf, 233)
    do append(clf, 0)
    do append(clf, 176)
    do append(clf, 222)
    do append(clf, 238)
    do append(clf, 136)
    do append(clf, 216)
    do append(clf, 238)
    do append(clf, 176)
    do append(clf, 173)
    do append(clf, 238)
    return clf
end

-- one task tail: framed emit + mov [done],1 + hlt + jmp <rel8 back to the loop head>.
func nc32_clog_task_tail(clf, done_vaddr, jmprel):
    clf = nc32_clog_frame(clf)
    do append(clf, 199)
    do append(clf, 5)
    clf = nc_append_le32(clf, done_vaddr)
    clf = nc_append_le32(clf, 1)
    do append(clf, 244)
    do append(clf, 235)
    do append(clf, jmprel)
    return clf
end

func nc32_clog_emit_head(clh, gdtr_vaddr, esp_top, idtr_vaddr, inq_vaddr, pos_vaddr, done_vaddr, cur_vaddr, tcb0_vaddr, tcb1_vaddr, seedA_vaddr, seedB_vaddr):
    do append(clh, 250)
    do append(clh, 15)
    do append(clh, 1)
    do append(clh, 21)
    clh = nc_append_le32(clh, gdtr_vaddr)
    do append(clh, 234)
    clh = nc_append_le32(clh, 1048603)
    do append(clh, 8)
    do append(clh, 0)
    do append(clh, 102)
    do append(clh, 184)
    do append(clh, 16)
    do append(clh, 0)
    do append(clh, 142)
    do append(clh, 216)
    do append(clh, 142)
    do append(clh, 192)
    do append(clh, 142)
    do append(clh, 224)
    do append(clh, 142)
    do append(clh, 232)
    do append(clh, 142)
    do append(clh, 208)
    do append(clh, 188)
    clh = nc_append_le32(clh, esp_top)
    do append(clh, 15)
    do append(clh, 1)
    do append(clh, 29)
    clh = nc_append_le32(clh, idtr_vaddr)
    clh = nc32_uart_init(clh)
    clh = nc32_timer_out_imm(clh, 17, 32)
    clh = nc32_timer_out_imm(clh, 17, 160)
    clh = nc32_timer_out_imm(clh, 32, 33)
    clh = nc32_timer_out_imm(clh, 40, 161)
    clh = nc32_timer_out_imm(clh, 4, 33)
    clh = nc32_timer_out_imm(clh, 2, 161)
    clh = nc32_timer_out_imm(clh, 1, 33)
    clh = nc32_timer_out_imm(clh, 1, 161)
    clh = nc32_timer_out_imm(clh, 254, 33)
    clh = nc32_timer_out_imm(clh, 255, 161)
    clh = nc32_timer_out_imm(clh, 52, 67)
    clh = nc32_timer_out_imm(clh, 255, 64)
    clh = nc32_timer_out_imm(clh, 255, 64)
    do append(clh, 102)
    do append(clh, 186)
    do append(clh, 253)
    do append(clh, 3)
    do append(clh, 236)
    do append(clh, 168)
    do append(clh, 1)
    do append(clh, 116)
    do append(clh, 247)
    do append(clh, 102)
    do append(clh, 186)
    do append(clh, 248)
    do append(clh, 3)
    do append(clh, 236)
    do append(clh, 15)
    do append(clh, 182)
    do append(clh, 192)
    do append(clh, 163)
    clh = nc_append_le32(clh, inq_vaddr)
    do append(clh, 199)
    do append(clh, 5)
    clh = nc_append_le32(clh, pos_vaddr)
    clh = nc_append_le32(clh, 0)
    do append(clh, 199)
    do append(clh, 5)
    clh = nc_append_le32(clh, done_vaddr)
    clh = nc_append_le32(clh, 1)
    do append(clh, 199)
    do append(clh, 5)
    clh = nc_append_le32(clh, cur_vaddr)
    clh = nc_append_le32(clh, 2)
    do append(clh, 199)
    do append(clh, 5)
    clh = nc_append_le32(clh, tcb0_vaddr)
    clh = nc_append_le32(clh, seedA_vaddr)
    do append(clh, 199)
    do append(clh, 5)
    clh = nc_append_le32(clh, tcb1_vaddr)
    clh = nc_append_le32(clh, seedB_vaddr)
    do append(clh, 251)
    do append(clh, 235)
    do append(clh, 254)
    return clh
end

func nc_emit_multiboot32_cloggard_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(520, 0, "multiboot32-cloggard: task A main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(521, 0, "multiboot32-cloggard: task A main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(522, 0, "multiboot32-cloggard: task A body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(523, 0, "multiboot32-cloggard: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(524, 0, "multiboot32-cloggard: body length invariant")
        return 0
    end
    let off_A = 224
    let a_len = 5 + ebp_prefix + bodylen + 37
    let off_B = off_A + a_len
    let off_sched = off_B + 43
    let off_tables = off_sched + 128
    let off_after = off_tables + 300
    let off_data = nc32_roundup4(off_after)
    let inq_vaddr = 1048588 + off_data
    let pos_vaddr = inq_vaddr + 4
    let done_vaddr = inq_vaddr + 8
    let cur_vaddr = inq_vaddr + 12
    let tcb0_vaddr = inq_vaddr + 16
    let tcb1_vaddr = inq_vaddr + 20
    -- seeds (cold contexts, used once) come FIRST; each task runs on its OWN dedicated 256-byte
    -- stack (its entry does `mov esp,stackX_top`), so the running esp differs from the seed and the
    -- per-task warm save (mov [tcb+cur*4],esp) is LOAD-BEARING (NOP it -> tcb stays the seed ->
    -- cold re-dispatch -> the accumulation is lost). A 31-local body never reaches the cells.
    let off_seedA = off_data + 24
    let off_seedB = off_seedA + 44
    let off_stackA = off_seedB + 44
    let off_stackB = off_stackA + 256
    let off_guard = off_stackB + 256
    let code_len = off_guard + 16
    let stackA_top = 1048588 + off_stackA + 256
    let stackB_top = 1048588 + off_stackB + 256
    let memsz = 12 + code_len + 16384
    let esp_top = 1048576 + memsz
    let gate_vaddr = 1048588 + off_sched
    let gdt_vaddr = 1048588 + off_tables
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 264
    let seedA_vaddr = 1048588 + off_seedA
    let seedB_vaddr = 1048588 + off_seedB
    let a_entry = 1048588 + off_A
    let b_entry = 1048588 + off_B
    let com = new_buffer()
    com = nc32_clog_emit_head(com, gdtr_vaddr, esp_top, idtr_vaddr, inq_vaddr, pos_vaddr, done_vaddr, cur_vaddr, tcb0_vaddr, tcb1_vaddr, seedA_vaddr, seedB_vaddr)
    -- TASK A: mov esp,stackA_top (dedicated stack) + optional ebp frame + compiled body (-> eax=vA)
    -- + warm accumulate/emit glue.
    do append(com, 188)
    com = nc_append_le32(com, stackA_top)
    if nlocals > 0:
        do append(com, 137)
        do append(com, 229)
        do append(com, 131)
        do append(com, 236)
        do append(com, 4 * nlocals)
    end
    com = append_str(com, freeze(bodybuf))
    do append(com, 137)
    do append(com, 199)
    do append(com, 49)
    do append(com, 246)
    do append(com, 70)
    do append(com, 137)
    do append(com, 248)
    do append(com, 1)
    do append(com, 240)
    com = nc32_clog_task_tail(com, done_vaddr, 223)
    -- TASK B: mov esp,stackB_top (dedicated stack) + marker accumulate/emit glue.
    do append(com, 188)
    com = nc_append_le32(com, stackB_top)
    do append(com, 49)
    do append(com, 255)
    do append(com, 71)
    do append(com, 184)
    com = nc_append_le32(com, 176)
    do append(com, 1)
    do append(com, 248)
    com = nc32_clog_task_tail(com, done_vaddr, 220)
    -- SCHEDULER (128 bytes): completion-driven run-queue dispatcher.
    do append(com, 176)
    do append(com, 32)
    do append(com, 230)
    do append(com, 32)
    do append(com, 96)
    do append(com, 161)
    com = nc_append_le32(com, done_vaddr)
    do append(com, 133)
    do append(com, 192)
    do append(com, 116)
    do append(com, 73)
    do append(com, 161)
    com = nc_append_le32(com, pos_vaddr)
    do append(com, 131)
    do append(com, 248)
    do append(com, 4)
    do append(com, 115)
    do append(com, 65)
    do append(com, 161)
    com = nc_append_le32(com, cur_vaddr)
    do append(com, 131)
    do append(com, 248)
    do append(com, 2)
    do append(com, 116)
    do append(com, 7)
    do append(com, 137)
    do append(com, 36)
    do append(com, 133)
    com = nc_append_le32(com, tcb0_vaddr)
    do append(com, 139)
    do append(com, 13)
    com = nc_append_le32(com, pos_vaddr)
    do append(com, 161)
    com = nc_append_le32(com, inq_vaddr)
    do append(com, 211)
    do append(com, 232)
    do append(com, 131)
    do append(com, 224)
    do append(com, 1)
    do append(com, 163)
    com = nc_append_le32(com, cur_vaddr)
    do append(com, 255)
    do append(com, 5)
    com = nc_append_le32(com, pos_vaddr)
    do append(com, 199)
    do append(com, 5)
    com = nc_append_le32(com, done_vaddr)
    com = nc_append_le32(com, 0)
    do append(com, 139)
    do append(com, 36)
    do append(com, 133)
    com = nc_append_le32(com, tcb0_vaddr)
    do append(com, 97)
    do append(com, 207)
    do append(com, 97)
    do append(com, 207)
    -- exit: isa-debug-exit (QEMU) + "Shutdown" (Bochs power-off) + halt.
    do append(com, 102)
    do append(com, 186)
    do append(com, 244)
    do append(com, 0)
    do append(com, 176)
    do append(com, 0)
    do append(com, 238)
    do append(com, 102)
    do append(com, 186)
    do append(com, 0)
    do append(com, 137)
    com = nc32_emit_out_char(com, 83)
    com = nc32_emit_out_char(com, 104)
    com = nc32_emit_out_char(com, 117)
    com = nc32_emit_out_char(com, 116)
    com = nc32_emit_out_char(com, 100)
    com = nc32_emit_out_char(com, 111)
    com = nc32_emit_out_char(com, 119)
    com = nc32_emit_out_char(com, 110)
    do append(com, 250)
    do append(com, 244)
    do append(com, 235)
    do append(com, 253)
    -- TABLES (300) + DATA.
    com = nc32_timer_emit_tables(com, gdt_vaddr, idt_vaddr, gate_vaddr)
    com = nc_emit_zeroes_loop(com, off_data - off_after)
    com = nc_emit_zeroes_loop(com, 24)
    com = nc_emit_zeroes_loop(com, 32)
    com = nc_append_le32(com, a_entry)
    com = nc_append_le32(com, 8)
    com = nc_append_le32(com, 514)
    com = nc_emit_zeroes_loop(com, 32)
    com = nc_append_le32(com, b_entry)
    com = nc_append_le32(com, 8)
    com = nc_append_le32(com, 514)
    com = nc_emit_zeroes_loop(com, 256)
    com = nc_emit_zeroes_loop(com, 256)
    com = nc_emit_zeroes_loop(com, 16)
    let frozen_code = freeze(com)
    if length(frozen_code) != code_len:
        let f6 = nc_fail(525, 0, "multiboot32-cloggard: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

func nc_is_multiboot32_cloggard(source):
    let marker = "-- emit: multiboot32-cloggard"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

func nc32_roundup_4k(v):
    let r = v % 4096
    if r == 0:
        return v
    end
    return v + 4096 - r
end

-- chosen: the fixed 118-byte STRUCTURAL head (prologue 92 + #PF wrapper 26). Extends
-- zonday's GDT+IDT head with paging-enable. Only five le32 fields vary with the body
-- length (gdtr_vaddr, esp_top, idtr_vaddr, pd_vaddr, sentinel_rel32); everything else --
-- incl. the CR4 clear, the CR0.PG-enable, BOTH touch addresses, and the whole wrapper --
-- is a fixed byte sequence the white-box gate pins exactly.
--   cli; lgdt; far-jmp CS=0x08; reload DS/ES/FS/GS/SS=0x10; mov esp; lidt;
--   mov eax,cr4; and eax,0xFFFFFF4F (clear PAE/PSE/PGE -- Multiboot leaves CR4 UNDEFINED,
--     so PAE-set would reinterpret PD as a PDPT and triple-fault; SDM-mandated robustness);
--   mov eax,PD; mov cr3,eax; mov eax,cr0; or eax,0x80000000; mov cr0,eax (PAGING ON);
--   jmp $+2 (prefetch flush); TOUCH-A [0x2ff000] (mapped, must NOT fault);
--   TOUCH-B [0x300000] (the UNMAPPED neighbor, MUST #PF -> its EIP=0x10005b is the proof);
--   SENTINEL mov al,0xBB; jmp epilogue (reached only if B did NOT fault).
-- WRAPPER (the IDT vector-14 / #PF gate target): mov eax,cr2; cmp eax,0x300000; jne sentinel;
--   cmp dword [esp],0 (the #PF error code: not-present supervisor read == 0); jne sentinel;
--   cmp dword [esp+4],0x10005b (the saved EIP == TOUCH-B, proving WHICH access faulted);
--   jne sentinel -- then falls into the compiled handler body. CR2 alone is forgeable
--   (cr2 is ring-0-writable), so the proof rests on this wrapper + the white-box head pin.
func nc32_page_emit_head(buf, gdtr_vaddr, esp_top, idtr_vaddr, pd_vaddr, sentinel_rel32):
    do append(buf, 250)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 21)
    buf = nc_append_le32(buf, gdtr_vaddr)
    do append(buf, 234)
    buf = nc_append_le32(buf, 1048603)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 102)
    do append(buf, 184)
    do append(buf, 16)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, 216)
    do append(buf, 142)
    do append(buf, 192)
    do append(buf, 142)
    do append(buf, 224)
    do append(buf, 142)
    do append(buf, 232)
    do append(buf, 142)
    do append(buf, 208)
    do append(buf, 188)
    buf = nc_append_le32(buf, esp_top)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 29)
    buf = nc_append_le32(buf, idtr_vaddr)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 224)
    do append(buf, 37)
    do append(buf, 79)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 224)
    do append(buf, 184)
    buf = nc_append_le32(buf, pd_vaddr)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 216)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 192)
    do append(buf, 13)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 128)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 192)
    do append(buf, 235)
    do append(buf, 0)
    do append(buf, 139)
    do append(buf, 5)
    buf = nc_append_le32(buf, 3141632)
    do append(buf, 139)
    do append(buf, 5)
    buf = nc_append_le32(buf, 3145728)
    do append(buf, 176)
    do append(buf, 187)
    do append(buf, 233)
    buf = nc_append_le32(buf, sentinel_rel32)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 208)
    do append(buf, 61)
    buf = nc_append_le32(buf, 3145728)
    do append(buf, 117)
    do append(buf, 239)
    do append(buf, 131)
    do append(buf, 60)
    do append(buf, 36)
    do append(buf, 0)
    do append(buf, 117)
    do append(buf, 233)
    do append(buf, 129)
    do append(buf, 124)
    do append(buf, 36)
    do append(buf, 4)
    buf = nc_append_le32(buf, 1048667)
    do append(buf, 117)
    do append(buf, 223)
    return buf
end

-- chosen: GDT (null + flat 32-bit code 0x08 + data 0x10) + GDTR (limit 23), then a
-- FIFTEEN-entry IDT (vectors 0..13 NOT present -> any other exception triple-faults =
-- correct fail-closed RED; vector 14 = the #PF gate, offset=wrapper vaddr / selector
-- 0x0008 / attr 0x8E) + IDTR (limit 0x77 = 15*8-1). Emitter-laid-out at fixed vaddrs
-- (no runtime store-to-arbitrary-address -> typed-memory candidate (d) stays deferred).
func nc32_page_emit_tables(buf, gdt_vaddr, idt_vaddr, gate_vaddr):
    buf = nc_emit_zeroes_loop(buf, 8)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 154)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 146)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 23)
    do append(buf, 0)
    buf = nc_append_le32(buf, gdt_vaddr)
    buf = nc_emit_zeroes_loop(buf, 112)
    let glo = gate_vaddr % 65536
    let ghi_full = gate_vaddr / 65536
    let ghi = ghi_full % 65536
    do append(buf, glo % 256)
    do append(buf, glo / 256)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, ghi % 256)
    do append(buf, ghi / 256)
    do append(buf, 119)
    do append(buf, 0)
    buf = nc_append_le32(buf, idt_vaddr)
    return buf
end

-- chosen: the page directory (4 KiB). PDE[0] -> the page table (present+RW); the rest
-- are zero (not present). pt_vaddr is 4 KiB-aligned so +3 == |0x003.
func nc32_page_emit_pd(buf, pt_vaddr):
    buf = nc_append_le32(buf, pt_vaddr + 3)
    buf = nc_emit_zeroes_loop(buf, 4092)
    return buf
end

-- chosen: the page table (4 KiB, 1024 entries) identity-mapping 0..4 MiB as
-- (i*4096)|present|RW, EXCEPT entry 768 (linear 0x300000 = the neighbor B) left zero
-- (not present) -- the single hole that forces the #PF. i*4096 (tonka's `*`) avoids any
-- bit-shift; +3 sets present+RW since i*4096 is 4 KiB-aligned.
func nc32_page_emit_pt_loop(buf, i):
    if i >= 1024:
        return buf
    end
    if i == 768:
        buf = nc_append_le32(buf, 0)
    else:
        buf = nc_append_le32(buf, i * 4096 + 3)
    end
    return nc32_page_emit_pt_loop(buf, i + 1)
end

-- chosen driver. Layout (vaddr V0=0x10000c): [HEAD 118 (prologue+wrapper)]
-- [ebp-frame(0|5) + compiled toakie body] [shared 58-byte epilogue] [GDT/GDTR/IDT/IDTR 156]
-- [pad to 4 KiB] [PD 4096] [PT 4096]. The handler IS the compiled main() body (toakie
-- subset) reached via the #PF wrapper -- the anti-ceremony guard: the proof byte is normal
-- compiled lowering, not a canned blob. No `mov esp` in the body (the head set it; the
-- wrapper validated the fault frame first); it does NOT iret (a #PF re-faults on return
-- with the mapping unfixed; iret-resumption is a deferred later link). Reuses lingo's
-- ehdr/phdr/mbheader and toakie's verifier + 2-pass layout/lowering + epilogue verbatim.
func nc_emit_multiboot32_page_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(460, 0, "multiboot32-page: handler main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(461, 0, "multiboot32-page: handler main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(462, 0, "multiboot32-page: handler body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(463, 0, "multiboot32-page: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(464, 0, "multiboot32-page: body length invariant")
        return 0
    end
    let head_len = 118
    let hb = epi + 58
    let gdt_off = head_len + hb
    let gdt_vaddr = 1048588 + gdt_off
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 120
    let tables_end = idtr_vaddr + 6
    let pd_vaddr = nc32_roundup_4k(tables_end)
    let pt_vaddr = pd_vaddr + 4096
    let load_end = pt_vaddr + 4096
    let esp_top = load_end + 16384
    if esp_top > 3141632:
        let f7 = nc_fail(465, 0, "multiboot32-page: image collides with the mapped/unmapped test region")
        return 0
    end
    let gate_vaddr = 1048680
    let sentinel_rel32 = 26 + epi
    let cbuf = new_buffer()
    cbuf = nc32_page_emit_head(cbuf, gdtr_vaddr, esp_top, idtr_vaddr, pd_vaddr, sentinel_rel32)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    cbuf = nc32_page_emit_tables(cbuf, gdt_vaddr, idt_vaddr, gate_vaddr)
    let pre_pd_len = length(freeze(cbuf))
    let pad_to_pd = pd_vaddr - 1048588 - pre_pd_len
    cbuf = nc_emit_zeroes_loop(cbuf, pad_to_pd)
    cbuf = nc32_page_emit_pd(cbuf, pt_vaddr)
    cbuf = nc32_page_emit_pt_loop(cbuf, 0)
    let frozen_code = freeze(cbuf)
    let code_len = length(frozen_code)
    if code_len != load_end - 1048588:
        let f6 = nc_fail(466, 0, "multiboot32-page: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let memsz = filesz + 16384
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- multiboot32-store: the fixed 99-byte head (prologue + the runtime computed-address
-- store + the MMU-gate access). Extends chosen's paging-enable, then -- the new capability
-- (candidate (d)) -- computes a page-table-entry slot ADDRESS from the target vaddr in a
-- register and STORES a valid PTE there at runtime, mapping vaddr 0x300000 (left unmapped
-- at build time, PT[0x300]=0) to the present frame just above the page table. It then
-- ACCESSES 0x300000: the MMU is the judge -- if the runtime store landed at the right slot
-- with the right bits, the access succeeds; otherwise it #PFs into a fail-closed (limit-0)
-- IDT -> triple-fault. The compiled main() body (toakie subset) then computes the proof
-- byte (anti-ceremony: real compiled lowering, not a blob). No fault on the happy path,
-- so no #PF handler and no `iret`; no TLB flush (the page was never accessed, so nothing
-- is cached -- proven on both substrates). The computed slot: eax = (0x300000 >> 10) +
-- PT_vaddr; the store: mov [eax], (map_frame | present | RW). pt_vaddr and the map frame
-- are derived from pd_vaddr (pt = pd+4096, frame = pd+8192).
func nc32_store_emit_head(buf, gdtr_vaddr, esp_top, idtr_vaddr, pd_vaddr):
    let pt_vaddr = pd_vaddr + 4096
    let map_pte = pd_vaddr + 8195
    do append(buf, 250)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 21)
    buf = nc_append_le32(buf, gdtr_vaddr)
    do append(buf, 234)
    buf = nc_append_le32(buf, 1048603)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 102)
    do append(buf, 184)
    do append(buf, 16)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, 216)
    do append(buf, 142)
    do append(buf, 192)
    do append(buf, 142)
    do append(buf, 224)
    do append(buf, 142)
    do append(buf, 232)
    do append(buf, 142)
    do append(buf, 208)
    do append(buf, 188)
    buf = nc_append_le32(buf, esp_top)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 29)
    buf = nc_append_le32(buf, idtr_vaddr)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 224)
    do append(buf, 37)
    do append(buf, 79)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 224)
    do append(buf, 184)
    buf = nc_append_le32(buf, pd_vaddr)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 216)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 192)
    do append(buf, 13)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 128)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 192)
    do append(buf, 235)
    do append(buf, 0)
    do append(buf, 187)
    buf = nc_append_le32(buf, 3145728)
    do append(buf, 137)
    do append(buf, 216)
    do append(buf, 193)
    do append(buf, 232)
    do append(buf, 10)
    do append(buf, 5)
    buf = nc_append_le32(buf, pt_vaddr)
    do append(buf, 199)
    do append(buf, 0)
    buf = nc_append_le32(buf, map_pte)
    do append(buf, 160)
    buf = nc_append_le32(buf, 3145728)
    return buf
end

-- multiboot32-store tables: GDT (null + flat code 0x08 + data 0x10) + GDTR (limit 23) +
-- a FAIL-CLOSED IDTR (limit 0, base 0) -- no #PF handler is installed, so a #PF (which
-- only happens if the runtime store failed) cannot be delivered -> triple-fault = the
-- correct RED for this fixture. No IDT entries (simpler than chosen's 15-entry IDT).
func nc32_store_emit_tables(buf, gdt_vaddr):
    buf = nc_emit_zeroes_loop(buf, 8)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 154)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 146)
    do append(buf, 207)
    do append(buf, 0)
    do append(buf, 23)
    do append(buf, 0)
    buf = nc_append_le32(buf, gdt_vaddr)
    do append(buf, 0)
    do append(buf, 0)
    buf = nc_append_le32(buf, 0)
    return buf
end

-- multiboot32-store driver. Layout (vaddr V0=0x10000c): [HEAD 99 (prologue + computed
-- store + access)] [ebp-frame(0|5) + compiled toakie body] [shared 58-byte epilogue]
-- [GDT/GDTR/IDTR 36] [pad to 4 KiB] [PD 4096] [PT 4096, hole at 0x300]. Reuses chosen's
-- nc32_page_emit_pd/pt_loop verbatim (the build-time hole is what the runtime store fills)
-- and lingo's ehdr/phdr/mbheader + toakie's verifier + 2-pass layout/lowering + epilogue.
func nc_emit_multiboot32_store_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(467, 0, "multiboot32-store: main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(468, 0, "multiboot32-store: main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(469, 0, "multiboot32-store: body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(470, 0, "multiboot32-store: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(471, 0, "multiboot32-store: body length invariant")
        return 0
    end
    let head_len = 99
    let hb = epi + 58
    let gdt_off = head_len + hb
    let gdt_vaddr = 1048588 + gdt_off
    let gdtr_vaddr = gdt_vaddr + 24
    let idtr_vaddr = gdtr_vaddr + 6
    let tables_end = idtr_vaddr + 6
    let pd_vaddr = nc32_roundup_4k(tables_end)
    let pt_vaddr = pd_vaddr + 4096
    let load_end = pt_vaddr + 4096
    let esp_top = load_end + 16384
    if esp_top > 3145728:
        let f7 = nc_fail(472, 0, "multiboot32-store: image collides with the mapped vaddr region")
        return 0
    end
    let cbuf = new_buffer()
    cbuf = nc32_store_emit_head(cbuf, gdtr_vaddr, esp_top, idtr_vaddr, pd_vaddr)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_emit_epilogue(cbuf)
    cbuf = nc32_store_emit_tables(cbuf, gdt_vaddr)
    let pre_pd_len = length(freeze(cbuf))
    let pad_to_pd = pd_vaddr - 1048588 - pre_pd_len
    cbuf = nc_emit_zeroes_loop(cbuf, pad_to_pd)
    cbuf = nc32_page_emit_pd(cbuf, pt_vaddr)
    cbuf = nc32_page_emit_pt_loop(cbuf, 0)
    let frozen_code = freeze(cbuf)
    let code_len = length(frozen_code)
    if code_len != load_end - 1048588:
        let f6 = nc_fail(473, 0, "multiboot32-store: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let memsz = filesz + 16384
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- multiboot32-demand: the fixed 73-byte paging-enable prologue (IDENTICAL to liberi/chosen up
-- to `jmp $+2` -- cli; lgdt; far-jmp CS=0x08; reload DS/ES/FS/GS/SS=0x10; mov esp; lidt <REAL
-- #PF-handling IDTR>; clear CR4 (PAE/PSE/PGE); mov cr3 <own PD>; set CR0.PG; jmp $+2). Unlike
-- liberi, the store/access do NOT live in the head -- the faulting access is the GLUE after the
-- body, and the runtime store happens in the #PF HANDLER (the new capability).
func nc32_demand_emit_prologue(buf, gdtr_vaddr, esp_top, idtr_vaddr, pd_vaddr):
    do append(buf, 250)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 21)
    buf = nc_append_le32(buf, gdtr_vaddr)
    do append(buf, 234)
    buf = nc_append_le32(buf, 1048603)
    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 102)
    do append(buf, 184)
    do append(buf, 16)
    do append(buf, 0)
    do append(buf, 142)
    do append(buf, 216)
    do append(buf, 142)
    do append(buf, 192)
    do append(buf, 142)
    do append(buf, 224)
    do append(buf, 142)
    do append(buf, 232)
    do append(buf, 142)
    do append(buf, 208)
    do append(buf, 188)
    buf = nc_append_le32(buf, esp_top)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 29)
    buf = nc_append_le32(buf, idtr_vaddr)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 224)
    do append(buf, 37)
    do append(buf, 79)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 224)
    do append(buf, 184)
    buf = nc_append_le32(buf, pd_vaddr)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 216)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 192)
    do append(buf, 13)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 128)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 192)
    do append(buf, 235)
    do append(buf, 0)
    return buf
end

-- multiboot32-demand GLUE (9 bytes): the FAULTING, RESUMED, offset-indexed load. After the
-- compiled body leaves V in eax, `movzx eax,al` (index = V & 0xFF) then `mov al,[eax+0x300000]`
-- touches the build-time hole -> #PF. After the handler maps it and `iret`s, the load
-- RE-EXECUTES and reads seed[V] = V^0x5A from the now-mapped frame; the epilogue frames al.
-- This glue sits exactly at `epi` (the body's branch/RET target), so EVERY return path --
-- terminal RET fall-through AND mid-body `pop eax; jmp epi` -- funnels through the resume.
func nc32_demand_emit_glue(buf):
    do append(buf, 15)
    do append(buf, 182)
    do append(buf, 192)
    do append(buf, 138)
    do append(buf, 128)
    buf = nc_append_le32(buf, 3145728)
    return buf
end

-- multiboot32-demand #PF HANDLER (29 bytes -- THE NEW CAPABILITY, pinned hardest white-box).
-- Reached via the IDT vector-14 gate. It does NOT emit (the proof byte comes from the resumed
-- mainline load). It preserves eax (the faulting load's index V), reads CR2 (the faulting
-- linear address 0x300000+V), computes the PTE slot &PT[0x300] at runtime (shr eax,10; add
-- eax,PT_base -- liberi's computed store, now sourced from CR2), STORES a valid PTE (maps the
-- page), flushes the TLB via CR3 reload (empirically required on BOTH QEMU and Bochs -- the #PF
-- does NOT auto-invalidate the cached not-present walk), restores eax, drops the #PF error code
-- (`add esp,4` -- iret does NOT pop it; omitting it loads the error code as EIP -> triple-fault),
-- then `iret` RESUMES the faulting load. A mutation of any step (store/flush/add-esp/iret) leaves
-- the page unmapped or the frame corrupt -> #PF re-fault / triple-fault / wrong byte (all RED).
func nc32_demand_emit_handler(buf, pt_vaddr, frame_pte):
    do append(buf, 80)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 208)
    do append(buf, 193)
    do append(buf, 232)
    do append(buf, 10)
    do append(buf, 5)
    buf = nc_append_le32(buf, pt_vaddr)
    do append(buf, 199)
    do append(buf, 0)
    buf = nc_append_le32(buf, frame_pte)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 216)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 216)
    do append(buf, 88)
    do append(buf, 131)
    do append(buf, 196)
    do append(buf, 4)
    do append(buf, 207)
    return buf
end

-- multiboot32-demand SEEDED FRAME (4 KiB, file-backed in the loadable segment -- NOT bss).
-- The handler maps vaddr 0x300000 to this frame; the resumed load reads seed[V]. seed[i] =
-- i ^ 0x5A for i in 0..255 (a nonzero mask, so the byte is NOT V -- the resume is INDEPENDENTLY
-- load-bearing: a forge that emits V directly fails, and a forge that XORs an immediate is
-- caught white-box because the byte must come from `mov al,[mem]`). The rest is zero.
func nc32_demand_frame_loop(buf, i):
    if i >= 256:
        return buf
    end
    do append(buf, i ^ 90)
    return nc32_demand_frame_loop(buf, i + 1)
end

func nc32_demand_emit_frame(buf):
    buf = nc32_demand_frame_loop(buf, 0)
    buf = nc_emit_zeroes_loop(buf, 3840)
    return buf
end

-- multiboot32-demand driver. Layout (vaddr V0=0x10000c): [PROLOGUE 73 (paging-enable)]
-- [ebp-frame(0|5) + compiled toakie body] [GLUE 9 (faulting resumed load)] [shared 58-byte
-- epilogue] [#PF HANDLER 29] [GDT/GDTR/IDT(15)/IDTR 156 -- chosen's nc32_page_emit_tables,
-- vector-14 gate -> the handler] [pad to 4 KiB] [PD 4096 -> PT] [PT 4096, hole at 0x300]
-- [SEEDED FRAME 4096]. Reuses chosen's nc32_page_emit_pd/pt_loop (the runtime store fills the
-- hole) + the toakie verifier/2-pass layout/lowering + the shared epilogue + lingo's ehdr/phdr/
-- mbheader. The frame is part of the loaded segment (filesz), so the seed survives to runtime.
func nc_emit_multiboot32_demand_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(474, 0, "multiboot32-demand: main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(475, 0, "multiboot32-demand: main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(476, 0, "multiboot32-demand: body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(477, 0, "multiboot32-demand: too many locals (max 31)")
        return 0
    end
    let ebp_prefix = 0
    if nlocals > 0:
        ebp_prefix = 5
    end
    let lay = nc32_layout_loop(code, 0, n, ebp_prefix, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - ebp_prefix:
        let f5 = nc_fail(478, 0, "multiboot32-demand: body length invariant")
        return 0
    end
    let off_handler = 73 + ebp_prefix + bodylen + 9 + 58
    let handler_vaddr = 1048588 + off_handler
    let off_tables = off_handler + 29
    let gdt_vaddr = 1048588 + off_tables
    let gdtr_vaddr = gdt_vaddr + 24
    let idt_vaddr = gdtr_vaddr + 6
    let idtr_vaddr = idt_vaddr + 120
    let tables_end = idtr_vaddr + 6
    let pd_vaddr = nc32_roundup_4k(tables_end)
    let pt_vaddr = pd_vaddr + 4096
    let frame_vaddr = pt_vaddr + 4096
    let load_end = frame_vaddr + 4096
    let esp_top = load_end + 16384
    if esp_top > 3145728:
        let f7 = nc_fail(479, 0, "multiboot32-demand: image collides with the mapped vaddr region")
        return 0
    end
    let frame_pte = frame_vaddr + 3
    let cbuf = new_buffer()
    cbuf = nc32_demand_emit_prologue(cbuf, gdtr_vaddr, esp_top, idtr_vaddr, pd_vaddr)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    cbuf = nc32_demand_emit_glue(cbuf)
    cbuf = nc32_emit_epilogue(cbuf)
    cbuf = nc32_demand_emit_handler(cbuf, pt_vaddr, frame_pte)
    cbuf = nc32_page_emit_tables(cbuf, gdt_vaddr, idt_vaddr, handler_vaddr)
    let pre_pd_len = length(freeze(cbuf))
    let pad_to_pd = pd_vaddr - 1048588 - pre_pd_len
    cbuf = nc_emit_zeroes_loop(cbuf, pad_to_pd)
    cbuf = nc32_page_emit_pd(cbuf, pt_vaddr)
    cbuf = nc32_page_emit_pt_loop(cbuf, 0)
    cbuf = nc32_demand_emit_frame(cbuf)
    let frozen_code = freeze(cbuf)
    let code_len = length(frozen_code)
    if code_len != load_end - 1048588:
        let f6 = nc_fail(480, 0, "multiboot32-demand: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let memsz = filesz + 16384
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- hoopteeter: the fixed 56-byte LONG-MODE TRANSITION head (emitter-laid-out structure, like
-- the ELF/MB headers -- honest structure, not compiled Herbert). In execution order (entered
-- AFTER the compiled body has stashed V in esi): cli; lgdt my own GDT (which has a 64-bit
-- L=1 code descriptor at 0x08); normalize CR4 = PAE only (Multiboot leaves CR4 UNDEFINED --
-- chosen's lesson, but here we SET PAE for 4-level paging); mov cr3 = PML4 physical; set
-- EFER.LME via wrmsr to MSR 0xC0000080 (RMW: rdmsr; or eax,0x100; wrmsr -- LME-only, NXE stays
-- clear); set CR0.PG (now in IA-32e COMPATIBILITY mode); ljmp 0x08:long_entry -- reload CS into
-- the 64-bit segment, entering true 64-bit mode. Two le32 fields vary (gdtr_vaddr, pml4_vaddr)
-- plus the ljmp target (long_entry_vaddr); everything else is a fixed byte sequence the
-- white-box gate pins exactly. CR4=0x20 and the ljmp selector 0x08 are load-bearing.
func nc32_long_emit_head(buf, gdtr_vaddr, pml4_vaddr, long_entry_vaddr):
    do append(buf, 250)
    do append(buf, 15)
    do append(buf, 1)
    do append(buf, 21)
    buf = nc_append_le32(buf, gdtr_vaddr)
    do append(buf, 184)
    do append(buf, 32)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 224)
    do append(buf, 184)
    buf = nc_append_le32(buf, pml4_vaddr)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 216)
    do append(buf, 185)
    do append(buf, 128)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 192)
    do append(buf, 15)
    do append(buf, 50)
    do append(buf, 13)
    do append(buf, 0)
    do append(buf, 1)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 15)
    do append(buf, 48)
    do append(buf, 15)
    do append(buf, 32)
    do append(buf, 192)
    do append(buf, 13)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 128)
    do append(buf, 15)
    do append(buf, 34)
    do append(buf, 192)
    do append(buf, 234)
    buf = nc_append_le32(buf, long_entry_vaddr)
    do append(buf, 8)
    do append(buf, 0)
    return buf
end

-- hoopteeter: the fixed 16-byte 64-bit OBSERVABLE (long_entry). The compiled body left its
-- return value V in eax and stashed it in esi before the mode switch. mov eax,esi (89 f0) +
-- nop (90) -- the FIRST 64-bit instruction reads esi (the LOW 32 bits = V) and ZERO-EXTENDS it
-- into rax, because a 32-bit `mov esi,eax` in protected mode leaves the HIGH 32 bits of rsi
-- ARCHITECTURALLY UNDEFINED (32-bit writes zero-extend only IN 64-bit mode) -- so reading rsi
-- directly (mov rax,rsi) would multiply (garbage<<32 | V) and corrupt the proof byte on real
-- silicon (the two emulators happen to zero it; cross-model Codex caught this, silicon-confirmed).
-- Then mov ecx,0x10001 (the fixed multiplier K); imul rax,rcx (REX.W 48 0F AF C1 -- 64-bit imul, the
-- low 64 bits; V*K << 2^64 so that IS the true product yet exceeds 2^32); shr rax,0x20 (REX.W 48 C1 E8 20 -- the HIGH dword into al). The shr count 0x20 (=32) is LOAD-BEARING: in
-- 32-bit/compat the count masks to 5 bits (0x20 & 0x1f = 0 -> no-op shift, al stays the low
-- byte) AND the REX.W 0x48 decodes as `dec eax`, so the identical bytes yield a DIFFERENT byte
-- -- which is exactly why a compat-mode (L=0 descriptor) forge fails. Leaves the proof byte in
-- al, then the shared epilogue frames it (0xDE<byte>0xAD on 0xE9 + result-dependent exit).
func nc32_long_emit_observable(buf):
    do append(buf, 137)
    do append(buf, 240)
    do append(buf, 144)
    do append(buf, 185)
    do append(buf, 1)
    do append(buf, 0)
    do append(buf, 1)
    do append(buf, 0)
    do append(buf, 72)
    do append(buf, 15)
    do append(buf, 175)
    do append(buf, 193)
    do append(buf, 72)
    do append(buf, 193)
    do append(buf, 232)
    do append(buf, 32)
    return buf
end

-- hoopteeter: the 30-byte GDT + GDTR. A 3-entry GDT: null, a 64-bit CODE descriptor
-- 0x00AF9A000000FFFF (P/DPL0/S/exec, G=1, and L=1 -- the long-mode bit, the single bit that
-- distinguishes true 64-bit from compatibility mode; the compat twin 0x00CF9A000000FFFF is
-- banned by the white-box gate), and a data descriptor 0x00AF92000000FFFF; then GDTR (limit
-- 0x17 = 3*8-1, base gdt_vaddr). Emitter-laid-out at a fixed vaddr.
func nc32_long_emit_gdt(buf, gdt_vaddr):
    buf = nc_emit_zeroes_loop(buf, 8)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 154)
    do append(buf, 175)
    do append(buf, 0)
    do append(buf, 255)
    do append(buf, 255)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 146)
    do append(buf, 175)
    do append(buf, 0)
    do append(buf, 23)
    do append(buf, 0)
    buf = nc_append_le32(buf, gdt_vaddr)
    return buf
end

-- hoopteeter: the PML4 (4 KiB). Entry 0 -> the PDPT (present+RW), the rest not present. PAE
-- entries are 8 bytes; the next-table pointer is the low dword (the table is 4 KiB-aligned, so
-- +3 == |present|RW), the high dword is 0 (no NX -- EFER.NXE stays clear, so bit 63 must be 0).
func nc32_long_emit_pml4(buf, pdpt_vaddr):
    buf = nc_append_le32(buf, pdpt_vaddr + 3)
    buf = nc_append_le32(buf, 0)
    buf = nc_emit_zeroes_loop(buf, 4088)
    return buf
end

-- hoopteeter: the PDPT (4 KiB). Entry 0 -> the PD (present+RW), the rest not present.
func nc32_long_emit_pdpt(buf, pd_vaddr):
    buf = nc_append_le32(buf, pd_vaddr + 3)
    buf = nc_append_le32(buf, 0)
    buf = nc_emit_zeroes_loop(buf, 4088)
    return buf
end

-- hoopteeter: the PD (4 KiB, 512 entries) identity-mapping the WHOLE low 1 GiB as 512 2-MiB
-- PAE pages: pd[i] = (i * 0x200000) | present | RW | PS(0x80) == i*2097152 + 0x83. i*0x200000
-- (tonka's `*`, no bit-shift) is 2-MiB-aligned so the low [20:0] frame bits are zero (a 2-MiB
-- PS page requires this). Mapping the full low 1 GiB (table size is a fixed 4 KiB regardless of
-- N) removes any image/stack/table-coverage question from the threat model -- nothing the image
-- touches is ever outside the map, so no spurious #PF/triple-fault as the image grows.
func nc32_long_emit_pd_loop(buf, i):
    if i >= 512:
        return buf
    end
    buf = nc_append_le32(buf, i * 2097152 + 131)
    buf = nc_append_le32(buf, 0)
    return nc32_long_emit_pd_loop(buf, i + 1)
end

-- hoopteeter driver. Layout (vaddr V0=0x10000c): [mov esp + ebp-frame(0|5)] [compiled toakie
-- body -- `return V` jumps to epi] [@epi: mov esi,eax (stash V)] [56-byte transition head]
-- [@long_entry: 16-byte 64-bit observable] [shared 58-byte epilogue] [GDT/GDTR 30] [pad to
-- 4 KiB] [PML4 4096] [PDPT 4096] [PD 4096]. The body IS the compiled main() body (toakie
-- subset: locals, + - *, ==, if/else, return) running in 32-bit -- the anti-ceremony guard:
-- the proof byte tracks NORMAL compiled lowering, not a canned blob. It then crosses into 64-bit
-- and the observable derives the proof byte = high dword of (V * 0x10001), 64-bit-distinguishing.
-- Reuses lingo's ehdr/phdr/mbheader + toakie's verifier/2-pass-layout/lowering + the shared
-- epilogue verbatim, so the eight prior modes are untouched (fixpoint preserved).
func nc_emit_multiboot32_long_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(492, 0, "multiboot32-long: main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(493, 0, "multiboot32-long: main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc32_body_ok(code, n):
        let f3 = nc_fail(494, 0, "multiboot32-long: body not in the control-flow+locals subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 31:
        let f4 = nc_fail(495, 0, "multiboot32-long: too many locals (max 31)")
        return 0
    end
    let prefix_len = 5
    if nlocals > 0:
        prefix_len = 10
    end
    let lay = nc32_layout_loop(code, 0, n, prefix_len, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc32_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - prefix_len:
        let f5 = nc_fail(496, 0, "multiboot32-long: body length invariant")
        return 0
    end
    let v0 = 1048588
    let long_entry_vaddr = v0 + epi + 58
    let gdt_off = epi + 132
    let gdt_vaddr = v0 + gdt_off
    let gdtr_vaddr = gdt_vaddr + 24
    let tables_end = gdtr_vaddr + 6
    let pml4_vaddr = nc32_roundup_4k(tables_end)
    let pdpt_vaddr = pml4_vaddr + 4096
    let pd_vaddr = pdpt_vaddr + 4096
    let load_end = pd_vaddr + 4096
    let esp_val = load_end + 16384
    if esp_val > 1073741824:
        let f7 = nc_fail(497, 0, "multiboot32-long: image exceeds the identity-mapped low 1 GiB")
        return 0
    end
    let cbuf = new_buffer()
    do append(cbuf, 188)
    cbuf = nc_append_le32(cbuf, esp_val)
    if nlocals > 0:
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 4 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    do append(cbuf, 137)
    do append(cbuf, 198)
    cbuf = nc32_long_emit_head(cbuf, gdtr_vaddr, pml4_vaddr, long_entry_vaddr)
    cbuf = nc32_long_emit_observable(cbuf)
    cbuf = nc32_emit_epilogue(cbuf)
    cbuf = nc32_long_emit_gdt(cbuf, gdt_vaddr)
    let pre_pml4_len = length(freeze(cbuf))
    let pad_to_pml4 = pml4_vaddr - v0 - pre_pml4_len
    cbuf = nc_emit_zeroes_loop(cbuf, pad_to_pml4)
    cbuf = nc32_long_emit_pml4(cbuf, pdpt_vaddr)
    cbuf = nc32_long_emit_pdpt(cbuf, pd_vaddr)
    cbuf = nc32_long_emit_pd_loop(cbuf, 0)
    let frozen_code = freeze(cbuf)
    let code_len = length(frozen_code)
    if code_len != load_end - v0:
        let f6 = nc_fail(498, 0, "multiboot32-long: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let memsz = filesz + 16384
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

-- toggler (TENTH kernel-arc link): "-- emit: multiboot32-long64" selects the freestanding image
-- that crosses into 64-bit long mode and runs a GENUINELY 64-bit COMPILED body -- the x86-64
-- BACKEND REUNIFICATION. hoopteeter (multiboot32-long) computes V in a 32-bit body and a canned
-- 16-byte observable derives the proof byte; toggler instead lowers the body through the SAME
-- near-axis 64-bit leaf emitters the Linux-ELF64 path uses (nc_emit_push_int/add/sub/mul -- REX.W),
-- AFTER entering long mode, so the proof byte = high dword of the body's OWN 64-bit result (a
-- multiply whose product exceeds 2^32: wrong under 32-bit-width arithmetic). One 64-bit lowering
-- table, both targets. Minimal slice -- straight-line arithmetic {PUSH_INT, ADD, SUB, MUL, RET},
-- single main(), no params/locals/branches (64-bit locals/branches widen a later link). With no
-- branches there are no body rel32s, so no layout pass is needed (emit the body, then measure).
-- The "-long64" suffix means nc_is_multiboot32 / _idt / _page / _store / _demand / _timer / _tick /
-- _long do NOT match (each requires its own marker followed by a newline; here source[mlen]='6').
func nc_is_multiboot32_long64(source):
    let marker = "-- emit: multiboot32-long64"
    let mlen = length(marker)
    if not nc_mb_marker_match(source, marker, 0, mlen):
        return false
    end
    if length(source) <= mlen:
        return false
    end
    return index(source, mlen) == 10
end

-- The widened 64-bit subset (trikea/f2): PUSH_INT (0), LOAD_LOCAL (3), STORE_LOCAL (4), ADD (5),
-- SUB (6), EQ (11), NE (12), BR (16), BR_IF_FALSE (17), MUL (42), RET (21). Mirrors the proven
-- 32-bit toakie control-flow+locals subset but at 64-bit width: locals are 8-byte rbp-frame slots
-- ([rbp - 8*(slot+1)]) and branches resolve through a 64-bit layout pass. Still rejects call (20),
-- bitwise (36/37), div/mod (43/44), and anything else -- those remain deferred.
func nc64_op_allowed(op):
    if op == 0:
        return true
    end
    if op == 3:
        return true
    end
    if op == 4:
        return true
    end
    if op == 5:
        return true
    end
    if op == 6:
        return true
    end
    if op == 11:
        return true
    end
    if op == 12:
        return true
    end
    if op == 16:
        return true
    end
    if op == 17:
        return true
    end
    if op == 42:
        return true
    end
    if op == 21:
        return true
    end
    return false
end

-- Stack effect of each admitted 64-bit op (pops then pushes). REUSES the width-agnostic nc32_pops/
-- nc32_pushes (stack semantics are width-independent), but adds NE (op 12), which nc32 never admitted
-- and so leaves at 0/0: NE has the SAME stack effect as EQ (op 11) -- pop 2 operands, push 1 result.
-- Without this, an NE in a 64-bit body would be tracked as a no-op in the depth walk and mis-verify.
func nc64_pops(op):
    if op == 12:
        return 2
    end
    return nc32_pops(op)
end

func nc64_pushes(op):
    if op == 12:
        return 1
    end
    return nc32_pushes(op)
end

-- Two-pass CFG verifier mirroring nc32 (PASS A: forward depth walk; PASS B: nc32_check_branches for
-- forward-only + merge-point depth agreement). A COPY of nc32_build_depths with the depth cap at 1500
-- (NOT 3000) -- 64-bit pushes are 8 bytes (1500*8 = 12 KiB < the 16 KiB stack reserve above load_end),
-- and using nc64_pops/nc64_pushes so NE (op 12) is accounted. Records the depth BEFORE each instr;
-- rejects any unknown opcode, any underflow, any RET not at depth exactly 1. Returns (ok, depths).
func nc64_build_depths(code, i, n, cur, depths):
    if i >= n:
        return (1, depths)
    end
    let op = get(code, i).0
    if not nc64_op_allowed(op):
        return (0, depths)
    end
    if cur > 1500:
        return (0, depths)
    end
    let pops = nc64_pops(op)
    if cur < pops:
        return (0, depths)
    end
    do add(depths, cur)
    if op == 21:
        if cur != 1:
            return (0, depths)
        end
    end
    return nc64_build_depths(code, i + 1, n, cur - pops + nc64_pushes(op), depths)
end

-- The full 64-bit subset gate (mirrors nc32_body_ok): ends in RET, all opcodes admitted +
-- stack-balanced (PASS A), all branches forward + depth-agreeing (PASS B, reusing the width-agnostic
-- nc32_check_branches). Defense-in-depth: the far-axis oracle has no C reference, so the gate proves
-- the body's well-formedness itself before the 64-bit layout pass resolves branch rel32s.
func nc64_body_ok(code, n):
    if n == 0:
        return false
    end
    if get(code, n - 1).0 != 21:
        return false
    end
    let bd = nc64_build_depths(code, 0, n, 0, new_array(int))
    if bd.0 == 0:
        return false
    end
    return nc32_check_branches(code, 0, n, bd.1)
end

-- Byte size each op lowers to (matching the EXACT 64-bit lowering in nc64_lower_loop): PUSH_INT 11
-- (48 B8 imm64; push), LOAD_LOCAL 5 (48 8B 45 disp8; push), STORE_LOCAL 5 (pop; 48 89 45 disp8),
-- ADD/SUB 6 (REX.W), EQ/NE 13 (pop;pop; REX.W cmp; setcc; movzx; push), BR 5 (e9 rel32),
-- BR_IF_FALSE 10 (pop; test; je rel32), MUL 7 (REX.W imul), RET 1 if last (pop rax; fall through to
-- the grading tail) else 6 (pop rax; jmp epilogue). Drives the two-pass layout that resolves branch
-- rel32s AND the driver's body-length invariant (a mis-sized/dropped op is caught, never silently
-- mis-emitted -- the no-silent-drop guard the other freestanding drivers carry).
func nc64_op_size(op, is_last):
    if op == 0:
        return 11
    end
    if op == 3:
        return 5
    end
    if op == 4:
        return 5
    end
    if op == 5:
        return 6
    end
    if op == 6:
        return 6
    end
    if op == 11:
        return 13
    end
    if op == 12:
        return 13
    end
    if op == 16:
        return 5
    end
    if op == 17:
        return 10
    end
    if op == 42:
        return 7
    end
    if op == 21:
        if is_last == 1:
            return 1
        end
        return 6
    end
    return 0
end

func nc64_body_size_loop(code, i, n, acc):
    if i >= n:
        return acc
    end
    let il = 0
    if i == n - 1:
        il = 1
    end
    return nc64_body_size_loop(code, i + 1, n, acc + nc64_op_size(get(code, i).0, il))
end

-- PASS 1 layout (mirrors nc32_layout_loop at 64-bit width): byte offset of each instr from code start
-- (offsets INCLUDE the prefix, so a branch rel cancels the prefix). Returns (offs, epilogue_off); a
-- branch target == n resolves to epilogue_off.
func nc64_layout_loop(code, i, n, cur, offs):
    if i >= n:
        return (offs, cur)
    end
    do add(offs, cur)
    let il = 0
    if i == n - 1:
        il = 1
    end
    return nc64_layout_loop(code, i + 1, n, cur + nc64_op_size(get(code, i).0, il), offs)
end

-- Frame-local displacement as a disp8 byte: [rbp - 8*(slot+1)]. nlocals is capped at 15 upstream
-- (max slot 14), so 8*(slot+1) <= 120 fits a signed byte. The cap is 15 not 16 because the frame
-- prologue is `sub rsp, imm8` (48 83 EC ib), which SIGN-EXTENDS: frame = 8*16 = 128 would encode as
-- 0x80 = -128 and ADD to rsp. So 15 locals (frame 120, 0x78) is the true boundary, not the disp8 limit.
func nc64_emit_local_disp(buf, slot):
    do append(buf, 256 - 8 * (slot + 1))
    return buf
end

-- PASS 2 lowering (mirrors nc32_lower_loop at 64-bit width): emit each instr's bytes, resolving
-- BR/BR_IF_FALSE/mid-RET rel32 from the layout. REUSES the near-axis 64-bit leaf emitters for
-- PUSH_INT/ADD/SUB/MUL (the reunification -- each carries REX.W 0x48); locals use 8-byte rbp-frame
-- slots ([rbp - 8*(slot+1)]); EQ/NE lower to REX.W cmp + setcc + movzx; branches use the same forward
-- rel32 machinery as nc32 (gated forward-only, so every rel32 is non-negative). Terminal RET lowers to
-- a single `pop rax` (0x58, the driver appends the grading tail); a mid-body RET lowers to pop rax;
-- jmp epilogue.
func nc64_lower_loop(buf, code, i, n, offs, epi):
    if i >= n:
        return buf
    end
    let op = get(code, i).0
    let il = 0
    if i == n - 1:
        il = 1
    end
    let endoff = get(offs, i) + nc64_op_size(op, il)
    if op == 0:
        buf = nc_emit_push_int(buf, get(code, i).1)
    elif op == 3:
        do append(buf, 72)
        do append(buf, 139)
        do append(buf, 69)
        buf = nc64_emit_local_disp(buf, get(code, i).1)
        do append(buf, 80)
    elif op == 4:
        do append(buf, 88)
        do append(buf, 72)
        do append(buf, 137)
        do append(buf, 69)
        buf = nc64_emit_local_disp(buf, get(code, i).1)
    elif op == 5:
        buf = nc_emit_add(buf)
    elif op == 6:
        buf = nc_emit_sub(buf)
    elif op == 11:
        do append(buf, 89)
        do append(buf, 88)
        do append(buf, 72)
        do append(buf, 57)
        do append(buf, 200)
        do append(buf, 15)
        do append(buf, 148)
        do append(buf, 194)
        do append(buf, 72)
        do append(buf, 15)
        do append(buf, 182)
        do append(buf, 194)
        do append(buf, 80)
    elif op == 12:
        do append(buf, 89)
        do append(buf, 88)
        do append(buf, 72)
        do append(buf, 57)
        do append(buf, 200)
        do append(buf, 15)
        do append(buf, 149)
        do append(buf, 194)
        do append(buf, 72)
        do append(buf, 15)
        do append(buf, 182)
        do append(buf, 194)
        do append(buf, 80)
    elif op == 16:
        do append(buf, 233)
        let t = get(code, i).1
        let toff = epi
        if t < n:
            toff = get(offs, t)
        end
        buf = nc_append_le32(buf, toff - endoff)
    elif op == 17:
        do append(buf, 88)
        do append(buf, 72)
        do append(buf, 133)
        do append(buf, 192)
        do append(buf, 15)
        do append(buf, 132)
        let t2 = get(code, i).1
        let toff2 = epi
        if t2 < n:
            toff2 = get(offs, t2)
        end
        buf = nc_append_le32(buf, toff2 - endoff)
    elif op == 42:
        buf = nc_emit_mul(buf)
    elif op == 21:
        if il == 1:
            do append(buf, 88)
        else:
            do append(buf, 88)
            do append(buf, 233)
            buf = nc_append_le32(buf, epi - endoff)
        end
    end
    return nc64_lower_loop(buf, code, i + 1, n, offs, epi)
end

-- trikea/f2 driver (widened toggler). Layout (vaddr V0=0x10000c): [56-byte transition head -> ljmp
-- 0x08:long_entry] [@long_entry (64-bit): mov esp,esp_val (BC imm32 -- zero-extends rsp; the one extra
-- instruction long mode needs because the 32-bit handoff leaves rsp[63:32] undefined)] [optional rbp
-- frame: mov rbp,rsp (48 89 E5) + sub rsp,8*nlocals (48 83 EC imm8) -- present iff the body uses
-- locals] [the compiled body lowered via nc64_lower_loop -- if/else + rbp-frame locals + 64-bit
-- arithmetic; mid-body RET jmps to the grading tail, terminal RET (pop rax) falls through] [shr
-- rax,0x20 -- the grading tail: high dword of the body's 64-bit result into al] [shared 58-byte
-- epilogue: frame 0xDE<byte>0xAD on 0xE9 + result-dependent isa-debug-exit] [GDT/GDTR 30] [pad to
-- 4 KiB] [PML4][PDPT][PD]. The prefix is 5 bytes (mov esp) with no locals, 12 (mov esp + mov rbp,rsp +
-- sub rsp,imm8) with locals; branch rel32s resolve through nc64_layout_loop (the prefix is the layout
-- origin, so rel32s cancel it). Reuses hoopteeter's transition head/GDT/PAE tables and lingo's ehdr/
-- phdr/mbheader + the shared epilogue verbatim, so the nine prior modes are byte-identical and the
-- self-host fixpoint is preserved. For a straight-line no-locals body, prefix_len=5 and the layout/lower
-- produce IDENTICAL bytes to the pre-widen path -> byte-identical image (the f2 byte-identity guarantee).
func nc_emit_multiboot32_long64_program(source):
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let funcs = prog.0
    if count(funcs) != 1:
        let f1 = nc_fail(500, 0, "multiboot32-long64: main may not call other functions")
        return 0
    end
    let mainfn = get(funcs, prog.2)
    if mainfn.2 != 0:
        let f2 = nc_fail(501, 0, "multiboot32-long64: main must take no parameters")
        return 0
    end
    let code = mainfn.4
    let n = count(code)
    if not nc64_body_ok(code, n):
        let f3 = nc_fail(502, 0, "multiboot32-long64: body not in the control-flow+locals 64-bit subset")
        return 0
    end
    let nlocals = nc32_nlocals_loop(code, 0, n, 0)
    if nlocals > 15:
        let f4 = nc_fail(504, 0, "multiboot32-long64: too many locals (max 15)")
        return 0
    end
    let prefix_len = 5
    if nlocals > 0:
        prefix_len = 12
    end
    let lay = nc64_layout_loop(code, 0, n, prefix_len, new_array(int))
    let offs = lay.0
    let epi = lay.1
    let bodybuf = new_buffer()
    bodybuf = nc64_lower_loop(bodybuf, code, 0, n, offs, epi)
    let bodylen = length(freeze(bodybuf))
    if bodylen != epi - prefix_len:
        let f5 = nc_fail(505, 0, "multiboot32-long64: body length invariant (a lowered op was dropped or mis-sized)")
        return 0
    end
    let v0 = 1048588
    let long_entry_vaddr = v0 + 56
    let region_len = prefix_len + bodylen + 4
    let epi_off = 56 + region_len
    let gdt_off = epi_off + 58
    let gdt_vaddr = v0 + gdt_off
    let gdtr_vaddr = gdt_vaddr + 24
    let tables_end = gdtr_vaddr + 6
    let pml4_vaddr = nc32_roundup_4k(tables_end)
    let pdpt_vaddr = pml4_vaddr + 4096
    let pd_vaddr = pdpt_vaddr + 4096
    let load_end = pd_vaddr + 4096
    let esp_val = load_end + 16384
    if esp_val > 1073741824:
        let f7 = nc_fail(503, 0, "multiboot32-long64: image exceeds the identity-mapped low 1 GiB")
        return 0
    end
    let cbuf = new_buffer()
    cbuf = nc32_long_emit_head(cbuf, gdtr_vaddr, pml4_vaddr, long_entry_vaddr)
    do append(cbuf, 188)
    cbuf = nc_append_le32(cbuf, esp_val)
    if nlocals > 0:
        do append(cbuf, 72)
        do append(cbuf, 137)
        do append(cbuf, 229)
        do append(cbuf, 72)
        do append(cbuf, 131)
        do append(cbuf, 236)
        do append(cbuf, 8 * nlocals)
    end
    cbuf = append_str(cbuf, freeze(bodybuf))
    do append(cbuf, 72)
    do append(cbuf, 193)
    do append(cbuf, 232)
    do append(cbuf, 32)
    cbuf = nc32_emit_epilogue(cbuf)
    cbuf = nc32_long_emit_gdt(cbuf, gdt_vaddr)
    let pre_pml4_len = length(freeze(cbuf))
    let pad_to_pml4 = pml4_vaddr - v0 - pre_pml4_len
    cbuf = nc_emit_zeroes_loop(cbuf, pad_to_pml4)
    cbuf = nc32_long_emit_pml4(cbuf, pdpt_vaddr)
    cbuf = nc32_long_emit_pdpt(cbuf, pd_vaddr)
    cbuf = nc32_long_emit_pd_loop(cbuf, 0)
    let frozen_code = freeze(cbuf)
    let code_len = length(frozen_code)
    if code_len != load_end - v0:
        let f6 = nc_fail(504, 0, "multiboot32-long64: code length invariant")
        return 0
    end
    let filesz = 12 + code_len
    let shoff = nc32_roundup4(4096 + 12 + code_len)
    let entry = 1048588
    let memsz = filesz + 16384
    let img = new_buffer()
    img = nc32_emit_ehdr(img, entry, shoff)
    img = nc32_emit_phdr(img, filesz, memsz)
    img = nc_emit_zeroes_loop(img, 4096 - 84)
    img = nc32_emit_mbheader(img)
    img = append_str(img, frozen_code)
    img = nc_emit_zeroes_loop(img, shoff - 4096 - 12 - code_len)
    img = nc_emit_zeroes_loop(img, 40)
    do fwriter(freeze(img))
    return 0
end

func main():
    let source = clogger()
    if nc_is_multiboot32_long64(source):
        let l6 = nc_emit_multiboot32_long64_program(source)
        return 0
    end
    if nc_is_multiboot32_long(source):
        let lm = nc_emit_multiboot32_long_program(source)
        return 0
    end
    if nc_is_multiboot32_bluefield(source):
        let bf = nc_emit_multiboot32_bluefield_program(source)
        return 0
    end
    if nc_is_multiboot32_contigo(source):
        let co = nc_emit_multiboot32_contigo_program(source)
        return 0
    end
    if nc_is_multiboot32_cloggard(source):
        let cg = nc_emit_multiboot32_cloggard_program(source)
        return 0
    end
    if nc_is_multiboot32_rizzing(source):
        let rz = nc_emit_multiboot32_rizzing_program(source)
        return 0
    end
    if nc_is_multiboot32_tick(source):
        let tk = nc_emit_multiboot32_tick_program(source)
        return 0
    end
    if nc_is_multiboot32_timer(source):
        let tm = nc_emit_multiboot32_timer_program(source)
        return 0
    end
    if nc_is_multiboot32_demand(source):
        let dm = nc_emit_multiboot32_demand_program(source)
        return 0
    end
    if nc_is_multiboot32_store(source):
        let st = nc_emit_multiboot32_store_program(source)
        return 0
    end
    if nc_is_multiboot32_page(source):
        let pg = nc_emit_multiboot32_page_program(source)
        return 0
    end
    if nc_is_multiboot32_idt(source):
        let z = nc_emit_multiboot32_idt_program(source)
        return 0
    end
    if nc_is_multiboot32_lodger(source):
        let lg = nc_emit_multiboot32_lodger_program(source)
        return 0
    end
    if nc_is_multiboot32_input(source):
        let mi = nc_emit_multiboot32_input_program(source)
        return 0
    end
    if nc_is_multiboot32(source):
        let mb_done = nc_emit_multiboot32_program(source)
        return 0
    end
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let has_faultable = nc_prog_has_faultable(prog)
    if has_faultable != 0:
        let diag_strings = nc_append_fault_rodata(prog.1)
    end
    let analyzed = nc_analyze_program(type_pool, prog, ast_result.1)
    if analyzed.0 != 0:
        let fail_an = nc_fail(analyzed.0, 0, "")
        return 0
    end
    let metas = analyzed.1
    let main_ret = get(metas, prog.2).1
    let pass1 = nc_pass1_program(prog, metas, analyzed.2, analyzed.3, has_faultable)
    if pass1.0 != 0:
        return 0
    end
    let funcs = prog.0
    let layouts = pass1.1
    let main_layout = get(layouts, prog.2)
    let diag_base = 0
    if has_faultable != 0:
        diag_base = nc_fault_helper_start(analyzed.3, has_faultable, main_ret)
    end
    let cbuf = new_buffer()
    let entry = nc_emit_entry_stub(cbuf, main_layout.0, analyzed.2, analyzed.3, has_faultable, main_ret, pass1.2, prog.1)
    if entry.0 != 0:
        return 0
    end
    let emitted = nc_emit_functions_loop(entry.1, funcs, metas, layouts, prog.1, pass1.2, diag_base, 0, count(funcs))
    if emitted.0 != 0:
        return 0
    end
    let frozen_code = freeze(emitted.1)
    let code_len = length(frozen_code)
    if code_len != pass1.2:
        let fail = nc_fail(418, 0, "program-length")
        return 0
    end
    let ro_len = nc_rodata_len(prog.1)
    let img = nc_roundup_page(120 + code_len + ro_len)
    let pad = img - 120 - code_len - ro_len
    let align_hi = 0
    if not nc_funcs_have_call(funcs):
        align_hi = 129
    end
    let buf = new_buffer()
    buf = nc_emit_ehdr(buf)
    buf = nc_emit_phdr(buf, img, align_hi)
    buf = append_str(buf, frozen_code)
    buf = nc_emit_rodata(buf, prog.1)
    buf = nc_emit_zeroes_loop(buf, pad)
    do fwriter(freeze(buf))
    return 0
end
