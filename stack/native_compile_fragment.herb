func nc_code_has_call_loop(code, i, n):
    if i >= n:
        return false
    end
    if get(code, i).0 == 20:
        return true
    end
    return nc_code_has_call_loop(code, i + 1, n)
end

func nc_funcs_have_call_loop(funcs, i, n):
    if i >= n:
        return false
    end
    if nc_code_has_call_loop(get(funcs, i).4, 0, count(get(funcs, i).4)):
        return true
    end
    return nc_funcs_have_call_loop(funcs, i + 1, n)
end

func nc_funcs_have_call(funcs):
    return nc_funcs_have_call_loop(funcs, 0, count(funcs))
end

func nc_mod4096_loop(v):
    if v < 4096:
        return v
    end
    return nc_mod4096_loop(v - 4096)
end

func nc_roundup_page(v):
    let rem = nc_mod4096_loop(v)
    if rem == 0:
        return v
    end
    return v + 4096 - rem
end

