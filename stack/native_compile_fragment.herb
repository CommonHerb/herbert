end

-- Multiply: pop rhs->rcx (0x59), pop lhs->rax (0x58), imul rax,rcx
-- (48 0F AF C1), push rax (0x50). imul keeps the low 64 bits, which is the
-- u64 modular-wrap product (identical for signed/unsigned). 7 bytes; must equal
-- nc_group_single_len(42).
func nc_emit_mul(buf):
    do append(buf, 89)
    do append(buf, 88)
    do append(buf, 72)
    do append(buf, 15)
    do append(buf, 175)
    do append(buf, 193)
    do append(buf, 80)
    return buf
end

-- Divide / modulo. pop rhs(divisor)->rcx (0x59), pop lhs(dividend)->rax (0x58).
-- Guard divide-by-zero BEFORE `div`: test rcx,rcx (48 85 C9); jz exit1
-- (0F 84 rel32) routes to the shared clean fault-exit (exit 1, empty stdout) --
-- exit-status parity with the C oracle's `herbert: line N: division by zero`.
-- (Exact-stderr text is deferred per the D13 fault-parity convention; the C
-- side keeps the located message, the native side matches exit status + empty
-- stdout. Reusing the located-diagnostic helper would be a much larger addition
-- -- a new ro-data fragment + diag handler -- so exit-status parity is used.)
-- Then xor rdx,rdx (48 31 D2) zero-extends the dividend, div rcx (48 F7 F1)
-- gives the unsigned 64-bit quotient in rax / remainder in rdx; push rax (0x50)
-- for `/`, push rdx (0x52) for `%`. 18 bytes; must equal
-- nc_group_single_len(43/44). The jz rel32 base is instr_off + 11 (the byte
-- after the rel32 field: 1+1+3 prefix + 2 jz opcode + 4 rel32).
func nc_emit_div_or_mod(buf, is_mod, exit_off, instr_off):
    do append(buf, 89)
    do append(buf, 88)
    do append(buf, 72)
    do append(buf, 133)
    do append(buf, 201)
    do append(buf, 15)
    do append(buf, 132)
    buf = nc_append_rel32(buf, exit_off, instr_off + 11)
    do append(buf, 72)
    do append(buf, 49)
    do append(buf, 210)
    do append(buf, 72)
    do append(buf, 247)
    do append(buf, 241)
    if is_mod != 0:
        do append(buf, 82)
    else:
        do append(buf, 80)
    end
    return buf
end

