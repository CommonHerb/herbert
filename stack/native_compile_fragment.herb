func nc_emit_br_and(buf, target, base):
    do append(buf, 72)
    do append(buf, 139)
    do append(buf, 4)
    do append(buf, 36)
    do append(buf, 72)
    do append(buf, 133)
    do append(buf, 192)
    do append(buf, 15)
    do append(buf, 132)
    buf = nc_append_rel32(buf, target, base)
    do append(buf, 72)
    do append(buf, 131)
    do append(buf, 196)
    do append(buf, 8)
    return buf
end

func nc_emit_br_or(buf, target, base):
    do append(buf, 72)
    do append(buf, 139)
    do append(buf, 4)
    do append(buf, 36)
    do append(buf, 72)
    do append(buf, 133)
