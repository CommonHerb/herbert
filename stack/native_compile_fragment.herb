func nc_emit_fault_helpers(buf, ro_base, helper_start):
    let write_off = helper_start + nc_fault_write_fd2_rel()
    let dec_off = helper_start + nc_fault_dec_fd2_rel()
    let exit_off = helper_start + nc_fault_exit1_rel()
    buf = nc_emit_diag_index(buf, ro_base, write_off, dec_off, exit_off)
    buf = nc_emit_diag_get(buf, ro_base, write_off, dec_off, exit_off)
    buf = nc_emit_diag_append(buf, ro_base, write_off, dec_off, exit_off)
    buf = nc_emit_write_fd2(buf)
    buf = nc_emit_dec_fd2(buf, write_off)
    return nc_emit_fault_exit1(buf)
end

func nc_emit_rdi_store_rax(buf, mag):
    do append(buf, 72)
    do append(buf, 137)
    if mag == 0:
        do append(buf, 7)
        return buf
    end
    if mag <= 127:
        do append(buf, 71)
        do append(buf, mag)
        return buf
    end
    do append(buf, 135)
    return nc_append_le32(buf, mag)
end

func nc_emit_arg_copies_loop(buf, k, nwords):
    if k >= nwords:
        return buf
    end
    let src_mag = 16 + nc_mul8(nwords - 1 - k)
    let dst_mag = nc_local_mag(k)
    buf = nc_emit_disp_rbp_load_rax(buf, 0, src_mag)
    buf = nc_emit_disp_rbp_store_rax(buf, 1, dst_mag)
    return nc_emit_arg_copies_loop(buf, k + 1, nwords)
end

func nc_emit_sret_save(buf, meta):
    if meta.6 == 0 - 1:
