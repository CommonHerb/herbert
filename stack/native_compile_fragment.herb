    end
    return nc_get_loads_len(width, j + 1, acc + nc_disp_len_rsi(nc_mul8(j)) + 1)
end

func nc_get_len(width):
    if width == 1:
        return 32
    end
    return 51 + nc_get_loads_len(width, 0, 0)
end

func nc_arr_add_store_len(width, k, acc):
    if k == 0 - 1:
