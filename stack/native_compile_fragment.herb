func nc_code_has_call_loop(code, i, n):
    if i >= n:
        return false
    end
    if get(code, i).0 == 20:
        return true
    end
    return nc_code_has_call_loop(code, i + 1, n)
end

func nc_funcs_have_call_loop(funcs, i, n):
    if i >= n:
        return false
    end
    if nc_code_has_call_loop(get(funcs, i).4, 0, count(get(funcs, i).4)):
        return true
    end
    return nc_funcs_have_call_loop(funcs, i + 1, n)
end

func nc_funcs_have_call(funcs):
    return nc_funcs_have_call_loop(funcs, 0, count(funcs))
end

func nc_mod4096_loop(v):
    if v < 4096:
        return v
    end
    return nc_mod4096_loop(v - 4096)
end

func nc_roundup_page(v):
    let rem = nc_mod4096_loop(v)
    if rem == 0:
        return v
    end
    return v + 4096 - rem
end

func nc_emit_disp_rbp_load_rax(buf, neg, mag):
    do append(buf, 72)
    do append(buf, 139)
    if nc_signed_fits8(neg, mag):
        do append(buf, 69)
        return nc_append_s8(buf, neg, mag)
    end
    do append(buf, 133)
    return nc_append_s32(buf, neg, mag)
end

func nc_emit_disp_rbp_store_rax(buf, neg, mag):
    do append(buf, 72)
    do append(buf, 137)
    if nc_signed_fits8(neg, mag):
        do append(buf, 69)
        return nc_append_s8(buf, neg, mag)
    end
    do append(buf, 133)
    return nc_append_s32(buf, neg, mag)
end

func nc_emit_disp_rbp_read_byte(buf, neg, mag):
    do append(buf, 72)
    do append(buf, 15)
    do append(buf, 182)
    if nc_signed_fits8(neg, mag):
        do append(buf, 69)
        return nc_append_s8(buf, neg, mag)
    end
    do append(buf, 133)
    return nc_append_s32(buf, neg, mag)
end

func nc_emit_disp_rbp_lea_rsi(buf, neg, mag):
    do append(buf, 72)
    do append(buf, 141)
    if nc_signed_fits8(neg, mag):
        do append(buf, 117)
        return nc_append_s8(buf, neg, mag)
    end
    do append(buf, 181)
    return nc_append_s32(buf, neg, mag)
