    do append(buf, 8)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 15)
    do append(buf, 5)
    do append(buf, 184)
    do append(buf, 231)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 0)
    do append(buf, 49)
    do append(buf, 255)
    do append(buf, 15)
    do append(buf, 5)
    return buf
end

func nc_lower_loop(fn, funcs, layout, layouts, i, n, buf):
    if i >= n:
        return buf
    end
    let code = fn.4
    let instr = get(code, i)
    let op = instr.0
    let a = instr.1
    let hfound = layout.3
    let hslot = layout.4
    let scratch_sz = layout.5
    let g = nc_group(code, i, n, fn, funcs, hfound, hslot, scratch_sz)
    if op == 33:
        return nc_lower_loop(fn, funcs, layout, layouts, g.1, n, buf)
    end
    if op == 3 and hfound != 0 and a == hslot:
        buf = nc_emit_read_byte(buf, fn, scratch_sz, get(code, i + 1).1)
        return nc_lower_loop(fn, funcs, layout, layouts, g.1, n, buf)
    end
    if op == 0:
        buf = nc_emit_push_int(buf, a)
    elif op == 1:
        buf = nc_emit_push_bool(buf, a)
    elif op == 3:
        buf = nc_emit_load_local(buf, a)
    elif op == 4:
        buf = nc_emit_store_local(buf, a)
    elif op == 5:
        buf = nc_emit_add(buf)
    elif op == 6:
        buf = nc_emit_sub(buf)
    elif op == 7:
        buf = nc_emit_cmp_setcc(buf, 146)
    elif op == 8:
        buf = nc_emit_cmp_setcc(buf, 150)
    elif op == 9:
        buf = nc_emit_cmp_setcc(buf, 151)
    elif op == 10:
        buf = nc_emit_cmp_setcc(buf, 147)
    elif op == 11:
        buf = nc_emit_cmp_setcc(buf, 148)
    elif op == 12:
        buf = nc_emit_cmp_setcc(buf, 149)
    elif op == 13:
        buf = nc_emit_not(buf)
    elif op == 16:
        buf = nc_emit_br(buf, layout.0 + get(layout.1, a), layout.0 + get(layout.1, i) + 5)
    elif op == 17:
        buf = nc_emit_br_if_false(buf, layout.0 + get(layout.1, a), layout.0 + get(layout.1, i) + 10)
    elif op == 18:
        buf = nc_emit_br_and(buf, layout.0 + get(layout.1, a), layout.0 + get(layout.1, i) + 13)
    elif op == 19:
        buf = nc_emit_br_or(buf, layout.0 + get(layout.1, a), layout.0 + get(layout.1, i) + 13)
    elif op == 20:
        let callee_layout = get(layouts, instr.1)
        if nc_is_tail_call(code, i, n):
            buf = nc_emit_tail_call(buf, callee_layout.0, layout.0 + get(layout.1, i) + g.0, fn.2, instr.2)
        else:
            buf = nc_emit_call(buf, callee_layout.0, layout.0 + get(layout.1, i) + 5, instr.2)
        end
    elif op == 21:
        buf = nc_emit_ret(buf)
    end
    return nc_lower_loop(fn, funcs, layout, layouts, g.1, n, buf)
end

func nc_emit_function(buf, fn, funcs, layout, layouts):
    let start_len = length(freeze(buf))
    buf = nc_emit_prologue(buf, layout.6)
    buf = nc_emit_arg_copies_loop(buf, 0, fn.2)
    if layout.3 != 0:
        buf = nc_emit_read(buf, fn.3, layout.5)
    end
    let after_prefix = length(freeze(buf)) - start_len
    if after_prefix != layout.7:
        return (nc_fail(418, 0, "prefix"), buf)
    end
    buf = nc_lower_loop(fn, funcs, layout, layouts, 0, count(fn.4), buf)
    let len = length(freeze(buf)) - start_len
    if len != layout.8:
        return (nc_fail(418, 0, "length"), buf)
    end
    return (0, buf)
end

func nc_emit_functions_loop(buf, funcs, layouts, i, n):
    if i >= n:
        return (0, buf)
    end
    let r = nc_emit_function(buf, get(funcs, i), funcs, get(layouts, i), layouts)
    if r.0 != 0:
        return r
    end
    return nc_emit_functions_loop(r.1, funcs, layouts, i + 1, n)
end

func nc_emit_zeroes_loop(buf, n):
    if n <= 0:
        return buf
    end
    do append(buf, 0)
    return nc_emit_zeroes_loop(buf, n - 1)
end

func main():
    let source = clogger()
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let ast_result = nc_verify_ast(nodes, parsed.0)
    if ast_result != 0:
        return 0
    end
    let prog = lower_program(nodes, parsed.0)
    let bc_result = nc_verify_bytecode(prog)
    if bc_result != 0:
        return 0
    end
    let pass1 = nc_pass1_program(prog)
    if pass1.0 != 0:
        return 0
    end
    let funcs = prog.0
    let layouts = pass1.1
    let main_layout = get(layouts, prog.2)
    let cbuf = new_buffer()
    cbuf = nc_emit_entry_stub(cbuf, main_layout.0)
    let emitted = nc_emit_functions_loop(cbuf, funcs, layouts, 0, count(funcs))
    if emitted.0 != 0:
        return 0
    end
    let frozen_code = freeze(emitted.1)
    let code_len = length(frozen_code)
    if code_len != pass1.2:
        let fail = nc_fail(418, 0, "program-length")
        return 0
    end
    let img = nc_roundup_page(120 + code_len)
    let pad = img - 120 - code_len
    let align_hi = 0
    if not nc_funcs_have_call(funcs):
        align_hi = 129
    end
    let buf = new_buffer()
    buf = nc_emit_ehdr(buf)
    buf = nc_emit_phdr(buf, img, align_hi)
    buf = append_str(buf, frozen_code)
    buf = nc_emit_zeroes_loop(buf, pad)
    do flogger(freeze(buf))
    return 0
end
