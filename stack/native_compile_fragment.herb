func nc_emit_cleanup(buf, words):
    let cleanup = nc_mul8(words)
    if cleanup <= 127:
        do append(buf, 72)
        do append(buf, 131)
        do append(buf, 196)
        do append(buf, cleanup)
    else:
        do append(buf, 72)
        do append(buf, 129)
        do append(buf, 196)
        buf = nc_append_le32(buf, cleanup)
    end
    return buf
end

func nc_emit_call_rel(buf, target, base):
    do append(buf, 232)
    return nc_append_rel32(buf, target, base)
end

func nc_emit_call_ret_words(buf, base_word, ret_width, k, n):
    if k >= n:
        return buf
    end
    buf = nc_emit_disp_rbp_load_rax(buf, 1, nc_sret_scratch_mag(base_word, ret_width, k))
    do append(buf, 80)
    return nc_emit_call_ret_words(buf, base_word, ret_width, k + 1, n)
end

func nc_emit_normal_call(buf, target, base, meta, cm):
    if cm.2 == 1:
        buf = nc_emit_disp_rbp_lea_rdi(buf, 1, nc_sret_scratch_mag(meta.7, cm.1, 0))
        buf = nc_emit_call_rel(buf, target, base)
        buf = nc_emit_cleanup(buf, cm.0)
        return nc_emit_call_ret_words(buf, meta.7, cm.1, 0, cm.1)
    end
    buf = nc_emit_call_rel(buf, target, base)
    buf = nc_emit_cleanup(buf, cm.0)
    do append(buf, 80)
    return buf
end

func nc_emit_tail_copy_loop(buf, k, nf, ng):
    if k >= nf:
        return buf
    end
    let src = nc_mul8(nf - 1 - k)
    let dst = nc_tail_dst_pair(ng, k)
    buf = nc_emit_rsp_load_rax(buf, src)
    buf = nc_emit_disp_rbp_store_rax(buf, dst.0, dst.1)
    return nc_emit_tail_copy_loop(buf, k + 1, nf, ng)
end

func nc_emit_tail_call(buf, target, base, ng, nf, sret_word, aggregate):
    do append(buf, 76)
    do append(buf, 139)
    do append(buf, 93)
    do append(buf, 8)
    do append(buf, 76)
    do append(buf, 139)
    do append(buf, 85)
    do append(buf, 0)
    buf = nc_emit_tail_copy_loop(buf, 0, nf, ng)
    let rslot = nc_rslot_pair(ng, nf)
    buf = nc_emit_disp_rbp_store_r11(buf, rslot.0, rslot.1)
    if aggregate != 0:
        buf = nc_emit_disp_rbp_load_rdi(buf, 1, nc_local_mag(sret_word))
    end
    buf = nc_emit_disp_rbp_lea_rsp(buf, rslot.0, rslot.1)
    do append(buf, 76)
    do append(buf, 137)
    do append(buf, 213)
    do append(buf, 233)
    return nc_append_rel32(buf, target, base)
end

func nc_emit_tuple_get_copy_loop(buf, j, f, w, s):
    if j >= f:
        return buf
    end
    let src = nc_mul8(w - 1 - (s + j))
    let dst = nc_mul8(w - 1 - j)
    buf = nc_emit_rsp_load_rax(buf, src)
    buf = nc_emit_rsp_store_rax(buf, dst)
    return nc_emit_tuple_get_copy_loop(buf, j + 1, f, w, s)
end

func nc_emit_tuple_get(buf, meta, pc):
    let tm = get(meta.10, pc)
    buf = nc_emit_tuple_get_copy_loop(buf, 0, tm.2, tm.0, tm.1)
    let drop = tm.0 - tm.2
    if drop > 0:
        buf = nc_emit_cleanup(buf, drop)
    end
    return buf
end

func nc_emit_ret(buf, meta):
    if meta.2 <= 1:
        do append(buf, 88)
        do append(buf, 201)
        do append(buf, 195)
        return buf
    end
    buf = nc_emit_disp_rbp_load_rdi(buf, 1, nc_local_mag(meta.6))
    buf = nc_emit_aggregate_ret_stores(buf, meta.2 - 1)
    do append(buf, 201)
    do append(buf, 195)
    return buf
end

func nc_emit_aggregate_ret_stores(buf, k):
    if k == 0 - 1:
        return buf
    end
    do append(buf, 88)
    buf = nc_emit_rdi_store_rax(buf, nc_mul8(k))
    return nc_emit_aggregate_ret_stores(buf, k - 1)
end

func nc_emit_clogger(buf):
    do append(buf, 77)
    do append(buf, 137)
    do append(buf, 244)
    do append(buf, 77)
