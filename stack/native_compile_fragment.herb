-- Herbert diagnostics fragment. This is the error fragment with source
-- locations threaded through lexing, parsing, AST construction, and static
-- checking. It reads a Herbert program from stdin, emits a located diagnostic
-- for malformed input, and otherwise compiles and runs the program through
-- the same lowerer/VM path as the error fragment.
--
-- AST representation. Each node is a tuple (tag, atoms, kids, line) where:
--   - tag    : string — the S-expression head (e.g. "program", "add",
--                       "name", "if", "clause", "type-tuple", "dot")
--   - atoms  : array(string) — verbatim atoms following the tag (names,
--                       decimal integers for int/char/str payloads,
--                       "true"/"false", type words)
--   - kids   : array(int) — indices of child nodes in the shared pool
-- The pool is an array((string, array(string), array(int), int)). Children
-- are referenced by integer index into the pool — Herbert types are
-- finite (no recursive type aliases), so a node cannot directly contain
-- an array of nodes; an index-into-the-pool encoding is the standard
-- arena representation and lets a tuple-and-array AST hold the tree.
-- Counts (`count(pool)`, indices into arrays) are always non-negative,
-- so the parser never produces a negative intermediate value.
--
-- Parser structure. Each parse routine takes (tokens, pos, pool) and
-- returns (node_idx, new_pos). For list-collecting helpers (params,
-- args, statements) the caller passes the destination array and the
-- helper returns just the new position. Keyword classification is
-- positional: the lexer never tags keywords — an IDENTIFIER token's
-- text is inspected by the parser at the point where the grammar
-- decides whether `let`/`if`/`and`/`int`/... starts a production or
-- names a value. The full set of decision points is small and local
-- to each routine.
--
-- Serializer. `ser` walks the pool and appends bytes to a shared
-- buffer (the buffer is mutated by reference; the caller threads its
-- handle through assignment). One special case: a `dot` node emits
-- kids before atoms (the spec writes `(dot EXPR N)`); every other
-- node emits atoms before kids.

-- ====================================================================
-- LEXER FUNCTIONS (verbatim from stack/lexer_fragment.herb)
-- ====================================================================

func is_digit(c):
    return c >= '0' and c <= '9'
end

func is_lower(c):
    return c >= 'a' and c <= 'z'
end

func is_upper(c):
    return c >= 'A' and c <= 'Z'
end

func is_alpha(c):
    return is_lower(c) or is_upper(c)
end

func is_ident_start(c):
    return is_alpha(c) or c == '_'
end

func is_ident_cont(c):
    return is_ident_start(c) or is_digit(c)
end

func is_ws(c):
    return c == ' ' or c == '\n' or c == 9 or c == 13
end

func is_two_byte_op_start(c):
    return c == '=' or c == '!' or c == '<' or c == '>'
end

-- `<<` and `>>` are two-byte operators (a doubled `<`/`>`). They must be lexed
-- before the single-byte `<`/`>` (longest match), so the scanner checks this
-- before is_one_byte_op below.
func is_shift_op_start(c):
    return c == '<' or c == '>'
end

func is_one_byte_op(c):
    return c == '=' or c == '+' or c == '-' or c == '*' or c == '/' or c == '%' or c == '<' or c == '>' or c == '&' or c == '|' or c == '^' or c == '~'
end

func end_of_ident(src, i, n):
    if i >= n:
        return i
    elif is_ident_cont(index(src, i)):
        return end_of_ident(src, i + 1, n)
    else:
        return i
    end
end

func end_of_int(src, i, n):
    if i >= n:
        return i
    elif is_digit(index(src, i)):
        return end_of_int(src, i + 1, n)
    else:
        return i
    end
end

func end_of_line(src, i, n):
    if i >= n:
        return i
    elif index(src, i) == '\n':
        return i
    else:
        return end_of_line(src, i + 1, n)
    end
end

func end_of_string(src, i, n):
    let c = index(src, i)
    if c == '"':
        return i + 1
    elif c == '\\':
        return end_of_string(src, i + 2, n)
    else:
        return end_of_string(src, i + 1, n)
    end
end

func end_of_char(src, i, n):
    if index(src, i) == '\\':
        return i + 3
    else:
        return i + 2
    end
end

func pour(src, from, to, b):
    if from >= to:
        return b
    else:
        do append(b, index(src, from))
        return pour(src, from + 1, to, b)
    end
end

func slice_text(src, from, to):
    return freeze(pour(src, from, to, new_buffer()))
end

func scan(src, i, n, line, out):
    if i >= n:
        return out
    end
    let c = index(src, i)
    if is_ws(c):
        if c == '\n':
            return scan(src, i + 1, n, line + 1, out)
        end
        return scan(src, i + 1, n, line, out)
    elif c == '-' and i + 1 < n and index(src, i + 1) == '-':
        return scan(src, end_of_line(src, i + 2, n), n, line, out)
    elif is_ident_start(c):
        let j = end_of_ident(src, i + 1, n)
        do add(out, (0, slice_text(src, i, j), line))
        return scan(src, j, n, line, out)
    elif is_digit(c):
        let j = end_of_int(src, i + 1, n)
        do add(out, (1, slice_text(src, i, j), line))
        return scan(src, j, n, line, out)
    elif c == '"':
        let j = end_of_string(src, i + 1, n)
        do add(out, (2, slice_text(src, i, j), line))
        return scan(src, j, n, line, out)
    elif c == '\'':
        let j = end_of_char(src, i + 1, n)
        do add(out, (3, slice_text(src, i, j), line))
        return scan(src, j, n, line, out)
    elif is_two_byte_op_start(c) and i + 1 < n and index(src, i + 1) == '=':
        do add(out, (5, slice_text(src, i, i + 2), line))
        return scan(src, i + 2, n, line, out)
    elif is_shift_op_start(c) and i + 1 < n and index(src, i + 1) == c:
        do add(out, (5, slice_text(src, i, i + 2), line))
        return scan(src, i + 2, n, line, out)
    elif is_one_byte_op(c):
        do add(out, (5, slice_text(src, i, i + 1), line))
        return scan(src, i + 1, n, line, out)
    else:
        do add(out, (4, slice_text(src, i, i + 1), line))
        return scan(src, i + 1, n, line, out)
    end
end

func lex_source(src):
    return scan(src, 0, length(src), 1, new_array((int, string, int)))
end

-- ====================================================================
-- DECIMAL CONVERSION (no */% in Herbert; build div10/mod10 by subtraction)
-- ====================================================================

func div10_acc(n, q):
    if n < 10:
        return q
    end
    return div10_acc(n - 10, q + 1)
end

func div10(n):
    return div10_acc(n, 0)
end

func mod10(n):
    if n < 10:
        return n
    end
    return mod10(n - 10)
end

-- Append decimal digits of n to buf, high-order first. Recursive on
-- div10(n); not a true tail call but the interpreter's heap-stack
-- model has no fixed depth ceiling.
func emit_decimal(buf, n):
    if n >= 10:
        buf = emit_decimal(buf, div10(n))
    end
    do append(buf, 48 + mod10(n))
    return buf
end

func int_to_str(n):
    return freeze(emit_decimal(new_buffer(), n))
end

-- ====================================================================
-- STRING / BUFFER HELPERS
-- ====================================================================

func append_str_loop(buf, s, i, n):
    if i >= n:
        return buf
    end
    do append(buf, index(s, i))
    return append_str_loop(buf, s, i + 1, n)
end

func append_str(buf, s):
    return append_str_loop(buf, s, 0, length(s))
end

-- ====================================================================
-- AST NODE POOL
-- ====================================================================

func pool_new():
    return new_array((string, array(string), array(int), int))
end

func add_node(pool, tag, atoms, kids, line):
    do add(pool, (tag, atoms, kids, line))
    return count(pool) - 1
end

func atoms0():
    return new_array(string)
end

func atoms1(s):
    let a = new_array(string)
    do add(a, s)
    return a
end

func kids0():
    return new_array(int)
end

func kids1(i):
    let a = new_array(int)
    do add(a, i)
    return a
end

func kids2(a, b):
    let r = new_array(int)
    do add(r, a)
    do add(r, b)
    return r
end

func make_binop(pool, tag, lidx, ridx, line):
    return add_node(pool, tag, atoms0(), kids2(lidx, ridx), line)
end

-- ====================================================================
-- CHAR / STRING LITERAL DECODING
-- ====================================================================

-- s is the raw lexed CHAR text, e.g. "'a'" or "'\\n'" — three or four
-- bytes including the surrounding single quotes. Returns the byte value.
func decode_char(s):
    let c1 = index(s, 1)
    if c1 == '\\':
        let c2 = index(s, 2)
        if c2 == 'n':
            return 10
        end
        if c2 == '\\':
            return 92
        end
        return 39
    end
    return c1
end

-- s is the raw lexed STRING text including the surrounding double quotes.
-- Walk s[1 .. length(s)-1) decoding \n \\ \" into a buffer; returns the
-- frozen byte string.
func decode_string_loop(s, i, end_i, buf):
    if i >= end_i:
        return buf
    end
    let c = index(s, i)
    if c == '\\':
        let c2 = index(s, i + 1)
        if c2 == 'n':
            do append(buf, 10)
            return decode_string_loop(s, i + 2, end_i, buf)
        end
        if c2 == '\\':
            do append(buf, 92)
            return decode_string_loop(s, i + 2, end_i, buf)
        end
        do append(buf, 34)
        return decode_string_loop(s, i + 2, end_i, buf)
    end
    do append(buf, c)
    return decode_string_loop(s, i + 1, end_i, buf)
end

func decode_string(s):
    return freeze(decode_string_loop(s, 1, length(s) - 1, new_buffer()))
end

-- Append decimal forms of each byte of `bytes` (a string) as a fresh
-- entry in the `atoms` array.
func collect_str_atoms(atoms, bytes, i, n):
    if i >= n:
        return atoms
    end
    do add(atoms, int_to_str(index(bytes, i)))
    return collect_str_atoms(atoms, bytes, i + 1, n)
end

-- ====================================================================
-- TOKEN INSPECTION
-- ====================================================================

func tok_is_ident_text(tokens, pos, text):
    if pos >= count(tokens):
        return false
    end
    let t = get(tokens, pos)
    return t.0 == 0 and equal(t.1, text)
end

func tok_is_punct_text(tokens, pos, text):
    if pos >= count(tokens):
        return false
    end
    let t = get(tokens, pos)
    return t.0 == 4 and equal(t.1, text)
end

func tok_is_op_text(tokens, pos, text):
    if pos >= count(tokens):
        return false
    end
    let t = get(tokens, pos)
    return t.0 == 5 and equal(t.1, text)
end

-- ====================================================================
-- TYPE EXPRESSIONS (only inside new_array(...))
-- ====================================================================

func parse_type(tokens, pos, pool):
    let t = get(tokens, pos)
    let ln = t.2
    if t.0 == 0:
        if equal(t.1, "array"):
            -- array ( TYPE )
            pos = pos + 2
            let r = parse_type(tokens, pos, pool)
            pos = r.1 + 1
            return (add_node(pool, "type-array", atoms0(), kids1(r.0), ln), pos)
        end
        return (add_node(pool, "type", atoms1(t.1), kids0(), ln), pos + 1)
    end
    -- LPAREN starts a tuple type
    pos = pos + 1
    let kids = new_array(int)
    let r = parse_type(tokens, pos, pool)
    do add(kids, r.0)
    pos = parse_type_tail(tokens, r.1, pool, kids)
    pos = pos + 1
    return (add_node(pool, "type-tuple", atoms0(), kids, ln), pos)
end

func parse_type_tail(tokens, pos, pool, kids):
    if tok_is_punct_text(tokens, pos, ","):
        let r = parse_type(tokens, pos + 1, pool)
        do add(kids, r.0)
        return parse_type_tail(tokens, r.1, pool, kids)
    end
    return pos
end

-- ====================================================================
-- EXPRESSIONS
-- ====================================================================

func parse_expr(tokens, pos, pool):
    return parse_bitwise(tokens, pos, pool)
end

-- Bitwise/shift level (settled precedence c). Sits above the classless ladder:
-- parse a classless expression; if a bitwise/shift operator follows, the left
-- operand must be a single parenthesised/atomic primary (not a bare classless
-- chain) and the whole chain must stay within one class. A mix plants an
-- `nc_class_mix` poison node that nc_verify_ast rejects with ERR 442. This makes
-- `a & b | c`, `a << 2 + 3`, `x & 1 == 0`, and `1 + 2 << 1` all reject while
-- their fully-parenthesised forms parse. The existing ladder is unchanged.

-- Plant the `nc_class_mix` poison node and STOP the parser cleanly. The node is
-- added to the pool (so the post-parse all-functions scan in nc_verify_ast finds
-- it and rejects with ERR 442, regardless of reachability), and the returned
-- position is end-of-input so the enclosing body/func/program parse terminates
-- immediately instead of misparsing the leftover tokens (which, in a function
-- followed by more `func`s, runs parse_atom off the token stream -> a `get: out
-- of range` crash). A class-mix is always a reject, so discarding any trailing
-- tokens is correct -- the program will be rejected whole.
func plant_class_mix(tokens, pool, line):
    return (add_node(pool, "nc_class_mix", atoms0(), kids0(), line), count(tokens))
end

func parse_bitwise(tokens, pos, pool):
    let start = pos
    let r = parse_or(tokens, pos, pool)
    let cls = 0
    if r.1 < count(tokens):
        cls = bit_class(get(tokens, r.1).1)
        if get(tokens, r.1).0 != 5:
            cls = 0
        end
    end
    if cls == 0:
        return r
    end
    -- A bitwise/shift op follows. Verify the left operand is a single primary by
    -- re-parsing one prefix-unary primary from `start`: if it ends where parse_or
    -- stopped, parse_or added nothing (the operand is parenthesised/atomic);
    -- otherwise parse_or consumed an unparenthesised classless op -> mix.
    let primary = parse_not(tokens, start, pool)
    if primary.1 != r.1:
        return plant_class_mix(tokens, pool, get(tokens, r.1).2)
    end
    return parse_bitwise_loop(tokens, r.1, pool, r.0, cls)
end

func parse_bitwise_loop(tokens, pos, pool, lidx, cls):
    let oc = bin_op_class(tokens, pos)
    if oc == 0:
        -- End of the expression (`)`, `,`, `:`, `.`, `end`, EOF, ...).
        return (lidx, pos)
    end
    if oc == 5:
        -- A classless binary op after a committed bitwise chain: mix.
        return plant_class_mix(tokens, pool, get(tokens, pos).2)
    end
    if oc != cls:
        -- A different bitwise class without parentheses: mix.
        return plant_class_mix(tokens, pool, get(tokens, pos).2)
    end
    let op_tok = get(tokens, pos)
    let r = parse_not(tokens, pos + 1, pool)
    return parse_bitwise_loop(tokens, r.1, pool, make_binop(pool, bit_tag(op_tok.1), lidx, r.0, op_tok.2), cls)
end

func parse_or(tokens, pos, pool):
    let r = parse_and(tokens, pos, pool)
    return parse_or_loop(tokens, r.1, pool, r.0)
end

func parse_or_loop(tokens, pos, pool, lidx):
    if tok_is_ident_text(tokens, pos, "or"):
        let op_tok = get(tokens, pos)
        let r = parse_and(tokens, pos + 1, pool)
        return parse_or_loop(tokens, r.1, pool, make_binop(pool, "or", lidx, r.0, op_tok.2))
    end
    return (lidx, pos)
end

func parse_and(tokens, pos, pool):
    let r = parse_cmp(tokens, pos, pool)
    return parse_and_loop(tokens, r.1, pool, r.0)
end

func parse_and_loop(tokens, pos, pool, lidx):
    if tok_is_ident_text(tokens, pos, "and"):
        let op_tok = get(tokens, pos)
        let r = parse_cmp(tokens, pos + 1, pool)
        return parse_and_loop(tokens, r.1, pool, make_binop(pool, "and", lidx, r.0, op_tok.2))
    end
    return (lidx, pos)
end

func cmp_tag(text):
    if equal(text, "=="):
        return "eq"
    end
    if equal(text, "!="):
        return "ne"
    end
    if equal(text, "<"):
        return "lt"
    end
    if equal(text, ">"):
        return "gt"
    end
    if equal(text, "<="):
        return "le"
    end
    if equal(text, ">="):
        return "ge"
    end
    return ""
end

func parse_cmp(tokens, pos, pool):
    let r = parse_add(tokens, pos, pool)
    return parse_cmp_loop(tokens, r.1, pool, r.0)
end

func parse_cmp_loop(tokens, pos, pool, lidx):
    if pos >= count(tokens):
        return (lidx, pos)
    end
    let t = get(tokens, pos)
    if t.0 == 5:
        let tag = cmp_tag(t.1)
        if not equal(tag, ""):
            let r = parse_add(tokens, pos + 1, pool)
            return parse_cmp_loop(tokens, r.1, pool, make_binop(pool, tag, lidx, r.0, t.2))
        end
    end
    return (lidx, pos)
end

func add_tag(text):
    if equal(text, "+"):
        return "add"
    end
    if equal(text, "-"):
        return "sub"
    end
    return ""
end

-- Multiplicative operator -> AST tag. `*` `/` `%` bind tighter than `+ -`. They
-- are ordinary arithmetic (same operator class as add/sub), so no class-mix
-- poison applies to them; they just join the arithmetic ladder a tier tighter.
func mul_tag(text):
    if equal(text, "*"):
        return "mul"
    end
    if equal(text, "/"):
        return "div"
    end
    if equal(text, "%"):
        return "mod"
    end
    return ""
end

-- The bitwise/shift operators split into mutually-exclusive classes:
-- 1 = AND (&), 2 = OR (|), 3 = XOR (^), 4 = SHIFT (<< >>). 0 = not a
-- bitwise/shift op. Mirrors the C bootstrap's bit_class. Same-class chaining is
-- allowed and left-associative; mixing classes (or mixing with the classless
-- ladder) without parentheses is a parse-time reject (settled precedence c).
func bit_class(text):
    if equal(text, "&"):
        return 1
    end
    if equal(text, "|"):
        return 2
    end
    if equal(text, "^"):
        return 3
    end
    if equal(text, "<<"):
        return 4
    end
    if equal(text, ">>"):
        return 4
    end
    return 0
end

-- AST tag for a bitwise/shift operator token (only called when bit_class != 0).
func bit_tag(text):
    if equal(text, "&"):
        return "band"
    end
    if equal(text, "|"):
        return "bor"
    end
    if equal(text, "^"):
        return "bxor"
    end
    if equal(text, "<<"):
        return "shl"
    end
    return "shr"
end

-- Class id of the binary operator token at `pos` (kind-5 op or `and`/`or`
-- ident), for the require-parens mix check. Returns:
--   0  not a binary operator (ends the expression: ) , : . end EOF etc.)
--   1..4  a bitwise/shift class (see bit_class)
--   5  a classless binary op (+ - cmp and or) -- mixing one of these with a
--      committed bitwise chain (without parens) is a reject.
func bin_op_class(tokens, pos):
    if pos >= count(tokens):
        return 0
    end
    let t = get(tokens, pos)
    if t.0 == 0:
        if equal(t.1, "and") or equal(t.1, "or"):
            return 5
        end
        return 0
    end
    if t.0 != 5:
        return 0
    end
    let bc = bit_class(t.1)
    if bc != 0:
        return bc
    end
    if not equal(add_tag(t.1), ""):
        return 5
    end
    if not equal(mul_tag(t.1), ""):
        return 5
    end
    if not equal(cmp_tag(t.1), ""):
        return 5
    end
    return 0
end

func parse_add(tokens, pos, pool):
    let r = parse_mul(tokens, pos, pool)
    return parse_add_loop(tokens, r.1, pool, r.0)
end

func parse_add_loop(tokens, pos, pool, lidx):
    if pos >= count(tokens):
        return (lidx, pos)
    end
    let t = get(tokens, pos)
    if t.0 == 5:
        let tag = add_tag(t.1)
        if not equal(tag, ""):
            let r = parse_mul(tokens, pos + 1, pool)
            return parse_add_loop(tokens, r.1, pool, make_binop(pool, tag, lidx, r.0, t.2))
        end
    end
    return (lidx, pos)
end

-- Multiplicative tier (`*` `/` `%`): one precedence level tighter than additive
-- `+ -`, looser than the prefix-unary level (parse_not). Left-associative.
-- Mirrors parse_add, calling parse_not for its operands.
func parse_mul(tokens, pos, pool):
    let r = parse_not(tokens, pos, pool)
    return parse_mul_loop(tokens, r.1, pool, r.0)
end

func parse_mul_loop(tokens, pos, pool, lidx):
    if pos >= count(tokens):
        return (lidx, pos)
    end
    let t = get(tokens, pos)
    if t.0 == 5:
        let tag = mul_tag(t.1)
        if not equal(tag, ""):
            let r = parse_not(tokens, pos + 1, pool)
            return parse_mul_loop(tokens, r.1, pool, make_binop(pool, tag, lidx, r.0, t.2))
        end
    end
    return (lidx, pos)
end

func parse_not(tokens, pos, pool):
    if tok_is_ident_text(tokens, pos, "not"):
        let t = get(tokens, pos)
        let r = parse_not(tokens, pos + 1, pool)
        return (add_node(pool, "not", atoms0(), kids1(r.0), t.2), r.1)
    end
    -- `~` is the bitwise one's-complement unary: a distinct AST kind ("bnot")
    -- from boolean `not`, with an int (not bool) type rule, at the same prefix
    -- precedence level.
    if tok_is_op_text(tokens, pos, "~"):
        let t = get(tokens, pos)
        let r = parse_not(tokens, pos + 1, pool)
        return (add_node(pool, "bnot", atoms0(), kids1(r.0), t.2), r.1)
    end
    return parse_dot(tokens, pos, pool)
end

func parse_dot(tokens, pos, pool):
    let r = parse_atom(tokens, pos, pool)
    return parse_dot_loop(tokens, r.1, pool, r.0)
end

func parse_dot_loop(tokens, pos, pool, lidx):
    if tok_is_punct_text(tokens, pos, "."):
        let dot_tok = get(tokens, pos)
        let idx_tok = get(tokens, pos + 1)
        let new_idx = add_node(pool, "dot", atoms1(idx_tok.1), kids1(lidx), dot_tok.2)
        return parse_dot_loop(tokens, pos + 2, pool, new_idx)
    end
    return (lidx, pos)
end

func parse_atom(tokens, pos, pool):
    let t = get(tokens, pos)
    let k = t.0
    let s = t.1
    let ln = t.2
    if k == 1:
        return (add_node(pool, "int", atoms1(s), kids0(), ln), pos + 1)
    end
    if k == 3:
        return (add_node(pool, "char", atoms1(int_to_str(decode_char(s))), kids0(), ln), pos + 1)
    end
    if k == 2:
        let frozen = decode_string(s)
        let n = length(frozen)
        let atoms = atoms1(int_to_str(n))
        atoms = collect_str_atoms(atoms, frozen, 0, n)
        return (add_node(pool, "str", atoms, kids0(), ln), pos + 1)
    end
    if k == 0:
        if equal(s, "true"):
            return (add_node(pool, "bool", atoms1("true"), kids0(), ln), pos + 1)
        end
        if equal(s, "false"):
            return (add_node(pool, "bool", atoms1("false"), kids0(), ln), pos + 1)
        end
        if tok_is_punct_text(tokens, pos + 1, "("):
            return parse_call(tokens, pos, pool)
        end
        return (add_node(pool, "name", atoms1(s), kids0(), ln), pos + 1)
    end
    -- LPAREN: grouping or tuple
    return parse_group_or_tuple(tokens, pos + 1, pool, ln)
end

func parse_call(tokens, pos, pool):
    let name_tok = get(tokens, pos)
    let name = name_tok.1
    let ln = name_tok.2
    pos = pos + 2
    if equal(name, "new_array"):
        let r = parse_type(tokens, pos, pool)
        pos = r.1 + 1
        return (add_node(pool, "call", atoms1(name), kids1(r.0), ln), pos)
    end
    let kids = new_array(int)
    if tok_is_punct_text(tokens, pos, ")"):
        return (add_node(pool, "call", atoms1(name), kids, ln), pos + 1)
    end
    pos = parse_args_loop(tokens, pos, pool, kids)
    pos = pos + 1
    return (add_node(pool, "call", atoms1(name), kids, ln), pos)
end

func parse_args_loop(tokens, pos, pool, kids):
    let r = parse_expr(tokens, pos, pool)
    do add(kids, r.0)
    if tok_is_punct_text(tokens, r.1, ","):
        return parse_args_loop(tokens, r.1 + 1, pool, kids)
    end
    return r.1
end

func parse_group_or_tuple(tokens, pos, pool, line):
    let r = parse_expr(tokens, pos, pool)
    let first_idx = r.0
    pos = r.1
    if tok_is_punct_text(tokens, pos, ","):
        let kids = new_array(int)
        do add(kids, first_idx)
        pos = parse_tuple_tail(tokens, pos + 1, pool, kids)
        pos = pos + 1
        return (add_node(pool, "tuple", atoms0(), kids, line), pos)
    end
    pos = pos + 1
    return (first_idx, pos)
end

func parse_tuple_tail(tokens, pos, pool, kids):
    let r = parse_expr(tokens, pos, pool)
    do add(kids, r.0)
    if tok_is_punct_text(tokens, r.1, ","):
        return parse_tuple_tail(tokens, r.1 + 1, pool, kids)
    end
    return r.1
end

-- ====================================================================
-- STATEMENTS
-- ====================================================================

func is_body_terminator(tokens, pos):
    if pos >= count(tokens):
        return true
    end
    let t = get(tokens, pos)
    if t.0 != 0:
        return false
    end
    if equal(t.1, "end"):
        return true
    end
    if equal(t.1, "elif"):
        return true
    end
    if equal(t.1, "else"):
        return true
    end
    return false
end

func parse_body(tokens, pos, pool):
    let stmt_kids = new_array(int)
    pos = parse_body_loop(tokens, pos, pool, stmt_kids)
    let line = 0
    if pos < count(tokens):
        let t = get(tokens, pos)
        line = t.2
    end
    return (add_node(pool, "body", atoms0(), stmt_kids, line), pos)
end

func parse_body_loop(tokens, pos, pool, stmt_kids):
    if is_body_terminator(tokens, pos):
        return pos
    end
    let r = parse_stmt(tokens, pos, pool)
    do add(stmt_kids, r.0)
    return parse_body_loop(tokens, r.1, pool, stmt_kids)
end

func parse_stmt(tokens, pos, pool):
    let t = get(tokens, pos)
    -- t is IDENTIFIER per grammar
    let text = t.1
    let ln = t.2
    if equal(text, "let"):
        return parse_let(tokens, pos + 1, pool, ln)
    end
    if equal(text, "return"):
        return parse_return(tokens, pos + 1, pool, ln)
    end
    if equal(text, "do"):
        return parse_do(tokens, pos + 1, pool, ln)
    end
    if equal(text, "if"):
        return parse_if(tokens, pos + 1, pool, ln)
    end
    return parse_assign(tokens, pos, pool, ln)
end

func parse_let(tokens, pos, pool, line):
    let name_tok = get(tokens, pos)
    let name = name_tok.1
    let r = parse_expr(tokens, pos + 2, pool)
    return (add_node(pool, "let", atoms1(name), kids1(r.0), line), r.1)
end

func parse_return(tokens, pos, pool, line):
    let r = parse_expr(tokens, pos, pool)
    return (add_node(pool, "return", atoms0(), kids1(r.0), line), r.1)
end

func parse_do(tokens, pos, pool, line):
    let r = parse_expr(tokens, pos, pool)
    return (add_node(pool, "do", atoms0(), kids1(r.0), line), r.1)
end

func parse_assign(tokens, pos, pool, line):
    let name_tok = get(tokens, pos)
    let name = name_tok.1
    let r = parse_expr(tokens, pos + 2, pool)
    return (add_node(pool, "assign", atoms1(name), kids1(r.0), line), r.1)
end

func parse_if(tokens, pos, pool, line):
    let if_kids = new_array(int)
    pos = parse_clause_into(tokens, pos, pool, if_kids)
    pos = parse_elifs(tokens, pos, pool, if_kids)
    if tok_is_ident_text(tokens, pos, "else"):
        let r = parse_else_clause(tokens, pos + 1, pool)
        do add(if_kids, r.0)
        pos = r.1
    end
    -- consume "end"
    pos = pos + 1
    return (add_node(pool, "if", atoms0(), if_kids, line), pos)
end

func parse_elifs(tokens, pos, pool, if_kids):
    if tok_is_ident_text(tokens, pos, "elif"):
        pos = parse_clause_into(tokens, pos + 1, pool, if_kids)
        return parse_elifs(tokens, pos, pool, if_kids)
    end
    return pos
end

-- Safe token line lookup: the token's line, or 0 if pos is out of range. Used on
-- error-recovery paths where a class-mix has made parse_expr stop at end-of-input
-- (plant_class_mix), so `pos` can sit past the last token; a bare get(tokens, pos)
-- would then fault. The line is only cosmetic here (the program is rejected via
-- the nc_class_mix scan), so 0 is fine.
func tok_line_or0(tokens, pos):
    if pos >= count(tokens):
        return 0
    end
    return get(tokens, pos).2
end

func parse_clause_into(tokens, pos, pool, if_kids):
    let cr = parse_expr(tokens, pos, pool)
    pos = cr.1 + 1
    let br = parse_body(tokens, pos, pool)
    let cidx = add_node(pool, "clause", atoms0(), kids2(cr.0, br.0), tok_line_or0(tokens, pos))
    do add(if_kids, cidx)
    return br.1
end

func parse_else_clause(tokens, pos, pool):
    -- pos is just after 'else'; consume ':'
    let line = get(tokens, pos - 1).2
    pos = pos + 1
    let br = parse_body(tokens, pos, pool)
    return (add_node(pool, "else", atoms0(), kids1(br.0), line), br.1)
end

-- ====================================================================
-- FUNCTIONS / PROGRAM
-- ====================================================================

func parse_program(tokens, pos, pool):
    let kids = new_array(int)
    pos = parse_funcs(tokens, pos, pool, kids)
    let line = 0
    if count(tokens) > 0:
        line = get(tokens, 0).2
    end
    return (add_node(pool, "program", atoms0(), kids, line), pos)
end

func parse_funcs(tokens, pos, pool, kids):
    if pos >= count(tokens):
        return pos
    end
    let r = parse_funcdef(tokens, pos, pool)
    do add(kids, r.0)
    return parse_funcs(tokens, r.1, pool, kids)
end

func parse_funcdef(tokens, pos, pool):
    -- tokens[pos+0]: "func"; pos+1: name; pos+2: "("
    let line = get(tokens, pos).2
    let name_tok = get(tokens, pos + 1)
    let name = name_tok.1
    pos = pos + 3
    let pr = parse_param_list(tokens, pos, pool)
    pos = pr.1 + 2
    let br = parse_body(tokens, pos, pool)
    pos = br.1 + 1
    let kids = kids2(pr.0, br.0)
    return (add_node(pool, "func", atoms1(name), kids, line), pos)
end

func parse_param_list(tokens, pos, pool):
    let atoms = new_array(string)
    let line = get(tokens, pos).2
    if tok_is_punct_text(tokens, pos, ")"):
        return (add_node(pool, "params", atoms, kids0(), line), pos)
    end
    pos = parse_param_loop(tokens, pos, atoms)
    return (add_node(pool, "params", atoms, kids0(), line), pos)
end

func parse_param_loop(tokens, pos, atoms):
    let t = get(tokens, pos)
    do add(atoms, t.1)
    if tok_is_punct_text(tokens, pos + 1, ","):
        return parse_param_loop(tokens, pos + 2, atoms)
    end
    return pos + 1
end

-- ====================================================================
-- SERIALIZER
-- ====================================================================

func ser(buf, pool, idx):
    let node = get(pool, idx)
    let tag = node.0
    let atoms = node.1
    let kids = node.2
    do append(buf, '(')
    buf = append_str(buf, tag)
    if equal(tag, "dot"):
        buf = emit_kids(buf, pool, kids, 0, count(kids))
        buf = emit_atoms(buf, atoms, 0, count(atoms))
    else:
        buf = emit_atoms(buf, atoms, 0, count(atoms))
        buf = emit_kids(buf, pool, kids, 0, count(kids))
    end
    do append(buf, ')')
    return buf
end

func emit_atoms(buf, atoms, i, n):
    if i >= n:
        return buf
    end
    do append(buf, ' ')
    buf = append_str(buf, get(atoms, i))
    return emit_atoms(buf, atoms, i + 1, n)
end

func emit_kids(buf, pool, kids, i, n):
    if i >= n:
        return buf
    end
    do append(buf, ' ')
    buf = ser(buf, pool, get(kids, i))
    return emit_kids(buf, pool, kids, i + 1, n)
end

-- ====================================================================
-- EMITTER
-- ====================================================================

func fault(msg):
    let a = new_array((int, int))
    return get(a, 0)
end

func times10(n):
    return n + n + n + n + n + n + n + n + n + n
end

func parse_decimal_loop(s, i, n, acc):
    if i >= n:
        return acc
    end
    return parse_decimal_loop(s, i + 1, n, times10(acc) + index(s, i) - '0')
end

func parse_decimal(s):
    return parse_decimal_loop(s, 0, length(s), 0)
end

-- ====================================================================
-- BUNDLE DEMUX (virtual-stdin source channel)
-- A bundle on stdin is, positionally:
--   0x00 'H' 'E' 'R' 'B' '1'  <ASCII decimal D>  0x0A  <D source bytes>  <runtime_input to EOF>
--   \________ 6-byte MAGIC ________/  \ len(src) /  \LF/
-- The leading NUL makes the 6-byte magic collision-proof (NUL never
-- appears in valid Herbert source). The split is positional: once D is
-- parsed, source = stdin[src_start, src_start+D), runtime_input =
-- stdin[src_start+D, EOF). Bodies are never scanned. No magic, or any
-- malformed header, falls back to (stdin, "") = today's behavior.
-- ====================================================================

func bundle_has_magic(s):
    if length(s) < 6:
        return false
    end
    if index(s, 0) != 0:
        return false
    end
    if index(s, 1) != 'H':
        return false
    end
    if index(s, 2) != 'E':
        return false
    end
    if index(s, 3) != 'R':
        return false
    end
    if index(s, 4) != 'B':
        return false
    end
    if index(s, 5) != '1':
        return false
    end
    return true
end

-- Scan the decimal length field starting at offset 6. Walk forward over
-- ASCII digits; the field ends at the first 0x0A. Returns the index of
-- that 0x0A, or n if a non-digit non-LF byte appears or EOF is reached
-- first (malformed header).
func bundle_scan_lf(s, i, n):
    if i >= n:
        return n
    end
    let c = index(s, i)
    if c == '\n':
        return i
    end
    if is_digit(c):
        return bundle_scan_lf(s, i + 1, n)
    end
    return n
end

func bundle_parse_decimal_loop(s, i, n, acc, limit):
    if i >= n:
        return acc
    end
    if acc > limit:
        return limit + 1
    end
    let next = times10(acc) + index(s, i) - '0'
    if next > limit:
        return limit + 1
    end
    return bundle_parse_decimal_loop(s, i + 1, n, next, limit)
end

func bundle_parse_decimal(s, from, to, limit):
    return bundle_parse_decimal_loop(s, from, to, 0, limit)
end

func demux_bundle(stdin):
    if not bundle_has_magic(stdin):
        return (stdin, slice_text(stdin, 0, 0))
    end
    let n = length(stdin)
    let lf = bundle_scan_lf(stdin, 6, n)
    if lf >= n:
        return (stdin, slice_text(stdin, 0, 0))
    end
    if lf == 6:
        return (stdin, slice_text(stdin, 0, 0))
    end
    let d = bundle_parse_decimal(stdin, 6, lf, n)
    let src_start = lf + 1
    let src_end = src_start + d
    if src_end > n:
        return (stdin, slice_text(stdin, 0, 0))
    end
    let source = slice_text(stdin, src_start, src_end)
    let runtime_input = slice_text(stdin, src_end, n)
    return (source, runtime_input)
end

func op_push_int():
    return 0
end

func op_push_bool():
    return 1
end

func op_push_str():
    return 2
end

func op_load_local():
    return 3
end

func op_store_local():
    return 4
end

func op_add():
    return 5
end

func op_sub():
    return 6
end

func op_lt():
    return 7
end

func op_le():
    return 8
end

func op_gt():
    return 9
end

func op_ge():
    return 10
end

func op_eq():
    return 11
end

func op_ne():
    return 12
end

func op_not():
    return 13
end

func op_make_tuple():
    return 14
end

func op_tuple_get():
    return 15
end

func op_br():
    return 16
end

func op_br_if_false():
    return 17
end

func op_br_and():
    return 18
end

func op_br_or():
    return 19
end

func op_call():
    return 20
end

func op_ret():
    return 21
end

func op_length():
    return 22
end

func op_index():
    return 23
end

func op_slice():
    return 24
end

func op_equal():
    return 25
end

func op_new_buffer():
    return 26
end

func op_freeze():
    return 27
end

func op_new_array():
    return 28
end

func op_get():
    return 29
end

func op_count():
    return 30
end

func op_buf_append():
    return 31
end

func op_arr_add():
    return 32
end

func op_clogger():
    return 33
end

func op_flogger():
    return 34
end

func op_fwriter():
    return 35
end

-- Bitwise / shift opcodes. Appended at 36-41 (the dense 0-35 space is full and
-- the VM range-checks binops; never renumber an existing opcode). band/bor/bxor/
-- shl/shr are int x int -> int binops; bnot is the int -> int one's-complement
-- unary (a distinct opcode from boolean `not` at 13).
func op_band():
    return 36
end

func op_bor():
    return 37
end

func op_bxor():
    return 38
end

func op_shl():
    return 39
end

func op_shr():
    return 40
end

func op_bnot():
    return 41
end

-- Multiplicative opcodes. Appended at 42-44 after the current max (op_bnot=41);
-- NEVER renumber an existing opcode (the VM range-checks binops and pass-1 sizes
-- by op number). mul/div/mod are int x int -> int binops. div/mod also fault on a
-- zero divisor (a located runtime fault, exit-status parity with the C oracle),
-- so they are "faultable" (see nc_code_has_faultable_loop); mul never faults.
func op_mul():
    return 42
end

func op_div():
    return 43
end

func op_mod():
    return 44
end

-- trukfit (f3, device input): a 0-arg value builtin that reads ONE byte from the
-- COM1 RBR. Lowered ONLY by the multiboot32-input emit mode (nc32_lower_loop op 45);
-- it is deliberately absent from nc32_op_allowed/nc32_pops/nc32_pushes so every
-- OTHER mode and the near-axis path reject it (a body carrying op 45 fails the depth
-- gate / is rejected explicitly), keeping the device read isolated to the input mode.
func op_input_byte():
    return 45
end

func op_module_byte():
    return 46
end

func emit_instr(ir, op, a, b):
    do add(ir, (0, op, a, b, 0, "", 0))
    return ir
end

func emit_instr_line(ir, op, a, b, line):
    do add(ir, (0, op, a, b, 0, "", line))
    return ir
end

func emit_instr_meta(ir, op, a, b, meta):
    do add(ir, (0, op, a, b, meta, "", 0))
    return ir
end

func emit_target_instr(ir, op, label):
    do add(ir, (0, op, 0, 0, 0, label, 0))
    return ir
end

func emit_label(ir, label):
    do add(ir, (1, 0, 0, 0, 0, label, 0))
    return ir
end

func make_label(prefix, n):
    let buf = new_buffer()
    buf = append_str(buf, prefix)
    buf = append_str(buf, int_to_str(n))
    return freeze(buf)
end

func collect_labels_loop(ir, i, n, pc, labels):
    if i >= n:
        return labels
    end
    let item = get(ir, i)
    if item.0 == 1:
        do add(labels, (item.5, pc))
        return collect_labels_loop(ir, i + 1, n, pc, labels)
    end
    return collect_labels_loop(ir, i + 1, n, pc + 1, labels)
end

func collect_labels(ir):
    return collect_labels_loop(ir, 0, count(ir), 0, new_array((string, int)))
end

func find_label_pos_loop(labels, name, i, n):
    if i >= n:
        return fault("missing label")
    end
    let item = get(labels, i)
    if equal(item.0, name):
        return item.1
    end
    return find_label_pos_loop(labels, name, i + 1, n)
end

func find_label_pos(labels, name):
    return find_label_pos_loop(labels, name, 0, count(labels))
end

func resolve_ir_loop(ir, i, n, labels, out):
    if i >= n:
        return out
    end
    let item = get(ir, i)
    if item.0 == 1:
        return resolve_ir_loop(ir, i + 1, n, labels, out)
    end
    if equal(item.5, ""):
        do add(out, (item.1, item.2, item.3))
    else:
        do add(out, (item.1, find_label_pos(labels, item.5), item.3))
    end
    return resolve_ir_loop(ir, i + 1, n, labels, out)
end

func resolve_ir(ir):
    let labels = collect_labels(ir)
    return resolve_ir_loop(ir, 0, count(ir), labels, new_array((int, int, int)))
end

func resolve_new_array_meta_loop(ir, i, n, out):
    if i >= n:
        return out
    end
    let item = get(ir, i)
    if item.0 == 1:
        return resolve_new_array_meta_loop(ir, i + 1, n, out)
    end
    do add(out, item.4)
    return resolve_new_array_meta_loop(ir, i + 1, n, out)
end

func resolve_new_array_meta(ir):
    return resolve_new_array_meta_loop(ir, 0, count(ir), new_array(int))
end

func resolve_instr_lines_loop(ir, i, n, out):
    if i >= n:
        return out
    end
    let item = get(ir, i)
    if item.0 == 1:
        return resolve_instr_lines_loop(ir, i + 1, n, out)
    end
    do add(out, item.6)
    return resolve_instr_lines_loop(ir, i + 1, n, out)
end

func resolve_instr_lines(ir):
    return resolve_instr_lines_loop(ir, 0, count(ir), new_array(int))
end

func env_from_params_loop(params, i, n, names, slots):
    if i >= n:
        return (names, slots, n)
    end
    do add(names, get(params, i))
    do add(slots, i)
    return env_from_params_loop(params, i + 1, n, names, slots)
end

func env_from_params(params):
    return env_from_params_loop(params, 0, count(params), new_array(string), new_array(int))
end

func env_let(env, name):
    do add(env.0, name)
    do add(env.1, env.2)
    return (env.0, env.1, env.2 + 1)
end

func env_lookup_loop(names, slots, name, n):
    if n == 0:
        return fault("name undefined")
    end
    let k = n - 1
    if equal(get(names, k), name):
        return get(slots, k)
    end
    return env_lookup_loop(names, slots, name, k)
end

func env_lookup(env, name):
    return env_lookup_loop(env.0, env.1, name, count(env.0))
end

func env_rebuild_loop(env, i, keep, names, slots):
    if i >= keep:
        return (names, slots, env.2)
    end
    do add(names, get(env.0, i))
    do add(slots, get(env.1, i))
    return env_rebuild_loop(env, i + 1, keep, names, slots)
end

func env_rebuild(env, keep):
    return env_rebuild_loop(env, 0, keep, new_array(string), new_array(int))
end

func string_from_atoms_loop(atoms, i, n, buf):
    if i >= n:
        return buf
    end
    do append(buf, parse_decimal(get(atoms, i)))
    return string_from_atoms_loop(atoms, i + 1, n, buf)
end

func string_from_atoms(atoms):
    let n = parse_decimal(get(atoms, 0))
    if n + 1 != count(atoms):
        return fault("bad string node")
    end
    return freeze(string_from_atoms_loop(atoms, 1, count(atoms), new_buffer()))
end

func intern_string_loop(strings, s, i, n):
    if i >= n:
        do add(strings, s)
        return count(strings) - 1
    end
    if equal(get(strings, i), s):
        return i
    end
    return intern_string_loop(strings, s, i + 1, n)
end

func intern_string(strings, s):
    return intern_string_loop(strings, s, 0, count(strings))
end

func find_func_idx_loop(funcs, i, n, name, nodes):
    if i >= n:
        return fault("unknown function")
    end
    let fn = get(nodes, get(funcs, i))
    if equal(get(fn.1, 0), name):
        return i
    end
    return find_func_idx_loop(funcs, i + 1, n, name, nodes)
end

func find_func_idx(name, nodes, prog_idx):
    let prog = get(nodes, prog_idx)
    return find_func_idx_loop(prog.2, 0, count(prog.2), name, nodes)
end

func opcode_for_binop(tag):
    if equal(tag, "add"):
        return op_add()
    end
    if equal(tag, "sub"):
        return op_sub()
    end
    if equal(tag, "mul"):
        return op_mul()
    end
    if equal(tag, "div"):
        return op_div()
    end
    if equal(tag, "mod"):
        return op_mod()
    end
    if equal(tag, "eq"):
        return op_eq()
    end
    if equal(tag, "ne"):
        return op_ne()
    end
    if equal(tag, "lt"):
        return op_lt()
    end
    if equal(tag, "le"):
        return op_le()
    end
    if equal(tag, "gt"):
        return op_gt()
    end
    if equal(tag, "ge"):
        return op_ge()
    end
    if equal(tag, "band"):
        return op_band()
    end
    if equal(tag, "bor"):
        return op_bor()
    end
    if equal(tag, "bxor"):
        return op_bxor()
    end
    if equal(tag, "shl"):
        return op_shl()
    end
    return op_shr()
end

func emit_exprs(kids, i, n, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly):
    if i >= n:
        return ir
    end
    ir = emit_expr(get(kids, i), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
    return emit_exprs(kids, i + 1, n, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
end

func emit_call_expr(name, kids, call_node_idx, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly):
    let call_line = get(nodes, call_node_idx).3
    if equal(name, "new_array"):
        let elem = nc_type_from_type_expr(type_pool, nodes, get(kids, 0))
        if elem.0 != 0:
            return fault("bad new_array meta")
        end
        return emit_instr_meta(ir, op_new_array(), 0, 0, nc_type_intern_array(type_pool, elem.1))
    end
    ir = emit_exprs(kids, 0, count(kids), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
    if equal(name, "clogger"):
        return emit_instr(ir, op_clogger(), 0, 0)
    end
    if equal(name, "length"):
        return emit_instr(ir, op_length(), 0, 0)
    end
    if equal(name, "index"):
        return emit_instr_line(ir, op_index(), 0, 0, call_line)
    end
    if equal(name, "slice"):
        return emit_instr(ir, op_slice(), 0, 0)
    end
    if equal(name, "equal"):
        return emit_instr(ir, op_equal(), 0, 0)
    end
    if equal(name, "new_buffer"):
        return emit_instr(ir, op_new_buffer(), 0, 0)
    end
    if equal(name, "freeze"):
        return emit_instr(ir, op_freeze(), 0, 0)
    end
    if equal(name, "get"):
        return emit_instr_line(ir, op_get(), 0, 0, call_line)
    end
    if equal(name, "count"):
        return emit_instr(ir, op_count(), 0, 0)
    end
    if equal(name, "input_byte"):
        return emit_instr(ir, op_input_byte(), 0, 0)
    end
    if equal(name, "module_byte"):
        return emit_instr(ir, op_module_byte(), 0, 0)
    end
    if equal(name, "append") or equal(name, "add") or equal(name, "flogger"):
        return fault("void builtin in expression")
    end
    return emit_instr(ir, op_call(), nc_poly_lowered_call_target(poly, caller_inst_idx, call_node_idx), count(kids))
end

func emit_expr(node_idx, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly):
    let node = get(nodes, node_idx)
    let tag = node.0
    let atoms = node.1
    let kids = node.2
    if equal(tag, "int"):
        return emit_instr(ir, op_push_int(), parse_decimal(get(atoms, 0)), 0)
    end
    if equal(tag, "char"):
        return emit_instr(ir, op_push_int(), parse_decimal(get(atoms, 0)), 0)
    end
    if equal(tag, "str"):
        let s = string_from_atoms(atoms)
        return emit_instr(ir, op_push_str(), intern_string(strings, s), 0)
    end
    if equal(tag, "bool"):
        if equal(get(atoms, 0), "true"):
            return emit_instr(ir, op_push_bool(), 1, 0)
        end
        return emit_instr(ir, op_push_bool(), 0, 0)
    end
    if equal(tag, "name"):
        return emit_instr(ir, op_load_local(), env_lookup(env, get(atoms, 0)), 0)
    end
    if equal(tag, "and"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        let done = make_label("and", count(ir))
        ir = emit_target_instr(ir, op_br_and(), done)
        ir = emit_expr(get(kids, 1), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_label(ir, done)
    end
    if equal(tag, "or"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        let done = make_label("or", count(ir))
        ir = emit_target_instr(ir, op_br_or(), done)
        ir = emit_expr(get(kids, 1), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_label(ir, done)
    end
    if equal(tag, "not"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, op_not(), 0, 0)
    end
    if equal(tag, "bnot"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, op_bnot(), 0, 0)
    end
    if equal(tag, "add") or equal(tag, "sub") or equal(tag, "mul") or equal(tag, "div") or equal(tag, "mod") or equal(tag, "eq") or equal(tag, "ne") or equal(tag, "lt") or equal(tag, "le") or equal(tag, "gt") or equal(tag, "ge") or equal(tag, "band") or equal(tag, "bor") or equal(tag, "bxor") or equal(tag, "shl") or equal(tag, "shr"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        ir = emit_expr(get(kids, 1), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, opcode_for_binop(tag), 0, 0)
    end
    if equal(tag, "tuple"):
        ir = emit_exprs(kids, 0, count(kids), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, op_make_tuple(), count(kids), 0)
    end
    if equal(tag, "dot"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, op_tuple_get(), parse_decimal(get(atoms, 0)), 0)
    end
    if equal(tag, "call"):
        return emit_call_expr(get(atoms, 0), kids, node_idx, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
    end
    return fault("bad expression")
end

func body_ends_return(body_idx, nodes):
    let body = get(nodes, body_idx)
    let kids = body.2
    let n = count(kids)
    if n == 0:
        return false
    end
    let stmt = get(nodes, get(kids, n - 1))
    return equal(stmt.0, "return")
end

func emit_body(stmts, i, n, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly):
    if i >= n:
        return env
    end
    env = emit_stmt(get(stmts, i), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
    return emit_body(stmts, i + 1, n, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
end

func emit_do_call(call_idx, stmt_line, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly):
    let node = get(nodes, call_idx)
    if not equal(node.0, "call"):
        return fault("do non-call")
    end
    let name = get(node.1, 0)
    let kids = node.2
    if equal(name, "append"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        ir = emit_expr(get(kids, 1), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr_line(ir, op_buf_append(), 0, 0, stmt_line)
    end
    if equal(name, "add"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        ir = emit_expr(get(kids, 1), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, op_arr_add(), 0, 0)
    end
    if equal(name, "flogger"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, op_flogger(), 0, 0)
    end
    if equal(name, "fwriter"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return emit_instr(ir, op_fwriter(), 0, 0)
    end
    return fault("bad do call")
end

func emit_if_arms(kids, i, n, env, ir, strings, nodes, prog_idx, type_pool, join_label, caller_inst_idx, poly):
    if i >= n:
        return env
    end
    let arm_idx = get(kids, i)
    let arm = get(nodes, arm_idx)
    let scope_mark = count(env.0)
    if equal(arm.0, "else"):
        let body_idx = get(arm.2, 0)
        let body = get(nodes, body_idx)
        let body_env = emit_body(body.2, 0, count(body.2), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return env_rebuild(body_env, scope_mark)
    end
    let next_label = make_label("if", count(ir))
    ir = emit_expr(get(arm.2, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
    ir = emit_target_instr(ir, op_br_if_false(), next_label)
    let body_idx = get(arm.2, 1)
    let body = get(nodes, body_idx)
    let body_env = emit_body(body.2, 0, count(body.2), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
    env = env_rebuild(body_env, scope_mark)
    if (not body_ends_return(body_idx, nodes)) and i + 1 < n:
        ir = emit_target_instr(ir, op_br(), join_label)
    end
    ir = emit_label(ir, next_label)
    return emit_if_arms(kids, i + 1, n, env, ir, strings, nodes, prog_idx, type_pool, join_label, caller_inst_idx, poly)
end

func emit_if_stmt(kids, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly):
    let join_label = make_label("join", count(ir))
    env = emit_if_arms(kids, 0, count(kids), env, ir, strings, nodes, prog_idx, type_pool, join_label, caller_inst_idx, poly)
    ir = emit_label(ir, join_label)
    return env
end

func emit_stmt(stmt_idx, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly):
    let stmt = get(nodes, stmt_idx)
    let tag = stmt.0
    let atoms = stmt.1
    let kids = stmt.2
    if equal(tag, "let"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        ir = emit_instr(ir, op_store_local(), env.2, 0)
        return env_let(env, get(atoms, 0))
    end
    if equal(tag, "assign"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        ir = emit_instr(ir, op_store_local(), env_lookup(env, get(atoms, 0)), 0)
        return env
    end
    if equal(tag, "return"):
        ir = emit_expr(get(kids, 0), env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        ir = emit_instr(ir, op_ret(), 0, 0)
        return env
    end
    if equal(tag, "do"):
        ir = emit_do_call(get(kids, 0), stmt.3, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
        return env
    end
    if equal(tag, "if"):
        return emit_if_stmt(kids, env, ir, strings, nodes, prog_idx, type_pool, caller_inst_idx, poly)
    end
    return fault("bad statement")
end

func lower_func_poly(func_idx, inst_idx, entry_pc, strings, nodes, prog_idx, type_pool, poly):
    let fn = get(nodes, func_idx)
    let name = get(fn.1, 0)
    let params_node = get(nodes, get(fn.2, 0))
    let body_node = get(nodes, get(fn.2, 1))
    let env = env_from_params(params_node.1)
    let ir = new_array((int, int, int, int, int, string, int))
    let out_env = emit_body(body_node.2, 0, count(body_node.2), env, ir, strings, nodes, prog_idx, type_pool, inst_idx, poly)
    let code = resolve_ir(ir)
    let new_array_meta = resolve_new_array_meta(ir)
    let instr_lines = resolve_instr_lines(ir)
    return (name, entry_pc, count(params_node.1), out_env.2, code, new_array_meta, instr_lines)
end

func lower_program_poly_loop(instances, i, entry_pc, funcs, strings, nodes, prog_idx, type_pool, poly):
    if i >= count(instances):
        return funcs
    end
    let prog = get(nodes, prog_idx)
    let inst = get(instances, i)
    let fn = lower_func_poly(get(prog.2, inst.0), i, entry_pc, strings, nodes, prog_idx, type_pool, poly)
    do add(funcs, fn)
    return lower_program_poly_loop(instances, i + 1, entry_pc + count(fn.4), funcs, strings, nodes, prog_idx, type_pool, poly)
end

func find_table_func_loop(funcs, i, n, name):
    if i >= n:
        return fault("entry missing")
    end
    let fn = get(funcs, i)
    if equal(fn.0, name):
        return i
    end
    return find_table_func_loop(funcs, i + 1, n, name)
end

func find_table_func(funcs, name):
    return find_table_func_loop(funcs, 0, count(funcs), name)
end

func lower_program_poly(nodes, prog_idx, type_pool, poly):
    let strings = new_array(string)
    let funcs = new_array((string, int, int, int, array((int, int, int)), array(int), array(int)))
    funcs = lower_program_poly_loop(poly.0, 0, 0, funcs, strings, nodes, prog_idx, type_pool, poly)
    return (funcs, strings, 0)
end

func lower_program(nodes, prog_idx, type_pool):
    let ast_result = nc_verify_ast(nodes, prog_idx, type_pool)
    if ast_result.0 != 0:
        return (new_array((string, int, int, int, array((int, int, int)), array(int), array(int))), new_array(string), 0)
    end
    return lower_program_poly(nodes, prog_idx, type_pool, ast_result.2)
end

func opcode_name(op):
    if op == op_push_int():
        return "PUSH_INT"
    end
    if op == op_push_bool():
        return "PUSH_BOOL"
    end
    if op == op_push_str():
        return "PUSH_STR"
    end
    if op == op_load_local():
        return "LOAD_LOCAL"
    end
    if op == op_store_local():
        return "STORE_LOCAL"
    end
    if op == op_add():
        return "ADD"
    end
    if op == op_sub():
        return "SUB"
    end
    if op == op_lt():
        return "LT"
    end
    if op == op_le():
        return "LE"
    end
    if op == op_gt():
        return "GT"
    end
    if op == op_ge():
        return "GE"
    end
    if op == op_eq():
        return "EQ"
    end
    if op == op_ne():
        return "NE"
    end
    if op == op_not():
        return "NOT"
    end
    if op == op_make_tuple():
        return "MAKE_TUPLE"
    end
    if op == op_tuple_get():
        return "TUPLE_GET"
    end
    if op == op_br():
        return "BR"
    end
    if op == op_br_if_false():
        return "BR_IF_FALSE"
    end
    if op == op_br_and():
        return "BR_AND"
    end
    if op == op_br_or():
        return "BR_OR"
    end
    if op == op_call():
        return "CALL"
    end
    if op == op_ret():
        return "RET"
    end
    if op == op_length():
        return "LENGTH"
    end
    if op == op_index():
        return "INDEX"
    end
    if op == op_slice():
        return "SLICE"
    end
    if op == op_equal():
        return "EQUAL"
    end
    if op == op_new_buffer():
        return "NEW_BUFFER"
    end
    if op == op_freeze():
        return "FREEZE"
    end
    if op == op_new_array():
        return "NEW_ARRAY"
    end
    if op == op_get():
        return "GET"
    end
    if op == op_count():
        return "COUNT"
    end
    if op == op_buf_append():
        return "BUF_APPEND"
    end
    if op == op_arr_add():
        return "ARR_ADD"
    end
    if op == op_clogger():
        return "CLOGGER"
    end
    if op == op_flogger():
        return "FLOGGER"
    end
    if op == op_band():
        return "BAND"
    end
    if op == op_bor():
        return "BOR"
    end
    if op == op_bxor():
        return "BXOR"
    end
    if op == op_shl():
        return "SHL"
    end
    if op == op_shr():
        return "SHR"
    end
    if op == op_bnot():
        return "BNOT"
    end
    if op == op_mul():
        return "MUL"
    end
    if op == op_div():
        return "DIV"
    end
    if op == op_mod():
        return "MOD"
    end
    return "ARR_ADD"
end

func opcode_operands(op):
    if op == op_call():
        return 2
    end
    if op == op_push_int() or op == op_push_bool() or op == op_push_str() or op == op_load_local() or op == op_store_local() or op == op_make_tuple() or op == op_tuple_get() or op == op_br() or op == op_br_if_false() or op == op_br_and() or op == op_br_or():
        return 1
    end
    if op == op_clogger() or op == op_flogger():
        return 0
    end
    return 0
end

func append_quoted_pool_string_loop(buf, s, i, n):
    if i >= n:
        return buf
    end
    let c = index(s, i)
    if c == '\n':
        do append(buf, '\\')
        do append(buf, 'n')
    elif c == '\\':
        do append(buf, '\\')
        do append(buf, '\\')
    elif c == '"':
        do append(buf, '\\')
        do append(buf, '"')
    else:
        do append(buf, c)
    end
    return append_quoted_pool_string_loop(buf, s, i + 1, n)
end

func append_quoted_pool_string(buf, s):
    do append(buf, '"')
    buf = append_quoted_pool_string_loop(buf, s, 0, length(s))
    do append(buf, '"')
    return buf
end

func serialize_strings_loop(buf, strings, i, n):
    if i >= n:
        return buf
    end
    buf = emit_decimal(buf, i)
    do append(buf, ' ')
    buf = append_quoted_pool_string(buf, get(strings, i))
    do append(buf, '\n')
    return serialize_strings_loop(buf, strings, i + 1, n)
end

func serialize_funcs_loop(buf, funcs, i, n):
    if i >= n:
        return buf
    end
    let fn = get(funcs, i)
    buf = emit_decimal(buf, i)
    do append(buf, ' ')
    buf = append_str(buf, fn.0)
    buf = append_str(buf, " n_params=")
    buf = emit_decimal(buf, fn.2)
    buf = append_str(buf, " n_locals=")
    buf = emit_decimal(buf, fn.3)
    do append(buf, '\n')
    return serialize_funcs_loop(buf, funcs, i + 1, n)
end

func serialize_instr(buf, idx, instr):
    let op = instr.0
    buf = emit_decimal(buf, idx)
    do append(buf, ' ')
    buf = append_str(buf, opcode_name(op))
    if opcode_operands(op) >= 1:
        do append(buf, ' ')
        buf = emit_decimal(buf, instr.1)
    end
    if opcode_operands(op) >= 2:
        do append(buf, ' ')
        buf = emit_decimal(buf, instr.2)
    end
    do append(buf, '\n')
    return buf
end

func serialize_code_instrs(buf, code, i, n):
    if i >= n:
        return buf
    end
    buf = serialize_instr(buf, i, get(code, i))
    return serialize_code_instrs(buf, code, i + 1, n)
end

func serialize_code_loop(buf, funcs, i, n):
    if i >= n:
        return buf
    end
    let fn = get(funcs, i)
    buf = append_str(buf, "fn ")
    buf = emit_decimal(buf, i)
    do append(buf, ' ')
    buf = append_str(buf, fn.0)
    do append(buf, '\n')
    buf = serialize_code_instrs(buf, fn.4, 0, count(fn.4))
    return serialize_code_loop(buf, funcs, i + 1, n)
end

func serialize_bytecode(prog):
    let buf = new_buffer()
    buf = append_str(buf, "STRING_POOL\n")
    buf = serialize_strings_loop(buf, prog.1, 0, count(prog.1))
    do append(buf, '\n')
    buf = append_str(buf, "FUNCTIONS\n")
    buf = serialize_funcs_loop(buf, prog.0, 0, count(prog.0))
    do append(buf, '\n')
    buf = append_str(buf, "CODE\n")
    buf = serialize_code_loop(buf, prog.0, 0, count(prog.0))
    return freeze(buf)
end

-- ====================================================================
-- ERROR-HANDLING FRONT END
-- ====================================================================

func err_ok_tag():
    return 0
end

func err_err_tag():
    return 1
end

func err_no_diag():
    return (0, 0, "")
end

func err_diag(code, line, payload):
    return (code, line, payload)
end

func diagnostic_with_payload(prefix, payload, suffix):
    let buf = new_buffer()
    buf = append_str(buf, prefix)
    buf = append_str(buf, payload)
    buf = append_str(buf, suffix)
    return freeze(buf)
end

func diagnostic_message(code, payload):
    if code == 101:
        return "unexpected character"
    end
    if code == 102:
        return "expected digit"
    end
    if code == 103:
        return "integer literal does not fit in 64 bits"
    end
    if code == 104:
        return "unknown escape sequence"
    end
    if code == 105:
        return "unterminated escape"
    end
    if code == 106:
        return "newline in string literal"
    end
    if code == 107:
        return "unterminated string literal"
    end
    if code == 108:
        return "empty character literal"
    end
    if code == 109:
        return "character literal not closed"
    end
    if code == 110:
        return "newline in character literal"
    end
    if code == 201:
        return "expected 'func' at top level"
    end
    if code == 202:
        return "invalid function header"
    end
    if code == 203:
        return "expected end"
    end
    if code == 204:
        return "expected expression"
    end
    if code == 205:
        return "'do' must be followed by a call"
    end
    if code == 206:
        return "expected integer after '.'"
    end
    if code == 207:
        return "expected ')'"
    end
    if code == 208:
        return "new_array requires a type argument"
    end
    if code == 209:
        return "function body must contain at least one statement"
    end
    if code == 210:
        return "if/elif/else arm must contain at least one statement"
    end
    if code == 211:
        return "invalid type expression"
    end
    if code == 212:
        return "invalid assignment or name"
    end
    if code == 301:
        return diagnostic_with_payload("duplicate let '", payload, "' in this scope")
    end
    if code == 302:
        return diagnostic_with_payload("undefined name '", payload, "'")
    end
    if code == 303:
        return diagnostic_with_payload("assignment to undefined name '", payload, "'")
    end
    if code == 304:
        return diagnostic_with_payload("unknown function '", payload, "'")
    end
    if code == 305:
        return diagnostic_with_payload("wrong number of arguments to '", payload, "'")
    end
    if code == 306:
        return diagnostic_with_payload("wrong number of arguments to '", payload, "'")
    end
    if code == 307:
        return diagnostic_with_payload("wrong number of arguments to '", payload, "'")
    end
    if code == 308:
        return diagnostic_with_payload("builtin '", payload, "' has no value")
    end
    if code == 310:
        return diagnostic_with_payload("'do' requires a value-less call, got '", payload, "'")
    end
    if code == 311:
        return diagnostic_with_payload("duplicate parameter '", payload, "'")
    end
    if code == 312:
        return diagnostic_with_payload("duplicate function '", payload, "'")
    end
    if code == 313:
        return diagnostic_with_payload("function reuses built-in name '", payload, "'")
    end
    if code == 314:
        return "no main function defined"
    end
    if code == 315:
        return diagnostic_with_payload("function '", payload, "' must take zero parameters")
    end
    if code == 316:
        return diagnostic_with_payload("function '", payload, "' may complete without returning")
    end
    return "unknown error"
end

func serialize_diagnostic(diag):
    let code = diag.0
    let line = diag.1
    let payload = diag.2
    let buf = new_buffer()
    if line > 0:
        buf = append_str(buf, "line ")
        buf = append_str(buf, int_to_str(line))
        buf = append_str(buf, ": ")
    else:
        buf = append_str(buf, "program: ")
    end
    buf = append_str(buf, diagnostic_message(code, payload))
    buf = append_str(buf, " (ERR ")
    buf = append_str(buf, int_to_str(code))
    buf = append_str(buf, ")")
    return freeze(buf)
end

func serialize_error(code):
    return serialize_diagnostic(err_diag(code, 0, ""))
end

func err_empty_tokens():
    return new_array((int, string, int))
end

func err_lex_ok(tokens, eof_line):
    return (err_ok_tag(), err_no_diag(), tokens, eof_line)
end

func err_lex_fail(diag):
    return (err_err_tag(), diag, err_empty_tokens(), 0)
end

func err_pos_ok(pos):
    return (err_ok_tag(), err_no_diag(), pos)
end

func err_pos_fail(diag):
    return (err_err_tag(), diag, 0)
end

func err_parse_ok(pos):
    return (err_ok_tag(), err_no_diag(), pos, 0)
end

func err_parse_ok_extra(pos, extra):
    return (err_ok_tag(), err_no_diag(), pos, extra)
end

func err_parse_fail(diag):
    return (err_err_tag(), diag, 0, 0)
end

func err_parse_fail_at(code, line):
    return err_parse_fail(err_diag(code, line, ""))
end

func err_parse_fail_payload(code, line, payload):
    return err_parse_fail(err_diag(code, line, payload))
end

func err_token_line(tokens, pos, eof_line):
    if pos >= count(tokens):
        return eof_line
    end
    let t = get(tokens, pos)
    return t.2
end

func err_parse_fail_current(code, tokens, pos, eof_line):
    return err_parse_fail_at(code, err_token_line(tokens, pos, eof_line))
end

func err_check_ok():
    return (err_ok_tag(), err_no_diag())
end

func err_check_fail(diag):
    return (err_err_tag(), diag)
end

func err_check_fail_at(code, line, payload):
    return err_check_fail(err_diag(code, line, payload))
end

func err_empty_env():
    return new_array(string)
end

func err_env_ok(env):
    return (err_ok_tag(), err_no_diag(), env)
end

func err_env_fail(diag):
    return (err_err_tag(), diag, err_empty_env())
end

func err_env_fail_at(code, line, payload):
    return err_env_fail(err_diag(code, line, payload))
end

func err_expr_other():
    return 0
end

func err_expr_call():
    return 1
end

func err_expr_new_array():
    return 2
end

func err_is_valid_punct(c):
    return c == '(' or c == ')' or c == ',' or c == '.' or c == ':'
end

func err_end_of_int(src, i, n, line, acc):
    if i >= n:
        return err_pos_ok(i)
    end
    let c = index(src, i)
    if not is_digit(c):
        return err_pos_ok(i)
    end
    let d = c - '0'
    if acc > 1844674407370955161:
        return err_pos_fail(err_diag(103, line, ""))
    end
    if acc == 1844674407370955161 and d > 5:
        return err_pos_fail(err_diag(103, line, ""))
    end
    return err_end_of_int(src, i + 1, n, line, times10(acc) + d)
end

func err_string_escape_ok(c):
    return c == 'n' or c == '\\' or c == '"'
end

func err_char_escape_ok(c):
    return c == 'n' or c == '\\' or c == '\''
end

func err_end_of_string(src, i, n, line):
    if i >= n:
        return err_pos_fail(err_diag(107, line, ""))
    end
    let c = index(src, i)
    if c == '"':
        return err_pos_ok(i + 1)
    end
    if c == '\n':
        return err_pos_fail(err_diag(106, line, ""))
    end
    if c == '\\':
        if i + 1 >= n:
            return err_pos_fail(err_diag(105, line, ""))
        end
        if not err_string_escape_ok(index(src, i + 1)):
            return err_pos_fail(err_diag(104, line, ""))
        end
        return err_end_of_string(src, i + 2, n, line)
    end
    return err_end_of_string(src, i + 1, n, line)
end

func err_check_char_close(src, pos, n, line):
    if pos >= n:
        return err_pos_fail(err_diag(109, line, ""))
    end
    if index(src, pos) == '\n':
        return err_pos_fail(err_diag(110, line, ""))
    end
    if index(src, pos) != '\'':
        return err_pos_fail(err_diag(109, line, ""))
    end
    return err_pos_ok(pos + 1)
end

func err_end_of_char(src, i, n, line):
    if i >= n:
        return err_pos_fail(err_diag(109, line, ""))
    end
    let c = index(src, i)
    if c == '\n':
        return err_pos_fail(err_diag(110, line, ""))
    end
    if c == '\'':
        return err_pos_fail(err_diag(108, line, ""))
    end
    if c == '\\':
        if i + 1 >= n:
            return err_pos_fail(err_diag(105, line, ""))
        end
        if not err_char_escape_ok(index(src, i + 1)):
            return err_pos_fail(err_diag(104, line, ""))
        end
        return err_check_char_close(src, i + 2, n, line)
    end
    return err_check_char_close(src, i + 1, n, line)
end

func err_scan(src, i, n, line, out):
    if i >= n:
        return err_lex_ok(out, line)
    end
    let c = index(src, i)
    if is_ws(c):
        if c == '\n':
            return err_scan(src, i + 1, n, line + 1, out)
        end
        return err_scan(src, i + 1, n, line, out)
    elif c == '-' and i + 1 < n and index(src, i + 1) == '-':
        return err_scan(src, end_of_line(src, i + 2, n), n, line, out)
    elif is_ident_start(c):
        let j = end_of_ident(src, i + 1, n)
        do add(out, (0, slice_text(src, i, j), line))
        return err_scan(src, j, n, line, out)
    elif is_digit(c):
        let r = err_end_of_int(src, i, n, line, 0)
        if r.0 == err_err_tag():
            return err_lex_fail(r.1)
        end
        do add(out, (1, slice_text(src, i, r.2), line))
        return err_scan(src, r.2, n, line, out)
    elif c == '"':
        let r = err_end_of_string(src, i + 1, n, line)
        if r.0 == err_err_tag():
            return err_lex_fail(r.1)
        end
        do add(out, (2, slice_text(src, i, r.2), line))
        return err_scan(src, r.2, n, line, out)
    elif c == '\'':
        let r = err_end_of_char(src, i + 1, n, line)
        if r.0 == err_err_tag():
            return err_lex_fail(r.1)
        end
        do add(out, (3, slice_text(src, i, r.2), line))
        return err_scan(src, r.2, n, line, out)
    elif is_two_byte_op_start(c) and i + 1 < n and index(src, i + 1) == '=':
        do add(out, (5, slice_text(src, i, i + 2), line))
        return err_scan(src, i + 2, n, line, out)
    elif is_one_byte_op(c):
        do add(out, (5, slice_text(src, i, i + 1), line))
        return err_scan(src, i + 1, n, line, out)
    elif err_is_valid_punct(c):
        do add(out, (4, slice_text(src, i, i + 1), line))
        return err_scan(src, i + 1, n, line, out)
    end
    return err_lex_fail(err_diag(101, line, slice_text(src, i, i + 1)))
end

func err_lex_source(src):
    return err_scan(src, 0, length(src), 1, new_array((int, string, int)))
end

func err_is_reserved_word(s):
    if equal(s, "func") or equal(s, "let") or equal(s, "return") or equal(s, "do"):
        return true
    end
    if equal(s, "if") or equal(s, "elif") or equal(s, "else") or equal(s, "end"):
        return true
    end
    if equal(s, "and") or equal(s, "or") or equal(s, "not"):
        return true
    end
    if equal(s, "true") or equal(s, "false"):
        return true
    end
    if equal(s, "int") or equal(s, "bool") or equal(s, "string"):
        return true
    end
    return equal(s, "buffer") or equal(s, "array")
end

func err_is_valid_name_token(tokens, pos):
    if pos >= count(tokens):
        return false
    end
    let t = get(tokens, pos)
    return t.0 == 0 and not err_is_reserved_word(t.1)
end

func err_name_seen_loop(names, start, n, name):
    if start >= n:
        return false
    end
    if equal(get(names, start), name):
        return true
    end
    return err_name_seen_loop(names, start + 1, n, name)
end

func err_name_seen(names, name):
    return err_name_seen_loop(names, 0, count(names), name)
end

func err_parse_type(tokens, pos, eof_line):
    let line = err_token_line(tokens, pos, eof_line)
    if pos >= count(tokens):
        return err_parse_fail_at(211, line)
    end
    let t = get(tokens, pos)
    if t.0 == 0:
        if equal(t.1, "int") or equal(t.1, "bool") or equal(t.1, "string") or equal(t.1, "buffer"):
            return err_parse_ok(pos + 1)
        end
        if equal(t.1, "array"):
            if not tok_is_punct_text(tokens, pos + 1, "("):
                return err_parse_fail_current(211, tokens, pos + 1, eof_line)
            end
            let r = err_parse_type(tokens, pos + 2, eof_line)
            if r.0 == err_err_tag():
                return r
            end
            if not tok_is_punct_text(tokens, r.2, ")"):
                return err_parse_fail_current(211, tokens, r.2, eof_line)
            end
            return err_parse_ok(r.2 + 1)
        end
        return err_parse_fail_at(211, line)
    end
    if tok_is_punct_text(tokens, pos, "("):
        let r = err_parse_type(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_type_tuple_tail(tokens, r.2, eof_line, 1, line)
    end
    return err_parse_fail_at(211, line)
end

func err_parse_type_tuple_tail(tokens, pos, eof_line, n_items, tuple_line):
    if tok_is_punct_text(tokens, pos, ","):
        let r = err_parse_type(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_type_tuple_tail(tokens, r.2, eof_line, n_items + 1, tuple_line)
    end
    if not tok_is_punct_text(tokens, pos, ")"):
        return err_parse_fail_current(211, tokens, pos, eof_line)
    end
    if n_items < 2:
        return err_parse_fail_at(211, tuple_line)
    end
    return err_parse_ok(pos + 1)
end

func err_parse_expr(tokens, pos, eof_line):
    return err_parse_or(tokens, pos, eof_line)
end

func err_parse_or(tokens, pos, eof_line):
    let r = err_parse_and(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_or_loop(tokens, r.2, eof_line, r.3)
end

func err_parse_or_loop(tokens, pos, eof_line, root_kind):
    if tok_is_ident_text(tokens, pos, "or"):
        let r = err_parse_and(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_or_loop(tokens, r.2, eof_line, err_expr_other())
    end
    return err_parse_ok_extra(pos, root_kind)
end

func err_parse_and(tokens, pos, eof_line):
    let r = err_parse_cmp(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_and_loop(tokens, r.2, eof_line, r.3)
end

func err_parse_and_loop(tokens, pos, eof_line, root_kind):
    if tok_is_ident_text(tokens, pos, "and"):
        let r = err_parse_cmp(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_and_loop(tokens, r.2, eof_line, err_expr_other())
    end
    return err_parse_ok_extra(pos, root_kind)
end

func err_parse_cmp(tokens, pos, eof_line):
    let r = err_parse_add(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_cmp_loop(tokens, r.2, eof_line, r.3)
end

func err_parse_cmp_loop(tokens, pos, eof_line, root_kind):
    if pos >= count(tokens):
        return err_parse_ok_extra(pos, root_kind)
    end
    let t = get(tokens, pos)
    if t.0 == 5 and not equal(cmp_tag(t.1), ""):
        let r = err_parse_add(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_cmp_loop(tokens, r.2, eof_line, err_expr_other())
    end
    return err_parse_ok_extra(pos, root_kind)
end

func err_parse_add(tokens, pos, eof_line):
    let r = err_parse_mul(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_add_loop(tokens, r.2, eof_line, r.3)
end

func err_parse_add_loop(tokens, pos, eof_line, root_kind):
    if pos >= count(tokens):
        return err_parse_ok_extra(pos, root_kind)
    end
    let t = get(tokens, pos)
    if t.0 == 5 and not equal(add_tag(t.1), ""):
        let r = err_parse_mul(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_add_loop(tokens, r.2, eof_line, err_expr_other())
    end
    return err_parse_ok_extra(pos, root_kind)
end

-- Multiplicative tier in the structural err-parse mirror (`*` `/` `%`), one
-- level tighter than additive. Mirrors err_parse_add, calling err_parse_not.
func err_parse_mul(tokens, pos, eof_line):
    let r = err_parse_not(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_mul_loop(tokens, r.2, eof_line, r.3)
end

func err_parse_mul_loop(tokens, pos, eof_line, root_kind):
    if pos >= count(tokens):
        return err_parse_ok_extra(pos, root_kind)
    end
    let t = get(tokens, pos)
    if t.0 == 5 and not equal(mul_tag(t.1), ""):
        let r = err_parse_not(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_mul_loop(tokens, r.2, eof_line, err_expr_other())
    end
    return err_parse_ok_extra(pos, root_kind)
end

func err_parse_not(tokens, pos, eof_line):
    if tok_is_ident_text(tokens, pos, "not"):
        let r = err_parse_not(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_ok_extra(r.2, err_expr_other())
    end
    return err_parse_dot(tokens, pos, eof_line)
end

func err_parse_dot(tokens, pos, eof_line):
    let r = err_parse_atom(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_dot_loop(tokens, r.2, eof_line, r.3)
end

func err_parse_dot_loop(tokens, pos, eof_line, root_kind):
    if tok_is_punct_text(tokens, pos, "."):
        if pos + 1 >= count(tokens):
            return err_parse_fail_current(206, tokens, pos + 1, eof_line)
        end
        let idx_tok = get(tokens, pos + 1)
        if idx_tok.0 != 1:
            return err_parse_fail_at(206, idx_tok.2)
        end
        return err_parse_dot_loop(tokens, pos + 2, eof_line, err_expr_other())
    end
    return err_parse_ok_extra(pos, root_kind)
end

func err_parse_atom(tokens, pos, eof_line):
    let line = err_token_line(tokens, pos, eof_line)
    if pos >= count(tokens):
        return err_parse_fail_at(204, line)
    end
    let t = get(tokens, pos)
    let k = t.0
    let s = t.1
    if k == 1 or k == 2 or k == 3:
        return err_parse_ok_extra(pos + 1, err_expr_other())
    end
    if k == 0:
        if equal(s, "true") or equal(s, "false"):
            return err_parse_ok_extra(pos + 1, err_expr_other())
        end
        if err_is_reserved_word(s):
            return err_parse_fail_at(204, line)
        end
        if tok_is_punct_text(tokens, pos + 1, "("):
            return err_parse_call(tokens, pos, eof_line)
        end
        return err_parse_ok_extra(pos + 1, err_expr_other())
    end
    if tok_is_punct_text(tokens, pos, "("):
        return err_parse_group_or_tuple(tokens, pos + 1, eof_line)
    end
    return err_parse_fail_at(204, line)
end

func err_parse_call(tokens, pos, eof_line):
    let name_tok = get(tokens, pos)
    let name = name_tok.1
    let line = name_tok.2
    pos = pos + 2
    if equal(name, "new_array"):
        if tok_is_punct_text(tokens, pos, ")"):
            return err_parse_fail_at(208, line)
        end
        let r = err_parse_type(tokens, pos, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        if not tok_is_punct_text(tokens, r.2, ")"):
            return err_parse_fail_current(208, tokens, r.2, eof_line)
        end
        return err_parse_ok_extra(r.2 + 1, err_expr_new_array())
    end
    if tok_is_punct_text(tokens, pos, ")"):
        return err_parse_ok_extra(pos + 1, err_expr_call())
    end
    let r = err_parse_args_loop(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    if not tok_is_punct_text(tokens, r.2, ")"):
        return err_parse_fail_current(207, tokens, r.2, eof_line)
    end
    return err_parse_ok_extra(r.2 + 1, err_expr_call())
end

func err_parse_args_loop(tokens, pos, eof_line):
    let r = err_parse_expr(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    if tok_is_punct_text(tokens, r.2, ","):
        return err_parse_args_loop(tokens, r.2 + 1, eof_line)
    end
    return err_parse_ok(r.2)
end

func err_parse_group_or_tuple(tokens, pos, eof_line):
    let r = err_parse_expr(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    if tok_is_punct_text(tokens, r.2, ","):
        let tr = err_parse_tuple_tail(tokens, r.2 + 1, eof_line)
        if tr.0 == err_err_tag():
            return tr
        end
        if not tok_is_punct_text(tokens, tr.2, ")"):
            return err_parse_fail_current(207, tokens, tr.2, eof_line)
        end
        return err_parse_ok_extra(tr.2 + 1, err_expr_other())
    end
    if not tok_is_punct_text(tokens, r.2, ")"):
        return err_parse_fail_current(207, tokens, r.2, eof_line)
    end
    return err_parse_ok_extra(r.2 + 1, r.3)
end

func err_parse_tuple_tail(tokens, pos, eof_line):
    let r = err_parse_expr(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    if tok_is_punct_text(tokens, r.2, ","):
        return err_parse_tuple_tail(tokens, r.2 + 1, eof_line)
    end
    return err_parse_ok(r.2)
end

func err_parse_body(tokens, pos, eof_line, seen_count):
    if is_body_terminator(tokens, pos):
        return err_parse_ok_extra(pos, seen_count)
    end
    let r = err_parse_stmt(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_body(tokens, r.2, eof_line, seen_count + 1)
end

func err_parse_stmt(tokens, pos, eof_line):
    let line = err_token_line(tokens, pos, eof_line)
    if pos >= count(tokens):
        return err_parse_fail_at(205, line)
    end
    let t = get(tokens, pos)
    if t.0 != 0:
        return err_parse_fail_at(205, line)
    end
    let text = t.1
    if equal(text, "let"):
        return err_parse_let(tokens, pos + 1, eof_line)
    end
    if equal(text, "return"):
        let r = err_parse_expr(tokens, pos + 1, eof_line)
        if r.0 == err_err_tag():
            return r
        end
        return err_parse_ok(r.2)
    end
    if equal(text, "do"):
        return err_parse_do(tokens, pos + 1, eof_line, line)
    end
    if equal(text, "if"):
        return err_parse_if(tokens, pos + 1, eof_line, line)
    end
    if err_is_reserved_word(text):
        return err_parse_fail_at(205, line)
    end
    return err_parse_assign(tokens, pos, eof_line)
end

func err_parse_let(tokens, pos, eof_line):
    if not err_is_valid_name_token(tokens, pos):
        return err_parse_fail_current(212, tokens, pos, eof_line)
    end
    if not tok_is_op_text(tokens, pos + 1, "="):
        return err_parse_fail_current(212, tokens, pos + 1, eof_line)
    end
    let r = err_parse_expr(tokens, pos + 2, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_ok(r.2)
end

func err_parse_assign(tokens, pos, eof_line):
    if not err_is_valid_name_token(tokens, pos):
        return err_parse_fail_current(212, tokens, pos, eof_line)
    end
    if not tok_is_op_text(tokens, pos + 1, "="):
        return err_parse_fail_current(212, tokens, pos, eof_line)
    end
    let r = err_parse_expr(tokens, pos + 2, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_ok(r.2)
end

func err_parse_do(tokens, pos, eof_line, do_line):
    let r = err_parse_expr(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    if r.3 != err_expr_call():
        return err_parse_fail_at(205, do_line)
    end
    return err_parse_ok(r.2)
end

func err_parse_if(tokens, pos, eof_line, if_line):
    let cr = err_parse_expr(tokens, pos, eof_line)
    if cr.0 == err_err_tag():
        return cr
    end
    if not tok_is_punct_text(tokens, cr.2, ":"):
        return err_parse_fail_current(204, tokens, cr.2, eof_line)
    end
    let br = err_parse_body(tokens, cr.2 + 1, eof_line, 0)
    if br.0 == err_err_tag():
        return br
    end
    if br.3 == 0:
        return err_parse_fail_at(210, if_line)
    end
    let ar = err_parse_elifs(tokens, br.2, eof_line, if_line)
    if ar.0 == err_err_tag():
        return ar
    end
    pos = ar.2
    if tok_is_ident_text(tokens, pos, "else"):
        let er = err_parse_else(tokens, pos + 1, eof_line, if_line)
        if er.0 == err_err_tag():
            return er
        end
        pos = er.2
    end
    if not tok_is_ident_text(tokens, pos, "end"):
        return err_parse_fail_current(203, tokens, pos, eof_line)
    end
    return err_parse_ok(pos + 1)
end

func err_parse_elifs(tokens, pos, eof_line, if_line):
    if tok_is_ident_text(tokens, pos, "elif"):
        let cr = err_parse_expr(tokens, pos + 1, eof_line)
        if cr.0 == err_err_tag():
            return cr
        end
        if not tok_is_punct_text(tokens, cr.2, ":"):
            return err_parse_fail_current(204, tokens, cr.2, eof_line)
        end
        let br = err_parse_body(tokens, cr.2 + 1, eof_line, 0)
        if br.0 == err_err_tag():
            return br
        end
        if br.3 == 0:
            return err_parse_fail_at(210, if_line)
        end
        return err_parse_elifs(tokens, br.2, eof_line, if_line)
    end
    return err_parse_ok(pos)
end

func err_parse_else(tokens, pos, eof_line, if_line):
    if not tok_is_punct_text(tokens, pos, ":"):
        return err_parse_fail_current(203, tokens, pos, eof_line)
    end
    let br = err_parse_body(tokens, pos + 1, eof_line, 0)
    if br.0 == err_err_tag():
        return br
    end
    if br.3 == 0:
        return err_parse_fail_at(210, if_line)
    end
    return err_parse_ok(br.2)
end

func err_parse_param_loop(tokens, pos, eof_line, params):
    if not err_is_valid_name_token(tokens, pos):
        return err_parse_fail_current(202, tokens, pos, eof_line)
    end
    let param_tok = get(tokens, pos)
    let name = param_tok.1
    if err_name_seen(params, name):
        return err_parse_fail_payload(311, param_tok.2, name)
    end
    do add(params, name)
    if tok_is_punct_text(tokens, pos + 1, ","):
        return err_parse_param_loop(tokens, pos + 2, eof_line, params)
    end
    return err_parse_ok_extra(pos + 1, count(params))
end

func err_parse_param_list(tokens, pos, eof_line):
    let params = new_array(string)
    if tok_is_punct_text(tokens, pos, ")"):
        return err_parse_ok_extra(pos, 0)
    end
    return err_parse_param_loop(tokens, pos, eof_line, params)
end

func err_parse_func(tokens, pos, eof_line):
    let line = err_token_line(tokens, pos, eof_line)
    if not err_is_valid_name_token(tokens, pos + 1):
        return err_parse_fail_current(202, tokens, pos + 1, eof_line)
    end
    if not tok_is_punct_text(tokens, pos + 2, "("):
        return err_parse_fail_current(202, tokens, pos + 2, eof_line)
    end
    let pr = err_parse_param_list(tokens, pos + 3, eof_line)
    if pr.0 == err_err_tag():
        return pr
    end
    if not tok_is_punct_text(tokens, pr.2, ")"):
        return err_parse_fail_current(202, tokens, pr.2, eof_line)
    end
    if not tok_is_punct_text(tokens, pr.2 + 1, ":"):
        return err_parse_fail_current(202, tokens, pr.2 + 1, eof_line)
    end
    let br = err_parse_body(tokens, pr.2 + 2, eof_line, 0)
    if br.0 == err_err_tag():
        return br
    end
    if br.3 == 0:
        return err_parse_fail_at(209, line)
    end
    if not tok_is_ident_text(tokens, br.2, "end"):
        return err_parse_fail_current(203, tokens, br.2, eof_line)
    end
    return err_parse_ok(br.2 + 1)
end

func err_parse_program_loop(tokens, pos, eof_line):
    if pos >= count(tokens):
        return err_parse_ok(pos)
    end
    if not tok_is_ident_text(tokens, pos, "func"):
        return err_parse_fail_current(201, tokens, pos, eof_line)
    end
    let r = err_parse_func(tokens, pos, eof_line)
    if r.0 == err_err_tag():
        return r
    end
    return err_parse_program_loop(tokens, r.2, eof_line)
end

func err_parse_program(tokens, eof_line):
    return err_parse_program_loop(tokens, 0, eof_line)
end

func err_is_builtin_name(name):
    if equal(name, "length") or equal(name, "index") or equal(name, "slice"):
        return true
    end
    if equal(name, "equal") or equal(name, "new_buffer") or equal(name, "freeze"):
        return true
    end
    if equal(name, "new_array") or equal(name, "get") or equal(name, "count"):
        return true
    end
    return equal(name, "append") or equal(name, "add") or equal(name, "clogger") or equal(name, "flogger") or equal(name, "fwriter") or equal(name, "input_byte") or equal(name, "module_byte")
end

func err_is_void_builtin(name):
    return equal(name, "append") or equal(name, "add") or equal(name, "flogger") or equal(name, "fwriter")
end

func err_is_value_builtin(name):
    if equal(name, "length") or equal(name, "index") or equal(name, "slice"):
        return true
    end
    if equal(name, "equal") or equal(name, "new_buffer") or equal(name, "freeze"):
        return true
    end
    return equal(name, "get") or equal(name, "count") or equal(name, "clogger") or equal(name, "input_byte") or equal(name, "module_byte")
end

func err_value_builtin_arity(name):
    if equal(name, "length"):
        return 1
    end
    if equal(name, "index"):
        return 2
    end
    if equal(name, "equal"):
        return 2
    end
    if equal(name, "new_buffer"):
        return 0
    end
    if equal(name, "freeze"):
        return 1
    end
    if equal(name, "get"):
        return 2
    end
    if equal(name, "count"):
        return 1
    end
    return 0
end

func err_void_builtin_arity(name):
    if equal(name, "fwriter"):
        return 1
    end
    if equal(name, "flogger"):
        return 1
    end
    return 2
end

func err_func_lookup_loop(func_kids, i, n, name, nodes):
    if i >= n:
        return (0, 0)
    end
    let fn = get(nodes, get(func_kids, i))
    if equal(get(fn.1, 0), name):
        let params_node = get(nodes, get(fn.2, 0))
        return (1, count(params_node.1))
    end
    return err_func_lookup_loop(func_kids, i + 1, n, name, nodes)
end

func err_func_lookup(nodes, prog_idx, name):
    let prog = get(nodes, prog_idx)
    return err_func_lookup_loop(prog.2, 0, count(prog.2), name, nodes)
end

func err_prepass_loop(func_kids, i, n, seen, nodes, found_main, main_params, main_line):
    if i >= n:
        if found_main == 0:
            return (err_err_tag(), err_diag(314, 0, ""), 0, 0)
        end
        if main_params != 0:
            return (err_err_tag(), err_diag(315, main_line, "main"), 0, 0)
        end
        return (err_ok_tag(), err_no_diag(), found_main, main_params)
    end
    let fn = get(nodes, get(func_kids, i))
    let name = get(fn.1, 0)
    if err_is_builtin_name(name):
        return (err_err_tag(), err_diag(313, fn.3, name), 0, 0)
    end
    if err_name_seen(seen, name):
        return (err_err_tag(), err_diag(312, fn.3, name), 0, 0)
    end
    do add(seen, name)
    let params_node = get(nodes, get(fn.2, 0))
    if equal(name, "main"):
        found_main = 1
        main_params = count(params_node.1)
        main_line = fn.3
    end
    return err_prepass_loop(func_kids, i + 1, n, seen, nodes, found_main, main_params, main_line)
end

func err_prepass(nodes, prog_idx):
    let prog = get(nodes, prog_idx)
    return err_prepass_loop(prog.2, 0, count(prog.2), new_array(string), nodes, 0, 0, 0)
end

func err_env_from_params_loop(params, i, n, env):
    if i >= n:
        return env
    end
    do add(env, get(params, i))
    return err_env_from_params_loop(params, i + 1, n, env)
end

func err_env_from_params(params):
    return err_env_from_params_loop(params, 0, count(params), new_array(string))
end

func err_env_rebuild_loop(env, i, keep, out):
    if i >= keep:
        return out
    end
    do add(out, get(env, i))
    return err_env_rebuild_loop(env, i + 1, keep, out)
end

func err_env_rebuild(env, keep):
    return err_env_rebuild_loop(env, 0, keep, new_array(string))
end

func err_env_lookup_loop(env, name, n):
    if n == 0:
        return false
    end
    let k = n - 1
    if equal(get(env, k), name):
        return true
    end
    return err_env_lookup_loop(env, name, k)
end

func err_env_lookup(env, name):
    return err_env_lookup_loop(env, name, count(env))
end

func err_sem_exprs(kids, i, n, env, nodes, prog_idx):
    if i >= n:
        return err_check_ok()
    end
    let r = err_sem_expr(get(kids, i), env, nodes, prog_idx)
    if r.0 == err_err_tag():
        return r
    end
    return err_sem_exprs(kids, i + 1, n, env, nodes, prog_idx)
end

func err_sem_call_expr(name, kids, line, env, nodes, prog_idx):
    if equal(name, "new_array"):
        return err_check_ok()
    end
    if err_is_void_builtin(name):
        return err_check_fail_at(308, line, name)
    end
    if err_is_value_builtin(name):
        let args = err_sem_exprs(kids, 0, count(kids), env, nodes, prog_idx)
        if args.0 == err_err_tag():
            return args
        end
        if equal(name, "slice"):
            return err_check_ok()
        end
        if count(kids) != err_value_builtin_arity(name):
            return err_check_fail_at(306, line, name)
        end
        return err_check_ok()
    end
    let found = err_func_lookup(nodes, prog_idx, name)
    if found.0 == 0:
        return err_check_fail_at(304, line, name)
    end
    if found.1 != count(kids):
        return err_check_fail_at(305, line, name)
    end
    return err_sem_exprs(kids, 0, count(kids), env, nodes, prog_idx)
end

func err_sem_expr(node_idx, env, nodes, prog_idx):
    let node = get(nodes, node_idx)
    let tag = node.0
    let atoms = node.1
    let kids = node.2
    let line = node.3
    if equal(tag, "int") or equal(tag, "char") or equal(tag, "str") or equal(tag, "bool"):
        return err_check_ok()
    end
    if equal(tag, "name"):
        if not err_env_lookup(env, get(atoms, 0)):
            return err_check_fail_at(302, line, get(atoms, 0))
        end
        return err_check_ok()
    end
    if equal(tag, "call"):
        return err_sem_call_expr(get(atoms, 0), kids, line, env, nodes, prog_idx)
    end
    if equal(tag, "not") or equal(tag, "dot"):
        return err_sem_expr(get(kids, 0), env, nodes, prog_idx)
    end
    if equal(tag, "tuple"):
        return err_sem_exprs(kids, 0, count(kids), env, nodes, prog_idx)
    end
    if equal(tag, "and") or equal(tag, "or") or equal(tag, "add") or equal(tag, "sub") or equal(tag, "mul") or equal(tag, "div") or equal(tag, "mod") or equal(tag, "eq") or equal(tag, "ne") or equal(tag, "lt") or equal(tag, "le") or equal(tag, "gt") or equal(tag, "ge"):
        let left = err_sem_expr(get(kids, 0), env, nodes, prog_idx)
        if left.0 == err_err_tag():
            return left
        end
        return err_sem_expr(get(kids, 1), env, nodes, prog_idx)
    end
    return err_check_ok()
end

func err_sem_do_call(call_idx, do_line, env, nodes, prog_idx):
    let node = get(nodes, call_idx)
    if not equal(node.0, "call"):
        return err_check_fail_at(310, node.3, "")
    end
    let name = get(node.1, 0)
    let kids = node.2
    if not err_is_void_builtin(name):
        return err_check_fail_at(310, node.3, name)
    end
    let args = err_sem_exprs(kids, 0, count(kids), env, nodes, prog_idx)
    if args.0 == err_err_tag():
        return args
    end
    if count(kids) != err_void_builtin_arity(name):
        return err_check_fail_at(307, do_line, name)
    end
    return err_check_ok()
end

func err_sem_body(stmts, i, n, env, scope_mark, nodes, prog_idx):
    if i >= n:
        return err_env_ok(env)
    end
    let r = err_sem_stmt(get(stmts, i), env, scope_mark, nodes, prog_idx)
    if r.0 == err_err_tag():
        return r
    end
    return err_sem_body(stmts, i + 1, n, r.2, scope_mark, nodes, prog_idx)
end

func err_sem_if_arms(kids, i, n, env, nodes, prog_idx):
    if i >= n:
        return err_env_ok(env)
    end
    let arm = get(nodes, get(kids, i))
    let arm_mark = count(env)
    if equal(arm.0, "else"):
        let body = get(nodes, get(arm.2, 0))
        let br = err_sem_body(body.2, 0, count(body.2), env, arm_mark, nodes, prog_idx)
        if br.0 == err_err_tag():
            return br
        end
        env = err_env_rebuild(br.2, arm_mark)
        return err_sem_if_arms(kids, i + 1, n, env, nodes, prog_idx)
    end
    let cr = err_sem_expr(get(arm.2, 0), env, nodes, prog_idx)
    if cr.0 == err_err_tag():
        return err_env_fail(cr.1)
    end
    let body = get(nodes, get(arm.2, 1))
    let br = err_sem_body(body.2, 0, count(body.2), env, arm_mark, nodes, prog_idx)
    if br.0 == err_err_tag():
        return br
    end
    env = err_env_rebuild(br.2, arm_mark)
    return err_sem_if_arms(kids, i + 1, n, env, nodes, prog_idx)
end

func err_sem_stmt(stmt_idx, env, scope_mark, nodes, prog_idx):
    let stmt = get(nodes, stmt_idx)
    let tag = stmt.0
    let atoms = stmt.1
    let kids = stmt.2
    let line = stmt.3
    if equal(tag, "let"):
        let expr = err_sem_expr(get(kids, 0), env, nodes, prog_idx)
        if expr.0 == err_err_tag():
            return err_env_fail(expr.1)
        end
        let name = get(atoms, 0)
        if err_name_seen_loop(env, scope_mark, count(env), name):
            return err_env_fail_at(301, line, name)
        end
        do add(env, name)
        return err_env_ok(env)
    end
    if equal(tag, "assign"):
        let expr = err_sem_expr(get(kids, 0), env, nodes, prog_idx)
        if expr.0 == err_err_tag():
            return err_env_fail(expr.1)
        end
        if not err_env_lookup(env, get(atoms, 0)):
            return err_env_fail_at(303, line, get(atoms, 0))
        end
        return err_env_ok(env)
    end
    if equal(tag, "return"):
        let expr = err_sem_expr(get(kids, 0), env, nodes, prog_idx)
        if expr.0 == err_err_tag():
            return err_env_fail(expr.1)
        end
        return err_env_ok(env)
    end
    if equal(tag, "do"):
        let d = err_sem_do_call(get(kids, 0), line, env, nodes, prog_idx)
        if d.0 == err_err_tag():
            return err_env_fail(d.1)
        end
        return err_env_ok(env)
    end
    if equal(tag, "if"):
        return err_sem_if_arms(kids, 0, count(kids), env, nodes, prog_idx)
    end
    return err_env_ok(env)
end

func err_body_returns(body_idx, nodes):
    let body = get(nodes, body_idx)
    return err_body_returns_loop(body.2, 0, count(body.2), nodes)
end

func err_body_returns_loop(stmts, i, n, nodes):
    if i >= n:
        return false
    end
    let stmt = get(nodes, get(stmts, i))
    if equal(stmt.0, "return"):
        return true
    end
    if equal(stmt.0, "if") and err_if_returns(stmt.2, nodes):
        return true
    end
    return err_body_returns_loop(stmts, i + 1, n, nodes)
end

func err_if_returns(kids, nodes):
    if count(kids) == 0:
        return false
    end
    let last = get(nodes, get(kids, count(kids) - 1))
    if not equal(last.0, "else"):
        return false
    end
    return err_if_arms_return_loop(kids, 0, count(kids), nodes)
end

func err_if_arms_return_loop(kids, i, n, nodes):
    if i >= n:
        return true
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        body_idx = get(arm.2, 1)
    end
    if not err_body_returns(body_idx, nodes):
        return false
    end
    return err_if_arms_return_loop(kids, i + 1, n, nodes)
end

func err_sem_func(func_idx, nodes, prog_idx):
    let fn = get(nodes, func_idx)
    let params_node = get(nodes, get(fn.2, 0))
    let body_node = get(nodes, get(fn.2, 1))
    let env = err_env_from_params(params_node.1)
    let body_result = err_sem_body(body_node.2, 0, count(body_node.2), env, 0, nodes, prog_idx)
    if body_result.0 == err_err_tag():
        return err_check_fail(body_result.1)
    end
    if not err_body_returns(get(fn.2, 1), nodes):
        return err_check_fail_at(316, fn.3, get(fn.1, 0))
    end
    return err_check_ok()
end

func err_sem_funcs_loop(func_kids, i, n, nodes, prog_idx):
    if i >= n:
        return err_check_ok()
    end
    let r = err_sem_func(get(func_kids, i), nodes, prog_idx)
    if r.0 == err_err_tag():
        return r
    end
    return err_sem_funcs_loop(func_kids, i + 1, n, nodes, prog_idx)
end

func err_semantic_check(nodes, prog_idx):
    let prog = get(nodes, prog_idx)
    let pre = err_prepass(nodes, prog_idx)
    if pre.0 == err_err_tag():
        return err_check_fail(pre.1)
    end
    return err_sem_funcs_loop(prog.2, 0, count(prog.2), nodes, prog_idx)
end

-- ====================================================================
-- VM RUNTIME
-- ====================================================================

func tag_int():
    return 0
end

func tag_bool():
    return 1
end

func tag_string():
    return 2
end

func tag_buffer():
    return 3
end

func tag_tuple():
    return 4
end

func tag_array():
    return 5
end

func make_int_value(n):
    return (tag_int(), n)
end

func make_bool_value(b):
    if b:
        return (tag_bool(), 1)
    end
    return (tag_bool(), 0)
end

func make_string_value(i):
    return (tag_string(), i)
end

func make_buffer_value(i):
    return (tag_buffer(), i)
end

func make_tuple_value(i):
    return (tag_tuple(), i)
end

func make_array_value(i):
    return (tag_array(), i)
end

func require_int_payload(v):
    if v.0 != tag_int():
        return fault("expected int")
    end
    return v.1
end

func require_bool_test(v):
    if v.0 != tag_bool():
        return fault("expected bool")
    end
    return v.1 != 0
end

func builtin_length(args, pools):
    if count(args) != 1:
        return fault("length arity")
    end
    let v = get(args, 0)
    if v.0 != tag_string():
        return fault("length type")
    end
    return make_int_value(length(get(pools.0, v.1)))
end

func builtin_index(args, pools):
    if count(args) != 2:
        return fault("index arity")
    end
    let sv = get(args, 0)
    let pos = require_int_payload(get(args, 1))
    if sv.0 != tag_string():
        return fault("index type")
    end
    let s = get(pools.0, sv.1)
    if pos >= length(s):
        return fault("index range")
    end
    return make_int_value(index(s, pos))
end

func builtin_equal(args, pools):
    if count(args) != 2:
        return fault("equal arity")
    end
    let a = get(args, 0)
    let b = get(args, 1)
    if a.0 != tag_string():
        return fault("equal type")
    end
    if b.0 != tag_string():
        return fault("equal type")
    end
    return make_bool_value(equal(get(pools.0, a.1), get(pools.0, b.1)))
end

func builtin_new_buffer(args, pools):
    if count(args) != 0:
        return fault("new_buffer arity")
    end
    do add(pools.1, new_buffer())
    return make_buffer_value(count(pools.1) - 1)
end

func builtin_freeze(args, pools):
    if count(args) != 1:
        return fault("freeze arity")
    end
    let v = get(args, 0)
    if v.0 != tag_buffer():
        return fault("freeze type")
    end
    do add(pools.0, freeze(get(pools.1, v.1)))
    return make_string_value(count(pools.0) - 1)
end

func builtin_clogger(pools):
    let cell = pools.4
    if count(cell) >= 2:
        do add(pools.0, slice_text("", 0, 0))
        return make_string_value(count(pools.0) - 1)
    end
    do add(cell, 1)
    return make_string_value(get(cell, 0))
end

func builtin_get(args, pools):
    if count(args) != 2:
        return fault("get arity")
    end
    let av = get(args, 0)
    let pos = require_int_payload(get(args, 1))
    if av.0 != tag_array():
        return fault("get type")
    end
    let arr = get(pools.3, av.1)
    if pos >= count(arr):
        return fault("get range")
    end
    return get(arr, pos)
end

func builtin_count(args, pools):
    if count(args) != 1:
        return fault("count arity")
    end
    let av = get(args, 0)
    if av.0 != tag_array():
        return fault("count type")
    end
    return make_int_value(count(get(pools.3, av.1)))
end

func eval_do_append(args, pools):
    if count(args) != 2:
        return fault("append arity")
    end
    let bv = get(args, 0)
    let byte = require_int_payload(get(args, 1))
    if bv.0 != tag_buffer():
        return fault("append type")
    end
    if byte > 255:
        return fault("append byte")
    end
    do append(get(pools.1, bv.1), byte)
    return make_int_value(0)
end

func eval_do_add(args, pools):
    if count(args) != 2:
        return fault("add arity")
    end
    let av = get(args, 0)
    if av.0 != tag_array():
        return fault("add type")
    end
    do add(get(pools.3, av.1), get(args, 1))
    return make_int_value(0)
end

func eval_do_flogger(args, pools):
    if count(args) != 1:
        return fault("flogger arity")
    end
    let v = get(args, 0)
    if v.0 != tag_string():
        return fault("flogger type")
    end
    do flogger(get(pools.0, v.1))
    return make_int_value(0)
end

func serialize_tuple_items(buf, items, i, n, pools):
    if i >= n:
        return buf
    end
    if i > 0:
        do append(buf, ' ')
    end
    buf = serialize_value_into(buf, get(items, i), pools)
    return serialize_tuple_items(buf, items, i + 1, n, pools)
end

func serialize_value_into(buf, v, pools):
    if v.0 == tag_int():
        return emit_decimal(buf, v.1)
    end
    if v.0 == tag_tuple():
        do append(buf, '(')
        let items = get(pools.2, v.1)
        buf = serialize_tuple_items(buf, items, 0, count(items), pools)
        do append(buf, ')')
        return buf
    end
    if v.0 == tag_string():
        return append_str(buf, get(pools.0, v.1))
    end
    return fault("serialize value")
end

func serialize_value(v, pools):
    return freeze(serialize_value_into(new_buffer(), v, pools))
end

-- ====================================================================
-- VM STACK / FRAME HELPERS
-- ====================================================================

func value_array_prefix_loop(src, i, n, out):
    if i >= n:
        return out
    end
    do add(out, get(src, i))
    return value_array_prefix_loop(src, i + 1, n, out)
end

func value_array_prefix(src, n):
    return value_array_prefix_loop(src, 0, n, new_array((int, int)))
end

func value_array_slice_loop(src, i, n, out):
    if i >= n:
        return out
    end
    do add(out, get(src, i))
    return value_array_slice_loop(src, i + 1, n, out)
end

func stack_pop(stack):
    let n = count(stack)
    let v = get(stack, n - 1)
    return (value_array_prefix(stack, n - 1), v)
end

func stack_pop_n(stack, n):
    let live = count(stack) - n
    let args = value_array_slice_loop(stack, live, count(stack), new_array((int, int)))
    return (value_array_prefix(stack, live), args)
end

func locals_store_loop(old, k, v, i, n, out):
    if i >= n:
        return out
    end
    if i == k:
        do add(out, v)
    else:
        do add(out, get(old, i))
    end
    return locals_store_loop(old, k, v, i + 1, n, out)
end

func locals_store(old, k, v):
    return locals_store_loop(old, k, v, 0, count(old), new_array((int, int)))
end

func zero_locals_loop(i, n, out):
    if i >= n:
        return out
    end
    do add(out, make_int_value(0))
    return zero_locals_loop(i + 1, n, out)
end

func zero_locals(n):
    return zero_locals_loop(0, n, new_array((int, int)))
end

func callee_locals_loop(args, i, n_locals, out):
    if i >= n_locals:
        return out
    end
    if i < count(args):
        do add(out, get(args, i))
    else:
        do add(out, make_int_value(0))
    end
    return callee_locals_loop(args, i + 1, n_locals, out)
end

func callee_locals(args, n_params, n_locals):
    if count(args) != n_params:
        return fault("call arity")
    end
    return callee_locals_loop(args, 0, n_locals, new_array((int, int)))
end

func frame_array_prefix_loop(src, i, n, out):
    if i >= n:
        return out
    end
    do add(out, get(src, i))
    return frame_array_prefix_loop(src, i + 1, n, out)
end

func frame_array_prefix(src, n):
    return frame_array_prefix_loop(src, 0, n, new_array((int, int, array((int, int)), array((int, int)))))
end

func frame_stack_pop(frames):
    let n = count(frames)
    let f = get(frames, n - 1)
    return (frame_array_prefix(frames, n - 1), f)
end

func boot_strings_loop(src, i, n, out):
    if i >= n:
        return out
    end
    do add(out, get(src, i))
    return boot_strings_loop(src, i + 1, n, out)
end

func boot_strings(src):
    return boot_strings_loop(src, 0, count(src), new_array(string))
end

func args_empty():
    return new_array((int, int))
end

func builtin_new_array(pools):
    do add(pools.3, new_array((int, int)))
    return make_array_value(count(pools.3) - 1)
end

-- ====================================================================
-- VM EXECUTION
-- ====================================================================

func int_binop(op, lhs_v, rhs_v):
    let lhs = require_int_payload(lhs_v)
    let rhs = require_int_payload(rhs_v)
    if op == 5:
        return make_int_value(lhs + rhs)
    end
    if op == 6:
        return make_int_value(lhs - rhs)
    end
    if op == 7:
        return make_bool_value(lhs < rhs)
    end
    if op == 8:
        return make_bool_value(lhs <= rhs)
    end
    if op == 9:
        return make_bool_value(lhs > rhs)
    end
    if op == 10:
        return make_bool_value(lhs >= rhs)
    end
    if op == 11:
        return make_bool_value(lhs == rhs)
    end
    if op == 12:
        return make_bool_value(lhs != rhs)
    end
    -- Bitwise / shift binops (opcodes 36-40). Now that the language itself has
    -- these operators, the meta-circular VM implements them directly. Shift
    -- counts are masked to 6 bits (`rhs & 63`) to match both the C oracle and
    -- the x86 `shl/shr r/m64, cl` hardware masking; `>>` is logical.
    if op == 36:
        return make_int_value(lhs & rhs)
    end
    if op == 37:
        return make_int_value(lhs | rhs)
    end
    if op == 38:
        return make_int_value(lhs ^ rhs)
    end
    if op == 39:
        return make_int_value(lhs << (rhs & 63))
    end
    if op == 40:
        return make_int_value(lhs >> (rhs & 63))
    end
    -- Multiplicative binops (opcodes 42-44). mul keeps the low 64 bits (u64
    -- modular-wrap product); div/mod are unsigned 64-bit quotient/remainder and
    -- fault cleanly on a zero divisor (matching the C oracle and the native
    -- zero-check) rather than dividing by zero.
    if op == 42:
        return make_int_value(lhs * rhs)
    end
    if op == 43:
        if rhs == 0:
            return fault("division by zero")
        end
        return make_int_value(lhs / rhs)
    end
    if rhs == 0:
        return fault("division by zero")
    end
    return make_int_value(lhs % rhs)
end

func vm_push_result(frame, frames, pools, prog, v):
    do add(frame.3, v)
    return vm_loop((frame.0, frame.1 + 1, frame.2, frame.3), frames, pools, prog)
end

func vm_unary_builtin(frame, frames, pools, prog, builtin_id):
    let popped = stack_pop(frame.3)
    let args = new_array((int, int))
    do add(args, popped.1)
    if builtin_id == 22:
        do add(popped.0, builtin_length(args, pools))
    elif builtin_id == 27:
        do add(popped.0, builtin_freeze(args, pools))
    else:
        do add(popped.0, builtin_count(args, pools))
    end
    return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
end

func vm_binary_builtin(frame, frames, pools, prog, builtin_id):
    let popped = stack_pop_n(frame.3, 2)
    if builtin_id == 23:
        do add(popped.0, builtin_index(popped.1, pools))
    elif builtin_id == 25:
        do add(popped.0, builtin_equal(popped.1, pools))
    else:
        do add(popped.0, builtin_get(popped.1, pools))
    end
    return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
end

func vm_loop(frame, frames, pools, prog):
    let fn_info = get(prog.0, frame.0)
    let instr = get(prog.1, fn_info.0 + frame.1)
    let op = instr.0
    let a = instr.1
    let b = instr.2

    if op == 0:
        return vm_push_result(frame, frames, pools, prog, make_int_value(a))
    end
    if op == 1:
        return vm_push_result(frame, frames, pools, prog, make_bool_value(a != 0))
    end
    if op == 2:
        return vm_push_result(frame, frames, pools, prog, make_string_value(a))
    end
    if op == 3:
        return vm_push_result(frame, frames, pools, prog, get(frame.2, a))
    end
    if op == 4:
        let popped = stack_pop(frame.3)
        let locals = locals_store(frame.2, a, popped.1)
        return vm_loop((frame.0, frame.1 + 1, locals, popped.0), frames, pools, prog)
    end
    if op >= 5 and op <= 12:
        let rhs_popped = stack_pop(frame.3)
        let lhs_popped = stack_pop(rhs_popped.0)
        do add(lhs_popped.0, int_binop(op, lhs_popped.1, rhs_popped.1))
        return vm_loop((frame.0, frame.1 + 1, frame.2, lhs_popped.0), frames, pools, prog)
    end
    if op >= 36 and op <= 40:
        let rhs_popped = stack_pop(frame.3)
        let lhs_popped = stack_pop(rhs_popped.0)
        do add(lhs_popped.0, int_binop(op, lhs_popped.1, rhs_popped.1))
        return vm_loop((frame.0, frame.1 + 1, frame.2, lhs_popped.0), frames, pools, prog)
    end
    if op >= 42 and op <= 44:
        let rhs_popped = stack_pop(frame.3)
        let lhs_popped = stack_pop(rhs_popped.0)
        do add(lhs_popped.0, int_binop(op, lhs_popped.1, rhs_popped.1))
        return vm_loop((frame.0, frame.1 + 1, frame.2, lhs_popped.0), frames, pools, prog)
    end
    if op == 13:
        let popped = stack_pop(frame.3)
        do add(popped.0, make_bool_value(not require_bool_test(popped.1)))
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 41:
        let popped = stack_pop(frame.3)
        do add(popped.0, make_int_value(~require_int_payload(popped.1)))
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 14:
        let popped = stack_pop_n(frame.3, a)
        do add(pools.2, popped.1)
        do add(popped.0, make_tuple_value(count(pools.2) - 1))
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 15:
        let popped = stack_pop(frame.3)
        let tv = popped.1
        if tv.0 != tag_tuple():
            return fault("tuple get type")
        end
        let items = get(pools.2, tv.1)
        if a >= count(items):
            return fault("tuple get range")
        end
        do add(popped.0, get(items, a))
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 16:
        return vm_loop((frame.0, a, frame.2, frame.3), frames, pools, prog)
    end
    if op == 17:
        let popped = stack_pop(frame.3)
        if require_bool_test(popped.1):
            return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
        end
        return vm_loop((frame.0, a, frame.2, popped.0), frames, pools, prog)
    end
    if op == 18:
        let top = get(frame.3, count(frame.3) - 1)
        if not require_bool_test(top):
            return vm_loop((frame.0, a, frame.2, frame.3), frames, pools, prog)
        end
        let popped = stack_pop(frame.3)
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 19:
        let top = get(frame.3, count(frame.3) - 1)
        if require_bool_test(top):
            return vm_loop((frame.0, a, frame.2, frame.3), frames, pools, prog)
        end
        let popped = stack_pop(frame.3)
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 20:
        let popped = stack_pop_n(frame.3, b)
        let callee_info = get(prog.0, a)
        let locals = callee_locals(popped.1, callee_info.1, callee_info.2)
        -- Tail-position dispatch: if the instruction after this CALL is RET
        -- (op 21), the caller would only forward our result one level up, so
        -- elide its frame and let the callee RET straight to the grandcaller.
        -- Precondition: every function's terminal instruction is RET (enforced
        -- by ERR 316), so a CALL is never a function's last instruction and this
        -- peek never crosses a function boundary.
        if get(prog.1, fn_info.0 + frame.1 + 1).0 != 21:
            do add(frames, (frame.0, frame.1 + 1, frame.2, popped.0))
        end
        return vm_loop((a, 0, locals, new_array((int, int))), frames, pools, prog)
    end
    if op == 21:
        let popped = stack_pop(frame.3)
        if count(frames) == 0:
            return popped.1
        end
        let fp = frame_stack_pop(frames)
        let caller = fp.1
        do add(caller.3, popped.1)
        return vm_loop((caller.0, caller.1, caller.2, caller.3), fp.0, pools, prog)
    end
    if op == 22:
        return vm_unary_builtin(frame, frames, pools, prog, 22)
    end
    if op == 23:
        return vm_binary_builtin(frame, frames, pools, prog, 23)
    end
    if op == 24:
        return fault("slice deferred")
    end
    if op == 25:
        return vm_binary_builtin(frame, frames, pools, prog, 25)
    end
    if op == 26:
        return vm_push_result(frame, frames, pools, prog, builtin_new_buffer(args_empty(), pools))
    end
    if op == 27:
        return vm_unary_builtin(frame, frames, pools, prog, 27)
    end
    if op == 28:
        return vm_push_result(frame, frames, pools, prog, builtin_new_array(pools))
    end
    if op == 29:
        return vm_binary_builtin(frame, frames, pools, prog, 29)
    end
    if op == 30:
        return vm_unary_builtin(frame, frames, pools, prog, 30)
    end
    if op == 31:
        let popped = stack_pop_n(frame.3, 2)
        let ignored = eval_do_append(popped.1, pools)
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 32:
        let popped = stack_pop_n(frame.3, 2)
        let ignored = eval_do_add(popped.1, pools)
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    if op == 33:
        return vm_push_result(frame, frames, pools, prog, builtin_clogger(pools))
    end
    if op == 34:
        let popped = stack_pop_n(frame.3, 1)
        let ignored = eval_do_flogger(popped.1, pools)
        return vm_loop((frame.0, frame.1 + 1, frame.2, popped.0), frames, pools, prog)
    end
    return fault("bad opcode")
end

-- ====================================================================
-- EMITTER-TO-VM ADAPTER
-- ====================================================================

func adapt_function_table_loop(funcs, i, n, out):
    if i >= n:
        return out
    end
    let fn = get(funcs, i)
    do add(out, (fn.1, fn.2, fn.3))
    return adapt_function_table_loop(funcs, i + 1, n, out)
end

func adapt_code_loop(code, i, n, out):
    if i >= n:
        return out
    end
    do add(out, get(code, i))
    return adapt_code_loop(code, i + 1, n, out)
end

func adapt_instructions_loop(funcs, i, n, out):
    if i >= n:
        return out
    end
    let fn = get(funcs, i)
    out = adapt_code_loop(fn.4, 0, count(fn.4), out)
    return adapt_instructions_loop(funcs, i + 1, n, out)
end

func adapt_program(eprog):
    let funcs = eprog.0
    let function_table = new_array((int, int, int))
    function_table = adapt_function_table_loop(funcs, 0, count(funcs), function_table)
    let instructions = new_array((int, int, int))
    instructions = adapt_instructions_loop(funcs, 0, count(funcs), instructions)
    return (function_table, instructions, eprog.1, eprog.2)
end

-- ====================================================================
-- MAIN -- compile the embedded pipeline probe, adapt it, execute it in
-- the Herbert VM, and return the VM serialization as a string.
-- ====================================================================

-- ====================================================================
-- NATIVE CODEGEN LINK 4 BACK END
-- ====================================================================

func nc_diag_msg(code, payload):
    if code == 401:
        return "native-subset: bare clogger() call not allowed; use let h=clogger() then index(h,k)"
    end
    if code == 402:
        return "native-subset: index() must be called as index(<input-handle>,<int-literal>)"
    end
    if code == 403:
        return "native-subset: input handle must only be used as index(h,k); cannot return/pass/use-in-arithmetic/re-store it"
    end
    if code == 404:
        return diagnostic_with_payload("native-subset: forbidden construct '", payload, "'")
    end
    if code == 408:
        return diagnostic_with_payload("native-subset: forbidden bytecode opcode '", payload, "'")
    end
    if code == 409:
        return diagnostic_with_payload("native-subset: user-defined function calls are forbidden '", payload, "'")
    end
    if code == 411:
        return "native-subset: more than one clogger() call is not allowed"
    end
    if code == 412:
        return diagnostic_with_payload("native-subset: expected int expression", payload, "")
    end
    if code == 413:
        return diagnostic_with_payload("native-subset: expected bool expression", payload, "")
    end
    if code == 414:
        return "native-subset: branch join has conflicting local classes"
    end
    if code == 415:
        return diagnostic_with_payload("native-subset: invalid branch target ", payload, "")
    end
    if code == 416:
        return "native-subset: stack depth mismatch or underflow"
    end
    if code == 417:
        return "native-subset: bad push_bool payload"
    end
    if code == 418:
        return diagnostic_with_payload("native-subset: native layout invariant failed ", payload, "")
    end
    if code == 419:
        return diagnostic_with_payload("native-subset: unknown callee '", payload, "'")
    end
    if code == 420:
        return diagnostic_with_payload("native-subset: arity mismatch at call to '", payload, "'")
    end
    if code == 421:
        return "native-subset: user functions may not call main"
    end
    if code == 422:
        return "native-subset: argument/parameter class conflict"
    end
    if code == 423:
        return "native-subset: return class conflict"
    end
    if code == 424:
        return "native-subset: ambiguous or unconstrained function signature"
    end
    if code == 425:
        return "native-subset: input handle crosses a function boundary"
    end
    if code == 426:
        return "native-subset: invalid bytecode CALL target or arity"
    end
    if code == 427:
        return "native-subset: call/jmp/branch rel32 out of range"
    end
    if code == 428:
        return "native-subset: frame, signed displacement, or layout overflow"
    end
    if code == 429:
        return "native-subset: invalid function table"
    end
    if code == 430:
        return "native-subset: structural type conflict"
    end
    if code == 431:
        return "native-subset: tuple access on non-tuple or out of range"
    end
    if code == 432:
        return "native-subset: main must return int or bool"
    end
    if code == 433:
        return "native-subset: local rebind changes value width"
    end
    if code == 434:
        return "native-subset: invalid new_array type expression"
    end
    if code == 435:
        return "native-subset: array operation on non-array"
    end
    if code == 436:
        return "native-subset: array element type mismatch"
    end
    if code == 437:
        return "native-subset: buffer operation on non-buffer"
    end
    if code == 438:
        return "native-subset: deferred native operation"
    end
    if code == 439:
        return "native-subset: missing NEW_ARRAY metadata"
    end
    if code == 440:
        return "native-subset: value-less builtin used as a value"
    end
    if code == 441:
        return "native-subset: polymorphic instantiation does not terminate"
    end
    if code == 442:
        return "native-subset: bitwise/shift operator mixed with another operator class without parentheses"
    end
    return "native-subset: unknown error"
end

func nc_serialize_diag(code, line, payload):
    let msg = nc_diag_msg(code, payload)
    let buf = new_buffer()
    if line > 0:
        buf = append_str(buf, "line ")
        buf = append_str(buf, int_to_str(line))
        buf = append_str(buf, ": ")
    else:
        buf = append_str(buf, "program: ")
    end
    buf = append_str(buf, msg)
    buf = append_str(buf, " (ERR ")
    buf = append_str(buf, int_to_str(code))
    buf = append_str(buf, ")")
    return freeze(buf)
end

func nc_fail(code, line, payload):
    do flogger(nc_serialize_diag(code, line, payload))
    do flogger("\n")
    return 1
end

func nc_type_unknown():
    return 0
end

func nc_type_int():
    return 1
end

func nc_type_bool():
    return 2
end

func nc_type_string():
    return 3
end

func nc_type_buffer():
    return 4
end

func nc_type_struct_base():
    return 5
end

func nc_type_pool_new():
    return new_array((int, array(int)))
end

func nc_type_kind(pool, t):
    if t < nc_type_struct_base():
        return 0
    end
    return get(pool, t - nc_type_struct_base()).0
end

func nc_type_children(pool, t):
    return get(pool, t - nc_type_struct_base()).1
end

func nc_type_is_tuple(pool, t):
    return nc_type_kind(pool, t) == 1
end

func nc_type_is_array(pool, t):
    return nc_type_kind(pool, t) == 2
end

func nc_type_tuple_children(pool, t):
    return nc_type_children(pool, t)
end

func nc_type_array_elem(pool, t):
    return get(nc_type_children(pool, t), 0)
end

func nc_type_equal_children(pool, a, b, i, n):
    if i >= n:
        return true
    end
    if not nc_type_equal(pool, get(a, i), get(b, i)):
        return false
    end
    return nc_type_equal_children(pool, a, b, i + 1, n)
end

func nc_type_equal(pool, a, b):
    if a == b:
        return true
    end
    if nc_type_kind(pool, a) != 0 and nc_type_kind(pool, a) == nc_type_kind(pool, b):
        let ca = nc_type_children(pool, a)
        let cb = nc_type_children(pool, b)
        if count(ca) != count(cb):
            return false
        end
        return nc_type_equal_children(pool, ca, cb, 0, count(ca))
    end
    return false
end

func nc_type_tuple_matches_loop(pool, children, existing, i, n):
    if i >= n:
        return true
    end
    if not nc_type_equal(pool, get(children, i), get(existing, i)):
        return false
    end
    return nc_type_tuple_matches_loop(pool, children, existing, i + 1, n)
end

func nc_type_struct_matches(pool, kind, children, type_id):
    if nc_type_kind(pool, type_id) != kind:
        return false
    end
    let existing = nc_type_children(pool, type_id)
    if count(children) != count(existing):
        return false
    end
    return nc_type_tuple_matches_loop(pool, children, existing, 0, count(children))
end

func nc_type_intern_struct_loop(pool, kind, children, i, n):
    if i >= n:
        let id = count(pool) + nc_type_struct_base()
        do add(pool, (kind, children))
        return id
    end
    let tid = i + nc_type_struct_base()
    if nc_type_struct_matches(pool, kind, children, tid):
        return tid
    end
    return nc_type_intern_struct_loop(pool, kind, children, i + 1, n)
end

func nc_type_intern_tuple(pool, children):
    return nc_type_intern_struct_loop(pool, 1, children, 0, count(pool))
end

func nc_type_intern_array(pool, elem):
    let kids = new_array(int)
    do add(kids, elem)
    return nc_type_intern_struct_loop(pool, 2, kids, 0, count(pool))
end

func nc_type_width_tuple(pool, kids, i, n, acc):
    if i >= n:
        return acc
    end
    return nc_type_width_tuple(pool, kids, i + 1, n, acc + nc_type_width(pool, get(kids, i)))
end

func nc_type_width(pool, t):
    if t == nc_type_unknown():
        return 0
    end
    if t == nc_type_int() or t == nc_type_bool():
        return 1
    end
    if t == nc_type_string():
        return 2
    end
    if t == nc_type_buffer():
        return 1
    end
    if nc_type_is_array(pool, t):
        return 1
    end
    let kids = nc_type_tuple_children(pool, t)
    return nc_type_width_tuple(pool, kids, 0, count(kids), 0)
end

func nc_type_has_unknown_tuple(pool, kids, i, n):
    if i >= n:
        return false
    end
    if nc_type_has_unknown(pool, get(kids, i)):
        return true
    end
    return nc_type_has_unknown_tuple(pool, kids, i + 1, n)
end

func nc_type_has_unknown(pool, t):
    if t == nc_type_unknown():
        return true
    end
    if nc_type_kind(pool, t) != 0:
        let kids = nc_type_children(pool, t)
        return nc_type_has_unknown_tuple(pool, kids, 0, count(kids))
    end
    return false
end

func nc_type_vector_has_unknown(pool, vec, i, n):
    if i >= n:
        return false
    end
    if nc_type_has_unknown(pool, get(vec, i)):
        return true
    end
    return nc_type_vector_has_unknown(pool, vec, i + 1, n)
end

func nc_type_vector_equal_loop(pool, a, b, i, n):
    if i >= n:
        return true
    end
    if not nc_type_equal(pool, get(a, i), get(b, i)):
        return false
    end
    return nc_type_vector_equal_loop(pool, a, b, i + 1, n)
end

func nc_type_vector_equal(pool, a, b):
    if count(a) != count(b):
        return false
    end
    return nc_type_vector_equal_loop(pool, a, b, 0, count(a))
end

func nc_type_embeds_any_child(pool, a, kids, i, n):
    if i >= n:
        return false
    end
    if nc_type_embeds(pool, a, get(kids, i)):
        return true
    end
    return nc_type_embeds_any_child(pool, a, kids, i + 1, n)
end

func nc_type_embeds_tuple_positions(pool, a, b, i, n):
    if i >= n:
        return true
    end
    if not nc_type_embeds(pool, get(a, i), get(b, i)):
        return false
    end
    return nc_type_embeds_tuple_positions(pool, a, b, i + 1, n)
end

func nc_type_embeds(pool, a, b):
    if nc_type_equal(pool, a, b):
        return true
    end
    if nc_type_is_tuple(pool, b):
        let bkids = nc_type_tuple_children(pool, b)
        if nc_type_embeds_any_child(pool, a, bkids, 0, count(bkids)):
            return true
        end
    end
    if nc_type_is_array(pool, b):
        if nc_type_embeds(pool, a, nc_type_array_elem(pool, b)):
            return true
        end
    end
    if nc_type_is_tuple(pool, a) and nc_type_is_tuple(pool, b):
        let akids = nc_type_tuple_children(pool, a)
        let bkids2 = nc_type_tuple_children(pool, b)
        if count(akids) == count(bkids2):
            return nc_type_embeds_tuple_positions(pool, akids, bkids2, 0, count(akids))
        end
    end
    if nc_type_is_array(pool, a) and nc_type_is_array(pool, b):
        return nc_type_embeds(pool, nc_type_array_elem(pool, a), nc_type_array_elem(pool, b))
    end
    return false
end

func nc_poly_vector_embeds_loop(pool, old_args, new_args, i, n, strict):
    if i >= n:
        return strict
    end
    if not nc_type_embeds(pool, get(old_args, i), get(new_args, i)):
        return false
    end
    if not nc_type_equal(pool, get(old_args, i), get(new_args, i)):
        strict = true
    end
    return nc_poly_vector_embeds_loop(pool, old_args, new_args, i + 1, n, strict)
end

func nc_poly_vector_grows(pool, old_args, new_args):
    if count(old_args) != count(new_args):
        return false
    end
    return nc_poly_vector_embeds_loop(pool, old_args, new_args, 0, count(old_args), false)
end

func nc_type_merge_possible_children(pool, a, b, i, n):
    if i >= n:
        return true
    end
    if not nc_type_merge_possible(pool, get(a, i), get(b, i)):
        return false
    end
    return nc_type_merge_possible_children(pool, a, b, i + 1, n)
end

func nc_type_merge_possible(pool, old, want):
    if old == nc_type_unknown() or want == nc_type_unknown():
        return true
    end
    if nc_type_equal(pool, old, want):
        return true
    end
    if nc_type_is_array(pool, old) and nc_type_is_array(pool, want):
        return nc_type_merge_possible(pool, nc_type_array_elem(pool, old), nc_type_array_elem(pool, want))
    end
    if nc_type_is_tuple(pool, old) and nc_type_is_tuple(pool, want):
        let oa = nc_type_tuple_children(pool, old)
        let wa = nc_type_tuple_children(pool, want)
        if count(oa) != count(wa):
            return false
        end
        return nc_type_merge_possible_children(pool, oa, wa, 0, count(oa))
    end
    return false
end

func nc_type_has_array_unknown(pool, t):
    if nc_type_is_array(pool, t):
        if nc_type_has_unknown(pool, nc_type_array_elem(pool, t)):
            return true
        end
    end
    if nc_type_is_tuple(pool, t):
        return nc_type_has_array_unknown_children(pool, nc_type_tuple_children(pool, t), 0, count(nc_type_tuple_children(pool, t)))
    end
    return false
end

func nc_type_has_array_unknown_children(pool, kids, i, n):
    if i >= n:
        return false
    end
    if nc_type_has_array_unknown(pool, get(kids, i)):
        return true
    end
    return nc_type_has_array_unknown_children(pool, kids, i + 1, n)
end

func nc_type_merge_children(pool, a, b, i, n, out, changed, line):
    if i >= n:
        return (0, out, changed)
    end
    let m = nc_type_merge(pool, get(a, i), get(b, i), line)
    if m.0 != 0:
        return (m.0, out, changed)
    end
    do add(out, m.1)
    return nc_type_merge_children(pool, a, b, i + 1, n, out, nc_or_changed(changed, m.2), line)
end

func nc_type_merge(pool, old, want, line):
    if want == nc_type_unknown():
        return (0, old, 0)
    end
    if old == nc_type_unknown():
        return (0, want, 1)
    end
    if nc_type_equal(pool, old, want):
        return (0, old, 0)
    end
    if nc_type_is_array(pool, old) and nc_type_is_array(pool, want):
        let merged_elem = nc_type_merge(pool, nc_type_array_elem(pool, old), nc_type_array_elem(pool, want), line)
        if merged_elem.0 != 0:
            return (nc_fail(436, line, ""), old, 0)
        end
        let aid = nc_type_intern_array(pool, merged_elem.1)
        if nc_type_equal(pool, aid, old):
            return (0, old, 0)
        end
        return (0, aid, 1)
    end
    if nc_type_is_tuple(pool, old) and nc_type_is_tuple(pool, want):
        let oa = nc_type_tuple_children(pool, old)
        let wa = nc_type_tuple_children(pool, want)
        if count(oa) != count(wa):
            return (nc_fail(430, line, ""), old, 0)
        end
        let merged = nc_type_merge_children(pool, oa, wa, 0, count(oa), new_array(int), 0, line)
        if merged.0 != 0:
            return (merged.0, old, 0)
        end
        let tid = nc_type_intern_tuple(pool, merged.1)
        if nc_type_equal(pool, tid, old):
            return (0, old, 0)
        end
        return (0, tid, 1)
    end
    return (nc_fail(430, line, ""), old, 0)
end

func nc_type_is_int_bool(t):
    return t == nc_type_int() or t == nc_type_bool()
end

func nc_type_from_type_expr_children(pool, nodes, kids, i, n, out, line):
    if i >= n:
        return (0, nc_type_intern_tuple(pool, out))
    end
    let r = nc_type_from_type_expr(pool, nodes, get(kids, i))
    if r.0 != 0:
        return r
    end
    do add(out, r.1)
    return nc_type_from_type_expr_children(pool, nodes, kids, i + 1, n, out, line)
end

func nc_type_from_type_expr(pool, nodes, type_idx):
    let node = get(nodes, type_idx)
    if equal(node.0, "type"):
        let name = get(node.1, 0)
        if equal(name, "int"):
            return (0, nc_type_int())
        end
        if equal(name, "bool"):
            return (0, nc_type_bool())
        end
        if equal(name, "string"):
            return (0, nc_type_string())
        end
        if equal(name, "buffer"):
            return (0, nc_type_buffer())
        end
        return (nc_fail(434, node.3, ""), 0)
    end
    if equal(node.0, "type-array"):
        if count(node.2) != 1:
            return (nc_fail(434, node.3, ""), 0)
        end
        let elem = nc_type_from_type_expr(pool, nodes, get(node.2, 0))
        if elem.0 != 0:
            return elem
        end
        return (0, nc_type_intern_array(pool, elem.1))
    end
    if equal(node.0, "type-tuple"):
        if count(node.2) < 2:
            return (nc_fail(434, node.3, ""), 0)
        end
        return nc_type_from_type_expr_children(pool, nodes, node.2, 0, count(node.2), new_array(int), node.3)
    end
    return (nc_fail(434, node.3, ""), 0)
end

func nc_assignment_type_ok(pool, old, got):
    if old == nc_type_unknown() or got == nc_type_unknown():
        return true
    end
    if nc_type_equal(pool, old, got):
        return true
    end
    return nc_type_is_int_bool(old) and nc_type_is_int_bool(got)
end

func nc_is_clogger_call(node):
    if not equal(node.0, "call"):
        return false
    end
    if not equal(get(node.1, 0), "clogger"):
        return false
    end
    return count(node.2) == 0
end

func nc_count_clogger_expr(nodes, idx):
    let node = get(nodes, idx)
    let tag = node.0
    let kids = node.2
    if equal(tag, "call"):
        let name = get(node.1, 0)
        if equal(name, "clogger"):
            return 1
        end
    end
    return nc_count_clogger_kids(nodes, kids, 0, count(kids))
end

func nc_count_clogger_kids(nodes, kids, i, n):
    if i >= n:
        return 0
    end
    return nc_count_clogger_expr(nodes, get(kids, i)) + nc_count_clogger_kids(nodes, kids, i + 1, n)
end

func nc_count_clogger_body(nodes, stmts, i, n):
    if i >= n:
        return 0
    end
    let stmt = get(nodes, get(stmts, i))
    let tag = stmt.0
    let kids = stmt.2
    let here = 0
    if equal(tag, "let") or equal(tag, "assign") or equal(tag, "return"):
        here = nc_count_clogger_expr(nodes, get(kids, 0))
    elif equal(tag, "if"):
        here = nc_count_clogger_if_arms(nodes, kids, 0, count(kids))
    elif equal(tag, "do"):
        here = nc_count_clogger_expr(nodes, get(kids, 0))
    end
    return here + nc_count_clogger_body(nodes, stmts, i + 1, n)
end

func nc_count_clogger_if_arms(nodes, kids, i, n):
    if i >= n:
        return 0
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    let here = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        here = nc_count_clogger_expr(nodes, get(arm.2, 0))
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    return here + nc_count_clogger_body(nodes, body.2, 0, count(body.2)) + nc_count_clogger_if_arms(nodes, kids, i + 1, n)
end

func nc_find_handle_loop(nodes, stmts, i, n, found_name, found_count):
    if i >= n:
        return (found_name, found_count)
    end
    let stmt = get(nodes, get(stmts, i))
    if equal(stmt.0, "let"):
        let rhs = get(nodes, get(stmt.2, 0))
        if nc_is_clogger_call(rhs):
            return nc_find_handle_loop(nodes, stmts, i + 1, n, get(stmt.1, 0), found_count + 1)
        end
    end
    return nc_find_handle_loop(nodes, stmts, i + 1, n, found_name, found_count)
end

func nc_class_env_new():
    return (new_array(string), new_array(int))
end

func nc_class_env_add(env, name, klass):
    do add(env.0, name)
    do add(env.1, klass)
    return env
end

func nc_class_env_clone_loop(env, i, n, names, classes):
    if i >= n:
        return (names, classes)
    end
    do add(names, get(env.0, i))
    do add(classes, get(env.1, i))
    return nc_class_env_clone_loop(env, i + 1, n, names, classes)
end

func nc_class_env_clone(env):
    return nc_class_env_clone_loop(env, 0, count(env.0), new_array(string), new_array(int))
end

func nc_class_env_prefix_loop(env, i, keep, names, classes):
    if i >= keep:
        return (names, classes)
    end
    do add(names, get(env.0, i))
    do add(classes, get(env.1, i))
    return nc_class_env_prefix_loop(env, i + 1, keep, names, classes)
end

func nc_class_env_prefix(env, keep):
    return nc_class_env_prefix_loop(env, 0, keep, new_array(string), new_array(int))
end

func nc_class_env_lookup_info_loop(names, classes, name, n):
    if n == 0:
        return (0, 0, 0)
    end
    let k = n - 1
    if equal(get(names, k), name):
        return (1, k, get(classes, k))
    end
    return nc_class_env_lookup_info_loop(names, classes, name, k)
end

func nc_class_env_lookup_info(env, name):
    return nc_class_env_lookup_info_loop(env.0, env.1, name, count(env.0))
end

func nc_int_array_set_loop(src, i, n, target, value, out):
    if i >= n:
        return out
    end
    if i == target:
        do add(out, value)
    else:
        do add(out, get(src, i))
    end
    return nc_int_array_set_loop(src, i + 1, n, target, value, out)
end

func nc_int_array_set(src, target, value):
    return nc_int_array_set_loop(src, 0, count(src), target, value, new_array(int))
end

func nc_array_int_set_loop(src, i, n, target, value, out):
    if i >= n:
        return out
    end
    if i == target:
        do add(out, value)
    else:
        do add(out, get(src, i))
    end
    return nc_array_int_set_loop(src, i + 1, n, target, value, out)
end

func nc_array_int_set(src, target, value):
    return nc_array_int_set_loop(src, 0, count(src), target, value, new_array(array(int)))
end

func nc_class_env_set_idx(env, idx, klass):
    return (env.0, nc_int_array_set(env.1, idx, klass))
end

func nc_make_unknowns_loop(i, n, out):
    if i >= n:
        return out
    end
    do add(out, 0)
    return nc_make_unknowns_loop(i + 1, n, out)
end

func nc_make_unknowns(n):
    return nc_make_unknowns_loop(0, n, new_array(int))
end

func nc_sig_init_loop(func_kids, i, n, nodes, params, returns):
    if i >= n:
        return (params, returns)
    end
    let fn = get(nodes, get(func_kids, i))
    let pn = get(nodes, get(fn.2, 0))
    do add(params, nc_make_unknowns(count(pn.1)))
    do add(returns, 0)
    return nc_sig_init_loop(func_kids, i + 1, n, nodes, params, returns)
end

func nc_sig_init(nodes, prog_idx):
    let prog = get(nodes, prog_idx)
    return nc_sig_init_loop(prog.2, 0, count(prog.2), nodes, new_array(array(int)), new_array(int))
end

func nc_sig_get_param(sig, fn_idx, param_idx):
    return get(get(sig.0, fn_idx), param_idx)
end

func nc_sig_get_ret(sig, fn_idx):
    return get(sig.1, fn_idx)
end

func nc_sig_set_param(sig, fn_idx, param_idx, klass):
    let parr = get(sig.0, fn_idx)
    let new_parr = nc_int_array_set(parr, param_idx, klass)
    return (nc_array_int_set(sig.0, fn_idx, new_parr), sig.1)
end

func nc_sig_set_ret(sig, fn_idx, klass):
    return (sig.0, nc_int_array_set(sig.1, fn_idx, klass))
end

func nc_poly_max_instances():
    return 4096
end

func nc_poly_lookup_instance_loop(pool, instances, base_fn_idx, params, i, n):
    if i >= n:
        return 0 - 1
    end
    let inst = get(instances, i)
    if inst.0 == base_fn_idx:
        if nc_type_vector_equal(pool, inst.1, params):
            return i
        end
    end
    return nc_poly_lookup_instance_loop(pool, instances, base_fn_idx, params, i + 1, n)
end

func nc_poly_lookup_instance(pool, instances, base_fn_idx, params):
    return nc_poly_lookup_instance_loop(pool, instances, base_fn_idx, params, 0, count(instances))
end

func nc_poly_guard_parent_chain(pool, instances, parent_idx, base_fn_idx, params, line):
    if parent_idx == 0 - 1:
        return 0
    end
    let parent = get(instances, parent_idx)
    if parent.0 == base_fn_idx:
        if nc_poly_vector_grows(pool, parent.1, params):
            return nc_fail(441, line, "")
        end
    end
    return nc_poly_guard_parent_chain(pool, instances, parent.5, base_fn_idx, params, line)
end

func nc_poly_make_instance(base_fn_idx, params, ret, depth, lowered_idx, parent_idx):
    return (base_fn_idx, params, ret, depth, lowered_idx, parent_idx)
end

func nc_poly_get_or_create(pool, poly, base_fn_idx, params, parent_idx, sig, line):
    let instances = poly.0
    let existing = nc_poly_lookup_instance(pool, instances, base_fn_idx, params)
    if existing != 0 - 1:
        return (0, existing, sig, 0)
    end
    if count(instances) >= nc_poly_max_instances():
        return (nc_fail(441, line, ""), 0, sig, 0)
    end
    let guard = nc_poly_guard_parent_chain(pool, instances, parent_idx, base_fn_idx, params, line)
    if guard != 0:
        return (guard, 0, sig, 0)
    end
    let depth = 0
    if parent_idx != 0 - 1:
        depth = get(instances, parent_idx).3 + 1
    end
    let lowered = count(instances)
    do add(instances, nc_poly_make_instance(base_fn_idx, params, nc_type_unknown(), depth, lowered, parent_idx))
    do add(sig.0, params)
    do add(sig.1, nc_type_unknown())
    return (0, lowered, sig, 1)
end

func nc_poly_call_target_find_loop(targets, caller_inst_idx, call_node_idx, i, n):
    if i >= n:
        return 0 - 1
    end
    let target = get(targets, i)
    if target.0 == caller_inst_idx and target.1 == call_node_idx:
        return i
    end
    return nc_poly_call_target_find_loop(targets, caller_inst_idx, call_node_idx, i + 1, n)
end

func nc_poly_call_target_find(targets, caller_inst_idx, call_node_idx):
    return nc_poly_call_target_find_loop(targets, caller_inst_idx, call_node_idx, 0, count(targets))
end

func nc_poly_record_call_target(poly, caller_inst_idx, call_node_idx, callee_inst_idx):
    let targets = poly.1
    let existing = nc_poly_call_target_find(targets, caller_inst_idx, call_node_idx)
    if existing == 0 - 1:
        do add(targets, (caller_inst_idx, call_node_idx, callee_inst_idx))
        return 0
    end
    let old = get(targets, existing)
    if old.2 != callee_inst_idx:
        return nc_fail(430, 0, "")
    end
    return 0
end

func nc_poly_lowered_call_target(poly, caller_inst_idx, call_node_idx):
    let targets = poly.1
    let existing = nc_poly_call_target_find(targets, caller_inst_idx, call_node_idx)
    if existing == 0 - 1:
        return fault("missing polymorphic call target")
    end
    return get(targets, existing).2
end

func nc_poly_seed_main(nodes, prog_idx):
    let main_lookup = nc_func_lookup(nodes, prog_idx, "main")
    let instances = new_array((int, array(int), int, int, int, int))
    let call_targets = new_array((int, int, int))
    let params = new_array(array(int))
    let returns = new_array(int)
    let empty = new_array(int)
    do add(instances, nc_poly_make_instance(main_lookup.1, empty, nc_type_unknown(), 0, 0, 0 - 1))
    do add(params, empty)
    do add(returns, nc_type_unknown())
    return ((params, returns), (instances, call_targets))
end

func nc_poly_current_base(funcs, fn_idx):
    return get(funcs.0, fn_idx).0
end

func nc_or_changed(a, b):
    if a != 0 or b != 0:
        return 1
    end
    return 0
end

func nc_func_lookup_loop(func_kids, i, n, name, nodes):
    if i >= n:
        return (0, 0, 0, 0)
    end
    let fn = get(nodes, get(func_kids, i))
    if equal(get(fn.1, 0), name):
        let pn = get(nodes, get(fn.2, 0))
        return (1, i, count(pn.1), fn.3)
    end
    return nc_func_lookup_loop(func_kids, i + 1, n, name, nodes)
end

func nc_func_lookup(nodes, prog_idx, name):
    let prog = get(nodes, prog_idx)
    return nc_func_lookup_loop(prog.2, 0, count(prog.2), name, nodes)
end

func nc_table_check_loop(func_kids, i, n, seen, nodes, main_count, main_params, main_line):
    if i >= n:
        if main_count != 1:
            return nc_fail(429, 0, "main")
        end
        if main_params != 0:
            return nc_fail(429, main_line, "main")
        end
        return 0
    end
    let fn = get(nodes, get(func_kids, i))
    let name = get(fn.1, 0)
    if err_is_builtin_name(name):
        return nc_fail(429, fn.3, name)
    end
    if err_name_seen(seen, name):
        return nc_fail(429, fn.3, name)
    end
    do add(seen, name)
    let pn = get(nodes, get(fn.2, 0))
    if equal(name, "main"):
        main_count = main_count + 1
        main_params = count(pn.1)
        main_line = fn.3
    end
    return nc_table_check_loop(func_kids, i + 1, n, seen, nodes, main_count, main_params, main_line)
end

func nc_table_check(nodes, prog_idx):
    let prog = get(nodes, prog_idx)
    return nc_table_check_loop(prog.2, 0, count(prog.2), new_array(string), nodes, 0, 0, 0)
end

func nc_expr_calls_name(nodes, idx, name):
    let node = get(nodes, idx)
    if equal(node.0, "call"):
        if equal(get(node.1, 0), name):
            return true
        end
    end
    return nc_kids_call_name(nodes, node.2, 0, count(node.2), name)
end

func nc_kids_call_name(nodes, kids, i, n, name):
    if i >= n:
        return false
    end
    if nc_expr_calls_name(nodes, get(kids, i), name):
        return true
    end
    return nc_kids_call_name(nodes, kids, i + 1, n, name)
end

func nc_body_calls_name(nodes, stmts, i, n, name):
    if i >= n:
        return false
    end
    let stmt = get(nodes, get(stmts, i))
    let tag = stmt.0
    if equal(tag, "let") or equal(tag, "assign") or equal(tag, "return") or equal(tag, "do"):
        if nc_expr_calls_name(nodes, get(stmt.2, 0), name):
            return true
        end
    elif equal(tag, "if"):
        if nc_if_calls_name(nodes, stmt.2, 0, count(stmt.2), name):
            return true
        end
    end
    return nc_body_calls_name(nodes, stmts, i + 1, n, name)
end

func nc_if_calls_name(nodes, kids, i, n, name):
    if i >= n:
        return false
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        if nc_expr_calls_name(nodes, get(arm.2, 0), name):
            return true
        end
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    if nc_body_calls_name(nodes, body.2, 0, count(body.2), name):
        return true
    end
    return nc_if_calls_name(nodes, kids, i + 1, n, name)
end

func nc_func_called_somewhere_loop(func_kids, i, n, nodes, name):
    if i >= n:
        return false
    end
    let fn = get(nodes, get(func_kids, i))
    let body = get(nodes, get(fn.2, 1))
    if nc_body_calls_name(nodes, body.2, 0, count(body.2), name):
        return true
    end
    return nc_func_called_somewhere_loop(func_kids, i + 1, n, nodes, name)
end

func nc_unreachable_check_loop(func_kids, i, n, nodes):
    if i >= n:
        return 0
    end
    let fn = get(nodes, get(func_kids, i))
    let name = get(fn.1, 0)
    if not equal(name, "main"):
        if not nc_func_called_somewhere_loop(func_kids, 0, n, nodes, name):
            return nc_fail(424, fn.3, "")
        end
    end
    return nc_unreachable_check_loop(func_kids, i + 1, n, nodes)
end

func nc_unreachable_check(nodes, prog_idx):
    let prog = get(nodes, prog_idx)
    return nc_unreachable_check_loop(prog.2, 0, count(prog.2), nodes)
end

func nc_expr_uses_name(nodes, idx, name):
    let node = get(nodes, idx)
    if equal(node.0, "name") and equal(get(node.1, 0), name):
        return true
    end
    return nc_kids_uses_name(nodes, node.2, 0, count(node.2), name)
end

func nc_kids_uses_name(nodes, kids, i, n, name):
    if i >= n:
        return false
    end
    if nc_expr_uses_name(nodes, get(kids, i), name):
        return true
    end
    return nc_kids_uses_name(nodes, kids, i + 1, n, name)
end

func nc_body_uses_name(nodes, stmts, i, n, name):
    if i >= n:
        return false
    end
    let stmt = get(nodes, get(stmts, i))
    let tag = stmt.0
    if equal(tag, "let") or equal(tag, "assign") or equal(tag, "return") or equal(tag, "do"):
        if nc_expr_uses_name(nodes, get(stmt.2, 0), name):
            return true
        end
    elif equal(tag, "if"):
        if nc_if_uses_name(nodes, stmt.2, 0, count(stmt.2), name):
            return true
        end
    end
    return nc_body_uses_name(nodes, stmts, i + 1, n, name)
end

func nc_if_uses_name(nodes, kids, i, n, name):
    if i >= n:
        return false
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        if nc_expr_uses_name(nodes, get(arm.2, 0), name):
            return true
        end
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    if nc_body_uses_name(nodes, body.2, 0, count(body.2), name):
        return true
    end
    return nc_if_uses_name(nodes, kids, i + 1, n, name)
end

-- zelph: never-returning-function (type-bottom) recognition.
func nc_expr_count_name(nodes, idx, name):
    let node = get(nodes, idx)
    if equal(node.0, "name") and equal(get(node.1, 0), name):
        return 1
    end
    return nc_kids_count_name(nodes, node.2, 0, count(node.2), name)
end

func nc_kids_count_name(nodes, kids, i, n, name):
    if i >= n:
        return 0
    end
    return nc_expr_count_name(nodes, get(kids, i), name) + nc_kids_count_name(nodes, kids, i + 1, n, name)
end

func nc_body_count_name(nodes, stmts, i, n, name):
    if i >= n:
        return 0
    end
    let stmt = get(nodes, get(stmts, i))
    let tag = stmt.0
    let here = 0
    if equal(tag, "let") or equal(tag, "assign") or equal(tag, "return") or equal(tag, "do"):
        here = nc_expr_count_name(nodes, get(stmt.2, 0), name)
    elif equal(tag, "if"):
        here = nc_if_count_name(nodes, stmt.2, 0, count(stmt.2), name)
    end
    return here + nc_body_count_name(nodes, stmts, i + 1, n, name)
end

func nc_if_count_name(nodes, kids, i, n, name):
    if i >= n:
        return 0
    end
    let arm = get(nodes, get(kids, i))
    let here = 0
    let body_idx = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        here = nc_expr_count_name(nodes, get(arm.2, 0), name)
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    return here + nc_body_count_name(nodes, body.2, 0, count(body.2), name) + nc_if_count_name(nodes, kids, i + 1, n, name)
end

func nc_body_assigns_name(nodes, stmts, i, n, name):
    if i >= n:
        return false
    end
    let stmt = get(nodes, get(stmts, i))
    let tag = stmt.0
    if equal(tag, "assign"):
        if equal(get(stmt.1, 0), name):
            return true
        end
    elif equal(tag, "if"):
        if nc_if_assigns_name(nodes, stmt.2, 0, count(stmt.2), name):
            return true
        end
    end
    return nc_body_assigns_name(nodes, stmts, i + 1, n, name)
end

func nc_if_assigns_name(nodes, kids, i, n, name):
    if i >= n:
        return false
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    if nc_body_assigns_name(nodes, body.2, 0, count(body.2), name):
        return true
    end
    return nc_if_assigns_name(nodes, kids, i + 1, n, name)
end

func nc_body_let_target_count_name(nodes, stmts, i, n, name):
    if i >= n:
        return 0
    end
    let stmt = get(nodes, get(stmts, i))
    let tag = stmt.0
    let here = 0
    if equal(tag, "let"):
        if equal(get(stmt.1, 0), name):
            here = 1
        end
    elif equal(tag, "if"):
        here = nc_if_let_target_count_name(nodes, stmt.2, 0, count(stmt.2), name)
    end
    return here + nc_body_let_target_count_name(nodes, stmts, i + 1, n, name)
end

func nc_if_let_target_count_name(nodes, kids, i, n, name):
    if i >= n:
        return 0
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    return nc_body_let_target_count_name(nodes, body.2, 0, count(body.2), name) + nc_if_let_target_count_name(nodes, kids, i + 1, n, name)
end

func nc_top_let_is_new_array(nodes, stmts, i, n, name):
    if i >= n:
        return false
    end
    let stmt = get(nodes, get(stmts, i))
    if equal(stmt.0, "let") and equal(get(stmt.1, 0), name):
        let val = get(nodes, get(stmt.2, 0))
        if equal(val.0, "call") and equal(get(val.1, 0), "new_array"):
            return true
        end
        return false
    end
    return nc_top_let_is_new_array(nodes, stmts, i + 1, n, name)
end

func nc_return_is_trap(nodes, top_stmts, expr_idx):
    let node = get(nodes, expr_idx)
    if not equal(node.0, "call"):
        return false
    end
    if not equal(get(node.1, 0), "get"):
        return false
    end
    if count(node.2) != 2:
        return false
    end
    let arr = get(nodes, get(node.2, 0))
    if not equal(arr.0, "name"):
        return false
    end
    let xname = get(arr.1, 0)
    if not nc_top_let_is_new_array(nodes, top_stmts, 0, count(top_stmts), xname):
        return false
    end
    if nc_body_let_target_count_name(nodes, top_stmts, 0, count(top_stmts), xname) != 1:
        return false
    end
    if nc_body_count_name(nodes, top_stmts, 0, count(top_stmts), xname) != 1:
        return false
    end
    if nc_body_assigns_name(nodes, top_stmts, 0, count(top_stmts), xname):
        return false
    end
    return true
end

func nc_returns_all_trap(nodes, top_stmts, stmts, i, n):
    if i >= n:
        return (true, 0)
    end
    let stmt = get(nodes, get(stmts, i))
    let tag = stmt.0
    let here_ok = true
    let here_cnt = 0
    if equal(tag, "return"):
        here_cnt = 1
        here_ok = nc_return_is_trap(nodes, top_stmts, get(stmt.2, 0))
    elif equal(tag, "if"):
        let r = nc_if_returns_all_trap(nodes, top_stmts, stmt.2, 0, count(stmt.2))
        here_ok = r.0
        here_cnt = r.1
    end
    if not here_ok:
        return (false, here_cnt)
    end
    let rest = nc_returns_all_trap(nodes, top_stmts, stmts, i + 1, n)
    return (rest.0, here_cnt + rest.1)
end

func nc_if_returns_all_trap(nodes, top_stmts, kids, i, n):
    if i >= n:
        return (true, 0)
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    let r = nc_returns_all_trap(nodes, top_stmts, body.2, 0, count(body.2))
    if not r.0:
        return (false, r.1)
    end
    let rest = nc_if_returns_all_trap(nodes, top_stmts, kids, i + 1, n)
    return (rest.0, r.1 + rest.1)
end

func nc_func_never_returns_node(nodes, fn):
    let body = get(nodes, get(fn.2, 1))
    let stmts = body.2
    let r = nc_returns_all_trap(nodes, stmts, stmts, 0, count(stmts))
    if r.1 == 0:
        return false
    end
    return r.0
end

func nc_func_never_returns(nodes, prog_idx, fn_idx):
    let prog = get(nodes, prog_idx)
    return nc_func_never_returns_node(nodes, get(nodes, get(prog.2, fn_idx)))
end

func nc_sig_unify_param(pool, sig, fn_idx, param_idx, want, line):
    let old = nc_sig_get_param(sig, fn_idx, param_idx)
    let u = nc_type_merge(pool, old, want, line)
    if u.0 != 0:
        return (u.0, sig, 0)
    end
    if u.2 == 0:
        return (0, sig, 0)
    end
    return (0, nc_sig_set_param(sig, fn_idx, param_idx, u.1), 1)
end

func nc_sig_unify_ret(pool, sig, fn_idx, want, line):
    let old = nc_sig_get_ret(sig, fn_idx)
    let u = nc_type_merge(pool, old, want, line)
    if u.0 != 0:
        return (u.0, sig, 0)
    end
    if u.2 == 0:
        return (0, sig, 0)
    end
    return (0, nc_sig_set_ret(sig, fn_idx, u.1), 1)
end

func nc_seed_params_loop(params, i, n, sig, fn_idx, env):
    if i >= n:
        return env
    end
    env = nc_class_env_add(env, get(params, i), nc_sig_get_param(sig, fn_idx, i))
    return nc_seed_params_loop(params, i + 1, n, sig, fn_idx, env)
end

func nc_func_env_from_params(nodes, fn_node, sig, fn_idx):
    let pn = get(nodes, get(fn_node.2, 0))
    return nc_seed_params_loop(pn.1, 0, count(pn.1), sig, fn_idx, nc_class_env_new())
end

func nc_constrain_name(pool, nodes, node, env, want, sig, fn_idx, n_params):
    let name = get(node.1, 0)
    let li = nc_class_env_lookup_info(env, name)
    if li.0 == 0:
        return (nc_fail(404, node.3, "undefined-name"), env, sig, 0)
    end
    let u = nc_type_merge(pool, li.2, want, node.3)
    if u.0 != 0:
        return (u.0, env, sig, 0)
    end
    if u.2 == 0:
        return (0, env, sig, 0)
    end
    env = nc_class_env_set_idx(env, li.1, u.1)
    let changed = 0
    if li.1 < n_params:
        let su = nc_sig_unify_param(pool, sig, fn_idx, li.1, u.1, node.3)
        if su.0 != 0:
            return (su.0, env, sig, changed)
        end
        sig = su.1
        changed = su.2
    end
    return (0, env, sig, changed)
end

func nc_expect_concrete(pool, got, want, line):
    if got == 0 or want == 0 or nc_type_equal(pool, got, want):
        return 0
    end
    return nc_fail(430, line, "")
end

func nc_expect_array_elem(pool, got, want, line):
    if got == 0 or want == 0 or nc_type_equal(pool, got, want):
        return 0
    end
    if nc_type_has_unknown(pool, got) or nc_type_has_unknown(pool, want):
        if not nc_type_merge_possible(pool, got, want):
            return nc_fail(436, line, "")
        end
        let m = nc_type_merge(pool, got, want, line)
        if m.0 == 0:
            return 0
        end
        return m.0
    end
    return nc_fail(436, line, "")
end

func nc_constrain_string_value(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params, line):
    let r = nc_infer_expr(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params)
    if r.0 != 0:
        return (r.0, r.2, r.3, r.4)
    end
    if r.1 == nc_type_buffer():
        return (nc_fail(438, line, ""), r.2, r.3, r.4)
    end
    if r.1 == nc_type_unknown():
        return nc_constrain_expr(pool, nodes, prog_idx, idx, r.2, nc_type_string(), r.3, fn_idx, funcs, n_params)
    end
    let chk = nc_expect_concrete(pool, r.1, nc_type_string(), line)
    if chk != 0:
        return (chk, r.2, r.3, r.4)
    end
    return (0, r.2, r.3, r.4)
end

func nc_constrain_flogger_string_value(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params, line):
    let r = nc_infer_expr(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params)
    if r.0 != 0:
        return (r.0, r.2, r.3, r.4)
    end
    if r.1 == nc_type_unknown():
        return nc_constrain_expr(pool, nodes, prog_idx, idx, r.2, nc_type_string(), r.3, fn_idx, funcs, n_params)
    end
    let chk = nc_expect_concrete(pool, r.1, nc_type_string(), line)
    if chk != 0:
        return (chk, r.2, r.3, r.4)
    end
    return (0, r.2, r.3, r.4)
end

func nc_constrain_buffer_value(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params, line):
    let r = nc_infer_expr(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params)
    if r.0 != 0:
        return (r.0, r.2, r.3, r.4)
    end
    if r.1 == nc_type_unknown():
        return nc_constrain_expr(pool, nodes, prog_idx, idx, r.2, nc_type_buffer(), r.3, fn_idx, funcs, n_params)
    end
    if r.1 != nc_type_buffer():
        return (nc_fail(437, line, ""), r.2, r.3, r.4)
    end
    return (0, r.2, r.3, r.4)
end

func nc_constrain_array_value(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params, want_elem, line):
    let want = nc_type_intern_array(pool, want_elem)
    let r = nc_infer_expr(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params)
    if r.0 != 0:
        return (r.0, r.2, r.3, r.4)
    end
    if r.1 == nc_type_unknown():
        return nc_constrain_expr(pool, nodes, prog_idx, idx, r.2, want, r.3, fn_idx, funcs, n_params)
    end
    if not nc_type_is_array(pool, r.1):
        return (nc_fail(435, line, ""), r.2, r.3, r.4)
    end
    let merged = nc_type_merge(pool, r.1, want, line)
    if merged.0 != 0:
        return (merged.0, r.2, r.3, r.4)
    end
    if merged.2 == 0:
        return (0, r.2, r.3, r.4)
    end
    return nc_constrain_expr(pool, nodes, prog_idx, idx, r.2, merged.1, r.3, fn_idx, funcs, n_params)
end

func nc_collect_call_arg_types(pool, nodes, prog_idx, kids, i, n, env, sig, fn_idx, funcs, n_params, args, changed):
    if i >= n:
        return (0, args, env, sig, changed)
    end
    let arg_idx = get(kids, i)
    let ar = nc_infer_expr(pool, nodes, prog_idx, arg_idx, env, sig, fn_idx, funcs, n_params)
    if ar.0 != 0:
        return (ar.0, args, ar.2, ar.3, nc_or_changed(changed, ar.4))
    end
    do add(args, ar.1)
    return nc_collect_call_arg_types(pool, nodes, prog_idx, kids, i + 1, n, ar.2, ar.3, fn_idx, funcs, n_params, args, nc_or_changed(changed, ar.4))
end

func nc_poly_constrain_user_call(pool, nodes, prog_idx, call_idx, env, want, sig, fn_idx, funcs, n_params):
    let node = get(nodes, call_idx)
    let name = get(node.1, 0)
    let callee = nc_func_lookup(nodes, prog_idx, name)
    if callee.0 == 0:
        return (nc_fail(419, node.3, name), env, sig, 0)
    end
    if equal(name, "main"):
        return (nc_fail(421, node.3, ""), env, sig, 0)
    end
    if callee.2 != count(node.2):
        return (nc_fail(420, node.3, name), env, sig, 0)
    end
    let ar = nc_collect_call_arg_types(pool, nodes, prog_idx, node.2, 0, count(node.2), env, sig, fn_idx, funcs, n_params, new_array(int), 0)
    if ar.0 != 0:
        return (ar.0, ar.2, ar.3, ar.4)
    end
    if nc_type_vector_has_unknown(pool, ar.1, 0, count(ar.1)):
        return (0, ar.2, ar.3, ar.4)
    end
    let gi = nc_poly_get_or_create(pool, funcs, callee.1, ar.1, fn_idx, ar.3, node.3)
    if gi.0 != 0:
        return (gi.0, ar.2, gi.2, nc_or_changed(ar.4, gi.3))
    end
    let rec = nc_poly_record_call_target(funcs, fn_idx, call_idx, gi.1)
    if rec != 0:
        return (rec, ar.2, gi.2, nc_or_changed(ar.4, gi.3))
    end
    let changed = nc_or_changed(ar.4, gi.3)
    if nc_func_never_returns(nodes, prog_idx, callee.1):
        return (0, ar.2, gi.2, changed)
    end
    let su = nc_sig_unify_ret(pool, gi.2, gi.1, want, node.3)
    if su.0 != 0:
        return (su.0, ar.2, gi.2, changed)
    end
    return (0, ar.2, su.1, nc_or_changed(changed, su.2))
end

func nc_poly_infer_user_call(pool, nodes, prog_idx, call_idx, env, sig, fn_idx, funcs, n_params):
    let node = get(nodes, call_idx)
    let name = get(node.1, 0)
    let callee = nc_func_lookup(nodes, prog_idx, name)
    if callee.0 == 0:
        return (nc_fail(419, node.3, name), 0, env, sig, 0)
    end
    if equal(name, "main"):
        return (nc_fail(421, node.3, ""), 0, env, sig, 0)
    end
    if callee.2 != count(node.2):
        return (nc_fail(420, node.3, name), 0, env, sig, 0)
    end
    let ar = nc_collect_call_arg_types(pool, nodes, prog_idx, node.2, 0, count(node.2), env, sig, fn_idx, funcs, n_params, new_array(int), 0)
    if ar.0 != 0:
        return (ar.0, 0, ar.2, ar.3, ar.4)
    end
    if nc_type_vector_has_unknown(pool, ar.1, 0, count(ar.1)):
        return (0, nc_type_unknown(), ar.2, ar.3, ar.4)
    end
    let gi = nc_poly_get_or_create(pool, funcs, callee.1, ar.1, fn_idx, ar.3, node.3)
    if gi.0 != 0:
        return (gi.0, 0, ar.2, gi.2, nc_or_changed(ar.4, gi.3))
    end
    let rec = nc_poly_record_call_target(funcs, fn_idx, call_idx, gi.1)
    if rec != 0:
        return (rec, 0, ar.2, gi.2, nc_or_changed(ar.4, gi.3))
    end
    return (0, nc_sig_get_ret(gi.2, gi.1), ar.2, gi.2, nc_or_changed(ar.4, gi.3))
end

func nc_constrain_expr(pool, nodes, prog_idx, idx, env, want, sig, fn_idx, funcs, n_params):
    if want == 0:
        return (0, env, sig, 0)
    end
    let node = get(nodes, idx)
    if equal(node.0, "name"):
        return nc_constrain_name(pool, nodes, node, env, want, sig, fn_idx, n_params)
    end
    if equal(node.0, "call"):
        let name = get(node.1, 0)
        if not err_is_builtin_name(name):
            return nc_poly_constrain_user_call(pool, nodes, prog_idx, idx, env, want, sig, fn_idx, funcs, n_params)
        end
        if equal(name, "get"):
            if count(node.2) != 2:
                return (nc_fail(420, node.3, name), env, sig, 0)
            end
            let ar = nc_constrain_array_value(pool, nodes, prog_idx, get(node.2, 0), env, sig, fn_idx, funcs, n_params, want, node.3)
            if ar.0 != 0:
                return ar
            end
            let kr = nc_constrain_expr(pool, nodes, prog_idx, get(node.2, 1), ar.1, nc_type_int(), ar.2, fn_idx, funcs, n_params)
            return (kr.0, kr.1, kr.2, nc_or_changed(ar.3, kr.3))
        end
    end
    let r = nc_infer_expr(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params)
    if r.0 != 0:
        return (r.0, r.2, r.3, r.4)
    end
    let chk = nc_expect_concrete(pool, r.1, want, node.3)
    if chk != 0:
        return (chk, r.2, r.3, r.4)
    end
    return (0, r.2, r.3, r.4)
end

func nc_infer_call_args(pool, nodes, prog_idx, kids, i, n, callee_idx, env, sig, fn_idx, funcs, n_params, changed):
    if i >= n:
        return (0, env, sig, changed)
    end
    let arg_idx = get(kids, i)
    let ar = nc_infer_expr(pool, nodes, prog_idx, arg_idx, env, sig, fn_idx, funcs, n_params)
    if ar.0 != 0:
        return (ar.0, ar.2, ar.3, nc_or_changed(changed, ar.4))
    end
    env = ar.2
    sig = ar.3
    changed = nc_or_changed(changed, ar.4)
    let pcls = nc_sig_get_param(sig, callee_idx, i)
    if ar.1 != 0:
        let su = nc_sig_unify_param(pool, sig, callee_idx, i, ar.1, get(nodes, arg_idx).3)
        if su.0 != 0:
            return (su.0, env, sig, changed)
        end
        sig = su.1
        changed = nc_or_changed(changed, su.2)
    elif pcls != 0:
        let cu = nc_constrain_expr(pool, nodes, prog_idx, arg_idx, env, pcls, sig, fn_idx, funcs, n_params)
        if cu.0 != 0:
            return (cu.0, cu.1, cu.2, changed)
        end
        env = cu.1
        sig = cu.2
        changed = nc_or_changed(changed, cu.3)
    end
    return nc_infer_call_args(pool, nodes, prog_idx, kids, i + 1, n, callee_idx, env, sig, fn_idx, funcs, n_params, changed)
end

func nc_tuple_type_from_exprs(pool, nodes, prog_idx, kids, i, n, env, sig, fn_idx, funcs, n_params, child_types, changed):
    if i >= n:
        return (0, nc_type_intern_tuple(pool, child_types), env, sig, changed)
    end
    let r = nc_infer_expr(pool, nodes, prog_idx, get(kids, i), env, sig, fn_idx, funcs, n_params)
    if r.0 != 0:
        return (r.0, 0, r.2, r.3, nc_or_changed(changed, r.4))
    end
    do add(child_types, r.1)
    return nc_tuple_type_from_exprs(pool, nodes, prog_idx, kids, i + 1, n, r.2, r.3, fn_idx, funcs, n_params, child_types, nc_or_changed(changed, r.4))
end

func nc_tuple_child_start_loop(pool, kids, i, target, acc):
    if i >= target:
        return acc
    end
    return nc_tuple_child_start_loop(pool, kids, i + 1, target, acc + nc_type_width(pool, get(kids, i)))
end

func nc_infer_expr(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params):
    let node = get(nodes, idx)
    let tag = node.0
    let kids = node.2
    if equal(tag, "int") or equal(tag, "char"):
        return (0, nc_type_int(), env, sig, 0)
    end
    if equal(tag, "bool"):
        return (0, nc_type_bool(), env, sig, 0)
    end
    if equal(tag, "str"):
        return (0, nc_type_string(), env, sig, 0)
    end
    if equal(tag, "tuple"):
        return nc_tuple_type_from_exprs(pool, nodes, prog_idx, kids, 0, count(kids), env, sig, fn_idx, funcs, n_params, new_array(int), 0)
    end
    if equal(tag, "dot"):
        let r = nc_infer_expr(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params)
        if r.0 != 0:
            return r
        end
        if r.1 == nc_type_unknown():
            return (0, nc_type_unknown(), r.2, r.3, r.4)
        end
        if not nc_type_is_tuple(pool, r.1):
            return (nc_fail(431, node.3, ""), 0, r.2, r.3, r.4)
        end
        let children = nc_type_tuple_children(pool, r.1)
        let elem = parse_decimal(get(node.1, 0))
        if elem >= count(children):
            return (nc_fail(431, node.3, ""), 0, r.2, r.3, r.4)
        end
        return (0, get(children, elem), r.2, r.3, r.4)
    end
    if equal(tag, "name"):
        let name = get(node.1, 0)
        let li = nc_class_env_lookup_info(env, name)
        if li.0 == 0:
            return (nc_fail(404, node.3, "undefined-name"), 0, env, sig, 0)
        end
        return (0, li.2, env, sig, 0)
    end
    if equal(tag, "add") or equal(tag, "sub") or equal(tag, "mul") or equal(tag, "div") or equal(tag, "mod") or equal(tag, "band") or equal(tag, "bor") or equal(tag, "bxor") or equal(tag, "shl") or equal(tag, "shr"):
        -- Arithmetic and bitwise/shift binops are all int x int -> int: constrain
        -- both operands to int and yield int. mul/div/mod join add/sub here
        -- (ordinary arithmetic). A non-int operand hits the existing type-mismatch
        -- fail code via nc_constrain_expr (no new fail code needed).
        let l = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), env, nc_type_int(), sig, fn_idx, funcs, n_params)
        if l.0 != 0:
            return (l.0, 0, l.1, l.2, l.3)
        end
        let r = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 1), l.1, nc_type_int(), l.2, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, 0, r.1, r.2, nc_or_changed(l.3, r.3))
        end
        return (0, nc_type_int(), r.1, r.2, nc_or_changed(l.3, r.3))
    end
    if equal(tag, "eq") or equal(tag, "ne") or equal(tag, "lt") or equal(tag, "le") or equal(tag, "gt") or equal(tag, "ge"):
        let l = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), env, nc_type_int(), sig, fn_idx, funcs, n_params)
        if l.0 != 0:
            return (l.0, 0, l.1, l.2, l.3)
        end
        let r = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 1), l.1, nc_type_int(), l.2, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, 0, r.1, r.2, nc_or_changed(l.3, r.3))
        end
        return (0, nc_type_bool(), r.1, r.2, nc_or_changed(l.3, r.3))
    end
    if equal(tag, "and") or equal(tag, "or"):
        let l = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), env, nc_type_bool(), sig, fn_idx, funcs, n_params)
        if l.0 != 0:
            return (l.0, 0, l.1, l.2, l.3)
        end
        let r = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 1), l.1, nc_type_bool(), l.2, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, 0, r.1, r.2, nc_or_changed(l.3, r.3))
        end
        return (0, nc_type_bool(), r.1, r.2, nc_or_changed(l.3, r.3))
    end
    if equal(tag, "not"):
        let r = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), env, nc_type_bool(), sig, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, 0, r.1, r.2, r.3)
        end
        return (0, nc_type_bool(), r.1, r.2, r.3)
    end
    if equal(tag, "bnot"):
        -- `~` is int -> int (one's complement), the int-typed counterpart of the
        -- bool-typed `not` above. Constraining the operand to int rejects `~true`
        -- via the existing type-mismatch fail code.
        let r = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), env, nc_type_int(), sig, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, 0, r.1, r.2, r.3)
        end
        return (0, nc_type_int(), r.1, r.2, r.3)
    end
    if equal(tag, "nc_class_mix"):
        -- Poison node planted by the parser when bitwise/shift operators are
        -- mixed with another operator class (or a different bitwise class)
        -- without parentheses. Reject with the dedicated precedence fail code.
        return (nc_fail(442, node.3, ""), 0, env, sig, 0)
    end
    if equal(tag, "call"):
        let name = get(node.1, 0)
        if equal(name, "clogger"):
            return (0, nc_type_string(), env, sig, 0)
        end
        if equal(name, "input_byte"):
            return (0, nc_type_int(), env, sig, 0)
        end
        if equal(name, "module_byte"):
            return (0, nc_type_int(), env, sig, 0)
        end
        if equal(name, "length"):
            let r = nc_constrain_string_value(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params, node.3)
            if r.0 != 0:
                return (r.0, 0, r.1, r.2, r.3)
            end
            return (0, nc_type_int(), r.1, r.2, r.3)
        end
        if equal(name, "index"):
            let s = nc_constrain_string_value(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params, node.3)
            if s.0 != 0:
                return (s.0, 0, s.1, s.2, s.3)
            end
            let k = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 1), s.1, nc_type_int(), s.2, fn_idx, funcs, n_params)
            if k.0 != 0:
                return (k.0, 0, k.1, k.2, nc_or_changed(s.3, k.3))
            end
            return (0, nc_type_int(), k.1, k.2, nc_or_changed(s.3, k.3))
        end
        if equal(name, "equal"):
            let l = nc_constrain_string_value(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params, node.3)
            if l.0 != 0:
                return (l.0, 0, l.1, l.2, l.3)
            end
            let r = nc_constrain_string_value(pool, nodes, prog_idx, get(kids, 1), l.1, l.2, fn_idx, funcs, n_params, node.3)
            if r.0 != 0:
                return (r.0, 0, r.1, r.2, nc_or_changed(l.3, r.3))
            end
            return (0, nc_type_bool(), r.1, r.2, nc_or_changed(l.3, r.3))
        end
        if equal(name, "slice"):
            return (nc_fail(438, node.3, ""), 0, env, sig, 0)
        end
        if equal(name, "new_buffer"):
            return (0, nc_type_buffer(), env, sig, 0)
        end
        if equal(name, "freeze"):
            let b = nc_constrain_buffer_value(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params, node.3)
            if b.0 != 0:
                return (b.0, 0, b.1, b.2, b.3)
            end
            return (0, nc_type_string(), b.1, b.2, b.3)
        end
        if equal(name, "new_array"):
            if count(kids) != 1:
                return (nc_fail(434, node.3, ""), 0, env, sig, 0)
            end
            let elem = nc_type_from_type_expr(pool, nodes, get(kids, 0))
            if elem.0 != 0:
                return (elem.0, 0, env, sig, 0)
            end
            return (0, nc_type_intern_array(pool, elem.1), env, sig, 0)
        end
        if equal(name, "get"):
            let a = nc_infer_expr(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params)
            if a.0 != 0:
                return a
            end
            let k = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 1), a.2, nc_type_int(), a.3, fn_idx, funcs, n_params)
            if k.0 != 0:
                return (k.0, 0, k.1, k.2, nc_or_changed(a.4, k.3))
            end
            if a.1 == nc_type_unknown():
                let ar = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), k.1, nc_type_intern_array(pool, nc_type_unknown()), k.2, fn_idx, funcs, n_params)
                if ar.0 != 0:
                    return (ar.0, 0, ar.1, ar.2, nc_or_changed(nc_or_changed(a.4, k.3), ar.3))
                end
                return (0, nc_type_unknown(), ar.1, ar.2, nc_or_changed(nc_or_changed(a.4, k.3), ar.3))
            end
            if not nc_type_is_array(pool, a.1):
                return (nc_fail(435, node.3, ""), 0, k.1, k.2, nc_or_changed(a.4, k.3))
            end
            return (0, nc_type_array_elem(pool, a.1), k.1, k.2, nc_or_changed(a.4, k.3))
        end
        if equal(name, "count"):
            let a = nc_infer_expr(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params)
            if a.0 != 0:
                return a
            end
            if a.1 == nc_type_unknown():
                let ar = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), a.2, nc_type_intern_array(pool, nc_type_unknown()), a.3, fn_idx, funcs, n_params)
                if ar.0 != 0:
                    return (ar.0, 0, ar.1, ar.2, nc_or_changed(a.4, ar.3))
                end
                return (0, nc_type_int(), ar.1, ar.2, nc_or_changed(a.4, ar.3))
            end
            if not nc_type_is_array(pool, a.1):
                return (nc_fail(435, node.3, ""), 0, a.2, a.3, a.4)
            end
            return (0, nc_type_int(), a.2, a.3, a.4)
        end
        if err_is_void_builtin(name):
            return (nc_fail(440, node.3, name), 0, env, sig, 0)
        end
        if err_is_builtin_name(name):
            return (nc_fail(438, node.3, name), 0, env, sig, 0)
        end
        return nc_poly_infer_user_call(pool, nodes, prog_idx, idx, env, sig, fn_idx, funcs, n_params)
    end
    return (nc_fail(404, node.3, tag), 0, env, sig, 0)
end

func nc_rebind_env_type(pool, env, idx, old, got, line):
    if old != nc_type_unknown() and got != nc_type_unknown():
        if nc_type_has_unknown(pool, old) or nc_type_has_unknown(pool, got):
            if not nc_type_merge_possible(pool, old, got):
                if nc_type_is_array(pool, old) or nc_type_is_array(pool, got):
                    return (nc_fail(436, line, ""), env)
                end
                return (nc_fail(430, line, ""), env)
            end
            let mp = nc_type_merge(pool, old, got, line)
            if mp.0 != 0:
                return (mp.0, env)
            end
            return (0, nc_class_env_set_idx(env, idx, mp.1))
        end
        if nc_type_width(pool, old) != nc_type_width(pool, got):
            return (nc_fail(433, line, ""), env)
        end
        if nc_type_is_array(pool, old) or nc_type_is_array(pool, got):
            if not nc_type_equal(pool, old, got):
                return (nc_fail(436, line, ""), env)
            end
        end
        if not nc_assignment_type_ok(pool, old, got):
            return (nc_fail(430, line, ""), env)
        end
    end
    if got == nc_type_unknown():
        return (0, env)
    end
    return (0, nc_class_env_set_idx(env, idx, got))
end

func nc_infer_stmt(pool, nodes, prog_idx, stmt_idx, env, sig, fn_idx, funcs, n_params):
    let node = get(nodes, stmt_idx)
    let tag = node.0
    let kids = node.2
    if equal(tag, "let"):
        let r = nc_infer_expr(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, r.2, r.3, r.4, 0)
        end
        env = nc_class_env_add(r.2, get(node.1, 0), r.1)
        return (0, env, r.3, r.4, 0)
    end
    if equal(tag, "assign"):
        let li = nc_class_env_lookup_info(env, get(node.1, 0))
        if li.0 == 0:
            return (nc_fail(404, node.3, "assign-undefined"), env, sig, 0, 0)
        end
        let r = nc_infer_expr(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, r.2, r.3, r.4, 0)
        end
        let rb = nc_rebind_env_type(pool, r.2, li.1, li.2, r.1, node.3)
        if rb.0 != 0:
            return (rb.0, r.2, r.3, r.4, 0)
        end
        return (0, rb.1, r.3, r.4, 0)
    end
    if equal(tag, "return"):
        let r = nc_infer_expr(pool, nodes, prog_idx, get(kids, 0), env, sig, fn_idx, funcs, n_params)
        if r.0 != 0:
            return (r.0, r.2, r.3, r.4, 1)
        end
        sig = r.3
        let changed = r.4
        if nc_func_never_returns(nodes, prog_idx, nc_poly_current_base(funcs, fn_idx)):
            return (0, r.2, sig, changed, 1)
        end
        if r.1 != 0:
            let su = nc_sig_unify_ret(pool, sig, fn_idx, r.1, node.3)
            if su.0 != 0:
                return (su.0, r.2, sig, changed, 1)
            end
            sig = su.1
            changed = nc_or_changed(changed, su.2)
        else:
            let retc = nc_sig_get_ret(sig, fn_idx)
            if retc != 0:
                let cu = nc_constrain_expr(pool, nodes, prog_idx, get(kids, 0), r.2, retc, sig, fn_idx, funcs, n_params)
                if cu.0 != 0:
                    return (cu.0, cu.1, cu.2, changed, 1)
                end
                sig = cu.2
                changed = nc_or_changed(changed, cu.3)
            end
        end
        return (0, r.2, sig, changed, 1)
    end
    if equal(tag, "do"):
        let call_node = get(nodes, get(kids, 0))
        if equal(call_node.0, "call"):
            let name = get(call_node.1, 0)
            let ckids = call_node.2
            if equal(name, "append"):
                let b = nc_constrain_buffer_value(pool, nodes, prog_idx, get(ckids, 0), env, sig, fn_idx, funcs, n_params, call_node.3)
                if b.0 != 0:
                    return (b.0, b.1, b.2, b.3, 0)
                end
                let v = nc_constrain_expr(pool, nodes, prog_idx, get(ckids, 1), b.1, nc_type_int(), b.2, fn_idx, funcs, n_params)
                return (v.0, v.1, v.2, nc_or_changed(b.3, v.3), 0)
            end
            if equal(name, "add"):
                let a = nc_infer_expr(pool, nodes, prog_idx, get(ckids, 0), env, sig, fn_idx, funcs, n_params)
                if a.0 != 0:
                    return (a.0, a.2, a.3, a.4, 0)
                end
                let v = nc_infer_expr(pool, nodes, prog_idx, get(ckids, 1), a.2, a.3, fn_idx, funcs, n_params)
                if v.0 != 0:
                    return (v.0, v.2, v.3, nc_or_changed(a.4, v.4), 0)
                end
                let changed = nc_or_changed(a.4, v.4)
                env = v.2
                sig = v.3
                if a.1 == nc_type_unknown():
                    let elem = v.1
                    if elem == nc_type_unknown():
                        elem = nc_type_unknown()
                    end
                    let ar = nc_constrain_expr(pool, nodes, prog_idx, get(ckids, 0), env, nc_type_intern_array(pool, elem), sig, fn_idx, funcs, n_params)
                    return (ar.0, ar.1, ar.2, nc_or_changed(changed, ar.3), 0)
                end
                if not nc_type_is_array(pool, a.1):
                    return (nc_fail(435, call_node.3, ""), env, sig, changed, 0)
                end
                let elem_t = nc_type_array_elem(pool, a.1)
                if v.1 == nc_type_unknown():
                    let vc = nc_constrain_expr(pool, nodes, prog_idx, get(ckids, 1), env, elem_t, sig, fn_idx, funcs, n_params)
                    return (vc.0, vc.1, vc.2, nc_or_changed(changed, vc.3), 0)
                end
                let ok = nc_expect_array_elem(pool, v.1, elem_t, call_node.3)
                if ok != 0:
                    return (ok, env, sig, changed, 0)
                end
                if nc_type_has_unknown(pool, elem_t) and v.1 != nc_type_unknown():
                    let ar2 = nc_constrain_expr(pool, nodes, prog_idx, get(ckids, 0), env, nc_type_intern_array(pool, v.1), sig, fn_idx, funcs, n_params)
                    return (ar2.0, ar2.1, ar2.2, nc_or_changed(changed, ar2.3), 0)
                end
                return (0, env, sig, changed, 0)
            end
            if equal(name, "flogger"):
                if count(ckids) != 1:
                    return (nc_fail(420, call_node.3, "flogger"), env, sig, 0, 0)
                end
                let s = nc_constrain_flogger_string_value(pool, nodes, prog_idx, get(ckids, 0), env, sig, fn_idx, funcs, n_params, call_node.3)
                return (s.0, s.1, s.2, s.3, 0)
            end
            if equal(name, "fwriter"):
                if count(ckids) != 1:
                    return (nc_fail(420, call_node.3, "fwriter"), env, sig, 0, 0)
                end
                let sf = nc_constrain_flogger_string_value(pool, nodes, prog_idx, get(ckids, 0), env, sig, fn_idx, funcs, n_params, call_node.3)
                return (sf.0, sf.1, sf.2, sf.3, 0)
            end
            return (nc_fail(404, node.3, name), env, sig, 0, 0)
        end
        return (nc_fail(404, node.3, "do"), env, sig, 0, 0)
    end
    if equal(tag, "if"):
        let r = nc_infer_if(pool, nodes, prog_idx, kids, env, sig, fn_idx, funcs, n_params)
        return (r.0, r.1, r.2, r.3, 0)
    end
    return (nc_fail(404, node.3, tag), env, sig, 0, 0)
end

func nc_infer_body(pool, nodes, prog_idx, stmts, i, n, env, sig, fn_idx, funcs, n_params, changed):
    if i >= n:
        return (0, env, sig, changed)
    end
    let r = nc_infer_stmt(pool, nodes, prog_idx, get(stmts, i), env, sig, fn_idx, funcs, n_params)
    if r.0 != 0:
        return (r.0, r.1, r.2, nc_or_changed(changed, r.3))
    end
    changed = nc_or_changed(changed, r.3)
    if r.4 != 0:
        return (0, r.1, r.2, changed)
    end
    return nc_infer_body(pool, nodes, prog_idx, stmts, i + 1, n, r.1, r.2, fn_idx, funcs, n_params, changed)
end

func nc_contrib_add(contribs, env):
    do add(contribs, env)
    return contribs
end

func nc_join_merge_class(pool, a, b):
    if a == 0:
        return (0, b)
    end
    if b == 0:
        return (0, a)
    end
    let m = nc_type_merge(pool, a, b, 0)
    return (m.0, m.1)
end

func nc_join_one_index(pool, contribs, idx, j, n, cur):
    if j >= n:
        return (0, cur)
    end
    let env = get(contribs, j)
    let m = nc_join_merge_class(pool, cur, get(env.1, idx))
    if m.0 != 0:
        return m
    end
    return nc_join_one_index(pool, contribs, idx, j + 1, n, m.1)
end

func nc_join_build_loop(pool, entry_env, contribs, i, n, names, classes):
    if i >= n:
        return (0, (names, classes))
    end
    let klass = get(entry_env.1, i)
    if count(contribs) > 0:
        let m = nc_join_one_index(pool, contribs, i, 0, count(contribs), 0)
        if m.0 != 0:
            return (m.0, (names, classes))
        end
        klass = m.1
    end
    do add(names, get(entry_env.0, i))
    do add(classes, klass)
    return nc_join_build_loop(pool, entry_env, contribs, i + 1, n, names, classes)
end

func nc_join_env(pool, entry_env, contribs):
    return nc_join_build_loop(pool, entry_env, contribs, 0, count(entry_env.0), new_array(string), new_array(int))
end

func nc_if_has_else(nodes, kids):
    if count(kids) == 0:
        return false
    end
    let last = get(nodes, get(kids, count(kids) - 1))
    return equal(last.0, "else")
end

func nc_infer_if_arms(pool, nodes, prog_idx, kids, i, n, entry_env, sig, fn_idx, funcs, n_params, contribs, changed):
    if i >= n:
        return (0, contribs, sig, changed)
    end
    let arm = get(nodes, get(kids, i))
    let body_idx = 0
    let env_for_body = nc_class_env_clone(entry_env)
    if equal(arm.0, "else"):
        body_idx = get(arm.2, 0)
    else:
        let c = nc_constrain_expr(pool, nodes, prog_idx, get(arm.2, 0), entry_env, nc_type_bool(), sig, fn_idx, funcs, n_params)
        if c.0 != 0:
            return (c.0, contribs, c.2, nc_or_changed(changed, c.3))
        end
        sig = c.2
        changed = nc_or_changed(changed, c.3)
        body_idx = get(arm.2, 1)
    end
    let body = get(nodes, body_idx)
    let br = nc_infer_body(pool, nodes, prog_idx, body.2, 0, count(body.2), env_for_body, sig, fn_idx, funcs, n_params, 0)
    if br.0 != 0:
        return (br.0, contribs, br.2, nc_or_changed(changed, br.3))
    end
    sig = br.2
    changed = nc_or_changed(changed, br.3)
    if not body_ends_return(body_idx, nodes):
        contribs = nc_contrib_add(contribs, nc_class_env_prefix(br.1, count(entry_env.0)))
    end
    return nc_infer_if_arms(pool, nodes, prog_idx, kids, i + 1, n, entry_env, sig, fn_idx, funcs, n_params, contribs, changed)
end

func nc_infer_if(pool, nodes, prog_idx, kids, env, sig, fn_idx, funcs, n_params):
    let entry_env = nc_class_env_clone(env)
    let contribs = new_array((array(string), array(int)))
    let arms = nc_infer_if_arms(pool, nodes, prog_idx, kids, 0, count(kids), entry_env, sig, fn_idx, funcs, n_params, contribs, 0)
    if arms.0 != 0:
        return (arms.0, entry_env, arms.2, arms.3)
    end
    contribs = arms.1
    if not nc_if_has_else(nodes, kids):
        contribs = nc_contrib_add(contribs, nc_class_env_clone(entry_env))
    end
    let joined = nc_join_env(pool, entry_env, contribs)
    if joined.0 != 0:
        return (joined.0, entry_env, arms.2, arms.3)
    end
    return (0, joined.1, arms.2, arms.3)
end

func nc_infer_func(pool, nodes, prog_idx, func_kids, fn_idx, sig):
    let fn_node = get(nodes, get(func_kids, fn_idx))
    let name = get(fn_node.1, 0)
    let params_node = get(nodes, get(fn_node.2, 0))
    let body_node = get(nodes, get(fn_node.2, 1))
    let total_clogger = nc_count_clogger_body(nodes, body_node.2, 0, count(body_node.2))
    if equal(name, "main"):
        if total_clogger > 1:
            return (nc_fail(411, fn_node.3, ""), sig, 0)
        end
    elif total_clogger > 0:
        return (nc_fail(404, fn_node.3, "clogger"), sig, 0)
    end
    let env = nc_func_env_from_params(nodes, fn_node, sig, fn_idx)
    let br = nc_infer_body(pool, nodes, prog_idx, body_node.2, 0, count(body_node.2), env, sig, fn_idx, func_kids, count(params_node.1), 0)
    return (br.0, br.2, br.3)
end

func nc_infer_funcs_loop(pool, nodes, prog_idx, func_kids, i, n, sig, changed):
    if i >= n:
        return (0, sig, changed)
    end
    let r = nc_infer_func(pool, nodes, prog_idx, func_kids, i, sig)
    if r.0 != 0:
        return r
    end
    return nc_infer_funcs_loop(pool, nodes, prog_idx, func_kids, i + 1, n, r.1, nc_or_changed(changed, r.2))
end

func nc_poly_infer_instance(pool, nodes, prog_idx, funcs, inst_idx, sig):
    let prog = get(nodes, prog_idx)
    let inst = get(funcs.0, inst_idx)
    let fn_node = get(nodes, get(prog.2, inst.0))
    let name = get(fn_node.1, 0)
    let params_node = get(nodes, get(fn_node.2, 0))
    let body_node = get(nodes, get(fn_node.2, 1))
    let total_clogger = nc_count_clogger_body(nodes, body_node.2, 0, count(body_node.2))
    if equal(name, "main"):
        if total_clogger > 1:
            return (nc_fail(411, fn_node.3, ""), sig, 0)
        end
    elif total_clogger > 0:
        return (nc_fail(404, fn_node.3, "clogger"), sig, 0)
    end
    let env = nc_func_env_from_params(nodes, fn_node, sig, inst_idx)
    let br = nc_infer_body(pool, nodes, prog_idx, body_node.2, 0, count(body_node.2), env, sig, inst_idx, funcs, count(params_node.1), 0)
    return (br.0, br.2, br.3)
end

func nc_poly_infer_instances_loop(pool, nodes, prog_idx, funcs, i, sig, changed):
    if i >= count(funcs.0):
        return (0, sig, changed)
    end
    let r = nc_poly_infer_instance(pool, nodes, prog_idx, funcs, i, sig)
    if r.0 != 0:
        return r
    end
    return nc_poly_infer_instances_loop(pool, nodes, prog_idx, funcs, i + 1, r.1, nc_or_changed(changed, r.2))
end

func nc_poly_sig_solve_loop(pool, nodes, prog_idx, funcs, sig, remaining):
    let r = nc_poly_infer_instances_loop(pool, nodes, prog_idx, funcs, 0, sig, 0)
    if r.0 != 0:
        return r
    end
    if r.2 == 0:
        return r
    end
    if remaining <= 0:
        return (nc_fail(424, 0, ""), r.1, 0)
    end
    return nc_poly_sig_solve_loop(pool, nodes, prog_idx, funcs, r.1, remaining - 1)
end

func nc_sig_var_count_params(func_kids, i, n, nodes, acc):
    if i >= n:
        return acc + n
    end
    let fn = get(nodes, get(func_kids, i))
    let pn = get(nodes, get(fn.2, 0))
    return nc_sig_var_count_params(func_kids, i + 1, n, nodes, acc + count(pn.1))
end

func nc_sig_solve_loop(pool, nodes, prog_idx, func_kids, sig, remaining):
    let r = nc_infer_funcs_loop(pool, nodes, prog_idx, func_kids, 0, count(func_kids), sig, 0)
    if r.0 != 0:
        return r
    end
    if r.2 == 0:
        return r
    end
    if remaining <= 0:
        return (nc_fail(424, 0, ""), r.1, 0)
    end
    return nc_sig_solve_loop(pool, nodes, prog_idx, func_kids, r.1, remaining - 1)
end

func nc_sig_check_params_loop(pool, sig, fn_idx, i, n):
    if i >= n:
        return 0
    end
    let t = nc_sig_get_param(sig, fn_idx, i)
    if nc_type_has_array_unknown(pool, t):
        return nc_fail(438, 0, "")
    end
    if nc_type_has_unknown(pool, t):
        return nc_fail(424, 0, "")
    end
    return nc_sig_check_params_loop(pool, sig, fn_idx, i + 1, n)
end

func nc_check_used_wide_params_loop(pool, nodes, body_node, params, sig, fn_idx, i, n):
    if i >= n:
        return 0
    end
    let t = nc_sig_get_param(sig, fn_idx, i)
    if nc_type_width(pool, t) > 1:
        if not nc_body_uses_name(nodes, body_node.2, 0, count(body_node.2), get(params, i)):
            return nc_fail(424, 0, "")
        end
    end
    return nc_check_used_wide_params_loop(pool, nodes, body_node, params, sig, fn_idx, i + 1, n)
end

func nc_sig_check_concrete_loop(pool, func_kids, i, n, nodes, sig):
    if i >= n:
        return 0
    end
    let fn = get(nodes, get(func_kids, i))
    let pn = get(nodes, get(fn.2, 0))
    let body = get(nodes, get(fn.2, 1))
    let pr = nc_sig_check_params_loop(pool, sig, i, 0, count(pn.1))
    if pr != 0:
        return pr
    end
    let nret = nc_func_never_returns_node(nodes, fn)
    if not nret:
        let used = nc_check_used_wide_params_loop(pool, nodes, body, pn.1, sig, i, 0, count(pn.1))
        if used != 0:
            return used
        end
    end
    let ret = nc_sig_get_ret(sig, i)
    if not nret:
        if nc_type_has_array_unknown(pool, ret):
            return nc_fail(438, fn.3, "")
        end
        if nc_type_has_unknown(pool, ret):
            return nc_fail(424, fn.3, "")
        end
    end
    if equal(get(fn.1, 0), "main"):
        if ret != nc_type_int() and ret != nc_type_bool():
            return nc_fail(432, fn.3, "")
        end
    end
    return nc_sig_check_concrete_loop(pool, func_kids, i + 1, n, nodes, sig)
end

func nc_poly_sig_check_concrete_loop(pool, nodes, prog_idx, funcs, i, sig):
    if i >= count(funcs.0):
        return 0
    end
    let prog = get(nodes, prog_idx)
    let inst = get(funcs.0, i)
    let fn = get(nodes, get(prog.2, inst.0))
    let pn = get(nodes, get(fn.2, 0))
    let pr = nc_sig_check_params_loop(pool, sig, i, 0, count(pn.1))
    if pr != 0:
        return pr
    end
    let nret = nc_func_never_returns_node(nodes, fn)
    let ret = nc_sig_get_ret(sig, i)
    if not nret:
        if nc_type_has_array_unknown(pool, ret):
            return nc_fail(438, fn.3, "")
        end
        if nc_type_has_unknown(pool, ret):
            return nc_fail(424, fn.3, "")
        end
    end
    if i == 0 and equal(get(fn.1, 0), "main"):
        if ret != nc_type_int() and ret != nc_type_bool():
            return nc_fail(432, fn.3, "")
        end
    end
    return nc_poly_sig_check_concrete_loop(pool, nodes, prog_idx, funcs, i + 1, sig)
end

-- Scan EVERY parsed node (the whole pool) for an `nc_class_mix` poison node and
-- return its line, or 0 if none. Class-mix is a syntactic error the parser plants
-- on any class-mixing expression (parse_bitwise/parse_bitwise_loop), so a single
-- linear scan of the pool catches it in ANY function -- reachable from main or
-- not -- matching the C reference, which rejects class-mix syntactically for all
-- functions.
func nc_class_mix_scan_loop(nodes, i, n):
    if i >= n:
        return 0
    end
    if equal(get(nodes, i).0, "nc_class_mix"):
        return get(nodes, i).3
    end
    return nc_class_mix_scan_loop(nodes, i + 1, n)
end

func nc_class_mix_line(nodes):
    return nc_class_mix_scan_loop(nodes, 0, count(nodes))
end

func nc_verify_ast(nodes, prog_idx, pool):
    -- Reachability-independent class-mix rejection (matches C: a syntactic error in
    -- ANY function, reachable or not). This runs FIRST -- before the function-table
    -- check and the reachability-seeded poly verify (nc_poly_seed_main only seeds
    -- `main` and its call graph). It must precede nc_table_check because a class-mix
    -- makes the parser stop cleanly at end-of-input (plant_class_mix), which can
    -- drop a trailing `main`; reporting the table error first would mask the real
    -- ERR 442 (and diverge from C). A class-mix buried in dead code is no longer
    -- silently accepted, and a class-mix in a called function -- which used to
    -- crash the parser (`get: ... out of range`) -- now rejects cleanly here.
    let mix_line = nc_class_mix_line(nodes)
    if mix_line > 0:
        let mix_instances = new_array((int, array(int), int, int, int, int))
        let mix_targets = new_array((int, int, int))
        return (nc_fail(442, mix_line, ""), nc_sig_init(nodes, prog_idx), (mix_instances, mix_targets))
    end
    let tbl = nc_table_check(nodes, prog_idx)
    if tbl != 0:
        let empty_instances = new_array((int, array(int), int, int, int, int))
        let empty_targets = new_array((int, int, int))
        return (tbl, nc_sig_init(nodes, prog_idx), (empty_instances, empty_targets))
    end
    let seeded = nc_poly_seed_main(nodes, prog_idx)
    let solved = nc_poly_sig_solve_loop(pool, nodes, prog_idx, seeded.1, seeded.0, nc_poly_max_instances())
    if solved.0 != 0:
        return (solved.0, solved.1, seeded.1)
    end
    let concrete = nc_poly_sig_check_concrete_loop(pool, nodes, prog_idx, seeded.1, 0, solved.1)
    if concrete != 0:
        return (concrete, solved.1, seeded.1)
    end
    let replay = nc_poly_infer_instances_loop(pool, nodes, prog_idx, seeded.1, 0, solved.1, 0)
    return (replay.0, replay.1, seeded.1)
end

-- ====================================================================
-- BYTECODE VERIFY, LAYOUT, AND EMISSION
-- ====================================================================

func nc_code_branches_to_loop(code, target, i, n):
    if i >= n:
        return false
    end
    let instr = get(code, i)
    let op = instr.0
    if op == 16 or op == 17 or op == 18 or op == 19:
        if instr.1 == target:
            return true
        end
    end
    return nc_code_branches_to_loop(code, target, i + 1, n)
end

func nc_code_branches_to(code, target):
    return nc_code_branches_to_loop(code, target, 0, count(code))
end

func nc_is_tail_call(code, i, n):
    if i + 1 >= n:
        return false
    end
    let instr = get(code, i)
    let next = get(code, i + 1)
    if instr.0 != 20 or next.0 != 21:
        return false
    end
    return not nc_code_branches_to(code, i + 1)
end

func nc_opcode_name_for_diag(op):
    if op == 1:
        return "PUSH_BOOL"
    end
    if op == 2:
        return "PUSH_STR"
    end
    if op == 14:
        return "MAKE_TUPLE"
    end
    if op == 15:
        return "TUPLE_GET"
    end
    if op == 20:
        return "CALL"
    end
    if op == 22:
        return "LENGTH"
    end
    if op == 23:
        return "INDEX"
    end
    if op == 24:
        return "SLICE"
    end
    if op == 25:
        return "EQUAL"
    end
    if op == 26:
        return "NEW_BUFFER"
    end
    if op == 27:
        return "FREEZE"
    end
    if op == 28:
        return "NEW_ARRAY"
    end
    if op == 29:
        return "GET"
    end
    if op == 30:
        return "COUNT"
    end
    if op == 31:
        return "BUF_APPEND"
    end
    if op == 32:
        return "ARR_ADD"
    end
    if op == 33:
        return "CLOGGER"
    end
    if op == 34:
        return "FLOGGER"
    end
    if op == 35:
        return "FWRITER"
    end
    if op == 36:
        return "BAND"
    end
    if op == 37:
        return "BOR"
    end
    if op == 38:
        return "BXOR"
    end
    if op == 39:
        return "SHL"
    end
    if op == 40:
        return "SHR"
    end
    if op == 41:
        return "BNOT"
    end
    if op == 42:
        return "MUL"
    end
    if op == 43:
        return "DIV"
    end
    if op == 44:
        return "MOD"
    end
    return int_to_str(op)
end

func nc_count_clogger_bc_loop(code, i, n):
    if i >= n:
        return 0
    end
    let instr = get(code, i)
    let c = 0
    if instr.0 == 33:
        c = 1
    end
    return c + nc_count_clogger_bc_loop(code, i + 1, n)
end

func nc_make_ints_loop(i, n, value, out):
    if i >= n:
        return out
    end
    do add(out, value)
    return nc_make_ints_loop(i + 1, n, value, out)
end

func nc_make_ints(n, value):
    return nc_make_ints_loop(0, n, value, new_array(int))
end

func nc_make_tuple3s_loop(i, n, value, out):
    if i >= n:
        return out
    end
    do add(out, value)
    return nc_make_tuple3s_loop(i + 1, n, value, out)
end

func nc_make_tuple3s(n, value):
    return nc_make_tuple3s_loop(0, n, value, new_array((int, int, int)))
end

func nc_make_stacks_loop(i, n, out):
    if i >= n:
        return out
    end
    do add(out, new_array(int))
    return nc_make_stacks_loop(i + 1, n, out)
end

func nc_make_stacks(n):
    return nc_make_stacks_loop(0, n, new_array(array(int)))
end

func nc_tuple3_array_set_loop(src, i, n, target, value, out):
    if i >= n:
        return out
    end
    if i == target:
        do add(out, value)
    else:
        do add(out, get(src, i))
    end
    return nc_tuple3_array_set_loop(src, i + 1, n, target, value, out)
end

func nc_tuple3_array_set(src, target, value):
    return nc_tuple3_array_set_loop(src, 0, count(src), target, value, new_array((int, int, int)))
end

func nc_stack_prefix_loop(stack, i, n, out):
    if i >= n:
        return out
    end
    do add(out, get(stack, i))
    return nc_stack_prefix_loop(stack, i + 1, n, out)
end

func nc_stack_prefix(stack, keep):
    return nc_stack_prefix_loop(stack, 0, keep, new_array(int))
end

func nc_stack_push(stack, t):
    let out = nc_stack_prefix(stack, count(stack))
    do add(out, t)
    return out
end

func nc_stack_pop(stack, line):
    let n = count(stack)
    if n == 0:
        return (nc_fail(416, line, ""), stack, 0)
    end
    return (0, nc_stack_prefix(stack, n - 1), get(stack, n - 1))
end

func nc_stack_word_depth_loop(pool, stack, i, n, acc):
    if i >= n:
        return acc
    end
    return nc_stack_word_depth_loop(pool, stack, i + 1, n, acc + nc_type_width(pool, get(stack, i)))
end

func nc_stack_word_depth(pool, stack):
    return nc_stack_word_depth_loop(pool, stack, 0, count(stack), 0)
end

func nc_type_array_width_loop(pool, arr, i, n, acc):
    if i >= n:
        return acc
    end
    return nc_type_array_width_loop(pool, arr, i + 1, n, acc + nc_type_width(pool, get(arr, i)))
end

func nc_type_array_width(pool, arr):
    return nc_type_array_width_loop(pool, arr, 0, count(arr), 0)
end

func nc_init_local_types_params(sig, fn_idx, i, n, out):
    if i >= n:
        return out
    end
    do add(out, nc_sig_get_param(sig, fn_idx, i))
    return nc_init_local_types_params(sig, fn_idx, i + 1, n, out)
end

func nc_init_local_types_fill(i, n, out):
    if i >= n:
        return out
    end
    do add(out, nc_type_unknown())
    return nc_init_local_types_fill(i + 1, n, out)
end

func nc_init_local_types(fn, sig, fn_idx):
    let out = nc_init_local_types_params(sig, fn_idx, 0, fn.2, new_array(int))
    return nc_init_local_types_fill(fn.2, fn.3, out)
end

func nc_meta_expect_type(pool, got, want, line):
    if nc_type_equal(pool, got, want):
        return 0
    end
    return nc_fail(430, line, "")
end

func nc_meta_pop_expect(pool, stack, want, line):
    let p = nc_stack_pop(stack, line)
    if p.0 != 0:
        return p
    end
    let e = nc_meta_expect_type(pool, p.2, want, line)
    if e != 0:
        return (e, p.1, p.2)
    end
    return p
end

func nc_meta_store_local_type(pool, local_types, slot, got, line):
    if slot >= count(local_types):
        return (nc_fail(416, line, ""), local_types)
    end
    let old = get(local_types, slot)
    if old != nc_type_unknown() and got != nc_type_unknown():
        if nc_type_width(pool, old) != nc_type_width(pool, got):
            return (nc_fail(433, line, ""), local_types)
        end
        if nc_type_is_array(pool, old) or nc_type_is_array(pool, got):
            if not nc_type_equal(pool, old, got):
                return (nc_fail(436, line, ""), local_types)
            end
        end
        if not nc_assignment_type_ok(pool, old, got):
            return (nc_fail(430, line, ""), local_types)
        end
    end
    if got == nc_type_unknown():
        return (0, local_types)
    end
    return (0, nc_int_array_set(local_types, slot, got))
end

func nc_meta_tuple_children_from_stack(stack, from, i, n, out):
    if i >= n:
        return out
    end
    do add(out, get(stack, from + i))
    return nc_meta_tuple_children_from_stack(stack, from, i + 1, n, out)
end

func nc_meta_pop_call_args(pool, funcs, sig, callee_idx, stack, arg_i, line):
    if arg_i == 0 - 1:
        return (0, stack)
    end
    let p = nc_stack_pop(stack, line)
    if p.0 != 0:
        return (p.0, stack)
    end
    let want = nc_sig_get_param(sig, callee_idx, arg_i)
    let e = nc_meta_expect_type(pool, p.2, want, line)
    if e != 0:
        return (e, p.1)
    end
    return nc_meta_pop_call_args(pool, funcs, sig, callee_idx, p.1, arg_i - 1, line)
end

func nc_meta_call_arg_words_loop(pool, sig, callee_idx, i, n, acc):
    if i >= n:
        return acc
    end
    return nc_meta_call_arg_words_loop(pool, sig, callee_idx, i + 1, n, acc + nc_type_width(pool, nc_sig_get_param(sig, callee_idx, i)))
end

func nc_meta_call_arg_words(pool, funcs, sig, callee_idx):
    let fn = get(funcs, callee_idx)
    return nc_meta_call_arg_words_loop(pool, sig, callee_idx, 0, fn.2, 0)
end

func nc_meta_process_loop(pool, funcs, sig, fn_idx, main_idx, strings_count, code, new_array_meta, i, n, stack, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap):
    if i >= n:
        return (0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
    end
    let instr = get(code, i)
    let op = instr.0
    let na_type = get(new_array_meta, i)
    if op == 28:
        if na_type == 0:
            return (nc_fail(439, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
    elif na_type != 0:
        return (nc_fail(439, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
    end
    if op >= 26 and op <= 32:
        has_heap = 1
    end
    stacks = nc_array_int_set(stacks, i, stack)
    max_stack = nc_max_i(max_stack, nc_stack_word_depth(pool, stack))
    if op == 0:
        stack = nc_stack_push(stack, nc_type_int())
    elif op == 1:
        if instr.1 != 0 and instr.1 != 1:
            return (nc_fail(417, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(stack, nc_type_bool())
    elif op == 2:
        if instr.1 >= strings_count:
            return (nc_fail(428, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(stack, nc_type_string())
    elif op == 3:
        if instr.1 >= count(local_types):
            return (nc_fail(416, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let lt = get(local_types, instr.1)
        if nc_type_has_unknown(pool, lt):
            return (nc_fail(424, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(stack, lt)
    elif op == 4:
        let p = nc_stack_pop(stack, 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let st = nc_meta_store_local_type(pool, local_types, instr.1, p.2, 0)
        if st.0 != 0:
            return (st.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = p.1
        local_types = st.1
    elif op == 5 or op == 6 or op == 36 or op == 37 or op == 38 or op == 39 or op == 40 or op == 42 or op == 43 or op == 44:
        -- add/sub, the bitwise/shift binops (band/bor/bxor/shl/shr), and the
        -- multiplicative binops (mul/div/mod) all pop two ints and push one int;
        -- identical stack discipline.
        let r = nc_meta_pop_expect(pool, stack, nc_type_int(), 0)
        if r.0 != 0:
            return (r.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let l = nc_meta_pop_expect(pool, r.1, nc_type_int(), 0)
        if l.0 != 0:
            return (l.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(l.1, nc_type_int())
    elif op == 41:
        -- bnot: pop one int, push one int (the int-typed counterpart of op 13).
        let p = nc_meta_pop_expect(pool, stack, nc_type_int(), 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(p.1, nc_type_int())
    elif op == 7 or op == 8 or op == 9 or op == 10 or op == 11 or op == 12:
        let r = nc_meta_pop_expect(pool, stack, nc_type_int(), 0)
        if r.0 != 0:
            return (r.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let l = nc_meta_pop_expect(pool, r.1, nc_type_int(), 0)
        if l.0 != 0:
            return (l.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(l.1, nc_type_bool())
    elif op == 13:
        let p = nc_meta_pop_expect(pool, stack, nc_type_bool(), 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(p.1, nc_type_bool())
    elif op == 14:
        if count(stack) < instr.1:
            return (nc_fail(416, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let from = count(stack) - instr.1
        let kids = nc_meta_tuple_children_from_stack(stack, from, 0, instr.1, new_array(int))
        stack = nc_stack_prefix(stack, from)
        stack = nc_stack_push(stack, nc_type_intern_tuple(pool, kids))
    elif op == 15:
        let p = nc_stack_pop(stack, 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        if not nc_type_is_tuple(pool, p.2):
            return (nc_fail(431, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let kids = nc_type_tuple_children(pool, p.2)
        if instr.1 >= count(kids):
            return (nc_fail(431, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let elem_t = get(kids, instr.1)
        let tw = nc_type_width(pool, p.2)
        let es = nc_tuple_child_start_loop(pool, kids, 0, instr.1, 0)
        let ew = nc_type_width(pool, elem_t)
        tuple_meta = nc_tuple3_array_set(tuple_meta, i, (tw, es, ew))
        stack = nc_stack_push(p.1, elem_t)
    elif op == 16:
        stack = stack
    elif op == 17:
        let p = nc_meta_pop_expect(pool, stack, nc_type_bool(), 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = p.1
    elif op == 18 or op == 19:
        let p = nc_meta_pop_expect(pool, stack, nc_type_bool(), 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = p.1
    elif op == 20:
        if instr.1 >= count(funcs):
            return (nc_fail(426, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        if instr.1 == main_idx:
            return (nc_fail(421, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let callee = get(funcs, instr.1)
        if instr.2 != callee.2:
            return (nc_fail(426, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let popped = nc_meta_pop_call_args(pool, funcs, sig, instr.1, stack, instr.2 - 1, 0)
        if popped.0 != 0:
            return (popped.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let ret0 = nc_sig_get_ret(sig, instr.1)
        let nev = ret0 == nc_type_unknown()
        let ret = ret0
        if nev:
            ret = nc_sig_get_ret(sig, fn_idx)
        end
        let rw = nc_type_width(pool, ret)
        let aw = nc_meta_call_arg_words(pool, funcs, sig, instr.1)
        let kind = 0
        if rw > 1:
            kind = 1
        end
        if not nev and nc_is_tail_call(code, i, n):
            let my_ret = nc_sig_get_ret(sig, fn_idx)
            let my_rw = nc_type_width(pool, my_ret)
            let my_aw = nc_meta_call_arg_words(pool, funcs, sig, fn_idx)
            if aw == my_aw and rw == my_rw:
                if rw > 1:
                    kind = 3
                else:
                    kind = 2
                end
            end
        end
        call_meta = nc_tuple3_array_set(call_meta, i, (aw, rw, kind))
        if kind == 1 and rw > max_sret:
            max_sret = rw
        end
        stack = nc_stack_push(popped.1, ret)
    elif op == 21:
        if count(stack) != 1:
            return (nc_fail(416, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let ret = nc_sig_get_ret(sig, fn_idx)
        if ret != nc_type_unknown():
            if not nc_type_equal(pool, get(stack, 0), ret):
                return (nc_fail(430, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
            end
        end
        stack = new_array(int)
    elif op == 22:
        let p = nc_meta_pop_expect(pool, stack, nc_type_string(), 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(p.1, nc_type_int())
    elif op == 23:
        let idx = nc_meta_pop_expect(pool, stack, nc_type_int(), 0)
        if idx.0 != 0:
            return (idx.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let strv = nc_meta_pop_expect(pool, idx.1, nc_type_string(), 0)
        if strv.0 != 0:
            return (strv.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(strv.1, nc_type_int())
    elif op == 25:
        let r = nc_meta_pop_expect(pool, stack, nc_type_string(), 0)
        if r.0 != 0:
            return (r.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let l = nc_meta_pop_expect(pool, r.1, nc_type_string(), 0)
        if l.0 != 0:
            return (l.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(l.1, nc_type_bool())
    elif op == 24:
        return (nc_fail(438, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
    elif op == 26:
        heap_meta = nc_tuple3_array_set(heap_meta, i, (4, 0, 0))
        stack = nc_stack_push(stack, nc_type_buffer())
    elif op == 27:
        let p = nc_meta_pop_expect(pool, stack, nc_type_buffer(), 0)
        if p.0 != 0:
            return (nc_fail(437, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(p.1, nc_type_string())
    elif op == 28:
        if not nc_type_is_array(pool, na_type):
            return (nc_fail(439, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let elem_t = nc_type_array_elem(pool, na_type)
        let elem_w = nc_type_width(pool, elem_t)
        if elem_w <= 0:
            return (nc_fail(438, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        heap_meta = nc_tuple3_array_set(heap_meta, i, (1, elem_w, elem_t))
        stack = nc_stack_push(stack, na_type)
    elif op == 29:
        let idx = nc_meta_pop_expect(pool, stack, nc_type_int(), 0)
        if idx.0 != 0:
            return (idx.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let arr = nc_stack_pop(idx.1, 0)
        if arr.0 != 0:
            return (arr.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        if not nc_type_is_array(pool, arr.2):
            return (nc_fail(435, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let elem_t = nc_type_array_elem(pool, arr.2)
        let elem_w = nc_type_width(pool, elem_t)
        heap_meta = nc_tuple3_array_set(heap_meta, i, (2, elem_w, elem_t))
        stack = nc_stack_push(arr.1, elem_t)
    elif op == 30:
        let arr = nc_stack_pop(stack, 0)
        if arr.0 != 0:
            return (arr.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        if not nc_type_is_array(pool, arr.2):
            return (nc_fail(435, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = nc_stack_push(arr.1, nc_type_int())
    elif op == 31:
        let val = nc_meta_pop_expect(pool, stack, nc_type_int(), 0)
        if val.0 != 0:
            return (val.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let bufv = nc_meta_pop_expect(pool, val.1, nc_type_buffer(), 0)
        if bufv.0 != 0:
            return (nc_fail(437, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = bufv.1
    elif op == 32:
        let val = nc_stack_pop(stack, 0)
        if val.0 != 0:
            return (val.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let arr = nc_stack_pop(val.1, 0)
        if arr.0 != 0:
            return (arr.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        if not nc_type_is_array(pool, arr.2):
            return (nc_fail(435, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        let elem_t = nc_type_array_elem(pool, arr.2)
        let elem_w = nc_type_width(pool, elem_t)
        let ok = nc_expect_array_elem(pool, val.2, elem_t, 0)
        if ok != 0:
            return (ok, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        heap_meta = nc_tuple3_array_set(heap_meta, i, (3, elem_w, elem_t))
        stack = arr.1
    elif op == 33:
        if fn_idx != main_idx:
            return (nc_fail(408, 0, "CLOGGER"), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        if has_clogger != 0:
            return (nc_fail(411, 0, ""), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        has_clogger = 1
        has_heap = 1
        stack = nc_stack_push(stack, nc_type_string())
    elif op == 34:
        let p = nc_meta_pop_expect(pool, stack, nc_type_string(), 0)
        if p.0 != 0:
            return (p.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = p.1
    elif op == 35:
        let pf = nc_meta_pop_expect(pool, stack, nc_type_string(), 0)
        if pf.0 != 0:
            return (pf.0, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
        end
        stack = pf.1
    else:
        return (nc_fail(408, 0, nc_opcode_name_for_diag(op)), local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
    end
    max_stack = nc_max_i(max_stack, nc_stack_word_depth(pool, stack))
    return nc_meta_process_loop(pool, funcs, sig, fn_idx, main_idx, strings_count, code, new_array_meta, i + 1, n, stack, local_types, stacks, tuple_meta, call_meta, max_stack, max_sret, has_clogger, heap_meta, has_heap)
end

func nc_build_local_layout_loop(pool, local_types, i, n, bases, widths, base):
    if i >= n:
        return (0, bases, widths, base)
    end
    let t = get(local_types, i)
    if nc_type_has_array_unknown(pool, t):
        return (nc_fail(438, 0, ""), bases, widths, base)
    end
    if nc_type_has_unknown(pool, t):
        return (nc_fail(424, 0, ""), bases, widths, base)
    end
    let w = nc_type_width(pool, t)
    do add(bases, base)
    do add(widths, w)
    return nc_build_local_layout_loop(pool, local_types, i + 1, n, bases, widths, base + w)
end

func nc_build_one_meta(pool, prog, sig, fn_idx):
    let funcs = prog.0
    let fn = get(funcs, fn_idx)
    let code = fn.4
    let n = count(code)
    let heap_meta0 = nc_make_tuple3s(n, (0, 0, 0))
    if n == 0 or get(code, n - 1).0 != 21:
        return (nc_fail(416, 0, ""), (0, 0, 0, new_array(int), new_array(int), 0, 0, 0, 0, new_array(array(int)), new_array((int, int, int)), new_array((int, int, int)), 0, 0, heap_meta0, 0))
    end
    if count(fn.5) != n:
        return (nc_fail(439, 0, ""), (0, 0, 0, new_array(int), new_array(int), 0, 0, 0, 0, new_array(array(int)), new_array((int, int, int)), new_array((int, int, int)), 0, 0, heap_meta0, 0))
    end
    if count(fn.6) != n:
        return (nc_fail(439, 0, ""), (0, 0, 0, new_array(int), new_array(int), 0, 0, 0, 0, new_array(array(int)), new_array((int, int, int)), new_array((int, int, int)), 0, 0, heap_meta0, 0))
    end
    let local_types = nc_init_local_types(fn, sig, fn_idx)
    let stacks = nc_make_stacks(n + 1)
    let tuple_meta = nc_make_tuple3s(n, (0 - 1, 0 - 1, 0 - 1))
    let call_meta = nc_make_tuple3s(n, (0, 0, 0))
    let p = nc_meta_process_loop(pool, funcs, sig, fn_idx, prog.2, count(prog.1), code, fn.5, 0, n, new_array(int), local_types, stacks, tuple_meta, call_meta, 0, 0, 0, heap_meta0, 0)
    if p.0 != 0:
        return (p.0, (0, 0, 0, new_array(int), new_array(int), 0, 0, 0, 0, stacks, tuple_meta, call_meta, 0, 0, p.8, p.9))
    end
    let lay = nc_build_local_layout_loop(pool, p.1, 0, count(p.1), new_array(int), new_array(int), 0)
    if lay.0 != 0:
        return (lay.0, (0, 0, 0, new_array(int), new_array(int), 0, 0, 0, 0, stacks, tuple_meta, call_meta, 0, 0, p.8, p.9))
    end
    let ret = nc_sig_get_ret(sig, fn_idx)
    let retw = nc_type_width(pool, ret)
    let pwords = nc_meta_call_arg_words(pool, funcs, sig, fn_idx)
    let sret_word = 0 - 1
    let hidden = 0
    if retw > 1:
        sret_word = lay.3
        hidden = 1
    end
    let scratch_base = 0 - 1
    if p.6 > 0:
        scratch_base = lay.3 + hidden
    end
    return (0, (pwords, ret, retw, lay.1, lay.2, lay.3, sret_word, scratch_base, p.6, p.2, p.3, p.4, p.5, p.7, p.8, p.9))
end

func nc_analyze_program_loop(pool, prog, sig, i, n, metas, has_clogger, has_heap):
    if i >= n:
        return (0, metas, has_clogger, has_heap)
    end
    let m = nc_build_one_meta(pool, prog, sig, i)
    if m.0 != 0:
        return (m.0, metas, has_clogger, has_heap)
    end
    do add(metas, m.1)
    if m.1.13 != 0:
        has_clogger = 1
    end
    if m.1.15 != 0:
        has_heap = 1
    end
    return nc_analyze_program_loop(pool, prog, sig, i + 1, n, metas, has_clogger, has_heap)
end

func nc_analyze_program(pool, prog, sig):
    return nc_analyze_program_loop(pool, prog, sig, 0, count(prog.0), new_array((int, int, int, array(int), array(int), int, int, int, int, array(array(int)), array((int, int, int)), array((int, int, int)), int, int, array((int, int, int)), int)), 0, 0)
end

func nc_code_has_faultable_loop(code, i, n):
    if i >= n:
        return 0
    end
    let op = get(code, i).0
    -- 23/29/31 = index/get/append OOB faults; 43/44 = div/mod by-zero fault.
    -- A faultable op forces the fault-helper block (incl. the exit1 routine the
    -- div/mod zero-check jumps to) to be emitted. op_mul (42) never faults.
    if op == 23 or op == 29 or op == 31 or op == 43 or op == 44:
        return 1
    end
    return nc_code_has_faultable_loop(code, i + 1, n)
end

func nc_funcs_have_faultable_loop(funcs, i, n):
    if i >= n:
        return 0
    end
    if nc_code_has_faultable_loop(get(funcs, i).4, 0, count(get(funcs, i).4)) != 0:
        return 1
    end
    return nc_funcs_have_faultable_loop(funcs, i + 1, n)
end

func nc_prog_has_faultable(prog):
    return nc_funcs_have_faultable_loop(prog.0, 0, count(prog.0))
end

-- Little-endian byte-serialization helpers. Now that tonka added * / %, these
-- use real remainder/division. Pre-tonka (no * / %) they were O(value)
-- repeated-subtraction loops, which hung compilation on a large literal whose
-- PUSH_INT byte split ran billions of iterations (D15 -- throne). The byte
-- values are unchanged; only the cost is (O(value) -> O(1) per byte).
func nc_mod256(v):
    return v % 256
end

func nc_div256(v):
    return v / 256
end

func nc_append_le32(buf, v):
    let b0 = nc_mod256(v)
    let v1 = nc_div256(v)
    let b1 = nc_mod256(v1)
    let v2 = nc_div256(v1)
    let b2 = nc_mod256(v2)
    let v3 = nc_div256(v2)
    let b3 = nc_mod256(v3)
    do append(buf, b0)
    do append(buf, b1)
    do append(buf, b2)
    do append(buf, b3)
    return buf
end

func nc_append_le64(buf, v):
    let b0 = nc_mod256(v)
    let v1 = nc_div256(v)
    let b1 = nc_mod256(v1)
    let v2 = nc_div256(v1)
    let b2 = nc_mod256(v2)
    let v3 = nc_div256(v2)
    let b3 = nc_mod256(v3)
    let v4 = nc_div256(v3)
    let b4 = nc_mod256(v4)
    let v5 = nc_div256(v4)
    let b5 = nc_mod256(v5)
    let v6 = nc_div256(v5)
    let b6 = nc_mod256(v6)
    let v7 = nc_div256(v6)
    let b7 = nc_mod256(v7)
    do append(buf, b0)
    do append(buf, b1)
    do append(buf, b2)
    do append(buf, b3)
    do append(buf, b4)
    do append(buf, b5)
    do append(buf, b6)
    do append(buf, b7)
    return buf
end

func nc_append_s32(buf, neg, mag):
    if neg == 0:
        return nc_append_le32(buf, mag)
    end
    let m = mag - 1
    let b0 = nc_mod256(m)
    let v1 = nc_div256(m)
    let b1 = nc_mod256(v1)
    let v2 = nc_div256(v1)
    let b2 = nc_mod256(v2)
    let v3 = nc_div256(v2)
    let b3 = nc_mod256(v3)
    do append(buf, 255 - b0)
    do append(buf, 255 - b1)
    do append(buf, 255 - b2)
    do append(buf, 255 - b3)
    return buf
end

func nc_append_s8(buf, neg, mag):
    if neg == 0:
        do append(buf, mag)
    elif mag == 0:
        do append(buf, 0)
    else:
        do append(buf, 256 - mag)
    end
    return buf
end

func nc_signed_fits8(neg, mag):
    if neg == 0:
        return mag <= 127
    end
    return mag <= 128
end

func nc_rel_ok(target, base):
    if target >= base:
        return target - base < 2147483648
    end
    return base - target <= 2147483648
end

func nc_append_rel32(buf, target, base):
    if target >= base:
        return nc_append_le32(buf, target - base)
    end
    return nc_append_s32(buf, 1, base - target)
end

func nc_mul8_loop(acc, n):
    if n <= 0:
        return acc
    end
    return nc_mul8_loop(acc + 8, n - 1)
end

func nc_mul8(n):
    return nc_mul8_loop(0, n)
end

func nc_mod16_loop(v):
    if v < 16:
        return v
    end
    return nc_mod16_loop(v - 16)
end

func nc_mod16(v):
    return nc_mod16_loop(v)
end

func nc_round16_up(v):
    let m = nc_mod16(v)
    if m == 0:
        return v
    end
    return v + 16 - m
end

func nc_mod8_loop(v):
    if v < 8:
        return v
    end
    return nc_mod8_loop(v - 8)
end

func nc_round8_up(v):
    let m = nc_mod8_loop(v)
    if m == 0:
        return v
    end
    return v + 8 - m
end

func nc_disp_len_rbp(neg, mag):
    if nc_signed_fits8(neg, mag):
        return 4
    end
    return 7
end

func nc_disp_len_rbp_mzb(neg, mag):
    if nc_signed_fits8(neg, mag):
        return 5
    end
    return 8
end

func nc_disp_len_rsp(mag):
    if mag <= 127:
        return 5
    end
    return 8
end

func nc_disp_len_rdi(mag):
    if mag == 0:
        return 3
    end
    if mag <= 127:
        return 4
    end
    return 7
end

func nc_disp_len_rsi(mag):
    if mag == 0:
        return 3
    end
    if mag <= 127:
        return 4
    end
    return 7
end

func nc_disp_len_rsp_r8(mag):
    if mag <= 127:
        return 5
    end
    return 8
end

func nc_disp_pair_from_pos_minus(pos, sub):
    if pos >= sub:
        return (0, pos - sub)
    end
    return (1, sub - pos)
end

func nc_rslot_pair(ng, nf):
    let pos = 8 + nc_mul8(ng)
    let sub = nc_mul8(nf)
    return nc_disp_pair_from_pos_minus(pos, sub)
end

func nc_tail_dst_pair(ng, k):
    let pos = 8 + nc_mul8(ng)
    let sub = nc_mul8(k)
    return nc_disp_pair_from_pos_minus(pos, sub)
end

func nc_tail_copy_len_loop(k, nf, ng, acc):
    if k >= nf:
        return acc
    end
    let src = nc_mul8(nf - 1 - k)
    let dst = nc_tail_dst_pair(ng, k)
    return nc_tail_copy_len_loop(k + 1, nf, ng, acc + nc_disp_len_rsp(src) + nc_disp_len_rbp(dst.0, dst.1))
end

func nc_tail_len(ng, nf):
    let rslot = nc_rslot_pair(ng, nf)
    return 8 + nc_tail_copy_len_loop(0, nf, ng, 0) + nc_disp_len_rbp(rslot.0, rslot.1) + nc_disp_len_rbp(rslot.0, rslot.1) + 3 + 5
end

func nc_cleanup_len(nargs):
    if nc_mul8(nargs) <= 127:
        return 4
    end
    return 7
end

func nc_call_len(nargs):
    return 5 + nc_cleanup_len(nargs) + 1
end

func nc_local_mag(slot):
    return nc_mul8(slot + 1)
end

func nc_sub_len(frame_sz):
    if frame_sz <= 127:
        return 4
    end
    return 7
end

func nc_prologue_len(frame_sz):
    return 4 + nc_sub_len(frame_sz)
end

func nc_max_i(a, b):
    if a > b:
        return a
    end
    return b
end

func nc_frame_total_words(meta):
    let hidden = 0
    if meta.6 != 0 - 1:
        hidden = 1
    end
    return meta.5 + hidden + meta.8
end

func nc_frame_total(meta):
    return nc_round16_up(nc_mul8(nc_frame_total_words(meta)))
end

func nc_fault_route_len():
    return 12
