    end
    return nc_arr_add_store_len(width, k - 1, acc + 1 + nc_disp_len_rsi(nc_mul8(k)))
end

func nc_arr_add_len(width):
    return nc_disp_len_rsp_r8(nc_mul8(width)) + 177 + nc_arr_add_store_len(width, width - 1, 0)
end

func nc_rsp_store_len(mag):
    return nc_disp_len_rsp(mag)
end

func nc_tuple_get_copy_len_loop(j, f, w, s, acc):
    if j >= f:
        return acc
    end
    let src = nc_mul8(w - 1 - (s + j))
    let dst = nc_mul8(w - 1 - j)
    return nc_tuple_get_copy_len_loop(j + 1, f, w, s, acc + nc_disp_len_rsp(src) + nc_rsp_store_len(dst))
end

func nc_tuple_get_len(meta, pc):
    let tm = get(meta.10, pc)
    let drop = tm.0 - tm.2
    let cleanup = 0
    if drop > 0:
        cleanup = nc_cleanup_len(drop)
    end
    return nc_tuple_get_copy_len_loop(0, tm.2, tm.0, tm.1, 0) + cleanup
end

func nc_sret_scratch_mag(base_word, ret_width, k):
    return nc_mul8(base_word + ret_width - k)
end

func nc_call_ret_push_len_loop(base_word, ret_width, k, n, acc):
    if k >= n:
        return acc
    end
    return nc_call_ret_push_len_loop(base_word, ret_width, k + 1, n, acc + nc_disp_len_rbp(1, nc_sret_scratch_mag(base_word, ret_width, k)) + 1)
end

func nc_normal_call_len(meta, pc):
    let cm = get(meta.11, pc)
    if cm.2 == 1:
        return nc_disp_len_rbp(1, nc_sret_scratch_mag(meta.7, cm.1, 0)) + 5 + nc_cleanup_len(cm.0) + nc_call_ret_push_len_loop(meta.7, cm.1, 0, cm.1, 0)
    end
    return 5 + nc_cleanup_len(cm.0) + 1
end

func nc_tail_len_for_meta(meta, pc):
    let cm = get(meta.11, pc)
    let extra = 0
    if cm.2 == 3:
        extra = nc_disp_len_rbp(1, nc_local_mag(meta.6))
    end
    return nc_tail_len(meta.0, cm.0) + extra
end

func nc_aggregate_ret_store_len_loop(k, retw, acc):
    if k == 0 - 1:
        return acc
    end
    return nc_aggregate_ret_store_len_loop(k - 1, retw, acc + 1 + nc_disp_len_rdi(nc_mul8(k)))
end

func nc_ret_len(meta):
    if meta.2 <= 1:
        return 3
    end
    return nc_disp_len_rbp(1, nc_local_mag(meta.6)) + nc_aggregate_ret_store_len_loop(meta.2 - 1, meta.2, 0) + 2
end

func nc_group(code, i, n, fn, funcs, meta, metas):
    if i >= n:
        return (0, n)
    end
    let instr = get(code, i)
    let op = instr.0
    if op == 3:
        let base = get(meta.3, instr.1)
        let width = get(meta.4, instr.1)
        return (nc_load_local_len(base, width), i + 1)
    end
    if op == 4:
        let base = get(meta.3, instr.1)
        let width = get(meta.4, instr.1)
        return (nc_store_local_len(base, width), i + 1)
    end
    if op == 15:
        return (nc_tuple_get_len(meta, i), i + 1)
    end
    if op == 29:
        return (nc_get_len(get(meta.14, i).1), i + 1)
    end
    if op == 32:
        return (nc_arr_add_len(get(meta.14, i).1), i + 1)
    end
    if op == 20:
        let cm = get(meta.11, i)
        if cm.2 == 2 or cm.2 == 3:
            return (nc_tail_len_for_meta(meta, i), i + 2)
        end
        return (nc_normal_call_len(meta, i), i + 1)
    end
    if op == 21:
        return (nc_ret_len(meta), i + 1)
    end
    return (nc_group_single_len(op), i + 1)
end

func nc_pass1_fill_group(offs, bounds, j, next_i, cur, start):
    if j >= next_i:
        return (offs, bounds)
    end
    do add(offs, cur)
    if j == start:
        do add(bounds, 1)
    else:
        do add(bounds, 0)
    end
    return nc_pass1_fill_group(offs, bounds, j + 1, next_i, cur, start)
end

func nc_pass1_layout_loop(code, i, n, cur, offs, bounds, fn, funcs, meta, metas):
    if i >= n:
        do add(offs, cur)
        do add(bounds, 0)
        return (offs, bounds, cur)
    end
    let g = nc_group(code, i, n, fn, funcs, meta, metas)
    let filled = nc_pass1_fill_group(offs, bounds, i, g.1, cur, i)
    return nc_pass1_layout_loop(code, g.1, n, cur + g.0, filled.0, filled.1, fn, funcs, meta, metas)
end

func nc_pass1_layout(fn, funcs, meta, metas, prefix_len):
    return nc_pass1_layout_loop(fn.4, 0, count(fn.4), prefix_len, new_array(int), new_array(int), fn, funcs, meta, metas)
end

func nc_branch_end_delta(op):
    if op == 16:
        return 5
    end
    if op == 17:
        return 10
    end
    return 13
end

func nc_branch_and_rel_verify_loop(code, i, n, fn, funcs, meta, metas, layout, layouts):
    if i >= n:
        return 0
    end
    let instr = get(code, i)
    let op = instr.0
    let g = nc_group(code, i, n, fn, funcs, meta, metas)
    if op == 16 or op == 17 or op == 18 or op == 19:
        let target = instr.1
        if target >= n or target <= i:
            return nc_fail(415, 0, int_to_str(target))
        end
        if get(layout.2, target) == 0:
            return nc_fail(415, 0, int_to_str(target))
        end
        let base = layout.0 + get(layout.1, i) + nc_branch_end_delta(op)
        let dest = layout.0 + get(layout.1, target)
        if dest <= base:
            return nc_fail(415, 0, int_to_str(target))
        end
        if not nc_rel_ok(dest, base):
            return nc_fail(427, 0, "")
        end
    end
    if op == 20:
        let callee_layout = get(layouts, instr.1)
        let target_entry = callee_layout.0
        let base = 0
        let cm = get(meta.11, i)
        if cm.2 == 2 or cm.2 == 3:
            base = layout.0 + get(layout.1, i) + g.0
        elif cm.2 == 1:
            base = layout.0 + get(layout.1, i) + nc_disp_len_rbp(1, nc_sret_scratch_mag(meta.7, cm.1, 0)) + 5
        else:
            base = layout.0 + get(layout.1, i) + 5
        end
        if not nc_rel_ok(target_entry, base):
            return nc_fail(427, 0, "")
        end
    end
    return nc_branch_and_rel_verify_loop(code, g.1, n, fn, funcs, meta, metas, layout, layouts)
end

func nc_verify_layout_rels_loop(funcs, metas, layouts, i, n):
    if i >= n:
        return 0
    end
    let fn = get(funcs, i)
    let meta = get(metas, i)
    let layout = get(layouts, i)
    let r = nc_branch_and_rel_verify_loop(fn.4, 0, count(fn.4), fn, funcs, meta, metas, layout, layouts)
    if r != 0:
        return r
    end
    return nc_verify_layout_rels_loop(funcs, metas, layouts, i + 1, n)
end

func nc_entry_stub_len(has_clogger, has_heap, has_faultable, main_ret):
    return nc_entry_layout(has_heap, has_faultable, main_ret).6
end

func nc_pass1_program_loop(funcs, metas, i, n, entry, layouts):
    if i >= n:
        return (0, layouts, entry)
    end
    let fn = get(funcs, i)
    let meta = get(metas, i)
    let frame_sz = nc_frame_total(meta)
    let prefix_len = nc_prologue_len(frame_sz) + nc_sret_save_len(meta) + nc_arg_copy_len_loop(0, meta.0, 0)
    let lay = nc_pass1_layout(fn, funcs, meta, metas, prefix_len)
    let fn_len = lay.2
    do add(layouts, (entry, lay.0, lay.1, frame_sz, prefix_len, fn_len))
    return nc_pass1_program_loop(funcs, metas, i + 1, n, entry + fn_len, layouts)
end

func nc_pass1_program(prog, metas, has_clogger, has_heap, has_faultable):
    let funcs = prog.0
    let layouts = new_array((int, array(int), array(int), int, int, int))
    let main_ret = get(metas, prog.2).1
    let entry_layout = nc_entry_layout(has_heap, has_faultable, main_ret)
    let stub_len = nc_entry_stub_len(has_clogger, has_heap, has_faultable, main_ret)
    let r = nc_pass1_program_loop(funcs, metas, 0, count(funcs), stub_len, layouts)
    if r.0 != 0:
        return r
    end
    let main_layout = get(r.1, prog.2)
    let call_main_base = entry_layout.0 + 5
    if not nc_rel_ok(main_layout.0, call_main_base):
        return (nc_fail(427, 0, ""), r.1, r.2)
    end
    let call_render_base = entry_layout.0 + 10
    if not nc_rel_ok(entry_layout.5, call_render_base):
        return (nc_fail(427, 0, ""), r.1, r.2)
    end
    let vr = nc_verify_layout_rels_loop(funcs, metas, r.1, 0, count(funcs))
    if vr != 0:
        return (vr, r.1, r.2)
    end
    return r
end

