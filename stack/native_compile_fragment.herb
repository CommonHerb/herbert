func nc_emit_call(buf, target, base, nargs):
    do append(buf, 232)
    buf = nc_append_rel32(buf, target, base)
    let cleanup = nc_mul8(nargs)
    if cleanup <= 127:
        do append(buf, 72)
        do append(buf, 131)
        do append(buf, 196)
        do append(buf, cleanup)
    else:
        do append(buf, 72)
        do append(buf, 129)
        do append(buf, 196)
        buf = nc_append_le32(buf, cleanup)
    end
    do append(buf, 80)
    return buf
end

func nc_emit_tail_copy_loop(buf, k, nf, ng):
    if k >= nf:
        return buf
    end
    let src = nc_mul8(nf - 1 - k)
    let dst = nc_tail_dst_pair(ng, k)
    buf = nc_emit_rsp_load_rax(buf, src)
    buf = nc_emit_disp_rbp_store_rax(buf, dst.0, dst.1)
    return nc_emit_tail_copy_loop(buf, k + 1, nf, ng)
end

func nc_emit_tail_call(buf, target, base, ng, nf):
    do append(buf, 76)
    do append(buf, 139)
    do append(buf, 93)
    do append(buf, 8)
    do append(buf, 76)
    do append(buf, 139)
    do append(buf, 85)
    do append(buf, 0)
    buf = nc_emit_tail_copy_loop(buf, 0, nf, ng)
    let rslot = nc_rslot_pair(ng, nf)
    buf = nc_emit_disp_rbp_store_r11(buf, rslot.0, rslot.1)
    buf = nc_emit_disp_rbp_lea_rsp(buf, rslot.0, rslot.1)
    do append(buf, 76)
    do append(buf, 137)
    do append(buf, 213)
    do append(buf, 233)
    return nc_append_rel32(buf, target, base)
end

