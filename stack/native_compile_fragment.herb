func nc_lower_loop(fn, funcs, meta, metas, layout, layouts, strings, code_len, i, n, buf):
    if i >= n:
        return buf
    end
    let code = fn.4
    let instr = get(code, i)
    let op = instr.0
    let a = instr.1
    let g = nc_group(code, i, n, fn, funcs, meta, metas)
    let instr_off = layout.0 + get(layout.1, i)
    if op == 0:
        buf = nc_emit_push_int(buf, a)
    elif op == 1:
        buf = nc_emit_push_bool(buf, a)
    elif op == 2:
        buf = nc_emit_push_str(buf, strings, a, instr_off, code_len)
    elif op == 3:
        buf = nc_emit_load_local(buf, get(meta.3, a), get(meta.4, a))
    elif op == 4:
        buf = nc_emit_store_local(buf, get(meta.3, a), get(meta.4, a))
    elif op == 5:
        buf = nc_emit_add(buf)
    elif op == 6:
        buf = nc_emit_sub(buf)
    elif op == 7:
        buf = nc_emit_cmp_setcc(buf, 146)
    elif op == 8:
        buf = nc_emit_cmp_setcc(buf, 150)
    elif op == 9:
        buf = nc_emit_cmp_setcc(buf, 151)
    elif op == 10:
        buf = nc_emit_cmp_setcc(buf, 147)
    elif op == 11:
        buf = nc_emit_cmp_setcc(buf, 148)
    elif op == 12:
        buf = nc_emit_cmp_setcc(buf, 149)
    elif op == 13:
        buf = nc_emit_not(buf)
    elif op == 15:
        buf = nc_emit_tuple_get(buf, meta, i)
    elif op == 16:
        buf = nc_emit_br(buf, layout.0 + get(layout.1, a), instr_off + 5)
    elif op == 17:
        buf = nc_emit_br_if_false(buf, layout.0 + get(layout.1, a), instr_off + 10)
    elif op == 18:
        buf = nc_emit_br_and(buf, layout.0 + get(layout.1, a), instr_off + 13)
    elif op == 19:
        buf = nc_emit_br_or(buf, layout.0 + get(layout.1, a), instr_off + 13)
    elif op == 20:
        let callee_layout = get(layouts, instr.1)
        let cm = get(meta.11, i)
        if cm.2 == 2:
            buf = nc_emit_tail_call(buf, callee_layout.0, instr_off + g.0, meta.0, cm.0, meta.6, 0)
        elif cm.2 == 3:
            buf = nc_emit_tail_call(buf, callee_layout.0, instr_off + g.0, meta.0, cm.0, meta.6, 1)
        else:
            let call_base = instr_off + 5
            if cm.2 == 1:
                call_base = instr_off + nc_disp_len_rbp(1, nc_sret_scratch_mag(meta.7, cm.1, 0)) + 5
            end
            buf = nc_emit_normal_call(buf, callee_layout.0, call_base, meta, cm)
        end
    elif op == 21:
        buf = nc_emit_ret(buf, meta)
    elif op == 22:
        buf = nc_emit_length(buf)
    elif op == 23:
        buf = nc_emit_index(buf)
    elif op == 25:
        buf = nc_emit_equal(buf)
    elif op == 26:
        buf = nc_emit_new_buffer(buf)
    elif op == 27:
        buf = nc_emit_freeze(buf)
    elif op == 28:
        buf = nc_emit_new_array(buf, get(meta.14, i).1)
    elif op == 29:
        buf = nc_emit_get(buf, get(meta.14, i).1)
    elif op == 30:
        buf = nc_emit_count(buf)
    elif op == 31:
        buf = nc_emit_buf_append(buf)
    elif op == 32:
        buf = nc_emit_arr_add(buf, get(meta.14, i).1)
    elif op == 33:
        buf = nc_emit_clogger(buf)
    elif op == 34:
        buf = nc_emit_flogger(buf)
    elif op == 35:
        buf = nc_emit_fwriter(buf)
    end
    return nc_lower_loop(fn, funcs, meta, metas, layout, layouts, strings, code_len, g.1, n, buf)
end

func nc_emit_function(buf, fn, funcs, meta, metas, layout, layouts, strings, code_len):
    let start_len = length(freeze(buf))
    buf = nc_emit_prologue(buf, layout.3)
    buf = nc_emit_sret_save(buf, meta)
    buf = nc_emit_arg_copies_loop(buf, 0, meta.0)
    let after_prefix = length(freeze(buf)) - start_len
    if after_prefix != layout.4:
        return (nc_fail(418, 0, "prefix"), buf)
    end
    buf = nc_lower_loop(fn, funcs, meta, metas, layout, layouts, strings, code_len, 0, count(fn.4), buf)
    let len = length(freeze(buf)) - start_len
    if len != layout.5:
        return (nc_fail(418, 0, "length"), buf)
    end
    return (0, buf)
end

func nc_emit_functions_loop(buf, funcs, metas, layouts, strings, code_len, i, n):
    if i >= n:
        return (0, buf)
    end
    let r = nc_emit_function(buf, get(funcs, i), funcs, get(metas, i), metas, get(layouts, i), layouts, strings, code_len)
    if r.0 != 0:
        return r
    end
    return nc_emit_functions_loop(r.1, funcs, metas, layouts, strings, code_len, i + 1, n)
end

func nc_emit_zeroes_loop(buf, n):
    if n <= 0:
        return buf
    end
    do append(buf, 0)
    return nc_emit_zeroes_loop(buf, n - 1)
end

func nc_emit_rodata_loop(buf, strings, i, n):
    if i >= n:
        return buf
    end
    buf = append_str(buf, get(strings, i))
    return nc_emit_rodata_loop(buf, strings, i + 1, n)
end

func nc_emit_rodata(buf, strings):
    return nc_emit_rodata_loop(buf, strings, 0, count(strings))
end

func main():
    let source = clogger()
    let tokens = lex_source(source)
    let nodes = pool_new()
    let parsed = parse_program(tokens, 0, nodes)
    let type_pool = nc_type_pool_new()
    let ast_result = nc_verify_ast(nodes, parsed.0, type_pool)
    if ast_result.0 != 0:
        return 0
    end
    let prog = lower_program_poly(nodes, parsed.0, type_pool, ast_result.2)
    let analyzed = nc_analyze_program(type_pool, prog, ast_result.1)
    if analyzed.0 != 0:
        let fail_an = nc_fail(analyzed.0, 0, "")
        return 0
    end
    let metas = analyzed.1
    let pass1 = nc_pass1_program(prog, metas, analyzed.2, analyzed.3)
    if pass1.0 != 0:
        return 0
    end
    let funcs = prog.0
    let layouts = pass1.1
    let main_layout = get(layouts, prog.2)
    let cbuf = new_buffer()
    cbuf = nc_emit_entry_stub(cbuf, main_layout.0, analyzed.2, analyzed.3)
    let emitted = nc_emit_functions_loop(cbuf, funcs, metas, layouts, prog.1, pass1.2, 0, count(funcs))
    if emitted.0 != 0:
        return 0
    end
    let frozen_code = freeze(emitted.1)
    let code_len = length(frozen_code)
    if code_len != pass1.2:
        let fail = nc_fail(418, 0, "program-length")
        return 0
    end
    let ro_len = nc_rodata_len(prog.1)
    let img = nc_roundup_page(120 + code_len + ro_len)
    let pad = img - 120 - code_len - ro_len
    let align_hi = 0
    if not nc_funcs_have_call(funcs):
        align_hi = 129
    end
    let buf = new_buffer()
    buf = nc_emit_ehdr(buf)
    buf = nc_emit_phdr(buf, img, align_hi)
    buf = append_str(buf, frozen_code)
    buf = nc_emit_rodata(buf, prog.1)
    buf = nc_emit_zeroes_loop(buf, pad)
    do flogger(freeze(buf))
    return 0
end
