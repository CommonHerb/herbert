func nc_render_int_body_len():
    return 58
end

func nc_render_bool_body_len():
    return 75
end

func nc_render_body_len(main_ret):
    if main_ret == nc_type_bool():
        return nc_render_bool_body_len()
    end
    return nc_render_int_body_len()
end

func nc_render_len(main_ret):
    return nc_render_body_len(main_ret) + nc_write_helper_len()
end

func nc_entry_head_len():
    return 19
end

func nc_entry_layout(has_heap, has_faultable, main_ret):
    let heap_len = 0
    if has_heap != 0:
        heap_len = 70
    end
    let head_len = nc_entry_head_len()
    let fault_len = 0
    if has_faultable != 0:
        fault_len = nc_fault_helper_len()
    end
    let render_len = nc_render_len(main_ret)
    let fault_start = heap_len + head_len
    let render_start = fault_start + fault_len
    let function_start = render_start + render_len
    return (heap_len, head_len, fault_len, render_len, fault_start, render_start, function_start)
end

func nc_fault_helper_start(has_heap, has_faultable, main_ret):
    return nc_entry_layout(has_heap, has_faultable, main_ret).4
end

